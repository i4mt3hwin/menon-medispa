---
import LandingPage from '../../layouts/LandingPage.astro';

const BOOKING_URL = "https://www.menonmedispa.com/request-appointment?service=Acne%20Facial";
const PHONE = "(973) 494-8431";
const PHONE_LINK = "tel:9734948431";
---

<LandingPage
  title="Acne Facial Millburn NJ | Medical-Grade Treatment | Menon MediSpa"
  description="Medical-grade acne facial in Millburn, NJ. 70-minute treatment targeting active breakouts, clogged pores, and acne scarring. Physician-supervised. Book today."
  ogTitle="Acne Facial | Menon MediSpa & Wellness"
  ogDescription="Medical-grade acne facial for clear, confident skin. 70-minute treatment. Physician-supervised at Millburn's top-rated MediSpa."
  ogUrl="https://get.menonmedispa.com/acne-facial"
  offerName="Acne Facial"
  offerPrice="165"
  bookingUrl={BOOKING_URL}
>
  <Fragment slot="mobile-cta">Book Your Acne Facial</Fragment>

  <!-- ========== HERO ========== -->
  <section class="hero-section relative overflow-hidden bg-navy pt-24 pb-16 sm:pt-28 sm:pb-20 lg:pt-32 lg:pb-24">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-navy"></div>
      <img src="/images/acne-treatment.png" alt="" class="absolute right-0 top-0 h-full w-full object-cover object-center sm:w-3/4 lg:w-2/3" style="filter: brightness(0.85); mask-image: linear-gradient(to right, transparent 0%, black 40%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 40%);" loading="eager" />
      <div class="absolute inset-0 bg-navy/50 sm:bg-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-navy/60 via-transparent to-navy/40"></div>
    </div>
    <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-lavender/5 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-64 w-64 rounded-full bg-gold/5 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl lg:max-w-xl">
        <div class="text-center lg:text-left">
          <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-gold/30 bg-gold/10 px-4 py-1.5 backdrop-blur-sm">
            <div class="flex text-gold">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
            <span class="text-xs font-semibold tracking-wide text-gold sm:text-sm">100+ 5 Star Reviews</span>
          </div>

          <h1 class="font-display text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
            Clear Skin Starts<br />
            <span class="italic text-gold">With the Right Facial.</span>
          </h1>

          <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/70 lg:mx-0 lg:text-xl">
            Medical-grade acne facial targeting <strong class="text-white">active breakouts, clogged pores, and scarring</strong> — 70 minutes of physician-supervised treatment for visible results.
          </p>

          <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center lg:justify-start">
            <a href={BOOKING_URL} data-lp-cta class="btn-primary inline-flex items-center gap-2 whitespace-nowrap rounded-full bg-gold px-5 py-3.5 text-sm font-bold text-black shadow-lg sm:px-8 sm:py-4 sm:text-lg">
              Book Your Acne Facial
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>

          <div class="mt-4 flex flex-wrap items-center justify-center gap-x-5 gap-y-1 text-xs text-white/50 lg:justify-start sm:text-sm">
            <span>70-minute treatment</span>
            <span class="hidden sm:inline">&middot;</span>
            <span>Medical-grade products</span>
            <span class="hidden sm:inline">&middot;</span>
            <span>All acne types</span>
          </div>

          <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 backdrop-blur-sm sm:px-4 sm:py-2">
            <svg class="h-4 w-4 shrink-0 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
            <span class="text-xs font-semibold text-white sm:text-sm">Physician-Supervised &middot; Licensed Estheticians</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRUST BAR ========== -->
  <section class="bg-purple py-3.5">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm font-medium text-white sm:text-base">
        <span class="flex items-center gap-2">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          Same-Week Appointments
        </span>
        <span class="flex items-center gap-2">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          Medical-Grade Expertise
        </span>
        <span class="flex items-center gap-2">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          State of the Art Equipment
        </span>
      </div>
    </div>
  </section>

  <!-- ========== WALL OF LOVE ========== -->
  <section class="animate-on-scroll bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="font-display text-3xl font-bold text-navy sm:text-4xl">
          Our Patients Love Their Results
        </h2>
        <p class="mt-3 text-lg text-text-muted">100+ five-star reviews. Here's what people are saying.</p>
      </div>

      <div class="mt-12 columns-1 gap-4 sm:columns-2 lg:columns-3">
        {[
          { quote: "I had a wonderful skincare experience at Menon! Cindy was incredibly knowledgeable, gentle, and professional. The results were amazing.", name: "Kathi Albanese" },
          { quote: "They have the best facials. My skin felt like it had been reborn! The process was gentle yet thorough.", name: "Rathi Vijay" },
          { quote: "Wonderful experience! Cindy was kind, knowledgeable, and recommended some great products that have gotten me the results I was looking for.", name: "LFGA" },
          { quote: "Dr. Menon is very knowledgeable and takes the time to understand my skin's needs, ensuring the best treatments every time.", name: "Juhi Mallik" },
          { quote: "Sarah was amazing for my facial! She explained everything in the easiest terms and told me exactly what I was doing wrong and how to correct it. 10/10!", name: "Kristin Kabous" },
          { quote: "If you're looking for a facial that delivers instant gratification, Menon Medispa is well worth it.", name: "Anna Marie Graziano" },
          { quote: "Absolutely loved getting a facial here!! Sarah is an amazing esthetician!! Would 100% recommend.", name: "Heidi S" },
          { quote: "Cindy was brilliant and very knowledgeable. The spa was clean and impeccable. Booked my next appointment.", name: "Kosh Palmer" },
          { quote: "Dr. Menon took the time to explain everything thoroughly and made me feel completely at ease. My results look so natural.", name: "Mawunyo Fafa" },
          { quote: "Today was my first treatment with Cindy and I can not be more happy. She answered all my questions and made me feel comfortable and welcome.", name: "Yahaira Jimenez" },
          { quote: "The best medspa in New Jersey!!! I started with customized IVs and now I'm hooked on the facials.", name: "NF" },
          { quote: "I had a wonderful experience. My face hasn't looked so beautiful in a long time. Very relaxing place and the staff is very welcoming.", name: "Bev's Cleaning Pro's" },
        ].map((item) => (
          <div class="mb-4 break-inside-avoid rounded-xl border border-cream-dark bg-white p-5 shadow-sm">
            <div class="flex text-gold mb-2">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
            <p class="text-sm leading-relaxed text-text-muted">"{item.quote}"</p>
            <div class="mt-3 text-xs font-semibold text-navy">— {item.name}</div>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href={BOOKING_URL} data-lp-cta class="btn-primary inline-flex items-center gap-2 rounded-full bg-gold px-7 py-3 text-base font-bold text-black shadow-md">
          Join 100+ Happy Patients — Book Now
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== BEFORE/AFTER ========== -->
  <section class="animate-on-scroll bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-navy sm:text-4xl">
        Real Results From Real Patients
      </h2>
      <p class="mt-3 text-lg text-text-muted">See the difference a medical-grade acne facial can make.</p>
      <div class="mt-10 overflow-hidden rounded-2xl shadow-lg">
        <img src="/images/acne-before-after.png" alt="Before and after acne facial treatment results" class="h-auto w-full object-cover" width="600" height="600" loading="lazy" />
      </div>
      <p class="mt-4 text-xs text-text-light italic">*Results may vary. Real Menon MediSpa patient shown with consent.</p>
    </div>
  </section>

  <!-- ========== WHAT IT TREATS ========== -->
  <section class="animate-on-scroll bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-navy sm:text-4xl">
        What Our Acne Facial Targets
      </h2>

      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {[
          { title: "Active breakouts", desc: "Medical-grade extractions and targeted treatments reduce active acne and prevent new breakouts from forming." },
          { title: "Clogged pores & blackheads", desc: "Deep cleansing and exfoliation clear congested pores that over-the-counter products can't reach." },
          { title: "Acne scarring & dark spots", desc: "Specialized treatments promote cell turnover and fade post-inflammatory hyperpigmentation over time." },
          { title: "Excess oil & inflammation", desc: "Balancing treatments regulate sebum production and calm redness and swelling." },
        ].map((item) => (
          <div class="rounded-xl border border-cream-dark bg-white p-6 text-left shadow-sm">
            <h3 class="font-display text-lg font-semibold text-navy">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== DOCTOR ========== -->
  <section class="animate-on-scroll bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <img src="/images/dr-menon-portrait.png" alt="Dr. Aditi Menon, MD at Menon Regenerative Institute" class="h-auto w-full object-cover" width="1954" height="778" loading="lazy" />
        </div>
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-gold">Why Menon MediSpa</span>
          <h2 class="mt-3 font-display text-3xl font-bold text-navy sm:text-4xl">
            Medical-Grade Acne Care.<br />Not a Spa Facial.
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-text-muted">
            This isn't a basic facial with a fancy name. Our acne treatments are <strong class="text-navy">physician-supervised and performed by licensed estheticians</strong> using medical-grade products that go far beyond what you'll find at a day spa. Dr. Aditi Menon oversees every treatment protocol.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              "Board-Certified physician supervision",
              "Licensed estheticians with acne specialization",
              "Medical-grade products and extractions",
              "Personalized treatment plans for your skin type",
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-text-muted">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ADD-ONS ========== -->
  <section class="animate-on-scroll bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-navy sm:text-4xl">
        Enhance Your Results
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-text-muted">
        Boost your acne facial with these powerful add-ons.
      </p>

      <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
        {[
          { img: "/images/addon-mask.png", name: "Customized Hydrogel Mask", price: "$25" },
          { img: "/images/addon-eye-treatment.png", name: "Eye Treatment", price: "$10" },
          { img: "/images/addon-lymph-drainage.png", name: "Manual Lymph Drainage", price: "$50" },
          { img: "/images/addon-led-light.png", name: "LED Light Therapy", price: "$35" },
          { img: "/images/addon-lip-perk.png", name: "Hydrafacial Lip Perk", price: "$30" },
          { img: "/images/addon-eye-perk.png", name: "Hydrafacial Eye Perk", price: "$40" },
        ].map((item) => (
          <div class="flex flex-col items-center gap-2 rounded-xl bg-white p-4">
            <img src={item.img} alt={item.name} class="h-16 w-16 object-contain" width="220" height="215" loading="lazy" />
            <span class="text-xs font-semibold text-navy text-center leading-tight">{item.name}</span>
            <span class="text-xs text-text-muted">{item.price}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== TEAM ========== -->
  <section class="animate-on-scroll bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <span class="text-xs font-bold uppercase tracking-widest text-gold">Our Team</span>
      <h2 class="mt-3 font-display text-3xl font-bold text-navy sm:text-4xl">
        Welcoming Faces. Expert Hands.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-text-muted">
        From your first consultation to your follow-up, our team is here to make you feel comfortable, confident, and cared for.
      </p>
      <div class="mt-10 overflow-hidden rounded-2xl shadow-lg">
        <img src="/images/team-photo.png" alt="The Menon MediSpa & Wellness team" class="h-auto w-full object-cover" width="1080" height="560" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="animate-on-scroll bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="font-display text-3xl font-bold text-navy sm:text-4xl">
          Questions? We've Got Answers.
        </h2>
      </div>

      <div class="mt-10 space-y-4">
        {[
          {
            q: "How is this different from a regular facial?",
            a: "Our acne facial uses medical-grade products and techniques under physician supervision — not the gentle cleanse-and-moisturize you'd get at a day spa. We do targeted extractions, use clinical-strength ingredients, and create a treatment plan specific to your acne type."
          },
          {
            q: "Will my skin break out after the facial?",
            a: "Some purging is normal in the first 24-48 hours, especially after extractions. This is actually a good sign — it means clogged pores are clearing. Your esthetician will explain what to expect and give you aftercare instructions."
          },
          {
            q: "How long does the treatment take?",
