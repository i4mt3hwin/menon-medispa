---
import LandingPage from '../../layouts/LandingPage.astro';

const PHONE = "(973) 494-8431";
const PHONE_LINK = "tel:9734948431";
---

<LandingPage
  title="HydraFacial Millburn NJ | Signature, Deluxe & Platinum | Menon MediSpa"
  description="Experience the HydraFacial at Menon MediSpa in Millburn, NJ. Three levels: Signature ($199), Deluxe ($250), Platinum ($325). Deep cleansing, extraction, and hydration. Book today."
  ogTitle="HydraFacial | Menon MediSpa & Wellness"
  ogDescription="The HydraFacial everyone's talking about. Three tiers from $199. Deep cleansing, extraction, hydration. Millburn's top-rated MediSpa."
  ogUrl="https://get.menonmedispa.com/hydrafacial"
  offerName="HydraFacial"
  offerPrice="199"
  bookingUrl="#choose-your-hydrafacial"
>
  <Fragment slot="mobile-cta">Book Your HydraFacial</Fragment>

  <!-- ========== HERO ========== -->
  <section class="hero-section relative overflow-hidden bg-navy pt-24 pb-16 sm:pt-28 sm:pb-20 lg:pt-32 lg:pb-24">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-navy"></div>
      <img src="/images/hydra-hero-new.png" alt="" class="absolute right-0 top-0 h-full w-full object-cover object-center sm:w-3/4 lg:w-2/3" style="filter: brightness(0.85); mask-image: linear-gradient(to right, transparent 0%, black 40%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 40%);" loading="eager" />
      <div class="absolute inset-0 bg-navy/50 sm:bg-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-navy/60 via-transparent to-navy/40"></div>
    </div>
    <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-lavender/5 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-64 w-64 rounded-full bg-gold/5 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl lg:max-w-xl">
        <div class="text-center lg:text-left">
          <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-gold/30 bg-gold/10 px-4 py-1.5 backdrop-blur-sm">
            <div class="flex text-gold">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
            <span class="text-xs font-semibold tracking-wide text-gold sm:text-sm">100+ 5 Star Reviews</span>
          </div>

          <h1 class="font-display text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
            The Facial That<br />
            <span class="italic text-gold">Changes Everything.</span>
          </h1>

          <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/70 lg:mx-0 lg:text-xl">
            Deep cleansing, extraction, and hydration in one treatment. <strong class="text-white">Instantly radiant skin</strong> — starting at just $199 at Millburn's top-rated MediSpa.
          </p>

          <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center lg:justify-start">
            <a href="#choose-your-hydrafacial" data-lp-cta class="btn-primary inline-flex items-center gap-2 whitespace-nowrap rounded-full bg-gold px-5 py-3.5 text-sm font-bold text-black shadow-lg sm:px-8 sm:py-4 sm:text-lg">
              Choose Your HydraFacial
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" /></svg>
            </a>
          </div>

          <div class="mt-4 flex flex-wrap items-center justify-center gap-x-5 gap-y-1 text-xs text-white/50 lg:justify-start sm:text-sm">
            <span>3 levels to choose from</span>
            <span class="hidden sm:inline">&middot;</span>
            <span>No downtime</span>
            <span class="hidden sm:inline">&middot;</span>
            <span>Instant results</span>
          </div>

          <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 backdrop-blur-sm sm:px-4 sm:py-2">
            <svg class="h-4 w-4 shrink-0 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
            <span class="text-xs font-semibold text-white sm:text-sm">Physician-Supervised &middot; Licensed Estheticians</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRUST BAR ========== -->
  <section class="bg-purple py-3.5">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm font-medium text-white sm:text-base">
        <span class="flex items-center gap-2">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          Same-Week Appointments
        </span>
        <span class="flex items-center gap-2">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          Medical-Grade Expertise
        </span>
        <span class="flex items-center gap-2">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          State of the Art Equipment
        </span>
      </div>
    </div>
  </section>

  <!-- ========== WALL OF LOVE ========== -->
  <section class="animate-on-scroll bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="font-display text-3xl font-bold text-navy sm:text-4xl">
          Our Patients Can't Stop Raving
        </h2>
        <p class="mt-3 text-lg text-text-muted">100+ five-star reviews. Here's what HydraFacial patients are saying.</p>
      </div>

      <div class="mt-12 columns-1 gap-4 sm:columns-2 lg:columns-3">
        {[
          { quote: "They have the best hydrafacials. Let me tell you, I've had facials before, but this was on another level. My skin felt like it had been reborn!", name: "Rathi Vijay" },
          { quote: "I received a HydraFacial at their Millburn NJ office a few times — Jennifer was excellent and the facial was very relaxing. The facility is very clean.", name: "Tammie Jones" },
          { quote: "If you're looking for a facial that delivers instant gratification, the HydraFacial is basically the gold standard. I recently visited Menon Medispa, and it was well worth it.", name: "Anna Marie Graziano" },
          { quote: "I had a wonderful skincare experience at Menon! Cindy was incredibly knowledgeable, gentle, and professional. I received a HydraFacial paired with dermaplaning, and the results were amazing.", name: "Kathi Albanese" },
          { quote: "Wonderful experience! Cindy was kind, knowledgeable, and recommended some great products that have gotten me the results I was looking for.", name: "LFGA" },
          { quote: "The best medspa in New Jersey!!! I started with customized IVs and now I'm hooked on the facials.", name: "NF" },
          { quote: "Cindy was brilliant and very knowledgeable. The spa was clean and impeccable. Booked my next appointment.", name: "Kosh Palmer" },
          { quote: "Dr. Menon is very knowledgeable and takes the time to understand my skin's needs, ensuring the best treatments every time.", name: "Juhi Mallik" },
          { quote: "Absolutely loved getting a facial here!! Sarah is an amazing esthetician!! Would 100% recommend getting any of the facials they offer.", name: "Heidi S" },
        ].map((item) => (
          <div class="mb-4 break-inside-avoid rounded-xl border border-cream-dark bg-white p-5 shadow-sm">
            <div class="flex text-gold mb-2">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
            <p class="text-sm leading-relaxed text-text-muted">"{item.quote}"</p>
            <div class="mt-3 text-xs font-semibold text-navy">— {item.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CHOOSE YOUR HYDRAFACIAL ========== -->
  <section id="choose-your-hydrafacial" class="animate-on-scroll bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="font-display text-3xl font-bold text-navy sm:text-4xl">
          Choose Your HydraFacial
        </h2>
        <p class="mt-3 text-lg text-text-muted">Three levels of glow. Pick the one that fits your goals.</p>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        <!-- Signature -->
        <div class="flex flex-col rounded-2xl border border-cream-dark bg-cream p-6 shadow-sm">
          <img src="/images/hydra-signature.png" alt="Signature HydraFacial" class="h-48 w-full rounded-xl object-cover mb-5" loading="lazy" />
          <div class="text-xs font-bold uppercase tracking-widest text-gold">Signature</div>
          <h3 class="mt-1 font-display text-xl font-bold text-navy">The Essentials</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">Deep cleansing, exfoliation, extraction, and hydration with super serums filled with antioxidants, peptides, and hyaluronic acid.</p>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="font-display text-3xl font-bold text-navy">$199</span>
            <span class="text-sm text-text-muted">/ 30 min</span>
          </div>
          <a href="https://www.menonmedispa.com/request-appointment?service=HydraFacial%20Signature%20(%24199)" data-lp-cta class="btn-primary mt-5 flex w-full items-center justify-center gap-2 rounded-full bg-gold py-3 text-sm font-bold text-black shadow-md">
            Book Signature
          </a>
        </div>

        <!-- Deluxe (featured) -->
        <div class="flex flex-col rounded-2xl border-2 border-gold bg-cream p-6 shadow-lg relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-gold px-4 py-1 text-xs font-bold text-white">Most Popular</div>
          <img src="/images/hydra-deluxe.png" alt="Deluxe HydraFacial" class="h-48 w-full rounded-xl object-cover mb-5" loading="lazy" />
          <div class="text-xs font-bold uppercase tracking-widest text-gold">Deluxe</div>
          <h3 class="mt-1 font-display text-xl font-bold text-navy">Enhanced Results</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">Everything in Signature plus targeted boosters for specific skin concerns, and LED light therapy to rejuvenate and restore.</p>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="font-display text-3xl font-bold text-navy">$250</span>
            <span class="text-sm text-text-muted">/ 1 hr</span>
          </div>
          <a href="https://www.menonmedispa.com/request-appointment?service=HydraFacial%20Deluxe%20(%24250)" data-lp-cta class="btn-primary mt-5 flex w-full items-center justify-center gap-2 rounded-full bg-gold py-3 text-sm font-bold text-black shadow-md">
            Book Deluxe
          </a>
        </div>

        <!-- Platinum -->
        <div class="flex flex-col rounded-2xl border border-cream-dark bg-cream p-6 shadow-sm">
          <img src="/images/hydra-platinum.png" alt="Platinum HydraFacial" class="h-48 w-full rounded-xl object-cover mb-5" loading="lazy" />
          <div class="text-xs font-bold uppercase tracking-widest text-gold">Platinum</div>
          <h3 class="mt-1 font-display text-xl font-bold text-navy">The Full Experience</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">Begin with lymphatic drainage to reduce inflammation, then the full HydraFacial with specialty boosters and LED light therapy. The ultimate skin reset.</p>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="font-display text-3xl font-bold text-navy">$325</span>
            <span class="text-sm text-text-muted">/ 1 hr 20 min</span>
          </div>
          <a href="https://www.menonmedispa.com/request-appointment?service=HydraFacial%20Platinum%20(%24325)" data-lp-cta class="btn-primary mt-5 flex w-full items-center justify-center gap-2 rounded-full bg-gold py-3 text-sm font-bold text-black shadow-md">
            Book Platinum
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== DOCTOR ========== -->
  <section class="animate-on-scroll bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <img src="/images/dr-menon-portrait.png" alt="Dr. Aditi Menon, MD" class="h-auto w-full object-cover" width="1954" height="778" loading="lazy" />
        </div>
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-gold">Why Menon MediSpa</span>
          <h2 class="mt-3 font-display text-3xl font-bold text-navy sm:text-4xl">
            Not All HydraFacials<br />Are Created Equal.
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-text-muted">
            The machine is the same everywhere — but the <strong class="text-navy">hands operating it make all the difference</strong>. At Menon MediSpa, every HydraFacial is performed by experienced, licensed estheticians under the supervision of Dr. Aditi Menon, MD. Your treatment is customized to your unique skin concerns, not a one-size-fits-all routine.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              "Board-Certified physician supervision",
              "Experienced, licensed estheticians",
              "Customized to your unique skin needs",
              "Top-rated MediSpa in Millburn since 2019",
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-text-muted">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TEAM ========== -->
  <section class="animate-on-scroll bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <span class="text-xs font-bold uppercase tracking-widest text-gold">Our Team</span>
      <h2 class="mt-3 font-display text-3xl font-bold text-navy sm:text-4xl">
        Welcoming Faces. Expert Hands.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-text-muted">
        From your first visit to your follow-up, our team is here to make you feel comfortable, confident, and cared for.
      </p>
      <div class="mt-10 overflow-hidden rounded-2xl shadow-lg">
        <img src="/images/team-photo.png" alt="The Menon MediSpa & Wellness team" class="h-auto w-full object-cover" width="1080" height="560" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="animate-on-scroll bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="font-display text-3xl font-bold text-navy sm:text-4xl">
          Questions? We've Got Answers.
        </h2>
      </div>

      <div class="mt-10 space-y-4">
        {[
          {
            q: "What's the difference between the three tiers?",
            a: "Signature ($199, 30 min) covers the core HydraFacial — cleanse, extract, hydrate. Deluxe ($250, 1 hr) adds LED light therapy and targeted boosters for specific concerns. Platinum ($325, 1 hr 20 min) adds lymphatic drainage on top of everything in Deluxe for the ultimate detox + glow experience."
          },
          {
            q: "Which level should I choose?",
            a: "First-timers or maintenance visits: Signature. Specific skin concerns (acne, aging, hyperpigmentation): Deluxe. Full reset or special occasion prep: Platinum. Your esthetician can also advise during your session."
          },
          {
            q: "Is there any downtime?",
            a: "None! HydraFacial is one of the few treatments where you leave looking better than when you walked in. No redness, no peeling — just an immediate glow. Many patients book before events."
          },
          {
            q: "How often should I get a HydraFacial?",
