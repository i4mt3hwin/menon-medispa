      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        {[
          {
            quote: "Jennifer is an amazing person to get laser hair removal from. She was very careful with it. Jennifer made it feel like nothing.",
            name: "Love Brooks",
          },
          {
            quote: "I tried laser hair removal at another medspa and did not have any results. Their machine here does wonders. Amazing staff, so nice and professional.",
            name: "Natalia Klobus",
          },
          {
            quote: "Cindy was amazing during my laser hair removal session, the whole staff is friendly and the office is nice and clean! I'm looking forward to my sessions.",
            name: "Christina Carr",
          },
        ].map((item) => (
          <div class="rounded-xl border border-cream-dark bg-cream p-6 shadow-sm">
            <div class="flex text-gold mb-3">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
