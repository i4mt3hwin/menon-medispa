        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-gold/10">
            <span class="font-display text-2xl font-bold text-gold">3</span>
          </div>
          <h3 class="mt-4 font-display text-lg font-semibold text-navy">Results</h3>
          <p class="mt-2 text-sm text-text-muted">After 6 sessions, enjoy lasting smooth skin. No more shaving.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <section class="animate-on-scroll bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="font-display text-3xl font-bold text-navy sm:text-4xl">
          What Our Laser Patients Are Saying
        </h2>
        <p class="mt-3 text-lg text-text-muted">Real reviews from real patients.</p>
