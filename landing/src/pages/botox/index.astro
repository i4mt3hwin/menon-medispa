      function collect(form) {
        var data = {};
        new FormData(form).forEach(function (v, k) { data[k] = typeof v === 'string' ? v : ''; });
        var params = new URLSearchParams(location.search);
        var stored = firstTouchUtms();
        UTM_KEYS.forEach(function (k) {
          var v = params.get(k) || stored[k];
          if (v && !data[k]) data[k] = v;
        });
        // Google Ads click ids -> /api/lead -> WhatConverts gclid (cross-origin: body is the only path).
        var clicks = firstTouchClickIds();
        CLICK_ID_KEYS.forEach(function (k) {
          var v = params.get(k) || clicks[k];
          if (v && !data[k]) data[k] = v;
        });
        if (!data.source_page) data.source_page = location.pathname + location.search;
        return data;
      }
      function val(form) { return form.dataset.leadValue ? Number(form.dataset.leadValue) : undefined; }
      function track(form, data) {
        try {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'lead_submit', form_type: data.type || 'lead' });
          window.dataLayer.push({
            event: 'form_submit',
            form_name: form.dataset.leadName || 'lp_lead',
            form_service: data.service_interest || '',
            form_value: val(form),
            form_currency: 'USD'
          });
        } catch (e) {}
        try {
          if (typeof fbq !== 'undefined') {
            fbq('track', 'CompleteRegistration', { content_name: form.dataset.leadContent || 'lp_lead', status: 'submitted' });
          }
        } catch (e) {}
        try {
          if (typeof gtag !== 'undefined') {
            gtag('event', 'generate_lead', { currency: 'USD', value: val(form), service: form.dataset.leadContent || 'lp_lead' });
          }
        } catch (e) {}
      }
      function enhance(form) {
        var root = form.closest('[data-leadform-root]') || form.parentElement;
        var errorEl = form.querySelector('[data-form-error]');
        var btn = form.querySelector('[type="submit"]');
        form.setAttribute('novalidate', '');
        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          var data = collect(form);
          var name = (data.name || '').trim();
          var email = (data.email || '').trim();
          var phone = (data.phone || '').trim();
          var err = null;
          if (!name) err = 'Please add your name.';
          else if (!email && !phone) err = 'Please add an email or phone number so we can confirm.';
          else if (email && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) err = 'That email address does not look right.';
          if (err) { if (errorEl) { errorEl.textContent = err; errorEl.hidden = false; } return; }
          if (errorEl) { errorEl.textContent = ''; errorEl.hidden = true; }
          if (btn) { btn.disabled = true; btn.dataset.label = btn.textContent || ''; btn.textContent = 'Sending…'; }
          try {
            var res = await fetch(ENDPOINT, { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(data) });
            var jsonResp = await res.json().catch(function () { return {}; });
            if (res.ok && jsonResp.ok) {
              track(form, data);
              form.hidden = true;
              var success = root && root.querySelector('[data-form-success]');
              if (success) { success.hidden = false; success.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
              return;
            }
            if (errorEl) { errorEl.textContent = 'Something went wrong. Please call us at ' + PHONE + '.'; errorEl.hidden = false; }
          } catch (e2) {
            if (errorEl) { errorEl.textContent = 'Something went wrong. Please call us at ' + PHONE + '.'; errorEl.hidden = false; }
          }
          if (btn) { btn.disabled = false; btn.textContent = btn.dataset.label || 'Submit'; }
        });
      }
      document.querySelectorAll('form[data-lead-form]').forEach(enhance);
    })();
  </script>

