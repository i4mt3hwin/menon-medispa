---
import LpTracking from "../../components/LpTracking.astro";

const PHONE = "(973) 494-8431";
const PHONE_LINK = "tel:9734948431";
// Ad LP: all "Book" CTAs scroll to the on-page lead form (#claim-offer) instead of the full scheduler —
// lower friction for cold paid traffic. The form posts to the main site's /api/lead (see handler below).
const BOOKING_URL = "#claim-offer";
const ADDRESS = "45 Essex St., Suite 202, Millburn, NJ 07041";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>$189 Botox Special | Menon MediSpa & Wellness | Millburn, NJ</title>
  <meta name="description" content="Physician-administered Botox — first 20 units just $189 for new clients. Dr. Aditi Menon personally performs every injection at Millburn's top-rated MediSpa. Book your appointment today." />

  <!-- OG Tags -->
  <meta property="og:title" content="$189 Botox Special | Menon MediSpa & Wellness" />
  <meta property="og:description" content="Physician-administered Botox — first 20 units just $189 for new clients. Board-certified Dr. Menon performs every injection." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.menonmedispa.com/botox-sale" />

  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-MSMM2PHT');</script>

  <!-- WhatConverts -->
  <script is:inline>var $wc_load=function(a){return JSON.parse(JSON.stringify(a))},$wc_leads=$wc_leads||{doc:{url:$wc_load(document.URL),ref:$wc_load(document.referrer),search:$wc_load(location.search),hash:$wc_load(location.hash)}};</script>
  <script is:inline async src="//s.ksrndkehqnwntyxlhgto.com/159358.js"></script>

  <!-- Meta Pixel Code -->
  <script is:inline>
  !function(f,b,e,v,n,t,s)
  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window, document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '1005972549954643');
  fbq('track', 'PageView');
  fbq('track', 'ViewContent', {
    content_name: '$189 Botox Special',
    content_category: 'medspa_landing',
    content_ids: ['/botox']
  });
  </script>
  <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=1005972549954643&ev=PageView&noscript=1" /></noscript>

  <!-- Meta Pixel - Contact event on any tel: link click -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('a[href^="tel:"]').forEach(function(link) {
        link.addEventListener('click', function() {
          fbq('track', 'Contact');
        });
      });
    });
  </script>

  <!-- First-touch UTM + Google Ads click-id capture (mirrors the shared LandingPage layout; this page
       is standalone). Read back by the lead-form handler below and forwarded to /api/lead. The gclid is
       what lets WhatConverts attribute this $189 ad lead to Google Ads (CPC). -->
  <script is:inline>
    (function () {
      try {
        var p = new URLSearchParams(location.search);
        var keys = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content'];
        var has = keys.some(function (k) { return p.get(k); });
        if (has && !localStorage.getItem('menonUtm')) {
          var o = {};
          keys.forEach(function (k) { var v = p.get(k); if (v) o[k] = v; });
          localStorage.setItem('menonUtm', JSON.stringify(o));
        }
        var clickKeys = ['gclid','gbraid','wbraid'];
        var c = {};
        clickKeys.forEach(function (k) { var v = p.get(k); if (v) c[k] = v; });
        if (!c.gclid) {
          var m = document.cookie.match(/(?:^|;\s*)_gcl_aw=([^;]+)/);
          if (m) { var seg = m[1].split('.'); if (seg.length >= 3) c.gclid = seg.slice(2).join('.'); }
        }
        if (Object.keys(c).length && !localStorage.getItem('menonClickIds')) {
          localStorage.setItem('menonClickIds', JSON.stringify(c));
        }
      } catch (e) {}
    })();
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet" />

