            <source srcset="/images/botox-ba-1.avif" type="image/avif" />
            <source srcset="/images/botox-ba-1.webp" type="image/webp" />
            <img src="/images/botox-ba-1.jpg" alt="Before and after Botox at Menon MediSpa - deep frown lines softened to a smooth, relaxed result" class="h-auto w-full object-cover" width="906" height="686" loading="lazy" />
          </picture>
        </div>
        <div class="ba-card overflow-hidden rounded-xl shadow-md">
          <picture>
            <source srcset="/images/botox-ba-2.avif" type="image/avif" />
            <source srcset="/images/botox-ba-2.webp" type="image/webp" />
            <img src="/images/botox-ba-2.jpg" alt="Before and after Botox at Menon MediSpa - a refreshed, natural-looking result" class="h-auto w-full object-cover" width="906" height="686" loading="lazy" />
          </picture>
        </div>
      </div>

      <p class="mt-6 text-center text-xs text-text-light italic">
        *Results may vary. All photos are real Menon MediSpa patients shown with consent.
      </p>

      <div class="mt-8 text-center">
        <a href={BOOKING_URL} data-lp-cta class="btn-primary inline-flex items-center gap-2 rounded-full bg-gold px-7 py-3 text-base font-bold text-black shadow-md">
          Get Results Like These — Book Now
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== VALUE PROP 1: Doctor ========== -->
  <section class="animate-on-scroll bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <img src="/images/dr-menon-portrait.png" alt="Dr. Aditi Menon, MD at Menon Regenerative Institute" class="h-auto w-full object-cover" width="1954" height="778" loading="lazy" />
        </div>
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-gold">Why Menon MediSpa</span>
          <h2 class="mt-3 font-display text-3xl font-bold text-navy sm:text-4xl">
            A Real Doctor.<br />Every Single Time.
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-text-muted">
            At most med spas, you'll be treated by a nurse or PA. At Menon MediSpa, <strong class="text-navy">Dr. Aditi Menon</strong> — a Board-Certified physician — personally performs every Botox injection. No hand-offs. No surprises. Just expert medical care from start to finish.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              "Board-Certified in Physical Medicine & Rehabilitation",
              "Founder, Menon MediSpa & Wellness (est. 2019)",
              "Expert in musculoskeletal & regenerative medicine",
