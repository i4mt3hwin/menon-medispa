       clicks, form starts. GTM-MSMM2PHT has no GA4 tag, so this is the GA4
       source for this page (sendPageView true). Only fires on the prod
       host -- previews log to console.debug. -->
  <LpTracking
    measurementId="G-Q7BGS5BFLM"
    prodHost="get.menonmedispa.com"
    sendPageView={true}
    bookingHosts={["www.menonmedispa.com"]}
  />

