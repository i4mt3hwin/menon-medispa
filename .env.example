# Example environment variables for Menon Medispa.
# Copy to `.env` (gitignored) for local dev, or set as Cloudflare Pages secrets.
# DEFERRED this session (P03) — see 04-architecture/publish-todo.md.

# Resend (contact / appointment-request form -> email). Set in Cloudflare Pages.
RESEND_API_KEY=
LEAD_NOTIFY_TO=        # business inbox that receives lead notifications
LEAD_FROM=             # verified Resend sender address
RESEND_AUDIENCE_ID=   # optional: when set, leads who tick the email-consent box are added to this Resend Audience

# Cloudflare (only needed for the GitHub Actions deploy fallback).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
