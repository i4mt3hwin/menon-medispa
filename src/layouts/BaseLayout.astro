---
/**
 * BaseLayout.astro, HTML shell + <head> meta scaffolding.
 *
 * P03 SKELETON: provides the meta/canonical/OG/Twitter/JSON-LD plumbing that
 * downstream phases populate per page. Per-page values come from:
 *   - 04-architecture/page-seo-plan.csv  (title / meta description / H1 per page)
 *   - 02-research/business-metadata.md   (org-level schema) -> src/lib/site.ts
 *
 * Header/Footer and the component library are intentionally NOT built here, 
 * that's 02-synthesize (components) + 03-build-replicate (pages). This layout
 * just renders a <slot/> so the scaffold compiles and pages can mount.
 */
import '../styles/tokens.css';
/* tokens.css @imports fonts.css, all design tokens + font faces loaded here */
import '../styles/base.css';
/* base.css, redesign layout system: container, section rhythm, responsive
   type, button system, and the media-background/overlay treatment. */
import site from '../lib/site';
import { resolveBooking } from '../lib/bookingRoutes';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ChatAssistant from '../components/ChatAssistant.astro';
import SocialProofToast from '../components/SocialProofToast.astro';
import ThirdPartyScripts from '../components/ThirdPartyScripts.astro';

export interface Props {
  /** <title>, from page-seo-plan.csv "Meta Title". Falls back to site name. */
  title?: string;
  /** meta description, from page-seo-plan.csv "Meta Description". */
  description?: string;
  /** Canonical URL. Defaults to the current page URL resolved against `site`. */
  canonical?: string;
  /** Open Graph image (absolute or site-relative). TODO(03-build): real default OG. */
  ogImage?: string;
  /** OG type, e.g. "website" | "article". */
  ogType?: string;
  /** Set true on noindex pages (e.g. thank-you / members redirect). */
  noindex?: boolean;
  /**
   * JSON-LD object(s) to inject. Pass the LocalBusiness/Service/FAQ/Breadcrumb
   * node(s) built per page (03-build). If omitted, nothing is emitted here.
   */
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
  /** Render only the page content and required scripts, without global site chrome. */
  minimalShell?: boolean;
}

const {
  title,
  description = site.description,
  canonical,
  // Default social-share image so every page gets an og:image / twitter:image.
  // Pages may override with a treatment-specific image. TODO(operator): swap for a
  // purpose-built 1200x630 brand card; the horizontal logo is a safe interim default.
  ogImage = '/images/medispa-logo-horizontal.png',
  ogType = 'website',
  noindex = false,
  jsonld,
  minimalShell = false,
} = Astro.props;

const pageTitle = title ?? `${site.legalName} | Millburn, NJ`;
// Resolve canonical against the configured `site` in astro.config.mjs.
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogImageURL = ogImage
  ? new URL(ogImage, Astro.site ?? site.url).href
  : undefined;

const jsonldArray = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];

// Context-aware booking routing: broad pages -> /consultation, specific treatment
// pages -> /request-appointment?service=<name>. A small inline script (end of body)
// applies this to every booking link. See lib/bookingRoutes.ts.
const book = resolveBooking(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Enable scroll-reveal hidden states only when JS runs (graceful + SEO-safe) -->
    <script is:inline>document.documentElement.classList.add('reveal-ready');</script>

    <!-- First-touch attribution: stash any utm_* on the landing URL so a lead booked
         later on a UTM-less page (e.g. /request-appointment) still carries the campaign.
         Read back in lib/leadForm.ts. First touch wins (never overwritten). -->
    <script is:inline>
      (function () {
        try {
          var p = new URLSearchParams(location.search);
          var keys = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content'];
          var has = keys.some(function (k) { return p.get(k); });
          if (has && !localStorage.getItem('menonUtm')) {
            var o = {};
            keys.forEach(function (k) { var v = p.get(k); if (v) o[k] = v; });
            localStorage.setItem('menonUtm', JSON.stringify(o));
          }
        } catch (e) {}
      })();
    </script>

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Brand favicon set (generated from the Menon logo). -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts: self-hosted via tokens.css → fonts.css @font-face.
         Preload LCP-critical faces:
           Raleway-v2 400 latin primary block → d42b96c5612a.woff2 (body, dominant 3867+ uses)
           Playfair Display 400 latin primary block → 973711d84225.woff2 (headings)
           Lato 400 latin primary block → 3f18028a04b3.woff2 (UI/eyebrow) -->
    <link rel="preload" href="/fonts/d42b96c5612a.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/973711d84225.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/3f18028a04b3.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={site.displayName} />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImageURL ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <!-- JSON-LD slot. Pass nodes via the `jsonld` prop (03-build). -->
    {jsonldArray.map((node) => (
      <script type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}

    <slot name="head" />
  </head>
  <body data-book-mode={book.mode} data-book-service={book.service} data-book-anchor={book.anchor}>
    {!minimalShell && <SiteHeader />}
    <slot />
    {!minimalShell && <SiteFooter />}

    <slot name="end-of-body" />

    {!minimalShell && <ChatAssistant />}
    {!minimalShell && <SocialProofToast />}
    <ThirdPartyScripts />

    <!-- Scroll reveal: fade + rise top-level sections (and [data-reveal] elements) as they enter view -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('body > section:not(.hero), [data-reveal]');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          for (var i = 0; i < els.length; i++) els[i].classList.add('is-visible');
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (en.isIntersecting) { en.target.classList.add('is-visible'); io.unobserve(en.target); }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
        els.forEach(function (e) { io.observe(e); });
      })();
    </script>

    <!-- Context-aware booking routing: rewrite generic booking links per page (see lib/bookingRoutes.ts). -->
    <script is:inline>
      (function () {
        var b = document.body;
        var mode = b.getAttribute('data-book-mode');
        var svc = b.getAttribute('data-book-service');
        var anchor = b.getAttribute('data-book-anchor');
        var links = document.querySelectorAll('a[href^="/request-appointment"]');
        for (var i = 0; i < links.length; i++) {
          var a = links[i];
          var href = a.getAttribute('href') || '';
          if (href.indexOf('service=') !== -1) continue; /* an explicit tier/service always wins */
          /* A CTA that says "consultation" (or opts in via data-book) always goes to the
             guided consultation — e.g. the bottom-of-page CTA on a specific treatment page.
             Land on #options (the free vs $50-with-Dr.-Menon choice), not the page top. */
          var txt = (a.textContent || '').toLowerCase();
          var wantsConsult = a.getAttribute('data-book') === 'consultation' || txt.indexOf('consultation') !== -1;
          if (mode === 'consultation' || wantsConsult) { a.setAttribute('href', '/consultation#options'); continue; }
          /* Multi-tier page: the generic Book scrolls down to the on-page tier choices. */
          if (mode === 'scroll' && anchor) { a.setAttribute('href', anchor); continue; }
          if (svc) { a.setAttribute('href', '/request-appointment?service=' + encodeURIComponent(svc)); }
        }
        /* SSR-hardcoded "/consultation" CTAs (pillar heroes, "Book a Consultation" cards) should
           also land on the options block, not the page top — except on the consultation page itself. */
        if (location.pathname.replace(/\/+$/, '') !== '/consultation') {
          var clinks = document.querySelectorAll('a[href="/consultation"]');
          for (var k = 0; k < clinks.length; k++) clinks[k].setAttribute('href', '/consultation#options');
        }
      })();
    </script>
  </body>
</html>
