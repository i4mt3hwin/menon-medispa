---
/**
 * BaseLayout.astro, HTML shell + <head> meta scaffolding.
 *
 * P03 SKELETON: provides the meta/canonical/OG/Twitter/JSON-LD plumbing that
 * downstream phases populate per page. Per-page values come from:
 *   - 04-architecture/page-seo-plan.csv  (title / meta description / H1 per page)
 *   - 02-research/business-metadata.md   (org-level schema) -> src/lib/site.ts
 *
 * Header/Footer and the component library are intentionally NOT built here, 
 * that's 02-synthesize (components) + 03-build-replicate (pages). This layout
 * just renders a <slot/> so the scaffold compiles and pages can mount.
 */
import '../styles/tokens.css';
/* tokens.css @imports fonts.css, all design tokens + font faces loaded here */
import '../styles/base.css';
/* base.css, redesign layout system: container, section rhythm, responsive
   type, button system, and the media-background/overlay treatment. */
import site from '../lib/site';
import { resolveBooking } from '../lib/bookingRoutes';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ChatAssistant from '../components/ChatAssistant.astro';
import SocialProofToast from '../components/SocialProofToast.astro';
import ThirdPartyScripts from '../components/ThirdPartyScripts.astro';

export interface Props {
  /** <title>, from page-seo-plan.csv "Meta Title". Falls back to site name. */
  title?: string;
  /** meta description, from page-seo-plan.csv "Meta Description". */
  description?: string;
  /** Canonical URL. Defaults to the current page URL resolved against `site`. */
  canonical?: string;
  /** Open Graph image (absolute or site-relative). TODO(03-build): real default OG. */
  ogImage?: string;
  /** OG type, e.g. "website" | "article". */
  ogType?: string;
  /** Set true on noindex pages (e.g. thank-you / members redirect). */
  noindex?: boolean;
  /**
   * JSON-LD object(s) to inject. Pass the LocalBusiness/Service/FAQ/Breadcrumb
   * node(s) built per page (03-build). If omitted, nothing is emitted here.
   */
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
  /** Render only the page content and required scripts, without global site chrome. */
  minimalShell?: boolean;
}

// Default social-share image: purpose-built 1200x630 brand card (generated by
// scripts/seo-og-card.mjs — white logo on brand plum + gold rule + location line).
// Pages may override with a treatment-specific 1200x630 image.
const DEFAULT_OG_IMAGE = '/og/default.png';

const {
  title,
  description = site.description,
  canonical,
  // Pages may override with a treatment-specific 1200x630 image.
  ogImage = DEFAULT_OG_IMAGE,
  ogType = 'website',
  noindex = false,
  jsonld,
  minimalShell = false,
} = Astro.props;

const pageTitle = title ?? `${site.legalName} | Millburn, NJ`;
// Resolve canonical against the configured `site`, then normalize to a single
// trailing-slash form so canonical == sitemap == the directory URL Cloudflare serves
// (pages build as /path/index.html and serve at /path/). Fixes the canonical (/path)
// vs sitemap (/path/) split-signal flagged in the SEO audit. Applies to both the
// derived canonical and the explicit `canonical=` props pages pass in.
const rawCanonical = canonical ?? new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const canonicalURL = (() => {
  try {
    const u = new URL(rawCanonical);
    if (!u.pathname.endsWith('/')) u.pathname += '/';
    return u.href;
  } catch {
    return rawCanonical.endsWith('/') ? rawCanonical : `${rawCanonical}/`;
  }
})();
const ogImageURL = ogImage
  ? new URL(ogImage, Astro.site ?? site.url).href
  : undefined;
// Default is now a real 1200x630 card, so every page with an OG image uses the large card.
const twitterCard = ogImageURL ? 'summary_large_image' : 'summary';

const jsonldArray = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];

// Context-aware booking routing: broad pages -> /consultation, specific treatment
// pages -> /request-appointment?service=<name>. A small inline script (end of body)
// applies this to every booking link. See lib/bookingRoutes.ts.
const book = resolveBooking(Astro.url.pathname);
const gtmId = site.integrations.analytics.gtmId;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Google Tag Manager owns Google tags, but waits for idle/interaction so it does not compete with first paint. */}
    {gtmId && (
      <script define:vars={{ gtmId }}>
        (function(w,d,s,l,i){
          w[l]=w[l]||[];
          var loaded=false;
          function loadGtm(){
            if(loaded) return;
            loaded=true;
            w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
            var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
            j.async=true;
            j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
            f.parentNode.insertBefore(j,f);
          }
          function schedule(){
            w.setTimeout(function(){
              if('requestIdleCallback' in w) w.requestIdleCallback(loadGtm,{timeout:1500});
              else loadGtm();
            },2500);
          }
          ['pointerdown','keydown','scroll','touchstart'].forEach(function(ev){
            w.addEventListener(ev,loadGtm,{once:true,passive:true});
          });
          if(d.readyState==='loading') d.addEventListener('DOMContentLoaded',schedule,{once:true});
          else schedule();
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
    <meta name="generator" content={Astro.generator} />

    <!-- Enable scroll-reveal hidden states only when JS runs (graceful + SEO-safe) -->
    <script is:inline>document.documentElement.classList.add('reveal-ready');</script>

    <!-- First-touch attribution: stash any utm_* AND the Google Ads click ids on the landing URL so a
         lead booked later on a clean URL (e.g. /request-appointment) still carries the campaign + the
         gclid. The gclid is what lets WhatConverts report the lead back to Google Ads as a CPC
         conversion. Read back in lib/leadForm.ts. First touch wins (never overwritten). -->
    <script is:inline>
      (function () {
        try {
          var p = new URLSearchParams(location.search);
          var keys = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content'];
          var has = keys.some(function (k) { return p.get(k); });
          if (has && !localStorage.getItem('menonUtm')) {
            var o = {};
            keys.forEach(function (k) { var v = p.get(k); if (v) o[k] = v; });
            localStorage.setItem('menonUtm', JSON.stringify(o));
          }
          // Google Ads click ids (auto-tagging puts gclid in the URL on the ad click; gbraid/wbraid
          // cover some iOS traffic). Fall back to Google's _gcl_aw cookie if the URL param was stripped.
          var clickKeys = ['gclid','gbraid','wbraid'];
          var c = {};
          clickKeys.forEach(function (k) { var v = p.get(k); if (v) c[k] = v; });
          if (!c.gclid) {
            var m = document.cookie.match(/(?:^|;\s*)_gcl_aw=([^;]+)/);
            if (m) { var seg = m[1].split('.'); if (seg.length >= 3) c.gclid = seg.slice(2).join('.'); }
          }
          if (Object.keys(c).length && !localStorage.getItem('menonClickIds')) {
            localStorage.setItem('menonClickIds', JSON.stringify(c));
          }
        } catch (e) {}
      })();
    </script>

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Brand favicon set (generated from the Menon logo). -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts: self-hosted via tokens.css -> fonts.css @font-face.
         Preload LCP-critical faces:
           Raleway-v2 400 latin primary block → d42b96c5612a.woff2 (body, dominant 3867+ uses)
           Playfair display legacy latin face → a220c9588ea3.woff2 (headings)
           Lato-light 400 → f8144e0c7432.woff2 (UI/eyebrow) -->
    <link rel="preload" href="/fonts/d42b96c5612a.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/a220c9588ea3.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/f8144e0c7432.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={site.displayName} />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <!-- JSON-LD slot. Pass nodes via the `jsonld` prop (03-build). -->
    {jsonldArray.map((node) => (
      <script type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}

    <slot name="head" />
  </head>
  <body data-book-mode={book.mode} data-book-service={book.service} data-book-anchor={book.anchor}>
    {/* Google Tag Manager (noscript) */}
    {gtmId && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${gtmId}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}
    {!minimalShell && <a href="#main" class="skip-link">Skip to content</a>}
    {!minimalShell && <SiteHeader />}
    {/* Single page-level <main> landmark (SEO/a11y). minimalShell pages (e.g. find-your-glow)
        provide their own <main>, so skip the wrapper there to avoid a nested/duplicate main. */}
    {minimalShell ? <slot /> : <main id="main"><slot /></main>}
    {!minimalShell && <SiteFooter />}

    <slot name="end-of-body" />

    {!minimalShell && <ChatAssistant />}
    {!minimalShell && <SocialProofToast />}
    <ThirdPartyScripts />

    <!-- Hero background video: pick the resolution for this viewport (phones / data-saver
         get a smaller file) and attach the source AFTER load, so the poster image stays the
         LCP element (the poster is a frame of the video, so the swap is seamless). The
         <source media> attribute is unreliable in Chrome, so selection happens here in JS. -->
    <script is:inline>
      (function () {
        var v = document.querySelector('video[data-hero-video]');
        if (!v) return;
        function attach() {
          if (v.dataset.heroLoaded) return;
          v.dataset.heroLoaded = '1';
          var small = window.matchMedia && window.matchMedia('(max-width: 768px)').matches;
          var saveData = navigator.connection && navigator.connection.saveData;
          var src = (small || saveData)
            ? (v.getAttribute('data-src-mobile') || v.getAttribute('data-src-desktop'))
            : v.getAttribute('data-src-desktop');
          if (!src) return;
          v.src = src;
          v.load();
          if (v.hasAttribute('autoplay')) {
            var p = v.play();
            if (p && p.catch) p.catch(function () {});
          }
        }
        function schedule() {
          if ('requestIdleCallback' in window) requestIdleCallback(attach, { timeout: 1500 });
          else setTimeout(attach, 200);
        }
        if (document.readyState === 'complete') schedule();
        else window.addEventListener('load', schedule, { once: true });
      })();
    </script>

    <!-- Lazy-load non-hero videos when they approach the viewport. -->
    <script is:inline>
      (function () {
        var videos = document.querySelectorAll('video[data-lazy-video]');
        if (!videos.length) return;
        function loadVideo(video) {
          if (video.dataset.videoLoaded) return;
          video.dataset.videoLoaded = 'true';
          if (video.dataset.src) {
            video.src = video.dataset.src;
            video.removeAttribute('data-src');
          }
          var sources = video.querySelectorAll('source[data-src]');
          for (var i = 0; i < sources.length; i++) {
            sources[i].src = sources[i].dataset.src;
            sources[i].removeAttribute('data-src');
          }
          video.load();
          if (video.hasAttribute('autoplay')) {
            var play = video.play();
            if (play && play.catch) play.catch(function () {});
          }
        }
        if (!('IntersectionObserver' in window)) {
          for (var i = 0; i < videos.length; i++) loadVideo(videos[i]);
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              loadVideo(entry.target);
              io.unobserve(entry.target);
            }
          });
        }, { rootMargin: '600px 0px', threshold: 0.01 });
        videos.forEach(function (video) { io.observe(video); });
      })();
    </script>

    <!-- Scroll reveal: fade + rise top-level sections (and [data-reveal] elements) as they enter view -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll(':is(body, main) > section:not(.hero), [data-reveal]');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          for (var i = 0; i < els.length; i++) els[i].classList.add('is-visible');
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (en.isIntersecting) { en.target.classList.add('is-visible'); io.unobserve(en.target); }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
        els.forEach(function (e) { io.observe(e); });
      })();
    </script>

    <!-- Context-aware booking routing: rewrite generic booking links per page (see lib/bookingRoutes.ts). -->
    <script is:inline>
      (function () {
        var b = document.body;
        var mode = b.getAttribute('data-book-mode');
        var svc = b.getAttribute('data-book-service');
        var anchor = b.getAttribute('data-book-anchor');
        var links = document.querySelectorAll('a[href^="/request-appointment"]');
        for (var i = 0; i < links.length; i++) {
          var a = links[i];
          var href = a.getAttribute('href') || '';
          if (href.indexOf('service=') !== -1) continue; /* an explicit tier/service always wins */
          if (a.getAttribute('data-book') === 'request') continue; /* opt-in: this CTA goes straight to the booking form, never rerouted to consultation */
          /* A CTA that says "consultation" (or opts in via data-book) always goes to the
             guided consultation — e.g. the bottom-of-page CTA on a specific treatment page.
             Land on #options (the free vs $50-with-Dr.-Menon choice), not the page top. */
          var txt = (a.textContent || '').toLowerCase();
          var wantsConsult = a.getAttribute('data-book') === 'consultation' || txt.indexOf('consultation') !== -1;
          if (mode === 'consultation' || wantsConsult) { a.setAttribute('href', '/consultation#options'); continue; }
          /* Multi-tier page: the generic Book scrolls down to the on-page tier choices. */
          if (mode === 'scroll' && anchor) { a.setAttribute('href', anchor); continue; }
          if (svc) { a.setAttribute('href', '/request-appointment?service=' + encodeURIComponent(svc)); }
        }
        /* SSR-hardcoded "/consultation" CTAs (pillar heroes, "Book a Consultation" cards) should
           also land on the options block, not the page top — except on the consultation page itself. */
        if (location.pathname.replace(/\/+$/, '') !== '/consultation') {
          var clinks = document.querySelectorAll('a[href="/consultation"]');
          for (var k = 0; k < clinks.length; k++) clinks[k].setAttribute('href', '/consultation#options');
        }
      })();
    </script>
  </body>
</html>
