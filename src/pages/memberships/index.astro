---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
---
<BaseLayout title="Membership Plans | Menon Medispa &amp; Wellness | Millburn, NJ" description="Explore Menon Medispa membership plans. Combine Signature Facials with IV Vitamin Therapy at incredible prices with our monthly subscription or package options.">
  <main class="sp" data-slug="memberships">
    <section class="sp-hero sp-hero--center" aria-label="Membership <em>Plans</em>">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Membership <em>Plans</em></h1>
        <p class="sp-hero__lead" style="text-align:center;margin:0 auto;max-width:560px;">Enjoy the benefits of our Membership program.</p>
      </div>
    </section>
    <section class="sp-plain" aria-label="Membership Plans">
    <div class="sp-container">
      <div class="sp-plain__inner">
        <h2 class="sp-plain__title">Enjoy the benefits of our Membership and enhance your beauty inside out.</h2>
        <div class="sp-plain__body">
          <p>Our Memberships offer you the choice to combine Menon Signature Facials with IV Vitamin Therapy at an incredible price! You can choose between a Monthly Subscription or a One Time Fee Package of 3 treatments.</p>
          <p>Interested to see what IV Drips are included in the Membership? Check out our <a href="http://www.ivmenonwelldrip.com" rel="noopener" target="_blank">IV Drip Menu</a>.</p>
          <p><a class="sp-btn sp-btn--gold" href="/members-booking">Go To Member's Booking Area</a></p>
          <p style="margin-top:1rem;font-family:var(--font-ui);color:#8a8088;font-size:var(--text-sm);">Once there are plans available for purchase, you'll see them here.</p>
        </div>
        <p style="margin-top:2rem;"><a class="sp-btn sp-btn--outline" href="/">Back to Home Page</a></p>
      </div>
    </div>
  </section>
  </main>
</BaseLayout>
