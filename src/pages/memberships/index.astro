---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout>
  <main class="pg" data-slug="memberships">
<section class="pg-section" data-section="Membership Plans">
  <h1 class="pg-h">Membership Plans</h1>
  <h3 class="pg-h">Enjoy the benefits of our Membership and enhance your beauty inside out.</h3>
  <p class="pg-text">Our Memberships offer you the choice to combine Menon Signature Facials with IV Vitamin Therapy at an incredible price! You can choose between a Monthly Subscription or a One Time Fee Package of 3 treatments.</p>
  <p class="pg-text">Interested to see what IV Drips are included in the Membership? Check out our IV Drip Menu.</p>
  <a class="pg-btn" href="/members-booking">Go To Member's Booking Area</a>
  <p class="pg-btnlabel">Back to Home Page</p>
</section>
  </main>
</BaseLayout>
