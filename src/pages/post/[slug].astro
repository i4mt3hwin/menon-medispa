---
/**
 * /post/[slug].astro
 * Dynamic route — 28 blog posts.
 * Full body available for 2 posts (captured); 26 posts render excerpt + CTA only.
 * Zero fabrication: body is verbatim captured HTML or excerpt-only fallback.
 */
import BlogPostTemplate from '@/components/BlogPostTemplate.astro';
import blogData from '@/data/blog.json';

// Full bodies captured for exactly 2 posts (wix-source.json had content).
// The wix-source content came back empty for both captured posts too — excerpt+CTA
// is the honest fallback for all 28. Content is NOT fabricated.
// Structure files exist for both but also yielded no body text.
// NOTE: If a rich-text body is recovered later, inject it here via blog-bodies.json.
const FULL_BODY_SLUGS: Record<string, string> = {
  // No full bodies were recovered from the Wix API or page snapshots.
  // Slots kept as a named map so bodies can be dropped in without structural changes.
};

export async function getStaticPaths() {
  return blogData.map((post: Record<string, string>) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Post {
  slug: string;
  title: string;
  firstPublished?: string;
  excerpt?: string;
  coverImage?: string;
}

const { post } = Astro.props as { post: Post };

// Use full body if recovered, otherwise render excerpt with read-more CTA.
const fullBody = FULL_BODY_SLUGS[post.slug];
const contentHtml = fullBody
  ? fullBody
  : post.excerpt
    ? `<p>${post.excerpt}</p>
<p style="font-family:var(--font-body);font-size:var(--text-sm);opacity:0.7;">
  This article is available on our website. Use the booking or contact links below to reach our team.
</p>`
    : '<p>Content coming soon.</p>';

// Format date for display
function formatDate(iso: string | undefined): string {
  if (!iso) return '';
  try {
    return new Date(iso).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  } catch {
    return iso;
  }
}
---

<BlogPostTemplate
  title={post.title}
  slug={post.slug}
  date={formatDate(post.firstPublished)}
  author="Menon Medispa"
  featured_image_src={post.coverImage}
  featured_image_alt={post.title}
  content_html={contentHtml}
/>
