---
/**
 * /post/[slug].astro, dynamic route for all 28 blog posts.
 * Resolves topic, read time, related posts, and Article JSON-LD from src/lib/blog,
 * then renders the unified BlogPostTemplate. Body HTML is the recovered verbatim
 * article (blog-bodies.json); excerpt + CTA is the honest fallback if ever missing.
 */
import BlogPostTemplate from '@/components/BlogPostTemplate.astro';
import blogBodies from '@/data/blog-bodies.json';
import { getAllPosts, getRelatedByTopic, formatDate } from '@/lib/blog';
import { buildArticleSchema } from '@/lib/articleSchema';

export async function getStaticPaths() {
  return getAllPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const bodies = blogBodies as Record<string, string>;

// Recovered verbatim body, else excerpt + CTA fallback (never fabricated).
const fullBody = bodies[post.slug];
const contentHtml = fullBody
  ? fullBody
  : post.excerpt
    ? `<p class="post-excerpt-lede">${post.excerpt}</p>
<div class="post-excerpt-cta-block">
  <p>To learn more, call us at <a href="tel:+19734948431">(973) 494-8431</a> or book a consultation with our team.</p>
  <a href="/request-appointment" class="post-excerpt-cta-link">Request an Appointment</a>
</div>`
    : '<p>Content coming soon.</p>';

const related = getRelatedByTopic(post.slug, 3);
const url = `/post/${post.slug}`;
const jsonld = buildArticleSchema({
  title: post.title,
  description: post.excerpt,
  url,
  image: post.coverImage,
  datePublished: post.date,
  topicLabel: post.topic.label,
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: post.topic.label, url: `/blog/${post.topic.slug}` },
    { name: post.title, url },
  ],
});
---

<BlogPostTemplate
  title={post.title}
  seoTitle={post.seoTitle}
  slug={post.slug}
  description={post.excerpt}
  date={formatDate(post.date)}
  readTime={post.readTime}
  coverImage={post.coverImage}
  content_html={contentHtml}
  topicLabel={post.topic.label}
  topicSlug={post.topic.slug}
  serviceSlug={post.topic.serviceSlug}
  serviceLabel={post.topic.serviceLabel}
  reviewTag={post.topic.reviewTag}
  related={related}
  jsonld={jsonld}
/>
