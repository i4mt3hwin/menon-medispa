---
/**
 * /post/[slug].astro
 * Dynamic route, 28 blog posts.
 * Full body available for 2 posts (captured); 26 posts render excerpt + CTA only.
 * Zero fabrication: body is verbatim captured HTML or excerpt-only fallback.
 */
import BlogPostTemplate from '@/components/BlogPostTemplate.astro';
import blogData from '@/data/blog.json';
import blogBodies from '@/data/blog-bodies.json';

// Full article bodies recovered verbatim from the live site (scripts/recover-blog-bodies.mjs)
// into blog-bodies.json, keyed by slug. Any slug missing here falls back to excerpt + CTA.
// Content is NOT fabricated: it is the client's own published article HTML.
const FULL_BODY_SLUGS = blogBodies as Record<string, string>;

export async function getStaticPaths() {
  return blogData.map((post: Record<string, string>) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Post {
  slug: string;
  title: string;
  firstPublished?: string;
  excerpt?: string;
  coverImage?: string;
}

const { post } = Astro.props as { post: Post };

// Use full body if recovered, otherwise render excerpt as teaser with booking CTA.
// NOTE: Full article bodies were not captured from Wix API (content.rendered was empty).
// A targeted re-capture of blog post bodies is needed to unlock the full articles.
const fullBody = FULL_BODY_SLUGS[post.slug];
const contentHtml = fullBody
  ? fullBody
  : post.excerpt
    ? `<p class="post-excerpt-lede">${post.excerpt}</p>
<div class="post-excerpt-cta-block">
  <p>To learn more, call us at <a href="tel:9734948431">(973) 494-8431</a> or book a consultation with our team.</p>
  <a href="/consultation" class="post-excerpt-cta-link">Book a Free Consultation</a>
</div>`
    : '<p>Content coming soon.</p>';

// Format date for display
function formatDate(iso: string | undefined): string {
  if (!iso) return '';
  try {
    return new Date(iso).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  } catch {
    return iso;
  }
}
---

<BlogPostTemplate
  title={post.title}
  slug={post.slug}
  date={formatDate(post.firstPublished)}
  author="Menon Medispa"
  featured_image_src={post.coverImage}
  featured_image_alt={post.title}
  content_html={contentHtml}
/>
