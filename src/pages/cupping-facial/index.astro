---
/**
 * Cupping Facial in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/cupping-facial/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Cupping Facial | Menon Medispa & Wellness | Millburn, NJ"
  description="Experience the ancient art of cupping modernized for facial rejuvenation in Millburn NJ. Improve circulation, reduce puffiness, and achieve a natural glow."
>
  <main class="sp" data-slug="cupping-facial">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Cupping Facial in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Cupping Facial in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Ancient Technique, Modern Glow</p>
            <p class="sp-hero__lead">Experience the rejuvenating power of facial cupping. This ancient technique modernized for today's skin uses gentle suction to boost circulation, reduce puffiness, and deliver a luminous, lifted appearance.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/651c7c197b52.png" alt="Cupping Facial in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Natural Glow Boost</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Reduces Puffiness</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> No Chemicals Needed</p>
      </div>
    </section>

    
    {/* ===== WHAT IS A CUPPING FACIAL? ===== */}
    <section class="sp-plain" aria-label="What is a Cupping Facial?">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">What is a Cupping Facial?</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Facial cupping uses small suction cups to gently lift and massage your skin, increasing circulation and lymphatic drainage. This increases blood flow to the treated areas, delivering nutrients and oxygen while removing toxins and reducing inflammation.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">The result is a natural, healthy glow, reduced puffiness, and over time, improved skin tone and elasticity. Unlike body cupping, facial cupping uses smaller, gentler cups and leaves no marks.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Benefits Include</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Improved circulation and skin radiance</li><li>Reduced facial puffiness and tension</li><li>Enhanced lymphatic drainage</li><li>Natural face-lifting effect</li><li>Improved product absorption</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>Does facial cupping hurt?</summary>
              <div class="sp-faq__answer"><p>Not at all! Facial cupping uses very gentle suction that feels like a relaxing massage. Most clients find it deeply soothing. The cups are much smaller and softer than those used for body cupping, and they're always kept moving to prevent any bruising.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How often should I get a cupping facial?</summary>
              <div class="sp-faq__answer"><p>For optimal results, we recommend weekly sessions for the first month, then monthly maintenance treatments. You'll notice immediate results including improved radiance and reduced puffiness after your very first session.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is cupping safe for all skin types?</summary>
              <div class="sp-faq__answer"><p>Facial cupping is generally safe for most skin types. However, it may not be suitable for clients with certain skin conditions like active rosacea, broken capillaries, or inflamed skin. We'll assess your skin during your consultation.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Discover Your Natural Radiance">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Discover Your Natural Radiance</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Book your cupping facial today and experience the ancient secret to a natural, luminous glow at Menon Medispa in Millburn, NJ.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
