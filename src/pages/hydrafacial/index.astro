---
/**
 * HydraFacial — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/hydrafacial/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="HydraFacial in Millburn NJ | Menon Medispa & Wellness"
  description="Discover our customized HydraFacial in Millburn NJ. Address specific skin concerns and enjoy radiant skin with our medical spa services. Book your appointment online today!"
>
  <main class="sp" data-slug="hydrafacial">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="HydraFacial">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">HydraFacial in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Turn Back Time with Smooth, Youthful Skin – Without Recovery or Downtime</p>
            <p class="sp-hero__lead">Discover our customized HydraFacial in Millburn NJ. Address specific skin concerns and enjoy radiant skin with our medical spa services. Book your appointment online today!</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/hydrafacial">Schedule Your HydraFacial™ Today</a>
              <a class="sp-btn sp-btn--white" href={`tel:${site.phone.tel}`}>Call For Free Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/34ef44b50a1c.jpg" alt="HydraFacial Treatment" width="454" height="341" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Immediate Visible Results</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Customized for Your Skin Type</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> No Downtime or Recovery</p>
      </div>
    </section>

    {/* ===== CONTENT ===== */}
    <section class="sp-plain" aria-label="About HydraFacial">
      <div class="sp-container">
        <div style="max-width:1060px;margin:0 auto;display:grid;grid-template-columns:1fr 420px;gap:3rem;align-items:start;">
          <div>
            <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1rem;">The Challenge of Maintaining Healthy, Radiant Skin</h2>
            <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Dealing with skin problems can be frustrating and confidence-draining. Environmental factors and aging leave skin looking dull while over-the-counter products fail to address deeper concerns.</p>
            <ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0 0 1rem;">
              <li>Conventional products rarely penetrate deep enough for lasting change</li>
              <li>Seasonal changes and stress constantly challenge skin's balance</li>
              <li>Different facial areas have completely different needs</li>
            </ul>
            <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1.5rem;">Traditional facial treatments offer only temporary relief. Most are either too harsh or too gentle to deliver real results. Thankfully we found the answer.</p>
            <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.5rem,2.5vw,1.9rem);color:var(--color-ink);margin:0 0 0.75rem;">The HydraFacial™ Solution: Advanced Skincare Technology</h2>
            <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">The HydraFacial™ treatment rejuvenates and protects your skin's health, providing immediate results without downtime.</p>
            <ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0 0 1.5rem;">
              <li>Advanced HydraFacial™ technology with patented Vortex-Fusion delivery system</li>
              <li>Painless extraction process that targets fine lines, texture issues, and congestion</li>
              <li>Superior results compared to traditional facial treatments</li>
            </ul>
            <div style="display:flex;flex-direction:column;gap:0.85rem;">
              <div style="background:#f8f4f0;padding:1rem 1.25rem;border-radius:var(--radius-sm);">
                <strong style="font-family:var(--font-display);color:var(--color-ink);">CLEANSE + PEEL</strong>
                <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0.25rem 0 0;font-size:var(--text-sm);line-height:1.6;">Uncover a new layer of skin with gentle exfoliation and relaxing resurfacing.</p>
              </div>
              <div style="background:#f8f4f0;padding:1rem 1.25rem;border-radius:var(--radius-sm);">
                <strong style="font-family:var(--font-display);color:var(--color-ink);">EXTRACT + HYDRATE</strong>
                <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0.25rem 0 0;font-size:var(--text-sm);line-height:1.6;">Remove debris from pores with painless suction. Nourish with intense moisturizers that quench skin.</p>
              </div>
              <div style="background:#f8f4f0;padding:1rem 1.25rem;border-radius:var(--radius-sm);">
                <strong style="font-family:var(--font-display);color:var(--color-ink);">FUSE + PROTECT</strong>
                <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0.25rem 0 0;font-size:var(--text-sm);line-height:1.6;">Saturate the skin's surface with antioxidants and peptides to maximize your glow.</p>
              </div>
            </div>
          </div>
          <div>
            <img src="/images/3c38afa74542.jpg" alt="HydraFacial treatment" width="720" height="594" loading="lazy" style="width:100%;height:auto;border-radius:var(--radius-sm);" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          They have the best hydrafacials. Let me tell you, I've had facials before, but this was on another level. My skin felt like it had been reborn! The process was gentle yet thorough, and I could literally see the gunk being extracted (which, yes, was oddly satisfying!).
          <cite>Rathi Vijay<span class="sp-quote__sub"> — Millburn Resident</span></cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    {/* ===== PHOTO GRID ===== */}
    <section class="sp-photos" aria-label="HydraFacial Gallery">
      <div class="sp-container">
        <div class="sp-photos__grid" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr));">
          <img src="/images/0123d7937bc5.jpg" alt="Before & After" loading="lazy" style="height:180px;" />
          <img src="/images/d4b982753ae2.jpg" alt="HydraFacial Treatment" loading="lazy" style="height:180px;" />
          <img src="/images/558017ce8956.jpg" alt="HydraFacial session" loading="lazy" style="height:180px;" />
          <img src="/images/098a5bd79bf4.jpg" alt="HydraFacial product" loading="lazy" style="height:180px;" />
          <img src="/images/9110e6d86cfe.jpg" alt="HydraFacial result" loading="lazy" style="height:180px;" />
          <img src="/images/98a9c356acaf.jpg" alt="Female treatment" loading="lazy" style="height:180px;" />
        </div>
      </div>
    </section>

    {/* ===== PRICING ===== */}
    <section class="sp-pricing" aria-label="HydraFacial Menu">
      <div class="sp-container">
        <div class="sp-pricing__head">
          <h2>HydraFacial Menu</h2>
          <p>Please note: Prices are for display only. After booking, a coordinator will reach out to confirm your appointment and discuss payment arrangements and any other questions you may have.</p>
        </div>
        <div class="sp-pricelist">
          <div class="sp-priceitem">
            <img class="sp-priceitem__thumb" src="/images/3f237fc217e2.jpg" alt="Signature HydraFacial" loading="lazy" />
            <div class="sp-priceitem__main">
              <a class="sp-priceitem__title" href="/booking-calendar/signature-hydrafacial">Signature HydraFacial</a>
              <p class="sp-priceitem__sub">Deeply cleanses, extracts and hydrates the skin</p>
              <a class="sp-priceitem__readmore" href="/service-page/signature-hydrafacial">Read More</a>
              <p class="sp-priceitem__sub" style="margin-top:0.25rem;">30 min</p>
            </div>
            <div class="sp-priceitem__price">$199</div>
            <a class="sp-btn sp-btn--gold sp-priceitem__cta" href="/booking-calendar/signature-hydrafacial">Request to Book</a>
          </div>
          <div class="sp-priceitem">
            <img class="sp-priceitem__thumb" src="/images/86072f9cbd9c.jpg" alt="Deluxe HydraFacial" loading="lazy" />
            <div class="sp-priceitem__main">
              <a class="sp-priceitem__title" href="/booking-calendar/deluxe-hydrafacial">Deluxe HydraFacial</a>
              <p class="sp-priceitem__sub">HydraFacial with LED Light Therapy and targeted boosters.</p>
              <a class="sp-priceitem__readmore" href="/service-page/deluxe-hydrafacial">Read More</a>
              <p class="sp-priceitem__sub" style="margin-top:0.25rem;">1 hr</p>
            </div>
            <div class="sp-priceitem__price">$250</div>
            <a class="sp-btn sp-btn--gold sp-priceitem__cta" href="/booking-calendar/deluxe-hydrafacial">Request to Book</a>
          </div>
          <div class="sp-priceitem">
            <img class="sp-priceitem__thumb" src="/images/52a268e013ba.png" alt="Platinum HydraFacial" loading="lazy" />
            <div class="sp-priceitem__main">
              <a class="sp-priceitem__title" href="/booking-calendar/platinum-hydrafacial">Platinum HydraFacial</a>
              <p class="sp-priceitem__sub">HydraFacial, Lymphatic Drainage &amp; LED Light Therapy</p>
              <a class="sp-priceitem__readmore" href="/service-page/platinum-hydrafacial">Read More</a>
              <p class="sp-priceitem__sub" style="margin-top:0.25rem;">1 hr 20 min</p>
            </div>
            <div class="sp-priceitem__price">$325</div>
            <a class="sp-btn sp-btn--gold sp-priceitem__cta" href="/booking-calendar/platinum-hydrafacial">Request to Book</a>
          </div>
        </div>
      </div>
    </section>

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently Asked Questions</h2>
          </div>
          <div class="sp-faq__list">
            <details class="sp-faq__item" open>
              <summary>What exactly is a HydraFacial™ and how does it work?</summary>
              <div class="sp-faq__answer"><p>HydraFacial™ is a medical-grade resurfacing treatment that cleanses, extracts, and hydrates your skin using patented Vortex-Fusion technology. This multi-step treatment delivers immediate results for skin health with no downtime by combining exfoliation with nourishing serums.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How is it different from other facial treatments?</summary>
              <div class="sp-faq__answer"><p>Unlike traditional facials, HydraFacial™ provides consistent results for all skin types without irritation. The treatment is fully customizable for your specific skin concerns and delivers deeper hydration than standard facials, with results visible immediately.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How often should I get a HydraFacial™ treatment?</summary>
              <div class="sp-faq__answer"><p>For optimal results, we recommend monthly treatments. This frequency helps maintain hydration levels and supports your skin's natural regeneration cycle. Your provider will suggest a personalized plan based on your specific skin concerns.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is there any HydraFacial™ aftercare I should follow?</summary>
              <div class="sp-faq__answer"><p>HydraFacial™ requires minimal aftercare. We recommend applying sunscreen and avoiding excessive sun exposure following your treatment. Your skin will be more receptive to products immediately after, making it an ideal time to use quality serums.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Begin Your Transformation Today">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Begin Your Transformation Today</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Ready to experience the benefits of Menon Medispa's HydraFacial™ but not sure if it's right for you? Take the first step toward Perfect Skin by scheduling your FREE personal consultation at Menon Medispa in Millburn, NJ.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Free Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
