---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';

import Section1 from '@/pages/_sections/body__section_1.astro';
import Section2 from '@/pages/_sections/body__section_2.astro';
import Section3 from '@/pages/_sections/body__section_3.astro';
import Section4 from '@/pages/_sections/body__section_4.astro';
import Section5 from '@/pages/_sections/body__section_5.astro';
import Section6 from '@/pages/_sections/body__section_6.astro';
import Section7 from '@/pages/_sections/body__section_7.astro';

const pageUrl = `${site.url}/body/`;
const pageDescription = 'Explore physician-led body treatments in Millburn, NJ at Menon Medispa, including laser hair removal, IV therapy, semaglutide, and vascular treatments.';
const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#collection`,
    url: pageUrl,
    name: 'Body Treatments',
    description: pageDescription,
    isPartOf: { '@id': site.schemaId },
    about: {
      '@type': 'Service',
      name: 'Body treatments',
      provider: { '@id': site.schemaId },
      areaServed: site.areaServed,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Body', item: pageUrl },
    ],
  },
];
---

<BaseLayout
  title="Body Treatments & Wellness in Millburn NJ | Menon Medispa"
  description={pageDescription}
  canonical={pageUrl}
  jsonld={jsonld}
>

  <!-- Section 1: Hero, Advanced Solutions for Total Body Wellness -->
  <Section1 />

  <!-- Section 2: Trust Bar, Same-Week Appointments | Medical-Grade Expertise | State of the Art Equipment -->
  <Section2 />

  <!-- Section 3: Services Grid, Comprehensive Body Treatments & Enhancements -->
  <Section3 />

  <!-- Section 4: Testimonial, What Our Clients Say (Alexa C.) -->
  <Section4 />

  <!-- Section 5: Why Choose, Why Choose Menon Medispa for Your Body Treatments? -->
  <Section5 />

  <!-- Section 6: FAQ, Frequently asked questions -->
  <Section6 />

  <!-- Section 7: Final CTA, Begin Your Transformation Today -->
  <Section7 />

</BaseLayout>

