---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout>
  <main class="pg" data-slug="consultation">
<section class="pg-section" data-section="Transform Your Skin with a Personalized Consultation">
  <img class="pg-img" src="/images/fc22050ddcb3.webp" alt="download copy.webp" width="1440" height="247" loading="lazy" />
  <h1 class="pg-h">Transform Your Skin with a Personalized Consultation</h1>
  <p class="pg-text">Our expert team will help determine the best treatments for your unique skincare needs and goals.</p>
</section>

<section class="pg-section" data-section="Why Choose Our Consultations?">
  <p class="pg-text">Schedule Your Consultation Today</p>
  <p class="pg-text">Fill out this form and we'll contact you within 24 hours</p>
  <p class="pg-btnlabel">Request My Consultation</p>
  <h2 class="pg-h">Why Choose Our Consultations?</h2>
  <p class="pg-text">At Menon Medispa &amp; Wellness, we take a personalized approach to your skincare journey.</p>
  <h3 class="pg-h">Expert Assessment</h3>
  <p class="pg-text">Our highly trained professionals will evaluate your skin's unique needs and concerns.</p>
  <h3 class="pg-h">Customized Treatment Plans</h3>
  <p class="pg-text">Receive personalized recommendations tailored specifically to your skin type and goals.</p>
  <h3 class="pg-h">Advanced Technology</h3>
  <p class="pg-text">Access to the latest aesthetic treatments and medical-grade skincare solutions.</p>
  <h3 class="pg-h">Flexible Consultation Options</h3>
  <p class="pg-text">Choose the consultation type that best fits your needs and budget.<br /><br />Consultation with Esthetician: FREE<br /><br />Consultation with Doctor: $50</p>
</section>

<section class="pg-section" data-section="Opening Hours">
  <h2 class="pg-h">Opening Hours</h2>
  <p class="pg-text">Menon Medispa &amp; Wellness</p>
  <p class="pg-text">45 Essex St, Suite 202, Millburn, NJ 07041, USA</p>
  <p class="pg-text">admin@menonregen.com</p>
  <p class="pg-text">(973) 494-8431</p>
  <p class="pg-text">Mon - Fri</p>
  <p class="pg-text">10:00 am – 6:00 pm</p>
  <p class="pg-text">Saturday</p>
  <p class="pg-text">10:00 am – 2:00 pm</p>
  <p class="pg-text">​Sunday</p>
  <p class="pg-text">CLOSED</p>
  <img class="pg-img" src="/images/464c5b23f583.png" alt="Facebook" width="23" height="23" loading="lazy" />
  <img class="pg-img" src="/images/a29df34857a1.png" alt="Instagram" width="23" height="23" loading="lazy" />
  <img class="pg-img" src="/images/d11778476dcb.png" alt="TikTok" width="23" height="23" loading="lazy" />
</section>
  </main>
</BaseLayout>
