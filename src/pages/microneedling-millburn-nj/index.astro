---
/**
 * Microneedling in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/microneedling-millburn-nj/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Microneedling in Millburn NJ | Menon Medispa & Wellness"
  description="Professional microneedling (SkinPen) in Millburn NJ. Reduce acne scars, fine lines, and improve overall skin texture with our FDA-cleared microneedling treatment."
>
  <main class="sp" data-slug="microneedling-millburn-nj">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Microneedling in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Microneedling in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">FDA-Cleared SkinPen Treatment for Transformative Results</p>
            <p class="sp-hero__lead">Microneedling with the SkinPen device is the gold-standard for skin rejuvenation. This FDA-cleared treatment creates thousands of micro-channels to trigger your skin's natural healing response, resulting in smoother, firmer, younger-looking skin.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/cebad624861f.jpg" alt="Microneedling in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> FDA-Cleared SkinPen</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Reduces Acne Scars</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Stimulates Collagen</p>
      </div>
    </section>

    
    {/* ===== HOW MICRONEEDLING WORKS ===== */}
    <section class="sp-plain" aria-label="How Microneedling Works">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">How Microneedling Works</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">The SkinPen creates thousands of microscopic punctures in the skin's surface, triggering the body's natural wound-healing process. This stimulates the production of new collagen and elastin, the proteins responsible for firm, smooth, youthful skin.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Unlike more aggressive resurfacing treatments, microneedling preserves the surface layer of the skin while working deep within the dermis. This makes it an excellent option for reducing acne scars, fine lines, large pores, stretch marks, and overall skin texture.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">What Microneedling Addresses</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Acne scars and post-inflammatory marks</li><li>Fine lines and early wrinkles</li><li>Enlarged pores</li><li>Uneven skin texture</li><li>Hyperpigmentation</li><li>Skin laxity and firmness</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>Is microneedling painful?</summary>
              <div class="sp-faq__answer"><p>A topical numbing cream is applied before treatment to ensure your comfort. Most clients describe the sensation as a light vibration. The treatment typically takes 30-60 minutes including numbing time. Mild redness and sensitivity are normal for 24-48 hours afterward.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How many sessions do I need?</summary>
              <div class="sp-faq__answer"><p>For optimal results with acne scars or more significant concerns, we recommend 3-6 sessions spaced 4-6 weeks apart. For general skin rejuvenation and anti-aging, 2-3 sessions per year are typically sufficient.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>When will I see results from microneedling?</summary>
              <div class="sp-faq__answer"><p>Initial improvements in skin texture and radiance can be seen within 1-2 weeks of treatment. More significant results, particularly for scars and collagen remodeling, develop over 3-6 months as new collagen continues to form.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Begin Your Skin Transformation">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Begin Your Skin Transformation</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Schedule your microneedling consultation at Menon Medispa in Millburn, NJ and take the first step toward smoother, younger-looking skin.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
