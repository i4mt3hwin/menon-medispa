---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout>
  <main class="pg" data-slug="meet-the-team">
<section class="pg-section" data-section="Meet the Menon Medispa Millburn Team">
  <img class="pg-img" src="/images/fc22050ddcb3.webp" alt="download copy.webp" width="1440" height="247" loading="lazy" />
  <h1 class="pg-h">Meet the Menon Medispa Millburn Team</h1>
</section>

<section class="pg-section">
  <p class="pg-text">Dedicated professionals committed to enhancing your natural beauty and well-being. Our diverse team combines specialized training in skincare, health, and relaxation techniques to create personalized experiences for rejuvenation and confidence.</p>
  <img class="pg-img" src="/images/88353b502c45.png" alt="DSC07528 copy_edited.png" width="295" height="356" loading="lazy" />
  <p class="pg-text">Dr. Aditi Menon, MD</p>
  <p class="pg-text">Founder &amp; CEO</p>
  <img class="pg-img" src="/images/807fae7ef1f5.png" alt="DSC07508 copy_edited.png" width="295" height="356" loading="lazy" />
  <p class="pg-text">Shruti Sen</p>
  <p class="pg-text">Practice Manager</p>
  <img class="pg-img" src="/images/48d39eee8013.png" alt="DSC07560-2 copy_edited.png" width="295" height="356" loading="lazy" />
  <p class="pg-text">Nancy C.</p>
  <p class="pg-text">Medical Assistant</p>
  <img class="pg-img" src="/images/df9285b183d3.png" alt="DSC07543 copy_edited_edited_edited.png" width="295" height="356" loading="lazy" />
  <p class="pg-text">Jennifer Ramirez</p>
  <p class="pg-text">Esthetician</p>
  <img class="pg-img" src="/images/10df2823350b.png" alt="DSC07515 copy_edited.png" width="295" height="356" loading="lazy" />
  <p class="pg-text">Rosemarie Boisselle</p>
  <p class="pg-text">Receptionist</p>
</section>

<section class="pg-section">
  <h6 class="pg-h">DR. ADITI MENON, MD</h6>
  <p class="pg-text">Dr. Aditi Menon, MD is Board Certified in Physical Medicine and Rehabilitation, and specializes in musculoskeletal, pain and sports medicine.</p>
  <p class="pg-text">Dr. Menon earned her medical degree at the State University of New York Brooklyn Downstate Medical Center College of Medicine. She then completed her residency in Physical Medicine and Rehabilitation at New York Presbyterian Hospital at New York-Presbyterian University Hospitals of Columbia Presbyterian and Weill Cornell with training in Hospital for Special Surgery and Memorial Sloan Kettering Cancer Center.</p>
  <p class="pg-text">Dr. Menon is trained in regenerative medicine and her passion is aesthetics.</p>
  <p class="pg-text">In her spare time, she teaches Indian classical dance and likes to spend time with her family.</p>
  <img class="pg-img" src="/images/68f97116134e.jpg" alt="DSC07528 copy_edited.jpg" width="821" height="772" loading="lazy" />
</section>

<section class="pg-section" data-section="Begin Your Transformation Today">
  <h2 class="pg-h">Begin Your Transformation Today</h2>
  <p class="pg-text">Menon Medispa Millburn NJ</p>
  <p class="pg-text">Ready to experience the benefits of Menon Medispa? Take the first step toward your transformation by scheduling your personal consultation at Menon Medispa in Millburn, NJ.</p>
  <a class="pg-btn" href="/contact">Schedule Consultation</a>
  <img class="pg-img" src="/images/b1a819f35921.webp" alt="Menon Office Staff.webp" width="431" height="560" loading="lazy" />
</section>
  </main>
</BaseLayout>
