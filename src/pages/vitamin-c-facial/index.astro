---
/**
 * Vitamin C Facial in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/vitamin-c-facial/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Vitamin C Facial | Menon Medispa & Wellness | Millburn, NJ"
  description="Professional Vitamin C facial in Millburn NJ. Brighten skin, reduce dark spots, and boost collagen production with our medical-grade Vitamin C treatment."
>
  <main class="sp" data-slug="vitamin-c-facial">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Vitamin C Facial in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Vitamin C Facial in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Brighten, Protect, and Rejuvenate Your Skin</p>
            <p class="sp-hero__lead">Our professional Vitamin C facial delivers powerful antioxidant protection while brightening your complexion, fading dark spots, and stimulating collagen production. Experience noticeably brighter, more even-toned skin after just one treatment.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/651c7c197b52.png" alt="Vitamin C Facial in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Brightens Complexion</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Reduces Dark Spots</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Boosts Collagen</p>
      </div>
    </section>

    
    {/* ===== WHY VITAMIN C IS ESSENTIAL FOR SKIN HEALTH ===== */}
    <section class="sp-plain" aria-label="Why Vitamin C is Essential for Skin Health">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">Why Vitamin C is Essential for Skin Health</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Vitamin C is one of the most powerful and well-researched skincare ingredients available. As a potent antioxidant, it neutralizes free radical damage, reduces inflammation, and plays a critical role in collagen synthesis.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Our medical-grade Vitamin C facial uses concentrations that cannot be achieved with at-home products, delivering transformative results you can see and feel immediately. The treatment is customized to your specific skin concerns and type.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Key Benefits</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Brightens dull, uneven complexion</li><li>Reduces hyperpigmentation and dark spots</li><li>Stimulates natural collagen production</li><li>Provides powerful antioxidant protection</li><li>Evens out skin tone</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>Is the Vitamin C facial suitable for sensitive skin?</summary>
              <div class="sp-faq__answer"><p>Yes, with the right formulation. We assess your skin before the treatment and select the appropriate Vitamin C concentration and formulation for your skin type. Clients with sensitive skin may start with a lower concentration and build up gradually.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How long do results last?</summary>
              <div class="sp-faq__answer"><p>Results from a single Vitamin C facial last approximately 2-4 weeks. For sustained benefits, we recommend regular monthly treatments. Consistent use helps maintain brightening effects and provides ongoing protection against environmental damage.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Can I combine this with other treatments?</summary>
              <div class="sp-faq__answer"><p>Absolutely! Vitamin C facials pair beautifully with chemical peels, microneedling, and other brightening treatments. We'll recommend the best combination for your specific skin goals during your consultation.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Reveal Your Brightest Skin">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Reveal Your Brightest Skin</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Experience the brightening power of our professional Vitamin C facial at Menon Medispa in Millburn, NJ.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
