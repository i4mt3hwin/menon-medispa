---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceHero from '@/components/ServiceHero.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import SalePopup from '@/components/SalePopup.astro';

import { getRelatedPosts } from '@/lib/relatedPosts';
import { buildServiceSchema } from '@/lib/serviceSchema';

// Kept full-width experiential bands (reused verbatim from the original build)
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import TrustBar from '@/pages/_sections/fillers-injectables__section_2.astro';
import JuvedermBand from '@/pages/_sections/fillers-injectables__section_4.astro';
import Pricing from '@/pages/_sections/fillers-injectables__section_5.astro';
import FinalCta from '@/pages/_sections/fillers-injectables__section_6.astro';

import heroImg from '@/assets/images/db8d4e94db1e.jpg';

const slug = 'fillers-injectables';
const posts = getRelatedPosts(slug);

// FAQ, single source for the on-page accordion AND the FAQPage schema.
const faqs = [
  {
    question: 'What is the difference between Botox and dermal fillers?',
    answer:
      'Botox is a neuromodulator that relaxes the muscles responsible for expression lines, such as crow\'s feet and forehead creases. Dermal fillers like Juvéderm add volume beneath the skin to smooth folds, restore lost fullness, and enhance features such as the lips and cheeks. Many clients combine both for a balanced, refreshed result.',
  },
  {
    question: 'How long do filler and injectable results last?',
    answer:
      'It depends on the treatment. Botox results typically last about 3 to 4 months, while Juvéderm dermal fillers can last between 12 and 24 months depending on the formula and area treated. We will review what to expect for your specific plan during your consultation.',
  },
  {
    question: 'Is there any downtime after treatment?',
    answer:
      'Most clients return to their normal activities right away. You may notice mild redness, swelling, tenderness, or small bruises at the injection sites, which usually fade within a few days. We provide aftercare guidance to support comfortable healing.',
  },
  {
    question: 'Does getting fillers or injectables hurt?',
    answer:
      'Most clients find these treatments very tolerable. Juvéderm fillers contain lidocaine to numb the area, and we can apply a topical numbing cream for added comfort. Botox injections involve only a quick pinch and are generally well tolerated.',
  },
  {
    question: 'Who performs the injectable treatments at Menon Medispa?',
    answer:
      'Our injectable treatments are physician-led by Dr. Aditi Menon, MD, who brings medical training and an aesthetic eye to every plan. Treatments are administered by qualified medical professionals so your care is precise, safe, and tailored to your goals.',
  },
];
const faqItems = faqs.map((f) => ({ question: f.question, answer_html: `<p>${f.answer}</p>` }));

const jsonld = buildServiceSchema({
  name: 'Fillers & Injectables in Millburn, NJ',
  description:
    'Advanced filler and injectable treatments in Millburn, NJ. BOTOX at $14 per unit, Juvederm from $750. Personalized treatments by medical professionals at Menon Medispa.',
  url: '/fillers-injectables',
  image: heroImg.src,
  type: 'MedicalProcedure',
  category: 'Injectables',
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Face', url: '/face' },
    { name: 'Fillers & Injectables', url: '/fillers-injectables' },
  ],
  faqs,
});
---

<BaseLayout
  title="Fillers & Injectables Millburn NJ | BOTOX & Juvederm | Menon Medispa"
  description="Advanced filler and injectable treatments in Millburn, NJ. BOTOX at $14 per unit, Juvederm from $750. Personalized treatments by medical professionals."
  canonical="https://www.menonmedispa.com/fillers-injectables"
  jsonld={jsonld}
>

  <ServiceHero
    eyebrow="FILLERS & INJECTABLES · MILLBURN, NJ"
    h1="Refresh Your Look with Premium Fillers & Injectables in Millburn, NJ"
    subhead="A full range of BOTOX and Juvederm treatments with customized plans designed for your unique facial anatomy, by our board-certified team."
    image={heroImg}
    imageAlt="Premium fillers and injectables at Menon Medispa Millburn NJ"
    price="Starting at $14 per unit"
    note="Customized treatment plans, administered by medical professionals."
    trust={{ stars: true, reviewText: '100+ 5 Star Reviews' }}
  />

  <TrustBar />

  <ServiceLayout>
    <!-- MAIN COLUMN -->
    <div class="svc-block">
      <h2>About Our Fillers &amp; Injectables</h2>

      <p class="svc-lead">At Menon Medispa, we offer a comprehensive range of dermal fillers and injectable treatments to help you achieve a naturally rejuvenated appearance.</p>

      <p>Our experienced team of medical professionals creates personalized treatment plans to address your unique concerns and goals.</p>

      <p>Our dermal fillers, including Juv&eacute;derm, are expertly administered to restore volume, smooth lines, and enhance facial contours. Each treatment is performed by our certified medical professionals who understand the art and science of facial aesthetics.</p>

      <p>Our <a href="/botox-millburn-nj">Botox &amp; Injectables</a> treatments are expertly administered by Dr. Menon, who uses precise techniques to smooth lines and restore youthful movement to the face.</p>

      <p>With our expertise and precision, we help you achieve results that look natural and last. Whether you're looking to address fine lines, restore volume, or enhance your lips, our team will create a customized treatment plan that's right for you.</p>

      <ul class="svc-features">
        <li>
          <h3>Customized Treatment Plans</h3>
          <p>Personalized plans designed for your unique facial anatomy and goals</p>
        </li>
        <li>
          <h3>Medical-Grade</h3>
          <p>Only FDA-approved injectables administered by certified professionals</p>
        </li>
        <li>
          <h3>Expert Technicians</h3>
          <p>Our team understands the art and science of facial aesthetics</p>
        </li>
        <li>
          <h3>Natural-Looking Results</h3>
          <p>Outcomes that look refreshed and authentic, never overdone</p>
        </li>
      </ul>
    </div>

    <!-- SIDEBAR -->
    <Fragment slot="aside">
      <QuickFacts
        cta
        reviewText="100+ 5 Star Reviews"
        items={[
          { label: 'BOTOX Price', value: '$14 per unit' },
          { label: 'Juvederm Fillers', value: 'From $750' },
          { label: 'Treatment plans', value: 'Customized' },
          { label: 'Performed by', value: 'Medical professionals' },
          { label: 'Location', value: 'Millburn, NJ' },
        ]}
      />
    </Fragment>
  </ServiceLayout>

  <JuvedermBand />

  <ServiceTestimonial slug="fillers-injectables" />

  <Pricing />

  <FaqAccordion heading="Frequently asked questions" items={faqItems} />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

</BaseLayout>
<!-- redesign: service-page template (hero + 2-col body + sticky sidebar). Bands 2/4/5/6 reused verbatim. Section 3 prose inlined into main column. Section 1 (hero) replaced by ServiceHero. No promo band present. -->
