---
/**
 * /request-appointment — appointment-request entry. The operator's primary
 * scheduling path is the Cal.com external embed (site.calcomUrl, placeholder
 * until real event-type URLs are provided). This page additionally offers the
 * consent-compliant appointment-request LeadForm (D1, non-PHI) as a fallback so
 * visitors can request a date/time even before Cal.com is live. Service dropdown
 * is seeded from the 17 captured Bookings categories (verbatim).
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeadForm from '@/components/LeadForm.astro';
import SchedulerEmbed from '@/components/SchedulerEmbed.astro';

const categories = [
  'Menon Facials', 'Laser Hair Removal', 'IV Drips', 'Custom IV Drips', 'Vitamin Shots',
  'Vascular Treatments', 'Fillers & Injectables', 'Massage', 'HydraFacial',
  'HydraFacial™ Keravive™', 'Laser Facials', 'Semaglutide', 'Hair Restoration',
  'Botox', 'Laser Hair Removal Package', 'Gift Cards', 'Sale',
];
---
<BaseLayout
  title="Request an Appointment | Menon Medispa & Wellness | Millburn, NJ"
  description="Request your appointment at Menon Medispa in Millburn, NJ. Choose a service and your preferred date and time, and our team will confirm.">
  <main class="ra">
    <section class="ra-section">
      <h1>Request an Appointment</h1>
      <p>Book online with our scheduler, or send us your preferred date and time below and we’ll confirm.</p>
      <SchedulerEmbed />
    </section>
    <section class="ra-section ra-form">
      <h2>Send an appointment request</h2>
      <LeadForm variant="appointment" services={categories} />
    </section>
  </main>
</BaseLayout>
<style>
  .ra-section { max-width: var(--container-content); margin: 0 auto; padding: var(--spacing-section) 1.5rem; font-family: var(--font-ui); }
  .ra-section h1 { font-family: var(--font-display); font-size: var(--text-5xl); text-align: center; }
  .ra-section > p { text-align: center; line-height: 1.7; }
  .ra-form h2 { font-family: var(--font-display); font-size: var(--text-3xl); }
</style>
