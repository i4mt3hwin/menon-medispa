---
/**
 * Dermaplaning Facial in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/dermaplaning-facial/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Dermaplaning Facial | Menon Medispa & Wellness | Millburn, NJ"
  description="Professional dermaplaning facial in Millburn NJ. Remove dead skin cells and peach fuzz for instantly smoother, brighter skin."
>
  <main class="sp" data-slug="dermaplaning-facial">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Dermaplaning Facial in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Dermaplaning Facial in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Instantly Smoother Skin, Zero Downtime</p>
            <p class="sp-hero__lead">Dermaplaning is a safe, effective exfoliating treatment that removes dead skin cells and vellus hair (peach fuzz) from your face, revealing a smoother, brighter complexion underneath. Perfect for all skin types with immediate results.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/651c7c197b52.png" alt="Dermaplaning Facial in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Instant Glow</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Removes Peach Fuzz</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Zero Downtime</p>
      </div>
    </section>

    
    {/* ===== HOW DERMAPLANING WORKS ===== */}
    <section class="sp-plain" aria-label="How Dermaplaning Works">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">How Dermaplaning Works</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">During dermaplaning, our licensed esthetician uses a sterile surgical scalpel held at a 45-degree angle to gently scrape the surface of your skin. This removes the outermost layer of dead skin cells and vellus hair, triggering your skin's natural renewal process.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">The result is immediately visible: your skin appears smoother, brighter, and more refined. Skincare products penetrate more effectively, and makeup applies more smoothly after dermaplaning.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Benefits of Dermaplaning</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Removes dead skin cells for immediate radiance</li><li>Eliminates peach fuzz for smoother makeup application</li><li>Enhances skincare product absorption by up to 70%</li><li>Reduces the appearance of fine lines and acne scars</li><li>Safe for pregnant women and sensitive skin</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>Will the peach fuzz grow back thicker after dermaplaning?</summary>
              <div class="sp-faq__answer"><p>No! This is a common misconception. Dermaplaning only removes vellus (soft, fine) hair. Vellus hair does not have the structure to grow back thicker or darker. Only terminal hair (like eyebrows) can change in texture.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How often should I get dermaplaning?</summary>
              <div class="sp-faq__answer"><p>We recommend dermaplaning every 3-4 weeks, which aligns with your skin's natural cell turnover cycle. Many clients combine it with a facial or chemical peel for enhanced results.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Who should avoid dermaplaning?</summary>
              <div class="sp-faq__answer"><p>Dermaplaning may not be suitable for clients with active acne breakouts, rosacea, eczema, psoriasis, or certain skin conditions. During your consultation, we'll assess your skin to ensure dermaplaning is the right treatment for you.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Reveal Your Best Skin">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Reveal Your Best Skin</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Experience the transformative results of professional dermaplaning at Menon Medispa in Millburn, NJ. Book your appointment today.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
