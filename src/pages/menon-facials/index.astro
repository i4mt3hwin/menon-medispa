---
/**
 * Menon Facials — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/menon-facials/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Menon Facials | Menon Medispa & Wellness | Millburn, NJ"
  description="Customized signature facials at Menon Medispa in Millburn NJ. Our skilled estheticians create personalized facial treatments for your unique skin needs."
>
  <main class="sp" data-slug="menon-facials">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Menon Facials">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Menon Facials</h1>
            <p class="sp-hero__eyebrow">Signature Facial Treatments Personalized for You</p>
            <p class="sp-hero__lead">Our signature Menon Facials are fully customized to address your unique skin concerns. Crafted by our skilled estheticians, each facial combines the best ingredients and techniques to reveal your most radiant, healthy skin.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/6447c7285078.jpg" alt="Menon Facials" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Fully Customized</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Medical-Grade Products</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Expert Estheticians</p>
      </div>
    </section>

    
    {/* ===== OUR FACIAL PHILOSOPHY ===== */}
    <section class="sp-plain" aria-label="Our Facial Philosophy">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">Our Facial Philosophy</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">At Menon Medispa, we believe every face is unique—and every facial should be too. Our estheticians begin with a thorough skin analysis before creating a customized treatment plan that addresses your specific concerns, whether that's dryness, acne, aging, or sensitivity.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">We use only medical-grade products and proven techniques to ensure every treatment delivers visible, lasting results. From deep cleansing to specialized serums and targeted treatments, every step of your facial is carefully chosen for your skin.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">What Every Menon Facial Includes</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Thorough skin analysis and consultation</li><li>Deep cleansing and exfoliation</li><li>Professional extractions (if needed)</li><li>Customized mask treatment</li><li>Targeted serums and moisturizers</li><li>Personalized home care recommendations</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How is the Menon Facial different from other facials?</summary>
              <div class="sp-faq__answer"><p>Every Menon Facial is uniquely customized to your skin's current needs. Unlike standard facials with a fixed protocol, our estheticians constantly assess and adapt the treatment based on how your skin responds. We use medical-grade products that aren't available over the counter.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How often should I get a facial?</summary>
              <div class="sp-faq__answer"><p>We recommend a professional facial every 4-6 weeks, aligning with your skin's natural cell turnover cycle. Regular facials help maintain results, address evolving skin concerns, and provide ongoing skin health benefits.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>What should I do before my facial appointment?</summary>
              <div class="sp-faq__answer"><p>Avoid using Retinol, AHAs/BHAs, or other active ingredients for 2-3 days before your appointment. Come with clean skin if possible. Let us know about any medications or skin conditions during booking.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Experience the Menon Facial Difference">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Experience the Menon Facial Difference</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Discover what a truly personalized facial can do for your skin. Book your Menon Facial at Menon Medispa in Millburn, NJ today.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
