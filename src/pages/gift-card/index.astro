---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
---
<BaseLayout title="Gift Cards | Menon Medispa &amp; Wellness | Millburn, NJ" description="Give the gift of beauty and wellness with Menon Medispa gift cards. Perfect for any occasion.">
  <main class="sp" data-slug="gift-card">
    <section class="sp-hero sp-hero--center" aria-label="Gift <em>Cards</em>">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Gift <em>Cards</em></h1>
        <p class="sp-hero__lead" style="text-align:center;margin:0 auto;max-width:560px;">Share the luxury of Menon Medispa with someone you love.</p>
      </div>
    </section>
    <section class="sp-plain" aria-label="Gift Cards">
    <div class="sp-container">
      <div class="sp-plain__inner">
        <h2 class="sp-plain__title">Give the Gift of Glow</h2>
        <div class="sp-plain__body">
          <p>Share the luxury of Menon Medispa with someone you love. Our gift cards are available in any denomination and can be used toward any of our treatments and services.</p>
          <p>Gift cards are available for purchase at our Millburn, NJ location or by calling us at (973) 494-8431.</p>
        </div>
        <a class="sp-btn sp-btn--gold" href="/contact">Contact Us to Purchase</a>
      </div>
    </div>
  </section>
  </main>
</BaseLayout>
