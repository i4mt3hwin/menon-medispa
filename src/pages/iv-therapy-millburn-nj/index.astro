---
/**
 * IV Therapy in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/iv-therapy-millburn-nj/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="IV Therapy in Millburn NJ | Menon Medispa & Wellness"
  description="IV vitamin drip therapy in Millburn NJ. Boost energy, immunity, and wellness with customized IV infusions. All drips are 500ml."
>
  <main class="sp" data-slug="iv-therapy-millburn-nj">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="IV Therapy in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">IV Therapy in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Boost Your Energy and Wellness with IV Therapy in Millburn, NJ</p>
            <p class="sp-hero__lead">Join countless clients in Millburn and Short Hills who trust Menon Medispa's IV Therapy to revitalize their body from the inside out. Our customized infusions deliver essential nutrients directly to your bloodstream—whether you're recovering from fatigue, stress, or simply want to feel your best every day.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/fc3ca8a7bdf0.jpg" alt="IV Therapy in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> 100% Bioavailability</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Customized Formulas</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Immediate Results</p>
      </div>
    </section>

    
    {/* ===== CONTENT ===== */}
    <section class="sp-plain" aria-label="Content">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;font-weight:700;">All IV Drips are 500ml. Upgrade to 1000ml for only $25</p>
        </div>
      </div>
    </section>
    {/* ===== FIND YOUR PERFECT IV DRIP ===== */}
    <section class="sp-plain" aria-label="Find Your Perfect IV Drip">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">Find Your Perfect IV Drip</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1.5rem;">Whether you're seeking to boost your immunity, enhance your energy, or support a specific health goal, we have a targeted IV therapy for you. Explore our curated categories below to discover how our advanced formulas can help you feel your best.</p>
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;">
  <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
    <h3 style="font-family:var(--font-display);font-weight:700;color:var(--color-ink);margin:0 0 0.5rem;font-size:var(--text-lg);">Immune Support</h3>
    <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0 0 0.75rem;font-size:var(--text-sm);line-height:1.6;">Strengthen your body's natural defenses and stay resilient year-round.</p>
    <a href="/immunity-support" style="color:var(--color-primary);font-family:var(--font-ui);font-size:var(--text-sm);font-weight:600;">Explore Immunity Drips →</a>
  </div>
  <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
    <h3 style="font-family:var(--font-display);font-weight:700;color:var(--color-ink);margin:0 0 0.5rem;font-size:var(--text-lg);">Energy &amp; Performance</h3>
    <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0 0 0.75rem;font-size:var(--text-sm);line-height:1.6;">Overcome daily fatigue, brain fog, and slow workout recovery.</p>
    <a href="/energy-performance" style="color:var(--color-primary);font-family:var(--font-ui);font-size:var(--text-sm);font-weight:600;">Explore Energy Drips →</a>
  </div>
  <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
    <h3 style="font-family:var(--font-display);font-weight:700;color:var(--color-ink);margin:0 0 0.5rem;font-size:var(--text-lg);">Anti-Aging &amp; Beauty</h3>
    <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0 0 0.75rem;font-size:var(--text-sm);line-height:1.6;">Unlock a radiant glow from within with age-defying formulas.</p>
    <a href="/anti-aging-beauty" style="color:var(--color-primary);font-family:var(--font-ui);font-size:var(--text-sm);font-weight:600;">Explore Beauty Drips →</a>
  </div>
  <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
    <h3 style="font-family:var(--font-display);font-weight:700;color:var(--color-ink);margin:0 0 0.5rem;font-size:var(--text-lg);">Recovery &amp; Detox</h3>
    <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0 0 0.75rem;font-size:var(--text-sm);line-height:1.6;">Reset, replenish, and recover after workouts or illness.</p>
    <a href="/recovery-detox" style="color:var(--color-primary);font-family:var(--font-ui);font-size:var(--text-sm);font-weight:600;">Explore Recovery Drips →</a>
  </div>
  <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
    <h3 style="font-family:var(--font-display);font-weight:700;color:var(--color-ink);margin:0 0 0.5rem;font-size:var(--text-lg);">NAD+ Therapy</h3>
    <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0 0 0.75rem;font-size:var(--text-sm);line-height:1.6;">Cutting-edge cellular repair, cognitive function, and longevity support.</p>
    <a href="/nad-iv-drip-therapy" style="color:var(--color-primary);font-family:var(--font-ui);font-size:var(--text-sm);font-weight:600;">Explore NAD+ Drips →</a>
  </div>
  <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
    <h3 style="font-family:var(--font-display);font-weight:700;color:var(--color-ink);margin:0 0 0.5rem;font-size:var(--text-lg);">Targeted Health Solutions</h3>
    <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0 0 0.75rem;font-size:var(--text-sm);line-height:1.6;">Advanced formulas to help manage chronic conditions.</p>
    <a href="/targeted-health-solutions-iv" style="color:var(--color-primary);font-family:var(--font-ui);font-size:var(--text-sm);font-weight:600;">Explore Health Solutions →</a>
  </div>
</div>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How long does an IV drip take?</summary>
              <div class="sp-faq__answer"><p>Most IV drip sessions take 30-60 minutes, depending on the formulation. You'll relax in our comfortable treatment area while the drip infuses. Our team will be on hand to ensure your comfort throughout the process.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Who administers the IV therapy?</summary>
              <div class="sp-faq__answer"><p>All IV therapies at Menon Medispa are administered by licensed medical professionals under Dr. Menon's supervision. We follow strict medical protocols to ensure safety and efficacy.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How often can I get IV therapy?</summary>
              <div class="sp-faq__answer"><p>This depends on your health goals and the specific formulation. Some clients benefit from weekly sessions, while others prefer monthly maintenance drips. Dr. Menon's team will create a personalized schedule based on your needs.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Revitalize Your Body from the Inside Out">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Revitalize Your Body from the Inside Out</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Schedule your IV therapy consultation at Menon Medispa in Millburn, NJ and experience the transformative power of direct-to-bloodstream nutrition.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
