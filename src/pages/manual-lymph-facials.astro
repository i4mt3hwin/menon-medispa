---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
import ServiceHero from '@/components/ServiceHero.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import SalePopup from '@/components/SalePopup.astro';

import { getRelatedPosts } from '@/lib/relatedPosts';
import { buildServiceSchema } from '@/lib/serviceSchema';

// Kept full-width experiential bands (reused verbatim from the original build)
import TrustBar from '@/pages/_sections/manual-lymph-facials__section_2.astro';
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import Process from '@/pages/_sections/manual-lymph-facials__section_5.astro';
import ServiceCard from '@/pages/_sections/manual-lymph-facials__section_6.astro';
import AddOns from '@/pages/_sections/manual-lymph-facials__section_7.astro';
import FinalCta from '@/pages/_sections/manual-lymph-facials__section_9.astro';

import heroImg from '@/assets/images/39875cd4ea73.webp';

const slug = 'manual-lymph-facials';
const posts = getRelatedPosts(slug);

const faqs = [
  {
    question: 'Does lymphatic drainage work on the face?',
    answer:
      'Facial lymphatic drainage uses gentle, rhythmic massage to encourage fluid movement and reduce the look of puffiness. Many clients notice a more refreshed, contoured appearance after treatment, especially around the under-eyes and jawline.',
  },
  {
    question: 'What are the benefits of a lymphatic drainage facial?',
    answer:
      'A lymphatic drainage facial helps reduce the look of puffiness, supports a more defined-looking jawline and contour, and leaves the skin looking brighter and more rested. By gently encouraging natural lymph flow, it helps your skin clear the fluid and buildup that can make it look dull or swollen. Many clients also find it calming and use it to look refreshed before an event or after travel.',
  },
  {
    question: 'How much does a lymphatic drainage facial cost?',
    answer:
      'A lymphatic drainage facial at Menon Medispa starts at $155 for a 60-minute treatment. Many clients begin with a short series to build results, and we review the best plan for your goals at your complimentary consultation so your pricing is clear before you book.',
  },
  {
    question: 'How often should I get a lymphatic drainage facial?',
    answer:
      'For a visible refresh, a single session works well before an event. For longer-lasting results, many clients do a short series of about 3 to 4 treatments spaced roughly 2 weeks apart, then return for occasional maintenance. Your provider tailors the schedule to your skin and your goals at your consultation.',
  },
  {
    question: 'How long does lymphatic drainage last on the face?',
    answer:
      'Results vary, but many clients enjoy a refreshed look for several days after a lymphatic drainage facial. Regular sessions may help maintain a less puffy, more balanced appearance over time.',
  },
  {
    question: 'What should I expect before and after a lymphatic drainage facial?',
    answer:
      'Before treatment, your provider will review your skin concerns and comfort level. After treatment, skin often looks calmer, smoother, and less puffy. There is typically no downtime, though hydration and gentle skincare are recommended.',
  },
  {
    question: 'Is facial lymphatic drainage massage painful?',
    answer:
      'No. This is a light, soothing technique rather than a deep-tissue massage. The goal is to support natural lymph flow with gentle pressure, making it a comfortable option for clients who want a refreshed look without aggressive treatment.',
  },
  {
    question: 'Are there side effects, and who should avoid a lymphatic drainage facial?',
    answer:
      'This is a gentle, low-risk treatment with no downtime, and most people tolerate it very well. It is generally not recommended if you have an active infection, a fever, or an active skin infection in the treatment area. If you have a heart or kidney condition or a history of blood clots, check with your doctor first. We review your health history at your consultation to make sure it is a good fit for you.',
  },
  {
    question: 'How is a lymphatic drainage facial different from gua sha or a regular facial?',
    answer:
      'All three support healthy, glowing skin, but they work differently. A regular facial focuses on cleansing, exfoliating, and hydrating the surface of the skin. Gua sha uses a smooth tool to massage and sculpt. A lymphatic drainage facial uses light, rhythmic hands-on massage specifically to move lymph fluid and reduce puffiness, which is why it is a favorite for looking less swollen and more contoured. Many clients combine it with other facials for a complete result.',
  },
];
const faqItems = faqs.map((f) => ({ question: f.question, answer_html: `<p>${f.answer}</p>` }));

const jsonld = buildServiceSchema({
  name: 'Manual Lymph Drainage Facials in Millburn, NJ',
  description:
    'Gentle lymphatic drainage facials in Millburn NJ. Reduce puffiness, support facial lymph flow, and restore a refreshed glow at Menon Medispa.',
  url: '/manual-lymph-facials',
  image: heroImg.src,
  type: 'Service',
  category: 'Facials',
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Face', url: '/face' },
    { name: 'Manual Lymph Facials', url: '/manual-lymph-facials' },
  ],
  faqs,
});
---

<BaseLayout
  title="Lymphatic Drainage Facial in Millburn NJ | Menon Medispa"
  description="Reduce facial puffiness with a lymphatic drainage facial in Millburn NJ. Manual lymph massage helps contour, refresh, and restore glow at Menon Medispa."
  canonical="https://www.menonmedispa.com/manual-lymph-facials"
  jsonld={jsonld}
>

  <ServiceHero
    eyebrow="MANUAL LYMPH DRAINAGE · MILLBURN, NJ"
    h1="Expert Manual Lymph Drainage Facials in Millburn, NJ"
    subhead="Reduce facial puffiness and reveal your natural glow in just one treatment, with a gentle, painless technique."
    image={heroImg}
    imageAlt="Manual lymph drainage facial treatment at Menon Medispa in Millburn, NJ"
    price="Starting at $155"
    note="Complimentary consultation to match you to the right treatment."
    trust={{ stars: true, reviewText: '100+ 5 Star Reviews' }}
  />

  <TrustBar />

  <ServiceLayout>
    <!-- MAIN COLUMN -->
    <div class="svc-block">
      <h2>Lymphatic Drainage Facial for Puffiness, Contour, and Glow</h2>

      <p class="svc-lead">Our gentle manual lymph drainage technique supports facial lymph flow, reduces the look of puffiness, and helps your contours look more refreshed. It is ideal for anyone dealing with morning puffiness, dull skin, or wanting a non-surgical way to look more rested.</p>

      <p>For clients searching for facial lymphatic drainage massage in NJ, Menon Medispa offers a calm, hands-on treatment in Millburn designed for visible refreshment without downtime.</p>

      <ul class="svc-features">
        <li>
          <h3>Immediate Visible Results</h3>
          <p>Many clients notice reduced puffiness, a more defined-looking jawline, and a fresh glow right after treatment. The gentle pressure helps encourage fluid movement, revealing a more rested facial appearance.</p>
        </li>
        <li>
          <h3>Long-Term Skin Health Benefits</h3>
          <p>Regular lymph drainage sessions train your lymphatic system to work more efficiently on its own. After 3–4 treatments spaced 2 weeks apart, many clients notice their morning puffiness is dramatically reduced even on days between treatments. Your skin tone becomes more even and firm.</p>
        </li>
        <li>
          <h3>Natural Detoxification Process</h3>
          <p>This treatment works with your body's lymphatic system to naturally eliminate waste and toxins that make your skin look dull and puffy. By improving lymphatic circulation, your skin gets better nutrients and oxygen delivery, which means healthier, more radiant skin that glows from within.</p>
        </li>
        <li>
          <h3>Perfect Recovery Treatment</h3>
          <p>Whether you're dealing with sinus congestion, recovering from dental work, or had cosmetic procedures, lymph drainage speeds healing and reduces swelling. It's gentle enough to use during recovery periods when other treatments would be too harsh for your sensitive skin.</p>
        </li>
      </ul>
    </div>

    <!-- SIDEBAR -->
    <Fragment slot="aside">
      <QuickFacts
        cta
        reviewText="100+ 5 Star Reviews"
        items={[
          { label: 'Price', value: '$155' },
          { label: 'Appointment', value: '60 minutes' },
          { label: 'Results', value: 'Visible immediately' },
          { label: 'Downtime', value: 'None' },
          { label: 'Location', value: 'Millburn, NJ' },
        ]}
      />
    </Fragment>
  </ServiceLayout>

  <ServiceTestimonial slug="manual-lymph-facials" />

  <Process />

  <ServiceCard />

  <AddOns />

  <FaqAccordion heading="Frequently asked questions" items={faqItems} />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

</BaseLayout>
<!-- redesign: service-page template (hero + 2-col body + sticky sidebar). Bands 2/5/6/7/9 kept verbatim; section_3 why-cards re-flowed into svc-features; section_4 testimonial swapped to <ServiceTestimonial slug="manual-lymph-facials" /> (provider-safe curated reviews); section_8 FAQ omitted (all answers blank/placeholder); section_10 June SALES promo removed (replaced by SalePopup). -->
