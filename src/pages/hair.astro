---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
import Section1 from './_sections/hair__section_1.astro';
import Section2 from './_sections/hair__section_2.astro';
import Section3 from './_sections/hair__section_3.astro';
import Section4 from './_sections/hair__section_4.astro';
import Section5 from './_sections/hair__section_5.astro';
import Section6 from './_sections/hair__section_6.astro';
import Section7 from './_sections/hair__section_7.astro';
import Section9 from './_sections/hair__section_9.astro';

const pageUrl = `${site.url}/hair`;
const pageDescription = 'Advanced hair restoration and scalp treatments in Millburn, NJ at Menon Medispa, including HydraFacial Keravive and PRP hair therapy.';
const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#collection`,
    url: pageUrl,
    name: 'Hair Restoration',
    description: pageDescription,
    isPartOf: { '@id': site.schemaId },
    about: {
      '@type': 'Service',
      name: 'Hair restoration and scalp treatments',
      provider: { '@id': site.schemaId },
      areaServed: site.areaServed,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Hair', item: pageUrl },
    ],
  },
];
---
<BaseLayout
  title="Hair Restoration Millburn NJ | HydraFacial Keravive & PRP | Menon Medispa"
  description={pageDescription}
  canonical={pageUrl}
  jsonld={jsonld}
>
  <Section1 />
  <Section2 />
  <!-- Wrapped so the treatment-picker grid is exempt from scroll-reveal (base.css) and is never
       stranded at opacity:0 if the IntersectionObserver doesn't fire on a narrow/short viewport. -->
  <div class="picker-no-reveal"><Section3 /></div>
  <Section4 />
  <Section5 />
  <Section6 />
  <Section7 />
  <Section9 />
</BaseLayout>
