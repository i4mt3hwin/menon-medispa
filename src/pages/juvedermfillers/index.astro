---
/**
 * Juvederm® Fillers in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/juvedermfillers/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Juvederm Fillers | Menon Medispa & Wellness | Millburn, NJ"
  description="Juvederm dermal fillers in Millburn NJ. Restore volume, enhance lips, and smooth wrinkles with FDA-approved hyaluronic acid fillers administered by Dr. Menon."
>
  <main class="sp" data-slug="juvedermfillers">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Juvederm® Fillers in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Juvederm® Fillers in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">FDA-Approved Hyaluronic Acid Fillers for Natural Volume</p>
            <p class="sp-hero__lead">Juvederm® dermal fillers are FDA-approved hyaluronic acid treatments that restore youthful volume, enhance lips, smooth deep lines, and contour facial features. Administered by Dr. Menon for natural, beautiful results.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/8ec275b96db1.jpeg" alt="Juvederm® Fillers in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> FDA-Approved</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Natural-Looking Results</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Dr. Menon Administered</p>
      </div>
    </section>

    
    {/* ===== ABOUT JUVEDERM® FILLERS ===== */}
    <section class="sp-plain" aria-label="About Juvederm® Fillers">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">About Juvederm® Fillers</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Juvederm® is the most popular hyaluronic acid filler family in the world, and for good reason. Hyaluronic acid occurs naturally in your skin and joints, making Juvederm exceptionally biocompatible and natural-feeling.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">The Juvederm family includes specialized formulations for different facial areas: Juvederm Voluma for cheeks, Juvederm Ultra and Ultra Plus for lips and nasolabial folds, and Juvederm Volbella for fine lines and subtle lip enhancement.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Treatment Areas</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Lip augmentation and definition</li><li>Cheek volume restoration</li><li>Nasolabial folds (smile lines)</li><li>Marionette lines</li><li>Under-eye hollows (tear troughs)</li><li>Jawline definition</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How much does Juvederm cost?</summary>
              <div class="sp-faq__answer"><p>Juvederm pricing starts at $750 per syringe at Menon Medispa. The total cost depends on the number of syringes needed and treatment areas. Dr. Menon will provide a personalized quote during your consultation based on your goals.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Does Juvederm hurt?</summary>
              <div class="sp-faq__answer"><p>Juvederm products contain lidocaine (a local anesthetic), which helps minimize discomfort during injection. We also apply topical numbing cream before treatment. Most clients describe the sensation as mild pressure or slight stinging that subsides quickly.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Can Juvederm be reversed?</summary>
              <div class="sp-faq__answer"><p>Yes! One of the major advantages of hyaluronic acid fillers like Juvederm is that they can be dissolved with an enzyme called hyaluronidase if needed. This provides an added safety net and flexibility to adjust results.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Restore Your Natural Volume">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Restore Your Natural Volume</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Schedule your Juvederm® consultation with Dr. Menon at Menon Medispa in Millburn, NJ today.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
