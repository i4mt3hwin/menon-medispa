---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
import ServiceHero from '@/components/ServiceHero.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import SalePopup from '@/components/SalePopup.astro';

import { getRelatedPosts } from '@/lib/relatedPosts';
import { buildServiceSchema } from '@/lib/serviceSchema';

// Kept full-width experiential bands (reused verbatim from the original build)
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import ServiceReviews from '@/components/ServiceReviews.astro';
import TrustBar from '@/pages/_sections/hydrafacial-keravive__section_2.astro';
import Process from '@/pages/_sections/hydrafacial-keravive__section_3.astro';
import Results from '@/pages/_sections/hydrafacial-keravive__section_4.astro';
import Pricing from '@/pages/_sections/hydrafacial-keravive__section_5.astro';
import FinalCta from '@/pages/_sections/hydrafacial-keravive__section_7.astro';

import heroImg from '@/assets/images/61235f21d512.jpeg';

const slug = 'hydrafacial-keravive';
const posts = getRelatedPosts(slug);

// FAQ, single source for the on-page accordion AND the FAQPage schema.
const faqs = [
  {
    question: 'Who is a good candidate for HydraFacial Keravive?',
    answer:
      'HydraFacial Keravive is ideal for anyone experiencing thinning hair, excess scalp buildup, dryness, or an unhealthy scalp environment. It is suitable for all hair types and works well alongside other hair restoration treatments such as PRP therapy or minoxidil.',
  },
  {
    question: 'Is the treatment painful or uncomfortable?',
    answer:
      'No, HydraFacial Keravive is a gentle, non-invasive treatment. Most clients describe the sensation as relaxing and soothing. There is no pain associated with the procedure, and clients can return to normal activities immediately afterward.',
  },
  {
    question: 'How many treatments will I need to see results?',
    answer:
      'A series of three monthly in-office treatments is recommended for optimal results, followed by maintenance sessions every 3 to 6 months. Many clients notice improvements in scalp health and hair texture after just one session.',
  },
  {
    question: 'Is there any downtime after the treatment?',
    answer:
      'There is no downtime with HydraFacial Keravive. You can wash and style your hair as normal and resume all daily activities immediately after your appointment.',
  },
  {
    question: 'Can this treatment be combined with PRP or other hair loss solutions?',
    answer:
      'Yes, HydraFacial Keravive works excellently as a complement to PRP (platelet-rich plasma) injections, laser hair therapy, and other hair restoration treatments. By optimizing the scalp environment, Keravive can enhance the effectiveness of these additional therapies.',
  },
  {
    question: 'How much does HydraFacial Keravive cost at Menon Medispa?',
    answer:
      'HydraFacial Keravive is $500 per session, or $1,295 for a recommended series of three treatments. We will confirm the right plan for your scalp at your free consultation.',
  },
];
const faqItems = faqs.map((f) => ({ question: f.question, answer_html: `<p>${f.answer}</p>` }));

const jsonld = buildServiceSchema({
  name: 'HydraFacial Keravive Scalp Treatment in Millburn, NJ',
  description:
    'HydraFacial Keravive scalp health treatment at Menon Medispa in Millburn, NJ. A revolutionary three-step program that cleanses, stimulates, nourishes, and hydrates the scalp for fuller, healthier-looking hair.',
  url: '/hydrafacial-keravive',
  image: heroImg.src,
  type: 'Service',
  category: 'Hair',
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Hair', url: '/hair' },
    { name: 'HydraFacial Keravive', url: '/hydrafacial-keravive' },
  ],
  faqs,
});
---

<BaseLayout
  title="HydraFacial Keravive Scalp Treatment in Millburn NJ | Menon Medispa"
  description="HydraFacial Keravive scalp treatment in Millburn, NJ: a deep scalp cleanse and detox that exfoliates buildup and hydrates the scalp for fuller, healthier-looking hair."
  canonical="https://www.menonmedispa.com/hydrafacial-keravive"
  jsonld={jsonld}
>

  <ServiceHero
    eyebrow="KERAVIVE SCALP TREATMENT · MILLBURN, NJ"
    h1="Healthier Scalp, Fuller-Looking Hair with HydraFacial Keravive in Millburn, NJ"
    subhead="A revolutionary three-step scalp health program that cleanses, nourishes, and hydrates your scalp for visibly fuller, healthier hair, with no downtime."
    image={heroImg}
    imageAlt="HydraFacial Keravive scalp treatment at Menon Medispa Millburn NJ"
    price="Starting at $500 per session"
    note="Free personal scalp consultation available."
    trust={{ stars: true, reviewText: '100+ 5 Star Reviews' }}
  />

  <TrustBar />

  <!-- Social proof pulled high (research: ~81% of attention is in the first 3 screenfuls) -->
  <ServiceTestimonial slug="hydrafacial-keravive" />

  <ServiceLayout>
    <!-- MAIN COLUMN -->
    <div class="svc-block">
      <h2>Rejuvenate Your Scalp to Reveal Fuller, Healthier-Looking Hair</h2>
      <p class="svc-lead">Experience the innovative HydraFacial Keravive treatment at Menon Medispa in Millburn, NJ, a revolutionary three-step scalp health program designed to cleanse, stimulate, nourish, and hydrate the scalp for fuller, healthier-looking hair.</p>

      <p>Think of it as a deep-cleansing facial for your scalp. HydraFacial Keravive detoxifies and exfoliates buildup, then nourishes and hydrates the scalp to create a healthier environment for fuller, healthier hair.</p>

      <p>HydraFacial Keravive is the first-of-its-kind scalp health treatment that cleanses, stimulates, nourishes, and hydrates the scalp using HydraFacial technology. The treatment targets the scalp and hair follicles, removing follicle-clogging debris and delivering a powerful blend of growth factors and skin proteins directly to the scalp.</p>

      <p>The treatment is completed with a take-home spray to extend the benefits and help you maintain healthier-looking hair between appointments. Most clients see noticeable improvements in scalp health and hair appearance after just a few sessions.</p>

      <p class="svc-eyebrow">A Three-Step Process</p>

      <ul class="svc-steps">
        <li>
          <h3>Cleanse + Exfoliate</h3>
          <p>HydraFacial Vortex Technology deeply cleanses and exfoliates the scalp, removing follicle-clogging sebum, dirt, and environmental debris.</p>
        </li>
        <li>
          <h3>Hydrate + Nourish</h3>
          <p>A proprietary blend of growth factors, skin proteins, and hyaluronic acid is infused into the scalp to nourish and hydrate hair follicles for a healthier environment.</p>
        </li>
        <li>
          <h3>Extend + Enhance</h3>
          <p>A take-home HydraFacial Keravive Peptide Complex Spray is provided to extend the benefits of the in-office treatment and support ongoing scalp health.</p>
        </li>
      </ul>

      <p class="svc-eyebrow">An Excellent Complement to Hair Restoration</p>

      <p>HydraFacial Keravive is an excellent complement to hair restoration treatments such as PRP, microneedling, or medication. By creating a healthy scalp environment, it maximizes the effectiveness of all other treatments you may be undergoing.</p>

      <p>Clinical studies show that 97% of patients reported an improvement in scalp health after three treatments, with 93% reporting improvement in hair fullness and 79% reporting reduction in hair shedding.</p>

      <ul class="svc-features">
        <li>
          <h3>Deep Scalp Cleanse</h3>
          <p>Removes follicle-clogging sebum, dirt, and debris with Vortex Technology</p>
        </li>
        <li>
          <h3>Growth Factor Infusion</h3>
          <p>Delivers growth factors, skin proteins, and hyaluronic acid directly to follicles</p>
        </li>
        <li>
          <h3>No Downtime</h3>
          <p>Resume all daily activities immediately, including washing and styling your hair</p>
        </li>
        <li>
          <h3>Combines With Other Treatments</h3>
          <p>Enhances PRP, laser therapy, and other hair restoration approaches</p>
        </li>
      </ul>
    </div>

    <!-- SIDEBAR -->
    <Fragment slot="aside">
      <QuickFacts
        cta
        reviewText="100+ 5 Star Reviews"
        items={[
          { label: 'Price', value: '$500 per session' },
          { label: 'Package', value: '$1,295 for 3 treatments' },
          { label: 'Recommended', value: '3 monthly sessions' },
          { label: 'Downtime', value: 'None' },
          { label: 'Location', value: 'Millburn, NJ' },
        ]}
      />
    </Fragment>
  </ServiceLayout>

  <!-- Mid-scroll CTA (repeat the Book CTA after the persuasion content; below-fold CTAs
       convert better for high-consideration treatments) -->
  <section class="section section--tint">
    <div class="container svc-midcta">
      <h2>Ready for a healthier scalp?</h2>
      <p>Book your HydraFacial Keravive, or start with a free scalp consultation, and we'll build a plan for fuller, healthier-looking hair.</p>
      <a href="/request-appointment?service=HydraFacial%20Keravive" class="btn btn--primary">Book Your Keravive</a>
    </div>
  </section>

  <Process />

  <Results />

  <Pricing />

  <!-- Deeper social proof: more real 5-star reviews from our clients -->
  <ServiceReviews slug="hydrafacial-keravive" excludeFirst heading="More 5-star reviews from our clients" />

  <FaqAccordion heading="Frequently asked questions" items={faqItems} bg_color="rgb(196 164 132 / 0.14)" />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

  <style>
    .svc-midcta { max-width: 680px; margin-inline: auto; text-align: center; }
    .svc-midcta h2 {
      font-family: var(--font-display);
      font-size: var(--text-h2);
      font-weight: var(--weight-regular);
      color: var(--color-text);
      line-height: 1.2;
      margin: 0 0 var(--space-sm);
      text-wrap: balance;
    }
    .svc-midcta p {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      line-height: 1.6;
      margin: 0 0 var(--space-md);
      opacity: 0.9;
    }
  </style>

</BaseLayout>
<!-- redesign: service-page template (hero + 2-col body + sticky sidebar). Bands 2/3/4/5/7 reused verbatim; section_6 FAQ lifted into FaqColumn; section_9 promo removed (replaced by SalePopup); prose from sections 1+3+4 re-flowed into main column. LeadForm (dropped during conversion) restored from section_6, placed before FinalCta. -->
