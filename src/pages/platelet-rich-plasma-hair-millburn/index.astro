---
/**
 * PRP Hair Restoration in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/platelet-rich-plasma-hair-millburn/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="PRP Hair Restoration | Menon Medispa & Wellness | Millburn, NJ"
  description="PRP hair restoration therapy in Millburn NJ. Natural, effective treatment for hair loss using your body's own growth factors to stimulate hair regrowth."
>
  <main class="sp" data-slug="platelet-rich-plasma-hair-millburn">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="PRP Hair Restoration in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">PRP Hair Restoration in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Natural Hair Regrowth Using Your Own Growth Factors</p>
            <p class="sp-hero__lead">Platelet-Rich Plasma (PRP) therapy harnesses the power of your own blood's growth factors to stimulate dormant hair follicles and promote natural hair regrowth. A safe, effective, and natural solution for hair loss.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/c6490dc57dd4.jpg" alt="PRP Hair Restoration in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> 100% Natural</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Uses Your Own Blood</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Proven Results</p>
      </div>
    </section>

    
    {/* ===== WHAT IS PRP HAIR RESTORATION? ===== */}
    <section class="sp-plain" aria-label="What is PRP Hair Restoration?">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">What is PRP Hair Restoration?</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Platelet-Rich Plasma (PRP) therapy involves drawing a small amount of your blood, processing it in a centrifuge to concentrate the platelets and growth factors, then injecting this concentrated plasma into your scalp. The growth factors activate dormant hair follicles and promote new hair growth.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">PRP is a completely natural treatment since it uses your own blood—eliminating the risk of allergic reactions or rejection. It's an effective option for both men and women experiencing hair thinning or early-stage hair loss.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Who Benefits from PRP?</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Men and women with androgenetic alopecia (pattern baldness)</li><li>Clients with thinning hair and reduced density</li><li>Early-stage hair loss candidates</li><li>Clients seeking to complement other hair treatments</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How many PRP sessions are needed?</summary>
              <div class="sp-faq__answer"><p>A typical initial protocol involves 3 monthly treatments, followed by maintenance sessions every 3-6 months. Most clients begin to notice improvement after 2-3 sessions, with full results developing over 6-12 months.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is PRP safe?</summary>
              <div class="sp-faq__answer"><p>PRP is extremely safe because it uses your own blood. The risk of infection or allergic reaction is minimal. The most common side effects are mild scalp tenderness and occasional temporary swelling at injection sites.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>What results can I expect from PRP hair restoration?</summary>
              <div class="sp-faq__answer"><p>Clinical studies show that PRP can increase hair count, hair thickness, and the growth phase of the hair cycle. Most clients experience a 20-40% improvement in hair density. Results are gradual—full effects are typically seen at 6-12 months.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Restore Your Hair Naturally">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Restore Your Hair Naturally</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Schedule your PRP hair restoration consultation at Menon Medispa in Millburn, NJ and start your journey to fuller, healthier hair.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
