---
/**
 * Semaglutide Medical Weight Loss — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/semaglutide/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Semaglutide Medical Weight Loss | Menon Medispa | Millburn, NJ"
  description="Semaglutide medical weight loss program in Millburn NJ. Physician-supervised weight management for sustainable results."
>
  <main class="sp" data-slug="semaglutide">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Semaglutide Medical Weight Loss">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Semaglutide Medical Weight Loss</h1>
            <p class="sp-hero__eyebrow">Physician-Supervised Weight Management in Millburn, NJ</p>
            <p class="sp-hero__lead">Our Semaglutide medical weight loss program offers a physician-supervised approach to sustainable weight management. Using FDA-approved GLP-1 receptor agonist therapy, we help you achieve your weight loss goals safely and effectively.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/cd90aa0cbbcb.jpg" alt="Semaglutide Medical Weight Loss" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> FDA-Approved</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Physician Supervised</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Sustainable Results</p>
      </div>
    </section>

    
    {/* ===== WHAT IS SEMAGLUTIDE? ===== */}
    <section class="sp-plain" aria-label="What is Semaglutide?">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">What is Semaglutide?</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Semaglutide is an FDA-approved GLP-1 receptor agonist that helps reduce appetite and food intake while improving blood sugar control. Originally developed for type 2 diabetes management, it has been proven highly effective for weight loss in clinical trials.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Under Dr. Menon's supervision, your treatment protocol will be carefully personalized to your health history, weight loss goals, and medical needs. We monitor your progress closely and adjust your program as needed.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">How It Works</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Reduces appetite and food cravings</li><li>Slows gastric emptying for longer satiety</li><li>Improves insulin sensitivity</li><li>Supports sustainable weight loss when combined with lifestyle changes</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>Am I a good candidate for Semaglutide?</summary>
              <div class="sp-faq__answer"><p>Semaglutide is typically recommended for adults with a BMI of 27+ with at least one weight-related condition, or a BMI of 30+. A thorough medical evaluation is required to ensure it's appropriate for you. Dr. Menon will review your complete health history.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>What results can I expect?</summary>
              <div class="sp-faq__answer"><p>Clinical studies show that semaglutide combined with lifestyle modifications can result in 10-15% reduction in body weight over 68 weeks. Individual results vary, and the medication works best when combined with healthy dietary changes and increased physical activity.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>What are the potential side effects?</summary>
              <div class="sp-faq__answer"><p>The most common side effects are gastrointestinal: nausea, vomiting, diarrhea, and constipation. These typically improve as your body adjusts. Less common side effects include pancreatitis risk. Your doctor will discuss all risks and benefits before starting treatment.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Start Your Weight Loss Journey">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Start Your Weight Loss Journey</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Schedule your Semaglutide consultation with Dr. Menon at Menon Medispa in Millburn, NJ and take the first step toward sustainable weight management.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
