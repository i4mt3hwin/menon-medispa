---
/**
 * Contact — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/contact/ (structure.json + rendered.html + screenshot)
 * Visual target: 01-discovery/screenshots/contact-desktop-full.png
 *
 * Layout: hero (centered) → contact form left / info+photo right → hours
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeadForm from '@/components/LeadForm.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Contact Us | Menon Medispa & Wellness | Millburn, NJ"
  description="Contact Menon Medispa in Millburn, NJ. Whether you have a question about a treatment, need assistance with scheduling, or are ready to begin your journey, our team is here to help."
>
  <main class="sp" data-slug="contact">

    {/* ===== HERO ===== */}
    <section class="sp-hero sp-hero--center" aria-label="Get In Touch">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Get In Touch</h1>
        <p class="sp-hero__lead" style="text-align:center;margin:0 auto;max-width:560px;">Whether you have a question about a treatment, need assistance with scheduling, or are ready to begin your journey, our team is here to help.</p>
      </div>
    </section>

    {/* ===== CONTACT SPLIT ===== */}
    <section class="sp-contact" aria-label="Contact Form and Info">
      <div class="sp-container sp-contact__grid">
        <div>
          <LeadForm variant="contact" />
        </div>
        <div class="sp-contact__info">
          <img src="/images/35c774fbba6d.png" alt="Menon Office Staff" width="425" height="323" loading="lazy" />
          <h2>Menon Medispa &amp; Wellness</h2>
          <p>45 Essex St, Suite 202, Millburn, NJ 07041, USA</p>
          <p><a href="mailto:admin@menonregen.com">admin@menonregen.com</a></p>
          <p><a href={`tel:${site.phone.tel}`}>{site.phone.display}</a></p>
          <div class="sp-contact__socials">
            <a href={site.social.facebook} rel="noopener" target="_blank">
              <img src="/images/464c5b23f583.png" alt="Facebook" width="23" height="23" loading="lazy" />
            </a>
            <a href={site.social.instagram} rel="noopener" target="_blank">
              <img src="/images/a29df34857a1.png" alt="Instagram" width="23" height="23" loading="lazy" />
            </a>
            <a href={site.social.tiktok} rel="noopener" target="_blank">
              <img src="/images/d11778476dcb.png" alt="TikTok" width="23" height="23" loading="lazy" />
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ===== OPENING HOURS ===== */}
    <section class="sp-hours" aria-label="Opening Hours">
      <div class="sp-container">
        <div class="sp-hours__inner">
          <h2 class="sp-hours__title">Opening Hours</h2>
          <table class="sp-hours__table">
            <tbody>
              <tr>
                <th>Mon - Fri</th>
                <td>10:00 am – 6:00 pm</td>
              </tr>
              <tr>
                <th>Saturday</th>
                <td>10:00 am – 4:00 pm</td>
              </tr>
              <tr>
                <th>Sunday</th>
                <td>CLOSED</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
