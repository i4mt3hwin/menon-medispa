---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
---
<BaseLayout title="Short Hills Medispa Treatments | Menon Medispa | Millburn, NJ" description="Short Hills and Millburn medispa treatments by Menon Medispa. Botox, facials, IV therapy, laser treatments and more serving the Short Hills, NJ area.">
  <main class="sp" data-slug="short-hills-medispa-treatments">

    <section class="sp-hero" aria-label="Short Hills Medispa">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Short Hills &amp; Millburn Medispa <em>Treatments</em></h1>
            <p class="sp-hero__eyebrow">Your Premier Medispa Serving Short Hills, NJ</p>
            <p class="sp-hero__lead">Menon Medispa is conveniently located in Millburn, just minutes from Short Hills, NJ. We offer the full range of medical spa treatments to Short Hills residents — from Botox and fillers to HydraFacials, laser treatments, and IV therapy.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/35c774fbba6d.png" alt="Menon Medispa serving Short Hills NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <section class="sp-badges">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">&#10003;</span> Minutes from Short Hills</p>
        <p class="sp-badge"><span class="sp-badge__check">&#10003;</span> Medical-Grade Treatments</p>
        <p class="sp-badge"><span class="sp-badge__check">&#10003;</span> Physician Led</p>
      </div>
    </section>

    <section class="sp-tgrid">
      <div class="sp-container">
        <div class="sp-tgrid__head">
          <h2 class="sp-script-title">Popular Treatments for <em>Short Hills Residents</em></h2>
          <p class="sp-tgrid__desc">Located just minutes from Short Hills, NJ, Menon Medispa offers the most comprehensive range of medical aesthetic and wellness treatments in the area.</p>
        </div>
        <div class="sp-tgrid__cols">
          <a href="/botox-millburn-nj" class="sp-tcard" style="text-decoration:none;">
            <img src="/images/f6d70f706248.jpg" alt="Botox" loading="lazy" />
            <div class="sp-tcard__tint"></div>
            <div class="sp-tcard__label"><span class="sp-tcard__title">BOTOX</span></div>
          </a>
          <a href="/hydrafacial" class="sp-tcard" style="text-decoration:none;">
            <img src="/images/34ef44b50a1c.jpg" alt="HydraFacial" loading="lazy" />
            <div class="sp-tcard__tint"></div>
            <div class="sp-tcard__label"><span class="sp-tcard__title">HYDRAFACIAL</span></div>
          </a>
          <a href="/laser-hair-removal" class="sp-tcard" style="text-decoration:none;">
            <img src="/images/67c41f4e43f3.jpeg" alt="Laser Hair Removal" loading="lazy" />
            <div class="sp-tcard__tint"></div>
            <div class="sp-tcard__label"><span class="sp-tcard__title">LASER HAIR REMOVAL</span></div>
          </a>
          <a href="/iv-therapy-millburn-nj" class="sp-tcard" style="text-decoration:none;">
            <img src="/images/fc3ca8a7bdf0.jpg" alt="IV Therapy" loading="lazy" />
            <div class="sp-tcard__tint"></div>
            <div class="sp-tcard__label"><span class="sp-tcard__title">IV THERAPY</span></div>
          </a>
        </div>
      </div>
    </section>

    <section class="sp-testimonial">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">&ldquo;</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    <section class="sp-cta">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Serving Short Hills from Millburn, NJ</h2>
          <p class="sp-cta__sub">Menon Medispa &amp; Wellness</p>
          <p>We're just minutes from Short Hills, making Menon Medispa the most convenient premier medispa for Short Hills residents. Schedule your personal consultation today and discover why our clients keep coming back.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
