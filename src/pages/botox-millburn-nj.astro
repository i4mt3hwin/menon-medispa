---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
import ServiceHero from '@/components/ServiceHero.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import SalePopup from '@/components/SalePopup.astro';
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import ServiceReviews from '@/components/ServiceReviews.astro';

import { getRelatedPosts } from '@/lib/relatedPosts';
import { buildServiceSchema } from '@/lib/serviceSchema';

// Kept full-width experiential bands (reused verbatim from the original build)
import TrustBar from '@/pages/_sections/botox-millburn-nj__section_2.astro';
import Gallery from '@/pages/_sections/botox-millburn-nj__section_6.astro';
import Pricing from '@/pages/_sections/botox-millburn-nj__section_7.astro';
import FinalCta from '@/pages/_sections/botox-millburn-nj__section_9.astro';

import heroImg from '@/assets/images/f6d70f706248.jpg';
import problemImg from '@/assets/images/9c00e61600b0.jpg';
import botoxReelPoster from '@/assets/images/botox-reel-poster.jpg';

const slug = 'botox-millburn-nj';
const posts = getRelatedPosts(slug);

// FAQ, single source for the on-page accordion AND the FAQPage schema.
const faqs = [
  {
    question: 'What is Botox and how does it work?',
    answer:
      'Botox is an FDA-approved injectable neuromodulator derived from botulinum toxin type A. When injected into targeted facial muscles, it temporarily blocks the nerve signals that cause those muscles to contract. This relaxes the muscles responsible for expression lines, smoothing the overlying skin and reducing the appearance of wrinkles. Results typically last 3 to 4 months.',
  },
  {
    question: 'What areas can Botox treat?',
    answer:
      'Botox is most commonly used to soften the horizontal lines across the forehead, the frown lines between the brows (often called the 11s), and the crow\'s feet around the eyes. It can also create a subtle lip flip that gives the upper lip a fuller look. At your consultation, Dr. Menon evaluates how your face moves and tailors a plan to the areas that will give you the most natural, refreshed result.',
  },
  {
    question: 'Do you offer a Botox lip flip?',
    answer:
      'Yes. A Botox lip flip places a few small units along the upper lip line so the edge of the lip gently rolls outward, making the upper lip look fuller and showing less gum when you smile. It uses far fewer units than dermal lip filler and gives a subtle, natural result. Dr. Menon can advise whether a lip flip, lip filler, or a combination best fits your goals.',
  },
  {
    question: 'What makes Botox at Menon Medispa different?',
    answer:
      'All Botox injections at Menon Medispa are administered by Dr. Menon herself. This physician-level expertise means your treatment is guided by a medical doctor with specialized training in facial anatomy and aesthetic medicine. Dr. Menon personally evaluates your facial dynamics and creates a customized treatment plan to achieve natural-looking results specific to your goals.',
  },
  {
    question: 'Will I look "frozen" or unnatural?',
    answer:
      'No. The goal of Botox at Menon Medispa is to create a refreshed, natural appearance that preserves your expressive range. Dr. Menon uses a conservative, targeted approach that relaxes the specific muscles causing lines while allowing the surrounding muscles to move normally. The result is subtle, natural-looking improvement that enhances rather than alters your appearance.',
  },
  {
    question: 'How long does Botox last?',
    answer:
      'Botox results typically last about 3 to 4 months. Many patients find that with regular treatments the effects last longer over time, as the treated muscles gradually weaken from less use. When you notice movement starting to return, it is time to plan your next visit.',
  },
  {
    question: 'How long does a Botox appointment take?',
    answer:
      'Most Botox appointments are quick. The injection portion often takes about 10 to 15 minutes, and the full visit is commonly completed in about 30 minutes depending on consultation needs and treatment areas.',
  },
  {
    question: 'How should I prepare for my first Botox appointment?',
    answer:
      'Arrive with clean skin if possible and be ready to review medications, supplements, allergies, and health history. Your provider may recommend avoiding alcohol and certain blood-thinning supplements before treatment to help reduce bruising risk.',
  },
  {
    question: 'How much does Botox cost and how many units will I need?',
    answer:
      'Botox at Menon Medispa is priced at $14 per unit. The number of units needed varies by the areas treated and your individual muscle strength, but most patients require between 20 to 50 units per session. Dr. Menon reviews the right number of units for your goals at your consultation, so your pricing is clear before treatment.',
  },
];
const faqItems = faqs.map((f) => ({ question: f.question, answer_html: `<p>${f.answer}</p>` }));

const jsonld = buildServiceSchema({
  name: 'Botox in Millburn, NJ',
  description:
    'Physician-administered Botox in Millburn, NJ. Natural-looking wrinkle softening by Dr. Menon with appointment prep, pricing, and timing guidance.',
  url: '/botox-millburn-nj',
  image: heroImg.src,
  type: 'MedicalProcedure',
  category: 'Injectables',
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Face', url: '/face' },
    { name: 'Botox', url: '/botox-millburn-nj' },
  ],
  faqs,
});
---

<BaseLayout
  title="Botox Treatment in Millburn NJ by Dr. Menon | Menon Medispa"
  description="Botox in Millburn NJ, administered by Dr. Menon for natural-looking wrinkle softening. Learn appointment timing, prep, pricing, and results before you book."
  canonical="https://www.menonmedispa.com/botox-millburn-nj"
  jsonld={jsonld}
>

  <ServiceHero
    eyebrow="BOTOX · MILLBURN, NJ"
    h1="Smooth, Natural-Looking Botox in Millburn, NJ"
    subhead="Physician-administered Botox that softens fine lines and wrinkles while keeping your natural expressions, refreshed, never frozen."
    image={heroImg}
    imageAlt="Botox treatment by Dr. Menon at Menon Medispa in Millburn, NJ"
    price="Starting at $14 per unit"
    note="No-obligation consultation, performed by Dr. Menon, MD."
    trust={{ stars: true, reviewText: '100+ 5 Star Reviews' }}
  />

  <TrustBar />

  <!-- Social proof pulled high (research: ~81% of attention is in the first 3 screenfuls) -->
  <ServiceTestimonial slug="botox-millburn-nj" />

  <ServiceLayout>
    <!-- MAIN COLUMN — solution/credibility first (front-load value), the problem context below -->
    <div class="svc-block">
      <h2>The Menon Medispa Botox Difference in Millburn, NJ</h2>
      <p class="svc-lead">Dr. Menon has built a physician-administered Botox program that delivers natural-looking results tailored to your facial anatomy and goals. Unlike discount injection services, every treatment is performed with the precision of a medical doctor.</p>

      <p class="svc-eyebrow">How It Works</p>
      <p>Botox is an FDA-approved neuromodulator that temporarily blocks the nerve signals behind muscle contractions. Injected into targeted facial muscles, it relaxes them so the overlying skin can smooth, for a refreshed, more youthful look.</p>
      <p>It is most commonly used to soften forehead lines, the frown lines between the brows (the 11s), and the crow's feet around the eyes. Dr. Menon also offers a Botox lip flip for a subtly fuller upper lip, and tailors the areas treated to the way your face moves.</p>

      <p class="svc-eyebrow">See Botox at Menon Medispa</p>
      <figure>
        <video
          data-lazy-video
          autoplay
          loop
          muted
          playsinline
          preload="none"
          aria-hidden="true"
          poster={botoxReelPoster.src}
          width="720"
          height="1280"
          style="display:block;width:100%;max-width:340px;height:auto;border-radius:var(--radius-sm);object-fit:cover;"
        >
          <source data-src="/videos/botox-reel.mp4" type="video/mp4" />
        </video>
        <figcaption>A real Botox treatment at our Millburn, NJ medispa, performed by Dr. Menon.</figcaption>
      </figure>

      <ul class="svc-features">
        <li>
          <h3>Targeted Treatment</h3>
          <p>Addresses facial muscles responsible for expression lines</p>
        </li>
        <li>
          <h3>Natural Results</h3>
          <p>Creates a relaxed appearance that looks refreshed, not frozen</p>
        </li>
        <li>
          <h3>Quick Results</h3>
          <p>Noticeable improvement with results visible within 3 to 7 days</p>
        </li>
        <li>
          <h3>Expert Care</h3>
          <p>Performed by Dr. Menon with personalized treatment planning</p>
        </li>
      </ul>
    </div>

    <div class="svc-block">
      <h2>Why Most Anti-Aging Treatments Fail</h2>
      <p class="svc-lead">Traditional skincare leaves so many Millburn and Short Hills residents still searching for real results.</p>
      <figure>
        <img src={problemImg.src} alt="Anti-aging skin concerns addressed at Menon Medispa Millburn NJ" width="488" height="428" loading="lazy" decoding="async" />
      </figure>

      <div class="svc-accent">
        <h3>Creams Miss the Mark</h3>
        <p>Topical creams only work on the surface, so they never reach the muscle contractions that cause expression lines.</p>
      </div>
      <div class="svc-accent">
        <h3>At-Home Treatments Fall Short</h3>
        <p>Facial exercises and DIY remedies don't address the muscle activity that creates lines over time.</p>
      </div>
      <div class="svc-accent">
        <h3>Over-the-Counter Promises</h3>
        <p>Drugstore anti-aging products offer short-term hydration, not a lasting change to dynamic wrinkles.</p>
      </div>

      <p class="svc-eyebrow">The Real Problem</p>
      <p>Dynamic wrinkles form when facial muscles contract during expressions like smiling, squinting, and frowning. Over time those repeated movements crease the skin, and as we lose collagen it bounces back less easily. It is a muscular issue, not a surface one, which is exactly what Botox is designed to address.</p>
    </div>

    <!-- SIDEBAR -->
    <Fragment slot="aside">
      <QuickFacts
        cta
        reviewText="100+ 5 Star Reviews"
        items={[
          { label: 'Price', value: '$14 per unit' },
          { label: 'Appointment', value: 'About 15 minutes' },
          { label: 'Results', value: 'Visible in 3–7 days' },
          { label: 'Lasts', value: '3–4 months' },
          { label: 'Performed by', value: 'Dr. Menon, MD' },
          { label: 'Location', value: 'Millburn, NJ' },
        ]}
      />
    </Fragment>
  </ServiceLayout>

  <!-- Mid-scroll CTA (research: repeat the same Book CTA after the persuasion content;
       below-fold CTAs convert better for high-consideration treatments) -->
  <section class="section section--tint">
    <div class="container svc-midcta">
      <h2>Ready to book your Botox consultation?</h2>
      <p>Book a consultation with Dr. Menon and we'll tailor a plan to the way your face moves and the results you want.</p>
      <a href="/request-appointment?service=Botox" class="btn btn--primary">Book Your Consultation</a>
    </div>
  </section>

  <div id="before-after"></div>
  <Gallery />

  <Pricing />

  <!-- Deeper social proof: more real 5-star reviews for this service -->
  <ServiceReviews slug="botox-millburn-nj" excludeFirst heading="More 5-star reviews from our clients" />

  <FaqAccordion heading="Frequently asked questions" items={faqItems} bg_color="rgb(196 164 132 / 0.14)" />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

  <style>
    .svc-midcta { max-width: 680px; margin-inline: auto; text-align: center; }
    .svc-midcta h2 {
      font-family: var(--font-display);
      font-size: var(--text-h2);
      font-weight: var(--weight-regular);
      color: var(--color-text);
      line-height: 1.2;
      margin: 0 0 var(--space-sm);
      text-wrap: balance;
    }
    .svc-midcta p {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      line-height: 1.6;
      margin: 0 0 var(--space-md);
      opacity: 0.9;
    }
  </style>

</BaseLayout>
<!-- redesign v2 (CRO+SEO reference pattern, matches laser-hair-removal): social proof pulled high
     (ServiceTestimonial after the trust bar), benefits/credibility-first body with the problem context
     below, a mid-scroll Book CTA, a 3-up real-reviews strip (ServiceReviews), and a tinted FAQ for band
     alternation. Copy preserved verbatim from the prior build; keyword additions use known/standard facts
     only (common treatment areas + "how long does Botox last" + areas FAQ). Lip flip, masseter/jaw, and
     aftercare specifics are flagged in medispa-questions.md (not added until confirmed). -->
