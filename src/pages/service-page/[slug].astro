---
/**
 * /service-page/[slug].astro
 * Dynamic route — 81 visible Wix Bookings services.
 * Content verbatim from src/data/services.json (generated from wix-api/bookings-services.json).
 * Known limit: metadata-only for 78/81 services (no long description captured).
 * Renders cleanly with title/category/price/duration/tagLine + Book CTA.
 */
import ServicePageTemplate from '@/components/ServicePageTemplate.astro';
import servicesData from '@/data/services.json';

export async function getStaticPaths() {
  return servicesData.map((service: Record<string, string>) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Service {
  slug: string;
  name: string;
  category?: string;
  price?: string;
  duration?: string;
  tagLine?: string;
}

const { service } = Astro.props as { service: Service };

// tagLine acts as the short description — render as description_html if present.
const descriptionHtml = service.tagLine
  ? `<p>${service.tagLine}</p>`
  : undefined;
---

<ServicePageTemplate
  title={service.name}
  slug={service.slug}
  category={service.category}
  price={service.price}
  duration={service.duration}
  description_html={descriptionHtml}
/>
