---
/**
 * /service-page/[slug].astro
 * Dynamic route, 81 visible Wix Bookings services.
 * Content verbatim from src/data/services.json (generated from wix-api/bookings-services.json).
 * Known limit: metadata-only for 78/81 services (no long description captured).
 * Renders cleanly with title/category/price/duration/tagLine + Book CTA.
 */
import ServicePageTemplate from '@/components/ServicePageTemplate.astro';
import servicesData from '@/data/services.json';

export async function getStaticPaths() {
  return servicesData.map((service: Record<string, string>) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Service {
  slug: string;
  name: string;
  category?: string;
  price?: string;
  duration?: string;
  tagLine?: string;
  description?: string;
  contactAddress?: string;
}

const { service } = Astro.props as { service: Service };

// Prefer full captured description over tagLine. tagLine shows as subtitle in hero.
const descriptionHtml = service.description
  ? `<p>${service.description}</p>`
  : service.tagLine
    ? `<p>${service.tagLine}</p>`
    : undefined;

const contactHtml = service.contactAddress
  ? `<address style="font-style:normal;"><strong>Address:</strong> ${service.contactAddress}</address><p><a href="tel:9734948431">(973) 494-8431</a> &nbsp;|&nbsp; <a href="mailto:admin@menonregen.com">admin@menonregen.com</a></p>`
  : undefined;
---

<ServicePageTemplate
  title={service.name}
  slug={service.slug}
  category={service.category}
  price={service.price}
  duration={service.duration}
  description_html={descriptionHtml}
  contact_html={contactHtml}
/>
