---
/**
 * Vascular Treatments in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/vascular-treatments/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Vascular Treatments | Menon Medispa & Wellness | Millburn, NJ"
  description="Vascular treatments for spider veins, rosacea, and vascular lesions in Millburn NJ. Medical-grade laser technology for clear, blemish-free skin."
>
  <main class="sp" data-slug="vascular-treatments">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Vascular Treatments in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Vascular Treatments in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Clear Spider Veins and Vascular Lesions with Medical-Grade Lasers</p>
            <p class="sp-hero__lead">Our medical-grade vascular treatments target and eliminate spider veins, rosacea, broken capillaries, and other vascular lesions with precision laser technology. Achieve clearer, more even-toned skin with minimal downtime.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/40c58ae9b34c.jpg" alt="Vascular Treatments in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Clears Spider Veins</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Treats Rosacea</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Minimal Downtime</p>
      </div>
    </section>

    
    {/* ===== VASCULAR CONDITIONS WE TREAT ===== */}
    <section class="sp-plain" aria-label="Vascular Conditions We Treat">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">Vascular Conditions We Treat</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Our Dye-VL and vascular laser treatments selectively target hemoglobin in blood vessels, causing them to collapse and be absorbed by the body. The surrounding tissue is left undamaged thanks to precise wavelength targeting.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Conditions Treated</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0 0 1rem;"><li>Spider veins (face and legs)</li><li>Rosacea and facial redness</li><li>Broken capillaries and telangiectasias</li><li>Port wine stains</li><li>Cherry angiomas</li><li>Diffuse redness</li></ul>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0;">Our treatments are performed by our medical team, ensuring the safest possible outcomes. We'll assess your specific condition during consultation to recommend the optimal treatment protocol.</p>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How many treatments are needed for spider veins?</summary>
              <div class="sp-faq__answer"><p>Most facial vascular concerns resolve in 1-3 treatments. Larger or more extensive areas may require additional sessions. Leg spider veins typically require 2-4 treatments. Treatment spacing depends on the severity and your skin's response.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is vascular laser treatment painful?</summary>
              <div class="sp-faq__answer"><p>Most clients describe a warm, rubber-band snapping sensation during treatment. The built-in cooling system helps manage discomfort. Topical anesthetic may be applied for more sensitive areas.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>What are the side effects of vascular treatment?</summary>
              <div class="sp-faq__answer"><p>Common temporary side effects include redness, mild swelling, and darkening of the treated vessels (which fade within 1-2 weeks as they are absorbed). Bruising is rare but possible. We recommend sun protection after treatment.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Achieve Clear, Even-Toned Skin">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Achieve Clear, Even-Toned Skin</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Schedule your vascular treatment consultation at Menon Medispa in Millburn, NJ and take the first step toward clearer skin.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
