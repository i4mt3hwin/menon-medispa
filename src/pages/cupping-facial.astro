---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceHero from '@/components/ServiceHero.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import SalePopup from '@/components/SalePopup.astro';

import { getRelatedPosts } from '@/lib/relatedPosts';
import { buildServiceSchema } from '@/lib/serviceSchema';

// Kept full-width experiential bands (reused verbatim from the original build)
import TrustBar from '@/pages/_sections/cupping-facial__section_2.astro';
import Process from '@/pages/_sections/cupping-facial__section_5.astro';
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import BookingCta from '@/pages/_sections/cupping-facial__section_6.astro';
import AddOns from '@/pages/_sections/cupping-facial__section_7.astro';
import FinalCta from '@/pages/_sections/cupping-facial__section_9.astro';

import heroImg from '@/assets/images/2d2699eae2a5.jpeg';

const slug = 'cupping-facial';
const posts = getRelatedPosts(slug);

const faqs = [
  {
    question: 'What do facial cupping before and after results look like?',
    answer:
      'Facial cupping results are usually subtle and natural-looking. Many clients notice less puffiness, a brighter complexion, and a temporarily lifted or more sculpted appearance after treatment.',
  },
  {
    question: 'How long do facial cupping results last?',
    answer:
      'Results vary by skin type, lifestyle, and treatment frequency. Many clients notice a refreshed look for several days, while a series of treatments may help support longer-lasting improvements in tone and puffiness.',
  },
  {
    question: 'Does facial cupping hurt or leave marks?',
    answer:
      'Facial cupping should feel gentle and should not be painful. The technique uses controlled movement and light suction on the face, so it is different from stronger body cupping that can leave circular marks.',
  },
  {
    question: 'Who is a good candidate for a cupping facial?',
    answer:
      'A cupping facial may be a good fit if you want a non-injection option for puffiness, dullness, and temporary facial contouring. Your provider will review your skin and health history before treatment.',
  },
];
const faqItems = faqs.map((f) => ({ question: f.question, answer_html: `<p>${f.answer}</p>` }));

const jsonld = buildServiceSchema({
  name: 'Cupping Facial in Millburn, NJ',
  description:
    'Facial cupping in Millburn NJ for puffiness, circulation, and a naturally lifted look. Gentle cupping facials at Menon Medispa.',
  url: '/cupping-facial',
  image: heroImg.src,
  type: 'Service',
  category: 'Facials',
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Face', url: '/face' },
    { name: 'Cupping Facial', url: '/cupping-facial' },
  ],
  faqs,
});
---

<BaseLayout
  title="Facial Cupping Results in Millburn NJ | Menon Medispa"
  description="Facial cupping for puffiness, circulation, and a lifted look. Menon Medispa offers cupping facials in Millburn NJ with no downtime."
  canonical="https://www.menonmedispa.com/cupping-facial"
  jsonld={jsonld}
>

  <ServiceHero
    eyebrow="CUPPING FACIAL · MILLBURN, NJ"
    h1="Natural Skin Lifting with a Cupping Facial in Millburn, NJ"
    subhead="Lift and tighten your skin without surgery or injections, using therapeutic cupping that boosts circulation, drains toxins, and firms from within."
    image={heroImg}
    imageAlt="Cupping Facial treatment at Menon Medispa in Millburn, NJ"
    price="Starting at $150"
    trust={{ stars: true, reviewText: '100+ 5 Star Reviews' }}
  />

  <TrustBar />

  <ServiceLayout>
    <!-- MAIN COLUMN -->
    <div class="svc-block">
      <h2>Facial Cupping for Puffiness, Circulation, and Natural Lift</h2>

      <p class="svc-lead">For clients who want visible refreshment without needles or downtime, cupping facial therapy offers a gentle, naturally rooted approach.</p>

      <p>Clients often ask about facial cupping before and after results. The most common changes are reduced puffiness, a brighter-looking complexion, and a temporary lifted appearance that looks refreshed rather than overdone.</p>

      <ul class="svc-features">
        <li>
          <h3>Immediate Lifting and Firming Effects</h3>
          <p>The negative pressure created by cupping immediately stimulates blood flow and tissue oxygenation, creating a visible lifting and tightening effect. Many clients notice firmer, more contoured skin right after their first session, with improvements that continue to build over subsequent treatments.</p>
        </li>
        <li>
          <h3>Increased Blood Flow and Collagen Production</h3>
          <p>Cupping helps stimulate facial circulation, supporting oxygen and nutrient delivery to the skin. This gentle boost can leave the complexion looking brighter, healthier, and more awake.</p>
        </li>
        <li>
          <h3>Natural Detoxification and Lymphatic Drainage</h3>
          <p>The gentle suction of cupping activates your lymphatic system, helping to flush out toxins, reduce fluid retention, and eliminate the puffiness that makes skin look tired and aged. This natural detoxification process leaves your complexion clearer, brighter, and more defined.</p>
        </li>
        <li>
          <h3>Long-Lasting Anti-Aging Benefits</h3>
          <p>Unlike a quick surface refresh, a series of cupping facials may help maintain improvements in puffiness, tone, and facial definition. Your provider can recommend a treatment rhythm based on your skin and goals.</p>
        </li>
      </ul>
    </div>

    <!-- SIDEBAR -->
    <Fragment slot="aside">
      <QuickFacts
        cta
        reviewText="100+ 5 Star Reviews"
        items={[
          { label: 'Price', value: '$150' },
          { label: 'Appointment', value: '1 hour' },
          { label: 'Results', value: 'Visible from first session' },
          { label: 'Downtime', value: 'None' },
          { label: 'Location', value: 'Millburn, NJ' },
        ]}
      />
    </Fragment>
  </ServiceLayout>

  <ServiceTestimonial slug="cupping-facial" />

  <Process />

  <BookingCta />

  <AddOns />

  <FaqAccordion heading="Frequently asked questions" items={faqItems} />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

</BaseLayout>
<!-- redesign: service-page template (hero + 2-col body + sticky sidebar). Bands 2/5/6/7/9 reused verbatim. Section 3 (benefits) re-flowed into svc-features in main column. Section 8 (FAQ) skipped — all answer_html were blank/placeholder; no fabrication. No promo band present. Section 4 (testimonial) swapped to <ServiceTestimonial slug="cupping-facial" /> (provider-safe curated reviews). -->
