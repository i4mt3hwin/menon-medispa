---
/**
 * Chemical Peel Facial in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/chemical-peel-facial/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Chemical Peel Facial | Menon Medispa & Wellness | Millburn, NJ"
  description="Medical-grade chemical peels in Millburn NJ. Reveal fresher, younger-looking skin with our customized chemical peel treatments."
>
  <main class="sp" data-slug="chemical-peel-facial">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Chemical Peel Facial in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Chemical Peel Facial in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Reveal Fresher, Younger-Looking Skin With Medical-Grade Peels</p>
            <p class="sp-hero__lead">Our customized chemical peels are designed to address your specific skin concerns—from acne scars and hyperpigmentation to fine lines and uneven texture. Experience the difference of medical-grade treatments at Menon Medispa.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/651c7c197b52.png" alt="Chemical Peel Facial in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Customized to Your Skin Type</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Minimal Downtime</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Visible Results</p>
      </div>
    </section>

    
    {/* ===== WHY CHEMICAL PEELS WORK ===== */}
    <section class="sp-plain" aria-label="Why Chemical Peels Work">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">Why Chemical Peels Work</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Chemical peels use carefully selected acids to exfoliate damaged outer skin layers, stimulating cell renewal and collagen production. The result: smoother, brighter, more even-toned skin.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Our peels are tailored to your skin's specific needs and concerns. Whether you're targeting acne, fine lines, sun damage, or dullness, Dr. Menon's team will select the optimal peel strength and formulation for your skin type.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">What to Expect</h3>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Your skin will be thoroughly cleansed before the peel solution is applied. You may feel a mild tingling or warmth during the treatment. The peel is neutralized and removed after the appropriate time. Results develop over the following days as your skin naturally sheds the treated layers.</p>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How many chemical peel treatments will I need?</summary>
              <div class="sp-faq__answer"><p>Most clients see optimal results with a series of 3-6 treatments, spaced 3-4 weeks apart. The exact number depends on your skin concerns and goals. We'll create a personalized treatment plan during your consultation.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is there downtime after a chemical peel?</summary>
              <div class="sp-faq__answer"><p>Downtime varies depending on peel strength. Light peels may cause mild redness for 1-2 days. Medium peels typically involve 5-7 days of visible peeling. We'll discuss what to expect based on your chosen treatment.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Who is a good candidate for chemical peels?</summary>
              <div class="sp-faq__answer"><p>Chemical peels work well for most skin types and tones when properly selected. They're especially effective for acne-prone skin, hyperpigmentation, fine lines, and uneven texture. We'll assess your skin and medical history during your consultation.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Begin Your Skin Transformation Today">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Begin Your Skin Transformation Today</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Ready to reveal fresher, younger-looking skin? Schedule your personalized chemical peel consultation at Menon Medispa in Millburn, NJ.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
