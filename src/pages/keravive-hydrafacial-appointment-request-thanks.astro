---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Picture from '@/components/Picture.astro';
import imgb048429488e3 from '@/assets/images/b048429488e3.jpg';
---
<BaseLayout
  title="Keravive HydraFacial Appointment Request Received | Menon Medispa"
  description="Thank you for your HydraFacial Keravive appointment request at Menon Medispa in Millburn, NJ. We will be in touch shortly."
  noindex={true}
>
  <section class="section thanks-hero">
    <div class="container--narrow thanks-hero__inner">

      <!-- Checkmark icon -->
      <div class="thanks-hero__icon" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="28" cy="28" r="28" fill="var(--color-cta)" fill-opacity="0.12"/>
          <path d="M16 28L24 36L40 20" stroke="var(--color-cta)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <h1 class="thanks-hero__heading">We Received Your HydraFacial Keravive Appointment Request</h1>

      <p class="thanks-hero__body">We will get in touch with you soon regarding your appointment details!</p>

      <p class="thanks-hero__body">In the meantime, follow us on social media to always stay up to date on our services and specials.</p>

      <div class="thanks-hero__social" role="list">
        <a href="https://www.instagram.com/menonmedispa" aria-label="Instagram" target="_blank" rel="noopener" role="listitem">
          <img src="https://static.wixstatic.com/media/01c3aff52f2a4dffa526d7a9843d46ea.png" alt="Instagram" width="25" height="25" />
        </a>
        <a href="https://www.facebook.com/menonmedispa" aria-label="Facebook" target="_blank" rel="noopener" role="listitem">
          <img src="https://static.wixstatic.com/media/0fdef751204647a3bbd7eaa2827ed4f9.png" alt="Facebook" width="25" height="25" />
        </a>
        <a href="https://www.tiktok.com/@menonmedispa" aria-label="TikTok" target="_blank" rel="noopener" role="listitem">
          <img src="https://static.wixstatic.com/media/11062b_6e7994bdd94b41178720ff1641a0f323~mv2.png" alt="TikTok" width="25" height="25" />
        </a>
      </div>

      <Picture
        src={imgb048429488e3}
        alt="HydraFacial Keravive Treatment"
        width={439}
        height={571}
        style="margin-top:2rem;max-width:100%;border-radius:4px;"
      />

      <a href="/" class="btn btn--primary btn--lg thanks-hero__cta">Return Home</a>

    </div>
  </section>
</BaseLayout>

<style>
  .thanks-hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .thanks-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .thanks-hero__icon {
    margin-bottom: 8px;
  }

  .thanks-hero__heading {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.15;
  }

  .thanks-hero__body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.75;
    margin: 0;
    opacity: 0.82;
  }

  .thanks-hero__social {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: center;
  }

  .thanks-hero__cta {
    margin-top: var(--space-xs);
  }

  @media (max-width: 768px) {
    .thanks-hero__heading {
      font-size: var(--text-h2);
    }

    .thanks-hero__cta {
      width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 600px) {
    .thanks-hero {
      min-height: 50vh;
    }
  }
</style>
