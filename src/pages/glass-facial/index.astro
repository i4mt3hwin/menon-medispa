---
/**
 * Glass Facial with Salmon DNA — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/glass-facial/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Glass Facial | Menon Medispa & Wellness | Millburn, NJ"
  description="The Glass Facial with Salmon DNA in Millburn NJ. Achieve the coveted glass skin look with this revolutionary Korean beauty treatment."
>
  <main class="sp" data-slug="glass-facial">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Glass Facial with Salmon DNA">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Glass Facial with Salmon DNA</h1>
            <p class="sp-hero__eyebrow">Achieve the Coveted "Glass Skin" Look</p>
            <p class="sp-hero__lead">The Glass Facial uses revolutionary Salmon DNA (PDRN) technology to deeply hydrate, regenerate, and illuminate your skin. The result? The coveted "glass skin" look—smooth, luminous, and translucent.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/651c7c197b52.png" alt="Glass Facial with Salmon DNA" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Deep Hydration</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Salmon DNA Technology</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Glass Skin Effect</p>
      </div>
    </section>

    
    {/* ===== WHAT IS THE GLASS FACIAL? ===== */}
    <section class="sp-plain" aria-label="What is the Glass Facial?">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">What is the Glass Facial?</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">The Glass Facial combines Salmon DNA (PDRN) technology with advanced hydration techniques to achieve the coveted Korean "glass skin" look—skin so smooth, clear, and luminous it resembles glass.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Salmon DNA (Polydeoxyribonucleotide) is a powerful regenerative ingredient that mimics human DNA, activating skin repair processes and stimulating collagen synthesis. The result is deeply hydrated, regenerated skin with improved texture and radiance.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Benefits</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Intense hydration and moisture retention</li><li>Improved skin elasticity and firmness</li><li>Reduced appearance of fine lines</li><li>Brighter, more luminous complexion</li><li>Suitable for all skin types</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>What makes Salmon DNA special for skin?</summary>
              <div class="sp-faq__answer"><p>Salmon DNA (PDRN) has an exceptional biocompatibility with human skin because its nucleotide structure is very similar to human DNA. It activates cell regeneration, stimulates collagen and hyaluronic acid production, and has powerful anti-inflammatory properties.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How many treatments do I need for best results?</summary>
              <div class="sp-faq__answer"><p>Most clients see optimal results with an initial series of 4-6 treatments spaced 2-3 weeks apart, followed by monthly maintenance treatments. However, you'll notice immediate improvement in hydration and radiance after your first session.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is the Glass Facial suitable for sensitive skin?</summary>
              <div class="sp-faq__answer"><p>Yes! The Glass Facial is exceptionally gentle and is ideal for sensitive, dehydrated, or aging skin. Salmon DNA is naturally biocompatible and rarely causes adverse reactions.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Achieve Your Glass Skin Goals">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Achieve Your Glass Skin Goals</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Experience the revolutionary Glass Facial with Salmon DNA at Menon Medispa in Millburn, NJ. Book your appointment today.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
