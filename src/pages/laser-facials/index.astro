---
/**
 * Laser Facials in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/laser-facials/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Laser Facials | Menon Medispa & Wellness | Millburn, NJ"
  description="Medical-grade laser facial treatments in Millburn NJ. Target skin concerns with precision laser technology for clearer, tighter, more youthful skin."
>
  <main class="sp" data-slug="laser-facials">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Laser Facials in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Laser Facials in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Precision Laser Technology for Transformative Results</p>
            <p class="sp-hero__lead">Our medical-grade laser facials use advanced laser technology to target specific skin concerns with precision—from acne and redness to fine lines, sun damage, and uneven texture. Experience the power of laser science in a comfortable, clinical setting.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/3be5824bfbc0.jpg" alt="Laser Facials in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Medical-Grade Technology</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Precise Targeting</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Visible Results</p>
      </div>
    </section>

    
    {/* ===== WHY CHOOSE LASER FACIALS? ===== */}
    <section class="sp-plain" aria-label="Why Choose Laser Facials?">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">Why Choose Laser Facials?</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Laser facials offer a level of precision and effectiveness that traditional topical treatments simply cannot match. By delivering controlled energy to specific depths within the skin, laser technology can address concerns at their source.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">At Menon Medispa, our laser facials are performed under medical supervision, ensuring the highest standards of safety and efficacy. We'll recommend the appropriate laser type and settings for your specific skin concerns and type.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Laser Facial Benefits</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Targets acne, redness, and vascular concerns</li><li>Reduces fine lines and skin laxity</li><li>Addresses hyperpigmentation and sun damage</li><li>Stimulates collagen production</li><li>Minimally invasive with minimal downtime</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>Are laser facials safe?</summary>
              <div class="sp-faq__answer"><p>Yes, when performed by trained medical professionals. At Menon Medispa, all laser treatments are supervised by our medical team. We conduct a thorough skin assessment before treatment to ensure the appropriate laser settings for your skin type and concerns.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How many laser facial treatments will I need?</summary>
              <div class="sp-faq__answer"><p>This depends on your specific skin concerns and goals. Typically, a series of 3-6 treatments is recommended for optimal results, with maintenance sessions every 3-6 months. We'll create a personalized treatment plan during your consultation.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>What is the recovery time?</summary>
              <div class="sp-faq__answer"><p>Recovery time varies depending on the specific laser used. Non-ablative laser facials typically have minimal downtime (redness for 1-2 days). More aggressive treatments may involve 3-7 days of visible healing. We'll discuss what to expect for your chosen treatment.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Begin Your Laser Skin Journey">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Begin Your Laser Skin Journey</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Discover the transformative power of medical-grade laser facials at Menon Medispa in Millburn, NJ.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
