---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
import ServiceHero from '@/components/ServiceHero.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import ServiceReviews from '@/components/ServiceReviews.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import SalePopup from '@/components/SalePopup.astro';

import { getRelatedPosts } from '@/lib/relatedPosts';
import { buildServiceSchema } from '@/lib/serviceSchema';

// Kept full-width experiential bands (reused verbatim from the original build)
import TrustBar from '@/pages/_sections/hydrafacial__section_2.astro';
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import Gallery from '@/pages/_sections/hydrafacial__section_7.astro';
import VideoShowcase from '@/pages/_sections/hydrafacial__section_8.astro';
import Pricing from '@/pages/_sections/hydrafacial__section_9.astro';
import AddOns from '@/pages/_sections/hydrafacial__section_10.astro';
import RightForYou from '@/pages/_sections/hydrafacial__section_11.astro';
import FinalCta from '@/pages/_sections/hydrafacial__section_13.astro';

import heroImg from '@/assets/images/hydrafacial-hero.jpg';

const slug = 'hydrafacial';
const posts = getRelatedPosts(slug);

// FAQ, single source for the on-page accordion AND the FAQPage schema.
const faqs = [
  {
    question: 'What exactly is a HydraFacial and how does it work?',
    answer:
      'HydraFacial is a multi-step facial treatment that uses patented Vortex-Fusion technology to cleanse, exfoliate, extract, and hydrate the skin simultaneously. The device uses unique spiral suction tips to remove debris from pores while delivering nourishing serums directly into the skin.',
  },
  {
    question: 'Do you offer HydraFacial near me in Millburn, NJ?',
    answer:
      'Yes. Menon Medispa offers HydraFacial treatments in Millburn, NJ for clients from Short Hills, Maplewood, South Orange, Summit, and nearby Essex County communities. Each treatment is customized to your skin type and goals.',
  },
  {
    question: 'How is it different from other facial treatments?',
    answer:
      'Unlike traditional facials, HydraFacial uses a closed-loop system to remove impurities without manual squeezing or discomfort. The Vortex-Fusion delivery system infuses the skin with medical-grade serums during extraction, making it more effective and comfortable than conventional treatments.',
  },
  {
    question: 'Does a HydraFacial hurt, and is there any downtime?',
    answer:
      'No. A HydraFacial is painless and often described as relaxing, more like a cool, hydrating massage than a typical extraction facial. There is no downtime, so you can apply makeup and return to your day right after. We recommend sunscreen and gentle skincare afterward to protect your results.',
  },
  {
    question: 'Are there side effects, and is a HydraFacial safe for sensitive skin?',
    answer:
      'HydraFacial is gentle and suitable for most skin types, including sensitive skin, because it hydrates as it exfoliates and does not rely on manual squeezing. Any side effects are usually mild and short-lived, such as slight redness right after treatment that typically settles within a few hours. If your skin is reactive or you have a specific condition, let your specialist know so the treatment and serums can be tailored to you.',
  },
  {
    question: 'How often should I get a HydraFacial treatment?',
    answer:
      'For optimal results, monthly HydraFacial treatments are recommended. However, many clients see significant improvement after just one session. Your skincare specialist will create a personalized treatment plan based on your specific skin goals and concerns.',
  },
  {
    question: 'Is there any HydraFacial aftercare I should follow?',
    answer:
      'HydraFacial requires minimal aftercare. You may apply makeup and return to normal activities immediately. We recommend avoiding direct sun exposure and applying SPF protection after your treatment. Your specialist may also recommend specific skincare products to maintain and enhance your results.',
  },
  {
    question: 'How long do HydraFacial results last?',
    answer:
      'Most clients enjoy a fresh, hydrated glow for about 5 to 7 days after a single HydraFacial, and the skin-quality benefits build with regular treatments. Because HydraFacial has no downtime, many clients schedule it monthly or before events to keep their skin looking its best.',
  },
  {
    question: 'How much does a HydraFacial cost?',
    answer:
      'HydraFacial at Menon Medispa starts at $199, with Signature, Deluxe, and Platinum options priced by the length of the treatment and the boosters included. Because the right treatment depends on your skin and your goals, we confirm your options and pricing at your visit, and you can see the current choices in our HydraFacial pricing above.',
  },
  {
    question: 'What is the difference between the Signature, Deluxe, and Platinum HydraFacial?',
    answer:
      'All three include the core HydraFacial steps that cleanse, exfoliate, extract, and hydrate the skin. The Signature is the essential treatment and a great first HydraFacial. The Deluxe and Platinum build on it with added steps such as a targeted booster serum and extra treatment time for more comprehensive results. At your consultation we match you to the tier that best fits your skin goals and budget.',
  },
];
const faqItems = faqs.map((f) => ({ question: f.question, answer_html: `<p>${f.answer}</p>` }));

const jsonld = buildServiceSchema({
  name: 'HydraFacial in Millburn, NJ',
  description:
    'Customized HydraFacial treatments at Menon Medispa in Millburn, NJ. Choose Signature, Deluxe, or Platinum options for brighter skin with no downtime.',
  url: '/hydrafacial',
  image: heroImg.src,
  type: 'Service',
  category: 'Facials',
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Face', url: '/face' },
    { name: 'HydraFacial', url: '/hydrafacial' },
  ],
  faqs,
});
---

<BaseLayout
  title="HydraFacial Near Me in Millburn NJ | Menon Medispa"
  description="Get a customized HydraFacial in Millburn NJ for smoother, brighter skin with no downtime. Signature, Deluxe, and Platinum options at Menon Medispa today."
  canonical="https://www.menonmedispa.com/hydrafacial"
  jsonld={jsonld}
>

  <ServiceHero
    eyebrow="HYDRAFACIAL · MILLBURN, NJ"
    h1="Radiant Skin with HydraFacial in Millburn, NJ"
    subhead="Turn back time with smooth, youthful skin, without recovery or downtime. Customized for your skin type with immediate, visible results."
    image={heroImg}
    imageAlt="HydraFacial treatment at Menon Medispa in Millburn, NJ"
    price="Starting at $199"
    note="Complimentary consultation to match you to the right HydraFacial."
    trust={{ stars: true, reviewText: '100+ 5 Star Reviews' }}
  />

  <TrustBar />

  <!-- Social proof pulled high (research: ~81% of attention is in the first 3 screenfuls) -->
  <ServiceTestimonial slug="hydrafacial" />

  <ServiceLayout>
    <!-- MAIN COLUMN — lead with the solution + how it works; the problem/context trimmed below -->
    <div class="svc-block">
      <h2>The HydraFacial&#8482; Solution: Advanced Skincare Technology</h2>

      <p>The HydraFacial&#8482; treatment rejuvenates and protects your skin's health while also helping to address the visible signs of aging. This non-invasive facial treatment addresses skin concerns from the inside out, deeply cleansing, exfoliating, extracting, and hydrating your skin using a patented Vortex-Fusion&#174; delivery system.</p>

      <p>For those searching for a hydra facial near me in New Jersey, Menon Medispa in Millburn brings the gold standard in skincare directly to you. Our licensed skincare specialists create personalized treatment plans that adapt to your unique skin needs.</p>

      <p>A HydraFacial treatment at Menon Medispa can be tailored for congestion, dullness, fine lines, dryness, or event-ready glow, with Signature, Deluxe, and Platinum options available in-office.</p>

      <ul class="svc-checks">
        <li>Advanced HydraFacial&#8482; technology with patented Vortex-Fusion&#174; delivery system</li>
        <li>Painless extraction process that targets fine lines, texture issues, and congestion</li>
        <li>Superior results compared to traditional facial treatments</li>
      </ul>

      <p>The treatment uses unique, single-use HydroPeel Tips, vortex-cut spirals that create a vacuum effect, removing impurities from deep within pores while simultaneously infusing the skin with nourishing serums. This exclusive three-step process delivers real results without discomfort or downtime.</p>

      <ul class="svc-steps">
        <li>
          <h3>Cleanse + Peel</h3>
          <p>Uncover a new layer of skin with gentle exfoliation and relaxing resurfacing.</p>
        </li>
        <li>
          <h3>Extract + Hydrate</h3>
          <p>Remove debris from pores with painless suction. Nourish with intense moisturizers that quench skin.</p>
        </li>
        <li>
          <h3>Fuse + Protect</h3>
          <p>Saturate the skin's surface with antioxidants and peptides to maximize your glow.</p>
        </li>
      </ul>
    </div>

    <div class="svc-block">
      <h2>A Better Way to Refresh Your Skin</h2>

      <p class="svc-lead">Dealing with skin problems can be frustrating and confidence-draining.</p>

      <p>Environmental factors and aging leave skin looking dull, uneven, and congested despite your best efforts.</p>

      <p>When searching for a hydrafacial near me, you deserve a treatment that is customized to your skin instead of a one-size-fits-all facial.</p>

      <ul class="svc-checks">
        <li>Conventional products rarely penetrate deep enough to address the root causes of skin concerns</li>
        <li>Seasonal changes and stress constantly challenge skin's balance</li>
        <li>Different facial areas have completely different needs</li>
      </ul>

      <p>Traditional facial treatments offer only temporary relief without addressing underlying skin health, and with diverse skin types, standard facials frequently disappoint and leave clients searching for something more effective.</p>
    </div>

    <!-- SIDEBAR -->
    <Fragment slot="aside">
      <QuickFacts
        cta
        reviewText="100+ 5 Star Reviews"
        items={[
          { label: 'Starting price', value: '$199' },
          { label: 'Appointment', value: '30 min – 1 hr 20 min' },
          { label: 'Results', value: 'Immediate, visible' },
          { label: 'Downtime', value: 'None' },
          { label: 'Skin types', value: 'All skin types' },
          { label: 'Location', value: 'Millburn, NJ' },
        ]}
      />
    </Fragment>
  </ServiceLayout>

  <!-- Mid-scroll CTA (research: repeat the Book CTA after the persuasion content) -->
  <section class="section section--tint">
    <div class="container svc-midcta">
      <h2>Ready to book your HydraFacial?</h2>
      <p>Book your visit and our team will match you to the right HydraFacial for your skin and goals.</p>
      <a href="/request-appointment?service=HydraFacial" class="btn btn--primary">Book Your HydraFacial</a>
    </div>
  </section>

  <VideoShowcase />

  <RightForYou />

  <Gallery />

  <Pricing />

  <AddOns />

  <!-- Deeper social proof: more real 5-star reviews for this service -->
  <ServiceReviews slug="hydrafacial" excludeFirst heading="More 5-star reviews from our clients" bg_color="rgb(196 164 132 / 0.14)" />

  <FaqAccordion heading="Frequently asked questions" items={faqItems} />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

  <style>
    .svc-midcta { max-width: 680px; margin-inline: auto; text-align: center; }
    .svc-midcta h2 {
      font-family: var(--font-display);
      font-size: var(--text-h2);
      font-weight: var(--weight-regular);
      color: var(--color-text);
      line-height: 1.2;
      margin: 0 0 var(--space-sm);
      text-wrap: balance;
    }
    .svc-midcta p {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      line-height: 1.6;
      margin: 0 0 var(--space-md);
      opacity: 0.9;
    }
  </style>

</BaseLayout>
<!-- redesign v2 (CRO+SEO reference pattern, structure-only): testimonial pulled high, body leads with the
     solution + 3-step process (problem/context trimmed below), mid-scroll Book CTA, a 3-up real-reviews strip
     (ServiceReviews), and bands resequenced for clean background alternation (Video/RightForYou/Gallery/Pricing/
     AddOns → white/dark/white/tint/white). Removed the standalone contact LeadForm in favor of the booking CTAs
     (matches the laser reference). Copy unchanged except a reframed problem heading + a trimmed transition line;
     keyword copy (before/after, melasma/tretinoin FAQ) deferred until the medispa confirms facts. -->
