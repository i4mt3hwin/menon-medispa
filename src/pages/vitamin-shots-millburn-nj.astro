---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceHero from '@/components/ServiceHero.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import SalePopup from '@/components/SalePopup.astro';

import { getRelatedPosts } from '@/lib/relatedPosts';
import { buildServiceSchema } from '@/lib/serviceSchema';

// Kept full-width experiential bands (reused verbatim from the original build)
import TrustBar from '@/pages/_sections/vitamin-shots-millburn-nj__section_2.astro';
import ServiceCards from '@/pages/_sections/vitamin-shots-millburn-nj__section_5.astro';
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import FinalCta from '@/pages/_sections/vitamin-shots-millburn-nj__section_7.astro';

import heroImg from '@/assets/images/be07a65c0c65.png';

const slug = 'vitamin-shots-millburn-nj';
const posts = getRelatedPosts(slug);

// No authored FAQ content on this page.
const faqs: { question: string; answer: string }[] = [];

const jsonld = buildServiceSchema({
  name: 'Vitamin Shots in Millburn, NJ',
  description:
    'Vitamin Shots at Menon Medispa in Millburn, NJ. B12, Glutathione, B Complex, Glow Shot, and Energy Shot starting at $35. Boost energy, immunity, and radiance.',
  url: '/vitamin-shots-millburn-nj',
  image: heroImg.src,
  type: 'Service',
  category: 'Wellness',
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Body', url: '/body' },
    { name: 'Vitamin Shots', url: '/vitamin-shots-millburn-nj' },
  ],
  faqs,
});
---

<BaseLayout
  title="Vitamin Shots in Millburn NJ | B12, Glutathione & More | Menon Medispa"
  description="Boost energy, immunity, and radiance with Vitamin Shots at Menon Medispa in Millburn, NJ. B12, Glutathione, B Complex, Glow Shot, and Energy Shot starting at $35. Call (973) 494-8431."
  canonical="https://www.menonmedispa.com/vitamin-shots-millburn-nj"
  jsonld={jsonld}
>

  <ServiceHero
    eyebrow="VITAMIN SHOTS · MILLBURN, NJ"
    h1="Boost Your Energy and Radiance with Vitamin Shots in Millburn, NJ"
    subhead="Join countless clients in Millburn and Short Hills who turn to Menon Medispa's Vitamin Shots for fast, effective wellness support, without the guesswork."
    image={heroImg}
    imageAlt="Vitamin Booster Shot at Menon Medispa Millburn NJ"
    price="Starting at $35"
    trust={{ stars: true, reviewText: '100+ 5 Star Reviews' }}
  />

  <TrustBar />

  <ServiceLayout>
    <!-- MAIN COLUMN -->
    <div class="svc-block">
      <h2>The Struggle with Low Energy and Vitamin Deficiency</h2>
      <p class="svc-lead">Constantly feeling tired, unfocused, or just "off" can make it hard to keep up with life. While coffee, energy drinks, and daily vitamins offer quick boosts, they rarely address the root cause:</p>

      <ul class="svc-checks">
        <li>Daily fatigue and low energy drain focus, motivation, and mood</li>
        <li>Oral supplements may not absorb efficiently or deliver fast results</li>
        <li>Poor diet, stress, and dehydration deplete essential nutrients</li>
        <li>Slower recovery from illness, workouts, or even travel becomes the norm</li>
      </ul>

      <p>Many people hesitate to take action because they're unsure what their body really needs, or whether vitamin injections actually work. The result? A frustrating cycle of burnout and band-aid solutions that don't restore lasting wellness.</p>

      <p>At Menon Medispa, our targeted Vitamin Shots deliver exactly what your body craves, quickly, safely, and effectively.</p>
    </div>

    <!-- SIDEBAR -->
    <Fragment slot="aside">
      <QuickFacts
        cta
        reviewText="100+ 5 Star Reviews"
        items={[
          { label: 'Price', value: 'Starting at $35' },
          { label: 'Appointment', value: 'Quick in-office visit' },
          { label: 'Results', value: 'Fast-acting relief' },
          { label: 'Location', value: 'Millburn, NJ' },
        ]}
      />
    </Fragment>
  </ServiceLayout>

  <ServiceCards />

  <ServiceTestimonial slug="vitamin-shots-millburn-nj" />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

</BaseLayout>
<!-- redesign: service-page template. Bands kept: section_2 (TrustBar), section_5 (ServiceCards), section_7 (FinalCta). Prose inlined from section_3 + section_4 heading. section_1 (Hero) extracted to ServiceHero. section_6 (Testimonial) swapped to <ServiceTestimonial slug="vitamin-shots-millburn-nj" /> (provider-safe curated review). section_9 (June Sales promo) removed, replaced by SalePopup. No FAQ authored on page. -->
