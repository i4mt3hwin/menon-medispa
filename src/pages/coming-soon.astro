---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Coming Soon | Menon Medispa" noindex={true}>
  <meta http-equiv="refresh" content="0;url=/" />
  <section class="section cs-redirect">
    <div class="container--narrow cs-redirect__inner">
      <p class="cs-redirect__text">Redirecting...</p>
    </div>
  </section>
</BaseLayout>


<style>
  .cs-redirect {
    text-align: center;
  }

  .cs-redirect__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .cs-redirect__text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
