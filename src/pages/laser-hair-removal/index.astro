---
/**
 * Laser Hair Removal in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/laser-hair-removal/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Laser Hair Removal | Menon Medispa & Wellness | Millburn, NJ"
  description="Professional laser hair removal in Millburn NJ. Permanently reduce unwanted hair with our medical-grade laser technology. Safe for all skin types."
>
  <main class="sp" data-slug="laser-hair-removal">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Laser Hair Removal in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Laser Hair Removal in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Permanent Hair Reduction with Medical-Grade Technology</p>
            <p class="sp-hero__lead">Say goodbye to razors, waxing, and ingrown hairs. Our medical-grade laser hair removal delivers permanent hair reduction for all body areas and skin types. Experience smoother, hair-free skin with our expert team at Menon Medispa.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/67c41f4e43f3.jpeg" alt="Laser Hair Removal in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Permanent Hair Reduction</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> All Skin Types</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Safe & Effective</p>
      </div>
    </section>

    
    {/* ===== HOW LASER HAIR REMOVAL WORKS ===== */}
    <section class="sp-plain" aria-label="How Laser Hair Removal Works">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">How Laser Hair Removal Works</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Laser hair removal uses targeted light energy that is absorbed by the melanin (pigment) in hair follicles. The heat generated destroys the follicle's ability to produce hair without damaging the surrounding skin.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Because hair grows in cycles, multiple treatments are needed to catch all follicles in their active growth phase. After completing a full treatment series, most clients enjoy permanent hair reduction of 80-90% with only occasional maintenance sessions needed.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Treatment Areas</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Face (upper lip, chin, cheeks, sideburns)</li><li>Underarms</li><li>Bikini &amp; Brazilian</li><li>Legs (full, lower, upper)</li><li>Arms (full, lower, upper)</li><li>Back &amp; chest</li><li>And more — full body available</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How many laser hair removal sessions do I need?</summary>
              <div class="sp-faq__answer"><p>Most clients need 6-8 treatments for significant permanent hair reduction. Sessions are spaced 4-6 weeks apart for body areas and 4 weeks for facial areas. The exact number varies based on your hair color, skin tone, and treatment area.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Does laser hair removal hurt?</summary>
              <div class="sp-faq__answer"><p>Most clients describe the sensation as a rubber band snap or light sting. Our advanced cooling systems help minimize discomfort during treatment. Many clients find it much more comfortable than waxing.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is laser hair removal safe for dark skin tones?</summary>
              <div class="sp-faq__answer"><p>Yes! Our medical-grade laser technology is safe and effective for all skin types, including darker skin tones. We use Nd:YAG laser wavelengths that are specifically safe for darker skin, minimizing the risk of hyperpigmentation.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Start Your Laser Hair Removal Journey">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Start Your Laser Hair Removal Journey</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Schedule your laser hair removal consultation at Menon Medispa in Millburn, NJ and take the first step toward permanently smooth skin.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
