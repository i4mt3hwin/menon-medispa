---

<!-- Section 7: IV Drip Menu Pricing Table -->
<section class="section s7-drip-menu">
  <div class="container">
    <div class="s7-drip-menu__grid">
      {drips.map((drip) => (
        <div class="s7-drip-menu__card">
          <div class="s7-drip-menu__card-img-wrap">
            <img
              src={drip.image.src}
              alt={drip.imageAlt}
              class="s7-drip-menu__card-img"
              loading="lazy"
              decoding="async"
              width="400"
              height="300"
            />
          </div>
          <div class="s7-drip-menu__card-body">
            <h3 class="s7-drip-menu__card-name">{drip.name}</h3>
            <p class="s7-drip-menu__card-volume">{drip.volume}</p>
            <p class="s7-drip-menu__card-price">{drip.price}</p>
            <div class="s7-drip-menu__card-actions">
              <a href={drip.readMoreUrl} class="btn btn--secondary btn--sm" aria-label={`Read more about ${drip.name}`}>Read More</a>
              <a
                href={drip.bookUrl}
                class="btn btn--primary btn--sm"
                target="_blank"
                rel="noopener noreferrer"
              >Book Now</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .s7-drip-menu__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .s7-drip-menu__card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-bg);
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.05);
  }

  .s7-drip-menu__card-img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    flex-shrink: 0;
  }

  .s7-drip-menu__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .s7-drip-menu__card:hover .s7-drip-menu__card-img {
    transform: scale(1.04);
  }

  .s7-drip-menu__card-body {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .s7-drip-menu__card-name {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s7-drip-menu__card-volume {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: rgba(0, 0, 0, 0.6);
    margin: 0;
    line-height: 1.4;
  }

  .s7-drip-menu__card-price {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .s7-drip-menu__card-actions {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: var(--space-xs);
  }

  @media (max-width: 1024px) {
    .s7-drip-menu__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .s7-drip-menu__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .s7-drip-menu__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }

    .s7-drip-menu__card-actions .btn {
      flex: 1;
      text-align: center;
    }
  }
</style>
