<!-- Section 5: Process, Simple, Relaxing, and Effective -->
<section class="section s5-process">
  <div class="container">

    <h2 class="s5-process__heading">Simple, Relaxing, and Effective</h2>

    <div class="s5-process__steps">

      <div class="s5-process__step">
        <h3 class="s5-process__step-title">Personalized Consultation</h3>
        <p class="s5-process__step-body">
          Before your session, our team will briefly consult with you to understand your recovery
          needs and recommend the right IV formula to get you back to feeling your best.
        </p>
      </div>

      <div class="s5-process__step">
        <h3 class="s5-process__step-title">Relax and Recharge</h3>
        <p class="s5-process__step-body">
          Settle into one of our comfortable therapy chairs as your customized IV drip is
          administered. The process is virtually painless and takes about 45-60 minutes, giving you
          time to rest and recover.
        </p>
      </div>

      <div class="s5-process__step">
        <h3 class="s5-process__step-title">Feel the Benefits</h3>
        <p class="s5-process__step-body">
          Most clients feel the hydrating and restorative effects almost immediately after their
          session. Energy levels improve, nausea subsides, and that overall feeling of being
          run-down begins to lift.
        </p>
      </div>

    </div>

  </div>
</section>

<style>
  .s5-process__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
    text-align: center;
  }

  .s5-process__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .s5-process__step {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .s5-process__step-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s5-process__step-body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .s5-process__steps {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }
</style>
