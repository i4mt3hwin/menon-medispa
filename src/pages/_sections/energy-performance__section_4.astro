---

<section class="section section--tint ep4-gallery">
  <div class="container--wide">
    <h2 class="ep4-gallery__heading">Hear From Our Customers!</h2>
    <div class="ep4-gallery__grid">
      <img src="/images/9ebaca3843d3.jpg" alt="Happy IV therapy client" width="376" height="376" loading="lazy" class="ep4-gallery__img" />
      <img src="/images/6c461885a28e.jpg" alt="Happy IV therapy client" width="376" height="376" loading="lazy" class="ep4-gallery__img" />
      <img src="/images/823792ea5ead.jpg" alt="Happy IV therapy client" width="376" height="376" loading="lazy" class="ep4-gallery__img" />
      <img src="/images/cd675890fe0d.jpg" alt="Happy IV therapy client" width="376" height="376" loading="lazy" class="ep4-gallery__img" />
      <img src="/images/2e5d1e68225a.jpg" alt="Happy IV therapy client" width="376" height="376" loading="lazy" class="ep4-gallery__img" />
    </div>
  </div>
</section>

<style>
  .ep4-gallery__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-md);
    line-height: 1.3;
    text-align: center;
  }

  .ep4-gallery__grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
  }

  .ep4-gallery__img {
    width: 376px;
    height: 376px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    display: block;
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .ep4-gallery__img {
      width: 280px;
      height: 280px;
    }
  }

  @media (max-width: 768px) {
    .ep4-gallery__img {
      width: calc(50% - var(--space-xs));
      height: auto;
      aspect-ratio: 1;
    }
  }

  @media (max-width: 600px) {
    .ep4-gallery__img {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
      max-width: 376px;
    }
  }
</style>
