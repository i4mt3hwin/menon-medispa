---
import site from '@/lib/site';
import heroBg from '@/assets/images/651c7c197b52.webp';
import productImg from '@/assets/images/33f6a2a1c88f.webp';
---

<section class="media-bg section s1-hero ep1-hero" style="--scrim-strength:0.60">
  <img class="media-bg__img media-bg__img--blur" src={heroBg.src} alt="" aria-hidden="true"
       loading="eager" decoding="async" width="1440" height="612" />
  <span class="media-bg__scrim media-bg__scrim--l"></span>

  <div class="media-bg__inner container on-media">
    <div class="s1-hero__layout">

      <div class="s1-hero__text">
        <p class="ep1-hero__eyebrow">Energy &amp; Performance IV Therapy in Millburn NJ</p>

        <h1 class="s1-hero__heading">
          Unlock your peak potential with sustained energy and mental clarity.
        </h1>

        <p class="s1-hero__body">
          Fight fatigue, brain fog, and slow workout recovery. Our Energy &amp; Performance IV drip in Millburn, NJ, delivers a direct infusion of vitamins and amino acids that your body absorbs immediately.
        </p>

        <div class="s1-hero__ctas">
          <a href={site.calcomUrl} class="btn btn--primary btn--lg">
            Book Your IV Therapy
          </a>
        </div>

        <div class="s1-hero__social-proof">
          <div class="s1-hero__social-icons">
            <img src="/images/90411e0041df.webp" alt="" class="s1-hero__social-icon" width="49" height="49" loading="lazy" />
            <img src="/images/305afeda5f9a.webp" alt="" class="s1-hero__social-icon" width="56" height="49" loading="lazy" />
            <img src="/images/b95880091b44.webp" alt="" class="s1-hero__social-icon" width="56" height="49" loading="lazy" />
          </div>
          <div class="s1-hero__stars-block">
            <p class="s1-hero__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="s1-hero__review-count">100+ 5 Star Reviews</p>
          </div>
        </div>
      </div>

      <div class="s1-hero__img-col">
        <img
          src={productImg.src}
          alt="IV Therapy bag with energy illustration"
          class="s1-hero__img"
          loading="eager"
          decoding="async"
          width="454"
          height="454"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .ep1-hero {
    min-height: 612px;
  }

  .media-bg__inner.container {
    padding-block: var(--section-py);
  }

  .ep1-hero__eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.4;
    opacity: 0.9;
  }

  .s1-hero__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .s1-hero__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 620px;
  }

  .s1-hero__heading {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.2;
  }

  .s1-hero__body {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.6;
  }

  .s1-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .s1-hero__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .s1-hero__social-icons {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .s1-hero__social-icons img {
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255,255,255,0.4);
    margin-left: -8px;
  }

  .s1-hero__social-icons img:first-child {
    margin-left: 0;
  }

  .s1-hero__social-icon {
    display: block;
    object-fit: contain;
    filter: brightness(1.15);
  }

  .s1-hero__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .s1-hero__stars {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1;
  }

  .s1-hero__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    margin: 0;
    line-height: 1.3;
  }

  .s1-hero__img-col {
    flex-shrink: 0;
    width: 454px;
  }

  .s1-hero__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.35);
  }

  @media (max-width: 1024px) {
    .s1-hero__img-col {
      width: 360px;
    }
  }

  @media (max-width: 768px) {
    .ep1-hero {
      min-height: auto;
    }

    .s1-hero__layout {
      flex-direction: column-reverse;
    }

    .s1-hero__text {
      max-width: 100%;
    }

    .s1-hero__img-col {
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }

    .s1-hero__ctas {
      flex-direction: column;
    }

    .s1-hero__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .s1-hero__social-proof {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
