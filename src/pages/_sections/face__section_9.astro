---
import site from '@/lib/site';

import promo1Img from '@/assets/images/56a3e3ac1335.jpg';
import promo2Img from '@/assets/images/86072f9cbd9c.jpg';
import promo3Img from '@/assets/images/dd355e57f3dd.jpg';
---

<div class="face-s9" id="flash-sale-modal" role="dialog" aria-modal="true" aria-label="Flash Sale promotions" hidden>
  <div class="face-s9__backdrop" onclick="this.closest('.face-s9').hidden=true"></div>
  <div class="face-s9__panel">
    <button class="face-s9__close" onclick="this.closest('.face-s9').hidden=true" aria-label="Close">&#10005;</button>
    <h2 class="face-s9__title">June SALES</h2>

    <div class="face-s9__promos">

      <div class="face-s9__promo">
        <img
          src={promo1Img.src}
          alt="BRO-tox Fathers Day Special"
          class="face-s9__promo-img"
          loading="lazy"
          decoding="async"
          width="110"
          height="110"
        />
        <div class="face-s9__promo-text">
          <p class="face-s9__promo-name">BRO-tox Fathers Day Special</p>
          <p class="face-s9__promo-label">Includes:</p>
          <ul class="face-s9__promo-list">
            <li>Botox $12 Per Unit</li>
            <li>Smooths forehead, frown lines &amp; crow's feet</li>
            <li>Personalized Treatment Plan with Dr. Menon</li>
          </ul>
        </div>
      </div>

      <div class="face-s9__promo">
        <img
          src={promo2Img.src}
          alt="Summer Glow HydraFacial"
          class="face-s9__promo-img"
          loading="lazy"
          decoding="async"
          width="110"
          height="110"
        />
        <div class="face-s9__promo-text">
          <p class="face-s9__promo-name">Summer Glow HydraFacial</p>
          <ul class="face-s9__promo-list">
            <li>Vitamin C Booster +</li>
            <li>Discount Dermaplaning $25</li>
            <li>($285 Value for $225)</li>
          </ul>
        </div>
      </div>

      <div class="face-s9__promo">
        <img
          src={promo3Img.src}
          alt="Custom Hydrating IV"
          class="face-s9__promo-img"
          loading="lazy"
          decoding="async"
          width="110"
          height="110"
        />
        <div class="face-s9__promo-text">
          <p class="face-s9__promo-name">Custom Hydrating IV</p>
          <ul class="face-s9__promo-list">
            <li>$99 Special Price</li>
            <li>Includes any two vitamins</li>
            <li>Hydrate, recharge, glow</li>
          </ul>
        </div>
      </div>

    </div>

    <a
      href={site.calcomUrl}
      class="face-s9__btn"
      target="_blank"
      rel="noopener noreferrer"
    >
      Explore all sales
    </a>
  </div>
</div>

<style>
  .face-s9 {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .face-s9[hidden] {
    display: none;
  }

  .face-s9__backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
  }

  .face-s9__panel {
    position: relative;
    background-color: var(--color-bg, #fff);
    border-radius: var(--radius-sm);
    padding: var(--space-xl);
    max-width: 680px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .face-s9__close {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    background: none;
    border: none;
    font-size: var(--text-lg);
    cursor: pointer;
    color: var(--color-text);
    padding: 4px 8px;
  }

  .face-s9__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    text-align: center;
  }

  .face-s9__promos {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .face-s9__promo {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .face-s9__promo-img {
    flex-shrink: 0;
    width: 110px;
    height: 110px;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }

  .face-s9__promo-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .face-s9__promo-name {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
  }

  .face-s9__promo-label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
  }

  .face-s9__promo-list {
    margin: 0;
    padding-left: 1.2em;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
  }

  .face-s9__btn {
    display: inline-block;
    align-self: center;
    padding: 10px 24px;
    background-color: var(--color-cta);
    color: var(--color-text);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    text-decoration: none;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-btn);
    transition: opacity 0.2s;
  }

  .face-s9__btn:hover {
    opacity: 0.88;
  }
</style>
