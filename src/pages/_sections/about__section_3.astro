---
import videoPosterImg from '@/assets/images/2ef11e239ab9.jpg';
---

<section class="section about-s3">
  <div class="container">
    <div class="about-s3__layout">

      <div class="about-s3__media">

        {/* Video, autoplay, loop, muted. Hidden on mobile via CSS. */}
        <video
          class="about-s3__video"
          data-lazy-video
          autoplay
          loop
          muted
          playsinline
          preload="none"
          aria-hidden="true"
          poster={videoPosterImg.src}
          width="846"
          height="458"
        >
          <source
            data-src="/videos/wix/f61cce_b930b3f48aa04baa8c7f669d63cdaebd.mp4"
            type="video/mp4"
          />
        </video>

        {/* Poster image, shown on mobile; hidden on desktop */}
        <img
          src={videoPosterImg.src}
          alt="Menon Medispa team bringing out the best in you"
          class="about-s3__poster"
          loading="lazy"
          decoding="async"
          width="846"
          height="458"
        />

      </div>

      <div class="about-s3__content">
        <p class="eyebrow">Our Mission</p>

        <h2 class="about-s3__heading">
          BRINGING OUT THE BEST IN YOU
        </h2>

        <p class="about-s3__body">
          Our mission is to ensure that when you visit Menon Medispa &amp; Wellness you will feel at home and leave looking and feeling better than when you came in.
        </p>

        <div class="about-s3__cta">
          <a href="/meet-the-team" class="btn btn--secondary about-s3__btn">
            MEET THE TEAM
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .about-s3__layout {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-lg);
  }

  .about-s3__media {
    flex-shrink: 0;
    width: 55%;
    max-width: 600px;
    position: relative;
  }

  .about-s3__video {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: 0 12px 32px rgb(30 24 41 / 0.14);
  }

  .about-s3__poster {
    display: none;
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: 0 12px 32px rgb(30 24 41 / 0.14);
    object-fit: cover;
  }

  .about-s3__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about-s3__heading {
    font-family: var(--font-ui);
    font-size: var(--text-lg);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    letter-spacing: 0.05em;
    margin: 0;
    line-height: 1.3;
  }

  .about-s3__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.7;
  }

  .about-s3__btn {
    border-color: rgb(44, 38, 50);
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 1024px) {
    .about-s3__media {
      width: 50%;
    }
  }

  @media (max-width: 768px) {
    .about-s3__layout {
      flex-direction: column;
    }

    .about-s3__media {
      width: 100%;
      max-width: 576px;
      margin: 0 auto;
    }

    .about-s3__video {
      opacity: 0;
      position: absolute;
      pointer-events: none;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }

    .about-s3__poster {
      display: block;
    }

    .about-s3__content {
      align-items: center;
      text-align: center;
    }

    .about-s3__btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
