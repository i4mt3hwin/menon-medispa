---
import site from '@/lib/site';
import officeImg from '@/assets/images/b1a819f35921.webp';
---

<section class="section section--dark sema-s9-cta">
  <div class="container">
    <div class="sema-s9__layout">

      <div class="sema-s9__text">

        <h2 class="sema-s9__heading">Begin Your Transformation Today</h2>

        <p class="sema-s9__subtitle">Menon Medispa Millburn NJ</p>

        <p class="sema-s9__body">
          Ready to experience the benefits of Semaglutide with Dr. Aditi Menon? Take the first step toward Medical Weight Loss by scheduling your personal consultation at Menon Medispa in Millburn, NJ.
        </p>

        <div class="sema-s9__actions">
          <a href={site.calcomUrl} class="btn btn--primary btn--lg">
            Schedule Consultation
          </a>
        </div>

      </div>

      <div class="sema-s9__img-col">
        <img
          src={officeImg.src}
          alt="Menon Medispa office staff in Millburn, NJ"
          class="sema-s9__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="560"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .sema-s9__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .sema-s9__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .sema-s9__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .sema-s9__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sema-s9__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .sema-s9__actions {
    margin-top: var(--space-xs);
  }

  .sema-s9__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .sema-s9__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .sema-s9__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .sema-s9__layout {
      flex-direction: column;
    }

    .sema-s9__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .sema-s9__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
