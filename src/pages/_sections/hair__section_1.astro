---
import site from '@/lib/site';

import heroBg from '@/assets/images/651c7c197b52.png';
import heroFeature from '@/assets/images/cf8274396252.jpg';
import reviewIcon1 from '@/assets/images/90411e0041df.png';
import reviewIcon2 from '@/assets/images/305afeda5f9a.png';
import reviewIcon3 from '@/assets/images/b95880091b44.png';
---

<section class="media-bg section s1-hero hair-hero" style="--scrim-strength:0.60">
  <img class="media-bg__img media-bg__img--blur" src={heroBg.src} alt="" aria-hidden="true"
       loading="eager" decoding="async" width="1440" height="625" />
  <span class="media-bg__scrim media-bg__scrim--l"></span>

  <div class="media-bg__inner container on-media">
    <div class="hair-hero__layout">
      <div class="hair-hero__content">

        <h1 class="hair-hero__heading">
          Rediscover the Full, Natural Hair You Love
        </h1>

        <p class="hair-hero__body">
          Combat thinning and stimulate new growth with our advanced, non-surgical therapies. Our medical experts create a personalized plan to restore your hair&rsquo;s vitality and your confidence.
        </p>

        <div class="hair-hero__ctas">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Request My Consultation
          </a>
        </div>

        <div class="hair-hero__social-proof">
          <div class="hair-hero__avatars">
            <img
              src={reviewIcon1.src}
              alt="Picture of a Client Who Reviewed Us"
              class="hair-hero__avatar"
              loading="lazy"
              decoding="async"
              width="46"
              height="50"
            />
            <img
              src={reviewIcon2.src}
              alt="Picture of a Client Who Reviewed Us"
              class="hair-hero__avatar"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
            <img
              src={reviewIcon3.src}
              alt="Picture of a Client Who Reviewed Us"
              class="hair-hero__avatar"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
          </div>
          <div class="hair-hero__stars-block">
            <p class="hair-hero__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="hair-hero__review-count">100+ 5 Star Reviews</p>
          </div>
        </div>

      </div>

      <div class="hair-hero__feature-img-wrap">
        <img
          src={heroFeature.src}
          alt="Hair restoration treatment at Menon Medispa Millburn NJ"
          loading="eager"
          decoding="async"
          width="480"
          height="268"
          class="hair-hero__feature-img"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .hair-hero {
    min-height: clamp(520px, 68vh, 660px);
  }

  .media-bg__inner.container {
    padding-block: clamp(58px, 8vw, 92px);
  }

  .hair-hero__layout {
    display: grid;
    grid-template-columns: minmax(0, 620px) minmax(280px, 480px);
    align-items: center;
    gap: clamp(40px, 7vw, 96px);
  }

  .hair-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 14px;
    max-width: 620px;
  }

  .hair-hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.15rem, 4vw, 3.6rem);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.08;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .hair-hero__body {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.6;
    max-width: 620px;
    text-wrap: pretty;
  }

  .hair-hero__feature-img-wrap {
    border-radius: var(--radius-sm);
    overflow: hidden;
    width: 100%;
    padding: 10px;
    border: 1px solid rgb(255 255 255 / 0.18);
    background: rgb(255 255 255 / 0.08);
    box-shadow: 0 24px 70px rgb(0 0 0 / 0.22);
  }

  .hair-hero__feature-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }

  .hair-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: 10px;
  }

  .hair-hero__social-proof {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    width: fit-content;
    margin-top: 8px;
    padding: 8px 16px 8px 10px;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.08);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .hair-hero__avatars {
    display: flex;
    align-items: center;
  }

  .hair-hero__avatar {
    display: block;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255, 255, 255, 0.8);
    margin-left: -8px;
  }

  .hair-hero__avatar:first-child {
    margin-left: 0;
  }

  .hair-hero__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }

  .hair-hero__stars {
    color: var(--color-star);
    font-size: var(--text-sm);
    letter-spacing: 2px;
    margin: 0;
    line-height: 1;
  }

  .hair-hero__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    margin: 0;
    line-height: 1.3;
  }

  @media (max-width: 1024px) {
    .hair-hero {
      min-height: 560px;
    }

    .hair-hero__layout {
      grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
      gap: var(--space-lg);
    }
  }

  @media (max-width: 768px) {
    .hair-hero {
      min-height: auto;
    }

    .hair-hero__layout {
      display: flex;
      flex-direction: column-reverse;
      align-items: stretch;
    }

    .hair-hero__ctas {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
    }

    .hair-hero__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .hair-hero__social-proof {
      flex-wrap: wrap;
      width: 100%;
      border-radius: var(--radius-sm);
    }
  }
</style>
