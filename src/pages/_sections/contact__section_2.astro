---
import LeadForm from '@/components/LeadForm.astro';
import Picture from '@/components/Picture.astro';
import officeStaffImg from '@/assets/contact/office-staff.webp';
import facebookImg from '@/assets/social/icon-facebook.webp';
import instagramImg from '@/assets/social/icon-instagram.webp';
import tiktokImg from '@/assets/social/icon-tiktok.webp';
---

<section class="contact-s2" aria-label="Contact form and info">
  <div class="contact-s2__inner">

    <!-- Left column: contact form (Wix form widget replaced with LeadForm, contact variant) -->
    <div class="contact-s2__form-col">
      <LeadForm
        fields={['name', 'email', 'phone', 'service', 'message']}
        submit_label="Send My Message"
        success_url="/thank-you"
      />
      <!-- SMS consent checkbox (verbatim from Wix form widget) -->
      <label class="contact-s2__sms-consent">
        <input type="checkbox" name="sms_consent" />
        <span>By checking this box, I agree to receive SMS messages from Menon Medispa through an automatic telephone dialing system </span>
      </label>
    </div>

    <!-- Right column: office image + NAP info -->
    <div class="contact-s2__info-col">
      <!-- Office staff image (widget: image, key 35c774fbba6d) -->
      <Picture
        src={officeStaffImg}
        alt="Menon Medispa office staff in Millburn, NJ"
        width={425}
        height={323}
        object_fit="cover"
        class_name="contact-s2__office-img"
      />

      <!-- Address block (widget: text-editor) -->
      <div class="contact-s2__address-block">
        <p class="contact-s2__address-text">Menon Medispa &amp; Wellness </p>
        <p class="contact-s2__address-text">45 Essex St, Suite 202, Millburn, NJ 07041, USA</p>
      </div>

      <!-- Email (widget: text-editor) -->
      <p class="contact-s2__contact-line">
        <a href="mailto:admin@menonregen.com" class="contact-s2__link">admin@menonregen.com</a>
      </p>

      <!-- Phone (widget: text-editor, operator override: always use (973) 494-8431) -->
      <p class="contact-s2__contact-line">
        <a href="tel:+19734948431" class="contact-s2__link">(973) 494-8431</a>
      </p>

      <!-- Social icons (widgets: image x3, Facebook, Instagram, TikTok) -->
      <ul class="contact-s2__social-list" aria-label="Social media">
        <li>
          <a href="https://www.facebook.com/menonmedispa" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <Picture
              src={facebookImg}
              alt="Facebook"
              width={23}
              height={23}
              object_fit="cover"
              class_name="contact-s2__social-icon"
            />
          </a>
        </li>
        <li>
          <a href="https://www.instagram.com/menonmedispa" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <Picture
              src={instagramImg}
              alt="Instagram"
              width={23}
              height={23}
              object_fit="cover"
              class_name="contact-s2__social-icon"
            />
          </a>
        </li>
        <li>
          <a href="https://www.tiktok.com/@menonmedispa" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <Picture
              src={tiktokImg}
              alt="TikTok"
              width={23}
              height={23}
              object_fit="cover"
              class_name="contact-s2__social-icon"
            />
          </a>
        </li>
      </ul>
    </div>

  </div>
</section>

<style>
  .contact-s2 {
    padding: var(--space-xl) var(--space-md);
  }

  .contact-s2__inner {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
    max-width: 1100px;
    margin: 0 auto;
  }

  .contact-s2__form-col {
    flex: 1 1 500px;
    min-width: 0;
  }

  .contact-s2__sms-consent {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    line-height: 1.5;
    cursor: pointer;
  }

  .contact-s2__sms-consent input[type="checkbox"] {
    margin-top: 2px;
    flex-shrink: 0;
  }

  .contact-s2__info-col {
    flex: 0 0 425px;
    min-width: 0;
  }

  .contact-s2__office-img {
    width: 100%;
    max-width: 425px;
    height: 323px;
    object-fit: cover;
    display: block;
    margin-bottom: var(--space-md);
  }

  .contact-s2__address-block {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .contact-s2__address-text {
    margin: 0;
    line-height: 1.6;
  }

  .contact-s2__contact-line {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    margin: 0 0 var(--space-xs);
  }

  .contact-s2__link {
    color: inherit;
    text-decoration: none;
  }

  .contact-s2__link:hover {
    text-decoration: underline;
  }

  .contact-s2__social-list {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: var(--space-sm) 0 0;
  }

  .contact-s2__social-icon {
    width: 23px;
    height: 23px;
    display: block;
  }

  @media (max-width: 980px) {
    .contact-s2 {
      padding: var(--space-lg) var(--space-sm);
    }

    .contact-s2__inner {
      flex-direction: column;
      gap: var(--space-md);
    }

    .contact-s2__form-col {
      flex: none;
      width: 100%;
    }

    .contact-s2__info-col {
      flex: none;
      width: 100%;
    }

    .contact-s2__office-img {
      max-width: 100%;
    }
  }
</style>
