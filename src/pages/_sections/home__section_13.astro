---
import SectionHeading from '@/components/SectionHeading.astro';
import RichText from '@/components/RichText.astro';
import Button from '@/components/Button.astro';
import Picture from '@/components/Picture.astro';
import site from '@/lib/site';

import staffImg from '@/assets/images/b1a819f35921.webp';
---

<section class="home-section-13">
  <div class="home-section-13__inner">

    <div class="home-section-13__text-col">
      <SectionHeading
        text="Begin Your Transformation Today"
        tag="h2"
        align="left"
        font="display"
      />

      <RichText
        html="<p>Menon Medispa Millburn NJ</p>"
        font="var(--font-body)"
        size="var(--text-sm)"
        color="var(--color-text)"
      />

      <RichText
        html="<p>Ready to experience the benefits of Menon Medispa? Take the first step toward Perfect Skin and Hair  by scheduling your personal consultation at Menon Medispa in Millburn, NJ.</p>"
        font="var(--font-body)"
        size="var(--text-sm)"
        color="var(--color-text)"
      />

      <div class="home-section-13__cta">
        <Button
          text="Schedule Your Consultation!"
          href={site.calcomUrl}
          variant="primary"
        />
      </div>
    </div>

    <div class="home-section-13__img-col">
      <Picture
        src={staffImg.src}
        alt="Menon Office Staff"
        width={431}
        loading="lazy"
        object_fit="cover"
      />
    </div>

  </div>
</section>

<style>
  .home-section-13 {
    width: 100%;
    box-sizing: border-box;
    padding: var(--space-xl) var(--space-lg);
  }

  .home-section-13__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-lg);
  }

  .home-section-13__text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .home-section-13__cta {
    margin-top: var(--space-xs);
  }

  .home-section-13__img-col {
    flex-shrink: 0;
    width: 431px;
  }

  .home-section-13__img-col img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
  }

  @media (max-width: 980px) {
    .home-section-13 {
      padding: var(--space-lg) var(--space-sm);
    }

    .home-section-13__inner {
      flex-direction: column;
    }

    .home-section-13__img-col {
      width: 100%;
      max-width: 281px;
      margin: 0 auto;
    }

    .home-section-13__text-col .section-heading {
      text-align: center;
    }
  }
</style>
