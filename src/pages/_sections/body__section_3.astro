---
import TreatmentCard from '@/components/TreatmentCard.astro';

import ivImg from '@/assets/images/914772453481.jpg';
import laserImg from '@/assets/images/67c41f4e43f3.jpeg';
import vascularImg from '@/assets/images/40c58ae9b34c.jpg';
import semaglutideImg from '@/assets/images/cd90aa0cbbcb.jpg';

const treatments = [
  {
    name: 'IV Vitamin Therapy',
    href: '/iv-therapy-millburn-nj',
    img: ivImg,
    alt: 'IV Vitamin Therapy at Menon Medispa Millburn NJ',
    descriptor: 'Boost your energy and wellness from the inside out',
  },
  {
    name: 'Laser Hair Removal',
    href: '/laser-hair-removal',
    img: laserImg,
    alt: 'Laser Hair Removal at Menon Medispa Millburn NJ',
    descriptor: 'Permanently smooth skin in just 6–8 treatments',
  },
  {
    name: 'Vascular Treatments',
    href: '/vascular-treatments',
    img: vascularImg,
    alt: 'Vascular Treatments at Menon Medispa Millburn NJ',
    descriptor: 'Vein & Vascular Treatments',
  },
  {
    name: 'Semaglutide',
    href: '/semaglutide',
    img: semaglutideImg,
    alt: 'Semaglutide weight loss treatment at Menon Medispa Millburn NJ',
    descriptor: 'Transform your health through medical weight loss',
  },
];
---

<section class="section body-grid">
  <div class="container">

    <div class="body-grid__intro">
      <h2 class="body-grid__heading">Comprehensive Body Treatments &amp; Enhancements</h2>
      <p class="body-grid__body">
        From laser hair removal and vein care to medically supervised weight loss and IV therapy, our physician-led body treatments are tailored to your goals.
      </p>
    </div>

    <div class="body-grid__cards">
      {treatments.map((t) => (
        <TreatmentCard
          name={t.name}
          href={t.href}
          img={t.img}
          alt={t.alt}
          descriptor={t.descriptor}
          ratio="4 / 5"
        />
      ))}
    </div>

    <div class="body-grid__sub-cta">
      <h3 class="body-grid__sub-heading">Not Sure Which Treatment Is Right for You?</h3>
      <p class="body-grid__sub-body">
        Book a consultation and our physician-led team will recommend a plan built around your goals, health profile, and lifestyle.
      </p>
      <a href="/consultation" class="btn btn--primary btn--lg">Book a Consultation</a>
    </div>

  </div>
</section>

<style>
  .body-grid .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .body-grid__intro {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .body-grid__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .body-grid__body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: var(--space-xs) 0 0;
    line-height: 1.6;
  }

  /* 2-column portrait grid at desktop, 1 column at mobile */
  .body-grid__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  /* Sub-CTA block */
  .body-grid__sub-cta {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: rgba(196, 164, 132, 0.08);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(0, 0, 0, 0.07);
  }

  .body-grid__sub-heading {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .body-grid__sub-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    /* 2-up on phones so the cards are compact (was 1-up at 360px = oversized + long scroll).
       minmax(0,1fr) is required: the cards are aspect-ratio boxes with all-absolute content
       (0 intrinsic width), so a bare 1fr track collapses them to 0 width. */
    .body-grid__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-sm);
    }
    /* tighten the overlay text so the smaller 2-up cards don't feel cramped */
    .body-grid__cards :global(.tcard__body) { padding: var(--space-sm); gap: 3px; }
    .body-grid__cards :global(.tcard__name) { font-size: var(--text-base); line-height: 1.1; }
    .body-grid__cards :global(.tcard__desc) { font-size: var(--text-xs); line-height: 1.3; }
    .body-grid__cards :global(.tcard__cue) { display: none; }

    .body-grid__sub-cta {
      padding: var(--space-md) var(--space-sm);
    }

    .body-grid__sub-cta .btn {
      align-self: stretch;
      text-align: center;
    }
  }
</style>
