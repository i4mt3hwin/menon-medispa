---
import testimonialBg from "@/assets/images/30cfb9e87c60.webp";
import googleRating from "@/assets/images/5be44787b3a9.webp";
---

<!-- Section 8: Testimonial, What Our Clients Say -->
<section class="media-bg section s8-testimonial" style="--scrim-strength:0.58">
  <img class="media-bg__img media-bg__img--blur" src={testimonialBg.src} alt="" aria-hidden="true"
       loading="lazy" decoding="async" width="1440" height="500" />
  <span class="media-bg__scrim media-bg__scrim--brand"></span>

  <div class="media-bg__inner container on-media">
    <div class="s8-testimonial__inner">

      <h3 class="s8-testimonial__label">What Our Clients Say</h3>

      <blockquote class="s8-testimonial__quote">
        <p class="s8-testimonial__quote-text">
          I started IV Therapy at Menon Medispa after months of feeling drained and foggy no matter how
          much I slept. After just one session, I felt noticeably more energized and focused, and the
          results lasted for days. The staff was professional and walked me through everything. This is
          now part of my regular self-care routine. Highly recommend!
        </p>
        <footer class="s8-testimonial__footer">
          <cite class="s8-testimonial__cite">Jessica M.</cite>
        </footer>
      </blockquote>

      <div class="s8-testimonial__stars">
        <img
          src={googleRating.src}
          alt="Google 5-star rating"
          class="s8-testimonial__stars-img"
          loading="lazy"
          decoding="async"
          width="160"
          height="60"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s8-testimonial__inner {
    max-width: var(--container-narrow);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .s8-testimonial__label {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  .s8-testimonial__quote {
    margin: 0;
    padding: 0;
  }

  .s8-testimonial__quote-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    margin: 0 0 var(--space-sm);
    line-height: 1.7;
    font-style: italic;
  }

  .s8-testimonial__footer {
    font-style: normal;
  }

  .s8-testimonial__cite {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    font-style: normal;
  }

  .s8-testimonial__stars {
    display: flex;
    justify-content: center;
  }

  .s8-testimonial__stars-img {
    display: block;
    height: auto;
    width: 160px;
  }
</style>
