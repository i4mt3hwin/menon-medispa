---
/**
 * job-opportunities__section_0.astro
 * Source: sections/01.json, section_index 1 (comp-lrwa6nwe)
 * Nearest heading: "Job Opportunities" (H1)
 * Widgets: H1 heading, H5 "Apply Now" subhead, Wix Form (replaced with LeadForm)
 */
import SectionHeading from '@/components/SectionHeading.astro';
import LeadForm from '@/components/LeadForm.astro';
---

<section class="section jobs-s0" aria-label="Job Opportunities application">
  <div class="container--narrow">

    {/* widget: heading H1 "Job Opportunities" */}
    <SectionHeading
      text="Job Opportunities"
      tag="h1"
      align="center"
    />

    {/* widget: heading H5 "Apply Now" (form section label from original Wix form) */}
    <h5 class="jobs-s0__form-heading">Apply Now</h5>

    {/*
      widget: form, Wix Form replaced with LeadForm per page instructions.
      Original fields: First Name, Last Name, Email, Phone, Link to CV/LinkedIn, Message.
      Mapped to LeadForm supported fields: name, email, phone, message.
      Submit label mirrors original Wix form button text "Apply Now".
    */}
    <LeadForm
      heading=""
      fields={['name', 'email', 'phone', 'message']}
      submit_label="Apply Now"
      success_url="/thank-you"
    />

  </div>
</section>

<style>
  .jobs-s0 {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .jobs-s0 .container--narrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    width: 100%;
  }

  .jobs-s0__form-heading {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    text-align: center;
    color: var(--color-text);
    margin: 0;
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .jobs-s0 .container--narrow {
      gap: var(--space-sm);
    }
  }
</style>
