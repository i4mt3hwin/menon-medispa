---
import googleBadge from '@/assets/images/5be44787b3a9.png';
---

<!-- Section 5: Request form (conversion focal) + social proof -->
<section class="section section--tint con-request" id="request">
  <div class="container">
    <div class="con-request__layout">

      {/* Left: the form */}
      <div class="con-request__form-col">
        <p class="eyebrow con-request__eyebrow">Request Your Consultation</p>
        <h2 class="con-request__heading">Let&rsquo;s Plan Your Best Skin</h2>
        <p class="con-request__sub">
          Fill out the form and we&rsquo;ll reach out within 24 hours. It&rsquo;s free, fast, and
          there&rsquo;s no obligation.
        </p>

        <div data-leadform-root>
        <form class="con-request__form" method="POST" action="/api/lead" novalidate>
          <div class="con-request__field-row">
            <div class="con-request__field">
              <label for="con-first-name" class="con-request__label">First Name <span aria-hidden="true">*</span></label>
              <input id="con-first-name" name="first_name" type="text" required autocomplete="given-name" class="con-request__input" placeholder="First Name" />
            </div>
            <div class="con-request__field">
              <label for="con-last-name" class="con-request__label">Last Name <span aria-hidden="true">*</span></label>
              <input id="con-last-name" name="last_name" type="text" required autocomplete="family-name" class="con-request__input" placeholder="Last Name" />
            </div>
          </div>

          <div class="con-request__field-row">
            <div class="con-request__field">
              <label for="con-phone" class="con-request__label">Phone</label>
              <input id="con-phone" name="phone" type="tel" autocomplete="tel" class="con-request__input" placeholder="Phone" />
            </div>
            <div class="con-request__field">
              <label for="con-email" class="con-request__label">Email <span aria-hidden="true">*</span></label>
              <input id="con-email" name="email" type="email" required autocomplete="email" class="con-request__input" placeholder="Email" />
            </div>
          </div>

          <div class="con-request__field">
            <label for="con-concerns" class="con-request__label">What would you like to work on? <span aria-hidden="true">*</span></label>
            <textarea id="con-concerns" name="message" required rows="4" class="con-request__textarea" placeholder="Tell us about your goals (no medical details, please)..."></textarea>
            <p class="con-request__warn">Please do not include medical details, conditions, or photos here.</p>
          </div>

          <input type="hidden" name="name" value="" />
          <input type="hidden" name="type" value="appointment_request" />
          <input type="hidden" name="send_confirmation" value="on" />
          <input type="text" name="company_website" tabindex="-1" autocomplete="off" class="con-request__hp" aria-hidden="true" />

          <p class="con-request__error" data-form-error hidden></p>
          <button type="submit" class="btn btn--primary btn--block btn--lg con-request__submit">
            Request My Consultation
          </button>

          <p class="con-request__fineprint">We respect your privacy. No spam, ever.</p>
        </form>
        <div class="con-request__success" data-form-success hidden>
          <h3 class="con-request__heading">Request received</h3>
          <p class="con-request__sub">Thanks! We will reach out within 24 hours to plan your consultation.</p>
          <p class="con-request__sub">Prefer to talk now? Call <a href="tel:+19734948431">(973) 494-8431</a>.</p>
        </div>
        </div>
      </div>

      {/* Right: social proof + reassurance */}
      <aside class="con-request__proof">
        <div class="con-request__proof-stars">
          <span class="con-request__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="con-request__proof-count">100+ 5 Star Reviews</span>
        </div>

        <blockquote class="con-request__quote">
          <p class="con-request__quote-text">
            &ldquo;Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable.
            Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always
            leave with great joy after seeing them.&rdquo;
          </p>
          <footer class="con-request__quote-author">Alexa C. &middot; Millburn Resident</footer>
        </blockquote>

        <ul class="con-request__assure">
          <li>Reply within 24 hours</li>
          <li>Free with an esthetician &middot; $50 with Dr. Menon (applied to treatment)</li>
          <li>Same-week appointments available</li>
        </ul>

        <img
          src={googleBadge.src}
          alt="5-star Google rating"
          class="con-request__google"
          loading="lazy"
          decoding="async"
          width="143"
          height="74"
        />
      </aside>

    </div>
  </div>
</section>

<style>
  .con-request__layout {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-xl);
    align-items: start;
  }

  /* ---- Form ---- */
  .con-request__form-col { display: flex; flex-direction: column; gap: var(--space-xs); }
  .con-request__eyebrow { margin: 0; color: var(--color-text); }

  .con-request__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .con-request__sub {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    line-height: 1.6;
    opacity: 0.85;
  }

  .con-request__form { display: flex; flex-direction: column; gap: var(--space-sm); }
  .con-request__field-row { display: flex; gap: var(--space-sm); }
  .con-request__field { display: flex; flex-direction: column; gap: 4px; flex: 1; }

  .con-request__label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    font-weight: var(--weight-bold);
    line-height: 1.3;
  }
  .con-request__label span { color: var(--color-cta); }

  .con-request__input, .con-request__textarea {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    width: 100%;
    box-sizing: border-box;
    line-height: 1.5;
    transition: border-color 0.2s;
    outline: none;
  }
  .con-request__input:focus, .con-request__textarea:focus { border-color: var(--color-cta); }
  .con-request__textarea { resize: vertical; min-height: 104px; }

  .con-request__submit { margin-top: var(--space-xs); }

  .con-request__fineprint {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.6;
    margin: 0;
    text-align: center;
  }

  /* ---- Social proof ---- */
  .con-request__proof {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    box-shadow: 0 4px 18px rgb(0 0 0 / 0.05);
    position: sticky;
    top: var(--space-lg);
  }

  .con-request__proof-stars { display: flex; align-items: center; gap: 8px; }
  .con-request__stars { color: var(--color-star); font-size: 1.2rem; letter-spacing: 2px; line-height: 1; }
  .con-request__proof-count { font-family: var(--font-ui); font-size: var(--text-sm); font-weight: var(--weight-bold); }

  .con-request__quote { margin: 0; padding: 0; }
  .con-request__quote-text {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text);
    margin: 0 0 var(--space-xs);
    line-height: 1.65;
  }
  .con-request__quote-author {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    opacity: 0.8;
  }

  .con-request__assure {
    list-style: none;
    margin: 0;
    padding: var(--space-sm) 0 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .con-request__assure li {
    position: relative;
    padding-left: 24px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }
  .con-request__assure li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-cta);
    font-weight: 700;
  }

  .con-request__google { display: block; width: 130px; height: auto; }

  @media (max-width: 900px) {
    .con-request__layout { grid-template-columns: 1fr; gap: var(--space-lg); }
    .con-request__proof { position: static; order: -1; }
  }

  @media (max-width: 600px) {
    .con-request__field-row { flex-direction: column; }
  }

  /* Lead-form wiring (submit handler in lib/leadForm.ts) */
  .con-request__warn {
    font-family: var(--font-body); font-size: var(--text-xs); color: #8a5a00; opacity: 0.85; margin: 4px 0 0; line-height: 1.4;
  }
  .con-request__hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .con-request__error {
    font-family: var(--font-body); font-size: var(--text-sm); color: #b00020;
    background: rgba(176,0,32,0.07); border: 1px solid rgba(176,0,32,0.2); border-radius: var(--radius-sm);
    padding: 10px 12px; margin: 0;
  }
  .con-request__success {
    display: flex; flex-direction: column; gap: var(--space-xs);
    padding: var(--space-lg); background: #fff; border: 1px solid rgba(0,0,0,0.08);
    border-radius: var(--radius-sm); box-shadow: 0 4px 18px rgb(0 0 0 / 0.05);
  }
  .con-request__success a { color: var(--color-cta); font-weight: 600; }
  /* The `hidden` attribute must beat the display:flex above. */
  .con-request__success[hidden] { display: none; }
</style>

<script>
  import { enhanceLeadForm } from '../../lib/leadForm';

  const form = document.querySelector('.con-request__form') as HTMLFormElement | null;
  if (form) {
    const nameHidden = form.querySelector('input[name="name"]') as HTMLInputElement;
    const first = form.querySelector('#con-first-name') as HTMLInputElement;
    const last = form.querySelector('#con-last-name') as HTMLInputElement;
    const syncName = () => { nameHidden.value = `${first.value} ${last.value}`.trim(); };
    first.addEventListener('input', syncName);
    last.addEventListener('input', syncName);
    // Runs before the enhancer's submit handler (added below), so the hidden
    // `name` is populated before the payload is read from the form.
    form.addEventListener('submit', syncName);
    enhanceLeadForm(form, {
      validate: (d) => (!d.message || !d.message.trim() ? 'Please tell us what you would like to work on.' : null),
    });
  }
</script>
