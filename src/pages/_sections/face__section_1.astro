---
import site from '@/lib/site';

import heroBg from '@/assets/images/facials-hero.jpg';
import reviewIcon1 from '@/assets/images/90411e0041df.png';
import reviewIcon2 from '@/assets/images/305afeda5f9a.png';
import reviewIcon3 from '@/assets/images/b95880091b44.png';
---

<section class="media-bg section s1-hero face-hero" style="--scrim-strength:0.60" data-pillar-hero>
  <img class="media-bg__img face-hero__bg" src={heroBg.src} alt="" aria-hidden="true"
       loading="eager" decoding="async" width="3000" height="1351" />
  <span class="media-bg__scrim media-bg__scrim--l"></span>
  <canvas class="pillar-hero__particles" data-pillar-hero-canvas aria-hidden="true"></canvas>

  <div class="media-bg__inner container on-media">
    <div class="face-hero__layout">
      <div class="face-hero__content">

        <h1 class="face-hero__eyebrow">
          Facial Treatments &amp; Medical Aesthetics in Millburn, NJ
        </h1>

        <h2 class="face-hero__heading">
          Leave with skin that looks brighter, feels smoother, and still feels like you.
        </h2>

        <p class="face-hero__body">
          Personalized facials, lasers, and medical aesthetics for clearer texture, brighter tone, and a treatment plan that fits your skin.
        </p>

        <div class="face-hero__ctas">
          <a
            href="/consultation"
            class="btn btn--primary btn--lg"
          >
            Book Today!
          </a>
        </div>

        <div class="face-hero__social-proof">
          <div class="face-hero__avatars">
            <img
              src={reviewIcon1.src}
              alt="Picture of a Client Who Reviewed Us"
              class="face-hero__avatar"
              loading="lazy"
              decoding="async"
              width="46"
              height="50"
            />
            <img
              src={reviewIcon2.src}
              alt="Picture of a Client Who Reviewed Us"
              class="face-hero__avatar"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
            <img
              src={reviewIcon3.src}
              alt="Picture of a Client Who Reviewed Us"
              class="face-hero__avatar"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
          </div>
          <div class="face-hero__stars-block">
            <p class="face-hero__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="face-hero__review-count">100+ 5 Star Reviews</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .face-hero {
    min-height: clamp(520px, 68vh, 660px);
    padding-block: 0;
    background: #1b1522;
  }

  .media-bg__inner.container {
    position: relative;
    z-index: 3;
    padding-block: clamp(58px, 8vw, 92px);
  }

  .face-hero__bg {
    object-position: 72% 50%;
    transform: scale(1.02);
  }

  .face-hero .media-bg__scrim--l {
    z-index: 1;
    background:
      linear-gradient(90deg, #1b1522 0%, rgb(27 21 34 / 0.96) 34%, rgb(27 21 34 / 0.68) 58%, rgb(27 21 34 / 0.2) 100%),
      linear-gradient(0deg, rgb(27 21 34 / 0.48) 0%, transparent 58%);
  }

  .pillar-hero__particles {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .face-hero__layout {
    display: block;
  }

  .face-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 14px;
    max-width: 640px;
  }

  .face-hero__eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.88rem, 1.2vw, 1rem);
    font-weight: var(--weight-bold);
    margin: 0;
    line-height: 1.35;
    color: var(--color-gold);
  }

  .face-hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.35vw, 4.15rem);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.04;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .face-hero__body {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.6;
    max-width: 620px;
    text-wrap: pretty;
  }

  .face-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: 10px;
  }

  .face-hero__social-proof {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    width: fit-content;
    margin-top: 8px;
    padding: 8px 16px 8px 10px;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.08);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .face-hero__avatars {
    display: flex;
    align-items: center;
  }

  .face-hero__avatar {
    display: block;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255, 255, 255, 0.86);
    margin-left: -8px;
  }

  .face-hero__avatar:first-child {
    margin-left: 0;
  }

  .face-hero__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }

  .face-hero__stars {
    color: var(--color-star);
    font-size: var(--text-sm);
    letter-spacing: 2px;
    margin: 0;
    line-height: 1;
  }

  .face-hero__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    margin: 0;
    line-height: 1.3;
  }

  @media (max-width: 1024px) {
    .face-hero {
      min-height: 560px;
    }
  }

  @media (max-width: 768px) {
    .face-hero {
      min-height: auto;
    }

    .face-hero .media-bg__scrim--l {
      background:
        linear-gradient(90deg, rgb(27 21 34 / 0.9) 0%, rgb(27 21 34 / 0.7) 100%),
        linear-gradient(0deg, rgb(27 21 34 / 0.42), transparent);
    }

    .face-hero__ctas {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
    }

    .face-hero__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .face-hero__social-proof {
      flex-wrap: wrap;
      border-radius: var(--radius-sm);
      width: 100%;
    }
  }
</style>

<script>
  (function () {
    const hero = document.querySelector('[data-pillar-hero]');
    if (!hero) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const canvas = hero.querySelector('[data-pillar-hero-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let w = 0, h = 0, dpr = 1, parts = [], raf = 0, running = false;
    function size() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = hero.clientWidth; h = hero.clientHeight;
      canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
      canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    function spawn(init) {
      return {
        x: Math.random() * w,
        y: init ? Math.random() * h : h + 14,
        r: 0.5 + Math.random() * 1.1,
        vy: 0.05 + Math.random() * 0.18,
        vx: (Math.random() - 0.5) * 0.12,
        a: 0.12 + Math.random() * 0.30,
        white: Math.random() < 0.32,
      };
    }
    function build() {
      const n = Math.max(12, Math.min(30, Math.round((w * h) / 54000)));
      parts = [];
      for (let i = 0; i < n; i++) parts.push(spawn(true));
    }
    function step() {
      ctx.clearRect(0, 0, w, h);
      for (const p of parts) {
        p.y -= p.vy; p.x += p.vx;
        if (p.y < -14) Object.assign(p, spawn(false));
        const rad = p.r * 7;
        const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, rad);
        const c = p.white ? '245,239,228' : '226,186,120';
        g.addColorStop(0, 'rgba(' + c + ',' + p.a + ')');
        g.addColorStop(0.5, 'rgba(' + c + ',' + (p.a * 0.35) + ')');
        g.addColorStop(1, 'rgba(' + c + ',0)');
        ctx.fillStyle = g;
        ctx.beginPath(); ctx.arc(p.x, p.y, rad, 0, 6.2832); ctx.fill();
      }
      raf = requestAnimationFrame(step);
    }
    function start() { if (!running) { running = true; raf = requestAnimationFrame(step); } }
    function stop() { running = false; cancelAnimationFrame(raf); }

    size(); build();
    let rt;
    window.addEventListener('resize', function () {
      clearTimeout(rt);
      rt = setTimeout(function () { size(); build(); }, 150);
    }, { passive: true });
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) { entry.isIntersecting ? start() : stop(); });
      }, { threshold: 0.01 }).observe(hero);
    } else {
      start();
    }
  })();
</script>
