---
import site from '@/lib/site';

import heroBg from '@/assets/images/651c7c197b52.png';
import reviewIcon1 from '@/assets/images/90411e0041df.png';
import reviewIcon2 from '@/assets/images/305afeda5f9a.png';
import reviewIcon3 from '@/assets/images/b95880091b44.png';
---

<section class="media-bg section s1-hero face-hero" style="--scrim-strength:0.60">
  <img class="media-bg__img media-bg__img--blur" src={heroBg.src} alt="" aria-hidden="true"
       loading="eager" decoding="async" width="1440" height="865" />
  <span class="media-bg__scrim media-bg__scrim--l"></span>

  <div class="media-bg__inner container on-media">
    <div class="face-hero__layout">
      <div class="face-hero__content">

        <h1 class="face-hero__heading">
          Facial Treatments &amp; Medical Aesthetics
        </h1>

        <h2 class="face-hero__subheading">
          Menon MediSpa Millburn
        </h2>

        <p class="face-hero__body">
          At Menon MediSpa in Millburn, NJ, our expert team offers a comprehensive range of medical-grade facial treatments tailored to your unique skin needs. From HydraFacials to laser treatments and medical aesthetics, we&rsquo;re dedicated to helping you achieve your best skin.
        </p>

        <div class="face-hero__ctas">
          <a
            href="/consultation"
            class="btn btn--primary btn--lg"
          >
            Book Today!
          </a>
        </div>

        <div class="face-hero__social-proof">
          <div class="face-hero__avatars">
            <img
              src={reviewIcon1.src}
              alt="Picture of a Client Who Reviewed Us"
              class="face-hero__avatar"
              loading="lazy"
              decoding="async"
              width="46"
              height="50"
            />
            <img
              src={reviewIcon2.src}
              alt="Picture of a Client Who Reviewed Us"
              class="face-hero__avatar"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
            <img
              src={reviewIcon3.src}
              alt="Picture of a Client Who Reviewed Us"
              class="face-hero__avatar"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
          </div>
          <div class="face-hero__stars-block">
            <p class="face-hero__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="face-hero__review-count">100+ 5 Star Reviews</p>
          </div>
        </div>

      </div>

      <div class="face-hero__visual" aria-hidden="true">
        <span class="face-hero__visual-line"></span>
      </div>
    </div>
  </div>
</section>

<style>
  .face-hero {
    min-height: clamp(520px, 68vh, 660px);
  }

  .media-bg__inner.container {
    padding-block: clamp(58px, 8vw, 92px);
  }

  .face-hero__layout {
    display: grid;
    grid-template-columns: minmax(0, 640px) minmax(220px, 1fr);
    align-items: center;
    gap: clamp(40px, 7vw, 112px);
  }

  .face-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 14px;
    max-width: 640px;
  }

  .face-hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.15rem, 4vw, 3.6rem);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.08;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .face-hero__subheading {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  .face-hero__body {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.6;
    max-width: 620px;
    text-wrap: pretty;
  }

  .face-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: 10px;
  }

  .face-hero__social-proof {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    width: fit-content;
    margin-top: 8px;
    padding: 8px 16px 8px 10px;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.08);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .face-hero__avatars {
    display: flex;
    align-items: center;
  }

  .face-hero__avatar {
    display: block;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255, 255, 255, 0.86);
    margin-left: -8px;
  }

  .face-hero__avatar:first-child {
    margin-left: 0;
  }

  .face-hero__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }

  .face-hero__stars {
    color: var(--color-star);
    font-size: var(--text-sm);
    letter-spacing: 2px;
    margin: 0;
    line-height: 1;
  }

  .face-hero__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    margin: 0;
    line-height: 1.3;
  }

  .face-hero__visual {
    justify-self: end;
    position: relative;
    width: min(34vw, 390px);
    min-height: 360px;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: var(--radius-sm);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.12), rgb(255 255 255 / 0.02)),
      radial-gradient(circle at 48% 32%, rgb(196 164 132 / 0.28), transparent 46%);
    box-shadow: 0 24px 70px rgb(0 0 0 / 0.24);
    overflow: hidden;
  }

  .face-hero__visual::before {
    content: "";
    position: absolute;
    inset: 18px;
    border: 1px solid rgb(255 255 255 / 0.18);
  }

  .face-hero__visual::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 46%;
    background: linear-gradient(0deg, rgb(27 21 34 / 0.58), transparent);
  }

  .face-hero__visual-line {
    position: absolute;
    left: 34px;
    right: 34px;
    bottom: 68px;
    height: 1px;
    background: rgb(255 255 255 / 0.42);
    z-index: 1;
  }

  @media (max-width: 1024px) {
    .face-hero {
      min-height: 560px;
    }

    .face-hero__layout {
      grid-template-columns: minmax(0, 1fr) 220px;
      gap: var(--space-lg);
    }

    .face-hero__visual {
      width: 220px;
      min-height: 300px;
    }
  }

  @media (max-width: 768px) {
    .face-hero {
      min-height: auto;
    }

    .face-hero__layout {
      display: block;
    }

    .face-hero__visual {
      display: none;
    }

    .face-hero__ctas {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
    }

    .face-hero__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .face-hero__social-proof {
      flex-wrap: wrap;
      border-radius: var(--radius-sm);
      width: 100%;
    }
  }
</style>
