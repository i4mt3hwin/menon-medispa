---
{/* BREAKDANCE: hand-authored from structure.json */}
import site from '@/lib/site';
---

<section class="section s5-process">
  <div class="container--narrow s5-process__inner">

    <h2 class="s5-process__heading">What To Expect During Your 60-Minute Microneedling Experience</h2>

    <div class="s5-process__steps">

      <div class="s5-process__step">
        <div class="s5-process__step-number" aria-hidden="true">1</div>
        <div class="s5-process__step-body">
          <h3 class="s5-process__step-title">Consultation &amp; Skin Assessment (10 minutes)</h3>
          <p class="s5-process__step-text">Your provider reviews your skin concerns and goals, and designs a personalized treatment plan.</p>
        </div>
      </div>

      <div class="s5-process__step">
        <div class="s5-process__step-number" aria-hidden="true">2</div>
        <div class="s5-process__step-body">
          <h3 class="s5-process__step-title">Numbing Cream Application (20 minutes)</h3>
          <p class="s5-process__step-text">A topical numbing cream is applied to ensure your comfort throughout the treatment.</p>
        </div>
      </div>

      <div class="s5-process__step">
        <div class="s5-process__step-number" aria-hidden="true">3</div>
        <div class="s5-process__step-body">
          <h3 class="s5-process__step-title">SkinPen Microneedling Treatment (20&ndash;30 minutes)</h3>
          <p class="s5-process__step-text">The SkinPen device creates thousands of micro-channels in a precise pattern tailored to your areas of concern.</p>
        </div>
      </div>

      <div class="s5-process__step">
        <div class="s5-process__step-number" aria-hidden="true">4</div>
        <div class="s5-process__step-body">
          <h3 class="s5-process__step-title">Growth Factor Serum Infusion (5 minutes)</h3>
          <p class="s5-process__step-text">A powerful growth factor serum is applied immediately after needling to penetrate deep into the micro-channels.</p>
        </div>
      </div>

      <div class="s5-process__step">
        <div class="s5-process__step-number" aria-hidden="true">5</div>
        <div class="s5-process__step-body">
          <h3 class="s5-process__step-title">Calming Serum &amp; Post-Treatment Care (5&ndash;10 minutes)</h3>
          <p class="s5-process__step-text">A calming serum is applied and you receive detailed aftercare instructions to maximize your results.</p>
        </div>
      </div>

    </div>

    <div class="s5-process__cta">
      <a
        href={site.calcomUrl}
        class="btn btn--primary btn--lg"
        target="_blank"
        rel="noopener noreferrer"
      >
        Book Your Session
      </a>
    </div>

  </div>
</section>

<style>
  .s5-process__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: center;
  }

  .s5-process__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    text-align: center;
    margin: 0;
    line-height: 1.3;
  }

  .s5-process__steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    width: 100%;
  }

  .s5-process__step {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .s5-process__step-number {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--color-cta);
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .s5-process__step-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: 6px;
  }

  .s5-process__step-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s5-process__step-text {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .s5-process__cta {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 600px) {
    .s5-process__cta .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
