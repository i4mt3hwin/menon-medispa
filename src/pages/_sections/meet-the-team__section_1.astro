---
import heroBg from '@/assets/images/fc22050ddcb3.webp';
---

<section class="media-bg section s1-hero mtt-s1-hero" style="--scrim-strength:0.55">
  <img
    class="media-bg__img"
    src={heroBg.src}
    alt="download copy.webp"
    loading="eager"
    decoding="async"
    width="1440"
    height="287"
  />
  <span class="media-bg__scrim media-bg__scrim--b"></span>

  <div class="media-bg__inner container on-media mtt-s1-hero__inner">
    <h1 class="mtt-s1-hero__heading">Meet the Menon Medispa Millburn Team</h1>
  </div>
</section>

<style>
  .mtt-s1-hero {
    min-height: 287px;
  }

  .mtt-s1-hero__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--section-py);
    text-align: center;
  }

  .mtt-s1-hero__heading {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.2;
  }

  @media (max-width: 1024px) {
    .mtt-s1-hero {
      min-height: 220px;
    }
  }

  @media (max-width: 768px) {
    .mtt-s1-hero {
      min-height: auto;
    }

    .mtt-s1-hero__inner {
      padding-block: var(--space-xl);
    }
  }

  @media (max-width: 600px) {
    .mtt-s1-hero__heading {
      font-size: var(--text-h2);
    }
  }
</style>
