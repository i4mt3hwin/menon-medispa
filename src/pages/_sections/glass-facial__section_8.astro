---
import site from '@/lib/site';

import staffImg from '@/assets/images/b1a819f35921.webp';
---

<section class="section section--dark s8-cta">
  <div class="container">
    <div class="s8-cta__layout">

      <div class="s8-cta__text">

        <h2 class="s8-cta__heading">
          Have Questions? Let&#39;s Create Your Perfect Skin Plan.
        </h2>

        <p class="s8-cta__subtitle">
          Menon Medispa Millburn NJ
        </p>

        <p class="s8-cta__body">
          Our expert aestheticians are here to guide you. Get in touch with us today to ask any questions or to arrange a complimentary consultation. We&#39;ll help you discover if the Glass Facial is the right choice for you.
        </p>

        <div class="s8-cta__actions">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Schedule Free Consultation
          </a>
        </div>

      </div>

      <div class="s8-cta__img-col">
        <img
          src={staffImg.src}
          alt="Menon Medispa staff ready to help with your Glass Facial in Millburn NJ"
          class="s8-cta__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="489"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s8-cta__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .s8-cta__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .s8-cta__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .s8-cta__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .s8-cta__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .s8-cta__actions {
    margin-top: var(--space-xs);
  }

  .s8-cta__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .s8-cta__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .s8-cta__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .s8-cta__layout {
      flex-direction: column;
    }

    .s8-cta__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .s8-cta__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
