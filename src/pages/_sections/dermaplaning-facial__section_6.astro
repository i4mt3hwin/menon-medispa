---
import imgBg from '@/assets/images/30cfb9e87c60.webp'
import imgRating from '@/assets/images/5be44787b3a9.webp'
---

<section class="media-bg section s6-testimonial" style="--scrim-strength:0.58">
  <img class="media-bg__img media-bg__img--blur" src={imgBg.src} alt="" aria-hidden="true" loading="lazy" decoding="async" width="1440" height="585" />
  <span class="media-bg__scrim media-bg__scrim--brand"></span>

  <div class="media-bg__inner container on-media">
    <div class="s6-testimonial__inner">

      <h3 class="s6-testimonial__label">What Our Clients Say</h3>

      <blockquote class="s6-testimonial__quote">
        <p class="s6-testimonial__quote-text">
          "They have the best hydrafacials. Let me tell you, I've had facials before, but this was on another level. My skin felt amazing after and I've been coming back ever since."
        </p>
        <footer class="s6-testimonial__footer">
          <cite class="s6-testimonial__cite">, Rathi Vijay, Millburn Resident</cite>
        </footer>
      </blockquote>

      <div class="s6-testimonial__stars">
        <img
          src={imgRating.src}
          alt="Google 5-star rating"
          class="s6-testimonial__stars-img"
          loading="lazy"
          width="120"
          height="30"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s6-testimonial__inner {
    max-width: var(--container-narrow);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .s6-testimonial__label {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  .s6-testimonial__quote {
    margin: 0;
    padding: 0;
  }

  .s6-testimonial__quote-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    margin: 0 0 var(--space-sm);
    line-height: 1.7;
    font-style: italic;
  }

  .s6-testimonial__footer {
    font-style: normal;
  }

  .s6-testimonial__cite {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    font-style: normal;
  }

  .s6-testimonial__stars {
    display: flex;
    justify-content: center;
  }

  .s6-testimonial__stars-img {
    display: block;
    height: 30px;
    width: auto;
  }
</style>
