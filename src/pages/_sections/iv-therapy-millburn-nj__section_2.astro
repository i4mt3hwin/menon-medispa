---
import img1 from "@/assets/images/9ebaca3843d3.jpg";
import img2 from "@/assets/images/6c461885a28e.jpg";
import img3 from "@/assets/images/823792ea5ead.jpg";
import img4 from "@/assets/images/cd675890fe0d.jpg";
import img5 from "@/assets/images/2e5d1e68225a.jpg";
---

<!-- Section 2: Customer Gallery, Hear From Our Customers -->
<section class="section section--tint s2-gallery">
  <div class="container">
    <h5 class="s2-gallery__heading eyebrow">Hear From Our Customers!</h5>
    <div class="s2-gallery__grid">
      <img
        src={img1.src}
        alt="Customer photo 1"
        class="s2-gallery__img"
        loading="lazy"
        decoding="async"
        width="400"
        height="300"
      />
      <img
        src={img2.src}
        alt="Customer photo 2"
        class="s2-gallery__img"
        loading="lazy"
        decoding="async"
        width="400"
        height="300"
      />
      <img
        src={img3.src}
        alt="Customer photo 3"
        class="s2-gallery__img"
        loading="lazy"
        decoding="async"
        width="400"
        height="300"
      />
      <img
        src={img4.src}
        alt="Customer photo 4"
        class="s2-gallery__img"
        loading="lazy"
        decoding="async"
        width="400"
        height="300"
      />
      <img
        src={img5.src}
        alt="Customer photo 5"
        class="s2-gallery__img"
        loading="lazy"
        decoding="async"
        width="400"
        height="300"
      />
    </div>
  </div>
</section>

<style>
  .s2-gallery__heading {
    text-align: center;
    margin: 0 0 var(--space-lg);
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    letter-spacing: normal;
    text-transform: none;
  }

  .s2-gallery__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-sm);
  }

  .s2-gallery__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
  }

  @media (max-width: 1024px) {
    .s2-gallery__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .s2-gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .s2-gallery__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }
  }
</style>
