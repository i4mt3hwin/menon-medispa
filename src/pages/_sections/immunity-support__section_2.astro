<section class="section section--tight section--tint is2-trust">
  <div class="container">
    <ul class="is2-trust__bar">
      <li class="is2-trust__item">100% Nutrient Absorption</li>
      <li class="is2-trust__divider" aria-hidden="true"></li>
      <li class="is2-trust__item">Strengthen Natural Defenses</li>
      <li class="is2-trust__divider" aria-hidden="true"></li>
      <li class="is2-trust__item">Faster Recovery from Illness</li>
    </ul>
  </div>
</section>

<style>
  .is2-trust__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .is2-trust__item {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .is2-trust__divider {
    width: 1px;
    height: 24px;
    background: rgba(0, 0, 0, 0.18);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .is2-trust__bar {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .is2-trust__divider {
      display: none;
    }
  }
</style>
