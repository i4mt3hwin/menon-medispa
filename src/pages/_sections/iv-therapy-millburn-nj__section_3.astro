<!-- Section 3: Find Your Perfect IV Drip, Services Grid -->
<section class="section s3-iv-categories">
  <div class="container">

    <h2 class="s3-iv-categories__heading">Find Your Perfect IV Drip</h2>

    <p class="s3-iv-categories__intro">
      Whether you're seeking to boost your immunity, enhance your energy, or support a specific health
      goal, we have a targeted IV therapy for you. Explore our curated categories below to discover
      how our advanced formulas can help you feel your best.
    </p>

    <div class="s3-iv-categories__grid">

      <div class="s3-iv-categories__card">
        <div class="s3-iv-categories__card-body">
          <h3 class="s3-iv-categories__card-title">Immune Support</h3>
          <p class="s3-iv-categories__card-desc">
            Strengthen your body's natural defenses with our immunity-boosting IV drips, formulated
            with powerful vitamins and antioxidants.
          </p>
          <a href="/immunity-support" class="btn btn--ghost">Explore Immunity Drips</a>
        </div>
      </div>

      <div class="s3-iv-categories__card">
        <div class="s3-iv-categories__card-body">
          <h3 class="s3-iv-categories__card-title">Energy &amp; Performance</h3>
          <p class="s3-iv-categories__card-desc">
            Overcome daily fatigue, brain fog, and low performance with our energy-focused IV
            formulations.
          </p>
          <a href="/energy-performance" class="btn btn--ghost">Explore Energy Drips</a>
        </div>
      </div>

      <div class="s3-iv-categories__card">
        <div class="s3-iv-categories__card-body">
          <h3 class="s3-iv-categories__card-title">Anti-Aging &amp; Beauty</h3>
          <p class="s3-iv-categories__card-desc">
            Unlock a radiant glow from within with our beauty-focused IV drips packed with
            skin-nourishing nutrients.
          </p>
          <a href="/anti-aging-beauty" class="btn btn--ghost">Explore Beauty Drips</a>
        </div>
      </div>

      <div class="s3-iv-categories__card">
        <div class="s3-iv-categories__card-body">
          <h3 class="s3-iv-categories__card-title">Recovery &amp; Detox</h3>
          <p class="s3-iv-categories__card-desc">
            Your fastest way to reset, replenish, and restore your body after illness, travel, or
            strenuous activity.
          </p>
          <a href="/recovery-detox" class="btn btn--ghost">Explore Recovery Drips</a>
        </div>
      </div>

      <div class="s3-iv-categories__card">
        <div class="s3-iv-categories__card-body">
          <h3 class="s3-iv-categories__card-title">NAD+ Therapy</h3>
          <p class="s3-iv-categories__card-desc">
            The cutting edge of wellness, NAD+ IV therapy supports cellular repair, energy production,
            and anti-aging at the molecular level.
          </p>
          <a href="/nad-iv-drip-therapy" class="btn btn--ghost">Explore NAD+ Drips</a>
        </div>
      </div>

      <div class="s3-iv-categories__card">
        <div class="s3-iv-categories__card-body">
          <h3 class="s3-iv-categories__card-title">Targeted Health Solutions</h3>
          <p class="s3-iv-categories__card-desc">
            Proactive nutritional support tailored to specific health concerns including gut health,
            heart health, and more.
          </p>
          <a href="/targeted-health-solutions-iv" class="btn btn--ghost">Explore Health Solutions</a>
        </div>
      </div>

      <div class="s3-iv-categories__card">
        <div class="s3-iv-categories__card-body">
          <h3 class="s3-iv-categories__card-title">The Myers' Cocktail</h3>
          <p class="s3-iv-categories__card-desc">
            The original IV vitamin drip, a proven blend of essential vitamins and minerals trusted by
            patients for decades.
          </p>
          <a href="/myers-cocktail-iv-therapy" class="btn btn--ghost">Learn About The Myers' Cocktail</a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .s3-iv-categories__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    line-height: 1.3;
    text-align: center;
  }

  .s3-iv-categories__intro {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.6;
    text-align: center;
    max-width: 680px;
    margin-inline: auto;
    margin-bottom: var(--space-lg);
  }

  .s3-iv-categories__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .s3-iv-categories__card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-bg);
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.05);
  }

  .s3-iv-categories__card-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .s3-iv-categories__card-title {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s3-iv-categories__card-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.5;
    flex: 1;
  }

  .s3-iv-categories__card .btn {
    align-self: flex-start;
    margin-top: var(--space-xs);
  }

  @media (max-width: 1024px) {
    .s3-iv-categories__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .s3-iv-categories__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }
  }
</style>
