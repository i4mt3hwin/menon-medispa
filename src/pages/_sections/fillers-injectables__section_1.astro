---
import site from '@/lib/site';
import heroBg from '@/assets/images/651c7c197b52.webp';
import heroIcon1 from '@/assets/images/90411e0041df.webp';
import heroIcon2 from '@/assets/images/305afeda5f9a.webp';
import heroIcon3 from '@/assets/images/b95880091b44.webp';
import heroProduct from '@/assets/images/db8d4e94db1e.jpg';
---

<section class="media-bg section s1-hero fi-s1-hero" style="--scrim-strength:0.60">
  <img class="media-bg__img media-bg__img--blur" src={heroBg.src} alt="" aria-hidden="true"
       loading="eager" decoding="async" width="1440" height="543" />
  <span class="media-bg__scrim media-bg__scrim--l"></span>

  <div class="media-bg__inner container on-media">
    <div class="fi-s1__layout">

      <div class="fi-s1__text">

        <h1 class="fi-s1__seo-heading">
          Fillers &amp; Injectables in Millburn NJ
        </h1>

        <h2 class="fi-s1__heading">
          Transform Your Appearance with Premium Fillers &amp; Injectables in Millburn NJ
        </h2>

        <p class="fi-s1__body">
          Our board-certified team offers a full range of injectable treatments including Botox and Juv&eacute;derm fillers to help you look naturally refreshed. Customized treatment plans designed for your unique facial anatomy.
        </p>

        <div class="fi-s1__ctas">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
          >
            Our Fillers &amp; Injectables
          </a>
        </div>

        <div class="fi-s1__social-proof">
          <div class="fi-s1__social-icons">
            <img
              src={heroIcon1.src}
              alt="Review platform"
              class="fi-s1__social-icon"
              loading="lazy"
              decoding="async"
              width="46"
              height="50"
            />
            <img
              src={heroIcon2.src}
              alt="Review platform"
              class="fi-s1__social-icon"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
            <img
              src={heroIcon3.src}
              alt="Review platform"
              class="fi-s1__social-icon"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
          </div>
          <div class="fi-s1__stars-block">
            <p class="fi-s1__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="fi-s1__review-count">100+ 5 Star Reviews</p>
          </div>
        </div>

      </div>

      <div class="fi-s1__img-col">
        <img
          src={heroProduct.src}
          alt="Premium fillers and injectables at Menon Medispa Millburn NJ"
          class="fi-s1__img"
          loading="eager"
          decoding="async"
          width="450"
          height="428"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .fi-s1-hero {
    min-height: 543px;
  }

  .media-bg__inner.container {
    padding-block: var(--section-py);
  }

  .fi-s1__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .fi-s1__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 620px;
  }

  .fi-s1__seo-heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    margin: 0;
    opacity: 0.7;
    line-height: 1.4;
  }

  .fi-s1__heading {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.2;
  }

  .fi-s1__body {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.6;
  }

  .fi-s1__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .fi-s1__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .fi-s1__social-icons {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .fi-s1__social-icon {
    display: block;
    object-fit: contain;
    filter: brightness(1.15);
  }

  .fi-s1__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .fi-s1__stars {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1;
  }

  .fi-s1__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    margin: 0;
    line-height: 1.3;
  }

  .fi-s1__img-col {
    flex-shrink: 0;
    width: 450px;
  }

  .fi-s1__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.35);
  }

  @media (max-width: 1024px) {
    .fi-s1__img-col {
      width: 360px;
    }
  }

  @media (max-width: 768px) {
    .fi-s1-hero {
      min-height: auto;
    }

    .fi-s1__layout {
      flex-direction: column-reverse;
    }

    .fi-s1__text {
      max-width: 100%;
    }

    .fi-s1__img-col {
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }

    .fi-s1__ctas {
      flex-direction: column;
    }

    .fi-s1__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .fi-s1__social-proof {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
