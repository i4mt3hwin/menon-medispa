---
import site from '@/lib/site'
import imgStaff from '@/assets/images/b1a819f35921.webp'
---

<section class="section section--dark ep9-cta">
  <div class="container">
    <div class="ep9-cta__layout">

      <div class="ep9-cta__text">
        <h2 class="ep9-cta__heading">Ready to Operate at 100%?</h2>
        <p class="ep9-cta__subtitle"><strong>Menon Medispa Millburn NJ</strong></p>
        <p class="ep9-cta__body">Stop settling for tired afternoons and slow recovery. It's time to discover what your body is truly capable of with our advanced IV therapy. Schedule your complimentary consultation today and take the first step toward peak performance.</p>
        <div class="ep9-cta__actions">
          <a href={site.calcomUrl} class="btn btn--primary btn--lg">Schedule Free Consultation</a>
        </div>
      </div>

      <div class="ep9-cta__img-col">
        <img
          src={imgStaff.src}
          alt="Menon Office Staff"
          class="ep9-cta__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="450"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .ep9-cta__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .ep9-cta__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .ep9-cta__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .ep9-cta__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ep9-cta__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .ep9-cta__actions {
    margin-top: var(--space-xs);
  }

  .ep9-cta__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .ep9-cta__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .ep9-cta__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .ep9-cta__layout {
      flex-direction: column;
    }

    .ep9-cta__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .ep9-cta__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
