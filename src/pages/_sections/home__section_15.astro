---
/**
 * home__section_15.astro, "June SALES" lightbox dialog
 * _is_lightbox: true  |  _trigger_text: "Flash Sale"
 * Rendered as an accessible <dialog> element, initially hidden.
 */
import SectionHeading from '@/components/SectionHeading.astro';
import ServicesGrid from '@/components/ServicesGrid.astro';
import Button from '@/components/Button.astro';

import brotoxImg from '@/assets/images/56a3e3ac1335.jpg';
import hydrafacialImg from '@/assets/images/86072f9cbd9c.jpg';
import ivImg from '@/assets/images/dd355e57f3dd.jpg';
---

<!-- June SALES dialog lightbox -->
<dialog
  id="june-sales-dialog"
  class="june-sales-dialog"
  aria-label="June SALES"
>
  <div class="june-sales-dialog__inner">

    <button
      class="june-sales-dialog__close"
      aria-label="Close"
      onclick="document.getElementById('june-sales-dialog').close()"
    >
      &#x2715;
    </button>

    <SectionHeading
      text="June SALES"
      tag="h2"
      align="center"
      font="display"
    />

    <div class="june-sales-dialog__grid">

      {/* Card 1, BRO-tox Fathers Day Special */}
      <div class="june-sales-card">
        <div class="june-sales-card__img-wrap">
          <img
            src={brotoxImg.src}
            alt="BRO-tox Fathers Day Special"
            class="june-sales-card__img"
            loading="lazy"
            decoding="async"
            width="300"
          />
        </div>
        <div class="june-sales-card__body">
          <h3 class="june-sales-card__title">BRO-tox Fathers Day Special</h3>
          <ul class="june-sales-card__features">
            <li>Botox $12 Per Unit</li>
            <li>Smooths forehead frown lines &amp; crow&#39;s feet</li>
            <li>Personalized Treatment Plan with Dr. Menon</li>
          </ul>
        </div>
      </div>

      {/* Card 2, Summer Glow HydraFacial */}
      <div class="june-sales-card">
        <div class="june-sales-card__img-wrap">
          <img
            src={hydrafacialImg.src}
            alt="Summer Glow HydraFacial"
            class="june-sales-card__img"
            loading="lazy"
            decoding="async"
            width="300"
          />
        </div>
        <div class="june-sales-card__body">
          <h3 class="june-sales-card__title">Summer Glow HydraFacial</h3>
          <ul class="june-sales-card__features">
            <li>Vitamin C Booster +</li>
            <li>Discount Dermaplaning $25</li>
            <li>($285 Value for $225)</li>
          </ul>
        </div>
      </div>

      {/* Card 3, Custom Hydrating IV */}
      <div class="june-sales-card">
        <div class="june-sales-card__img-wrap">
          <img
            src={ivImg.src}
            alt="Custom Hydrating IV"
            class="june-sales-card__img"
            loading="lazy"
            decoding="async"
            width="300"
          />
        </div>
        <div class="june-sales-card__body">
          <h3 class="june-sales-card__title">Custom Hydrating IV</h3>
          <ul class="june-sales-card__features">
            <li>$99 Special Price</li>
            <li>Includes any two vitamins</li>
            <li>Hydrate recharge glow</li>
          </ul>
        </div>
      </div>

    </div>

    <div class="june-sales-dialog__cta">
      <Button
        text="Explore all sales"
        href="/sale"
        variant="primary"
      />
    </div>

  </div>
</dialog>

<style>
  /* Dialog backdrop + positioning */
  .june-sales-dialog {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(92vw, 960px);
    max-height: 90vh;
    overflow-y: auto;
    border: none;
    border-radius: var(--radius-md);
    padding: 0;
    background: var(--color-surface);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.24);
  }

  .june-sales-dialog::backdrop {
    background: rgba(0, 0, 0, 0.55);
  }

  .june-sales-dialog__inner {
    position: relative;
    padding: var(--space-lg) var(--space-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  /* Close button */
  .june-sales-dialog__close {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    background: transparent;
    border: none;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    color: var(--color-text);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
  }

  .june-sales-dialog__close:hover {
    background: rgba(0, 0, 0, 0.06);
  }

  /* 3-column card grid */
  .june-sales-dialog__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    width: 100%;
  }

  /* Individual sale card */
  .june-sales-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.10);
    background: var(--color-surface);
  }

  .june-sales-card__img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .june-sales-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .june-sales-card__body {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .june-sales-card__title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
  }

  .june-sales-card__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .june-sales-card__features li {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
  }

  .june-sales-card__features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-cta);
    font-size: 0.85em;
  }

  .june-sales-dialog__cta {
    margin-top: var(--space-xs);
  }

  /* Override primary btn color to --color-accent per Wix source */
  .june-sales-dialog__cta :global(.btn--primary) {
    background-color: var(--color-accent);
  }

  @media (max-width: 980px) {
    .june-sales-dialog {
      width: 95vw;
      max-height: 92vh;
    }

    .june-sales-dialog__inner {
      padding: var(--space-md) var(--space-sm);
    }

    .june-sales-dialog__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
