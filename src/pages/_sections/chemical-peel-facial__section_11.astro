---
import promo1Img from '@/assets/images/dd355e57f3dd.jpg';
import promo2Img from '@/assets/images/86072f9cbd9c.jpg';
import promo3Img from '@/assets/images/56a3e3ac1335.jpg';
---

<section class="section section--tint cpf-s11">
  <div class="container">

    <h2 class="cpf-s11__heading">June SALES</h2>

    <div class="cpf-s11__grid">

      <div class="cpf-s11__card">
        <div class="cpf-s11__card-img-wrap">
          <img
            src={promo1Img.src}
            alt="BRO-tox Fathers Day Special at Menon Medispa"
            class="cpf-s11__card-img"
            loading="lazy"
            decoding="async"
            width="360"
            height="240"
          />
        </div>
        <div class="cpf-s11__card-body">
          <h3 class="cpf-s11__card-title">BRO-tox Fathers Day Special</h3>
          <ul class="cpf-s11__card-bullets">
            <li>Botox $12 Per Unit</li>
            <li>Smooths forehead, frown lines &amp; crow's feet</li>
            <li>Personalized Treatment Plan with Dr. Menon</li>
          </ul>
        </div>
      </div>

      <div class="cpf-s11__card">
        <div class="cpf-s11__card-img-wrap">
          <img
            src={promo2Img.src}
            alt="Summer Glow HydraFacial promotion at Menon Medispa"
            class="cpf-s11__card-img"
            loading="lazy"
            decoding="async"
            width="360"
            height="240"
          />
        </div>
        <div class="cpf-s11__card-body">
          <h3 class="cpf-s11__card-title">Summer Glow HydraFacial</h3>
          <ul class="cpf-s11__card-bullets">
            <li>Vitamin C Booster +</li>
            <li>Discount Dermaplaning $25</li>
            <li>($285 Value for $225)</li>
          </ul>
        </div>
      </div>

      <div class="cpf-s11__card">
        <div class="cpf-s11__card-img-wrap">
          <img
            src={promo3Img.src}
            alt="Custom Hydrating IV promotion at Menon Medispa"
            class="cpf-s11__card-img"
            loading="lazy"
            decoding="async"
            width="360"
            height="240"
          />
        </div>
        <div class="cpf-s11__card-body">
          <h3 class="cpf-s11__card-title">Custom Hydrating IV</h3>
          <ul class="cpf-s11__card-bullets">
            <li>$99 Special Price</li>
            <li>Includes any two vitamins</li>
            <li>Hydrate, recharge, glow</li>
          </ul>
        </div>
      </div>

    </div>

    <div class="cpf-s11__cta">
      <a href="/sale" class="btn btn--primary btn--lg">Explore all sales</a>
    </div>

  </div>
</section>

<style>
  .cpf-s11__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
    text-align: center;
  }

  .cpf-s11__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    width: 100%;
  }

  .cpf-s11__card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-bg);
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.05);
  }

  .cpf-s11__card-img-wrap {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .cpf-s11__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .cpf-s11__card:hover .cpf-s11__card-img {
    transform: scale(1.04);
  }

  .cpf-s11__card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-sm);
    flex: 1;
  }

  .cpf-s11__card-title {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .cpf-s11__card-bullets {
    list-style: disc;
    margin: 0;
    padding: 0 0 0 1.2em;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cpf-s11__card-bullets li {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .cpf-s11__cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 900px) {
    .cpf-s11__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .cpf-s11__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }

    .cpf-s11__cta .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
