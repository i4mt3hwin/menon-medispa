---
---

<!-- Section 10: Flash Sale lightbox → static promotional banner -->
<section class="section s10-promos" aria-label="June sales promotions">
  <div class="container container--narrow">

    <h2 class="s10-promos__heading">June SALES</h2>

    <ul class="s10-promos__list" role="list">
      <li class="s10-promos__item">
        <span class="s10-promos__name">BRO-tox</span>
      </li>
      <li class="s10-promos__item">
        <span class="s10-promos__name">Summer Glow HydraFacial</span>
      </li>
      <li class="s10-promos__item">
        <span class="s10-promos__name">Custom Hydrating IV</span>
      </li>
    </ul>

    <div class="s10-promos__cta-wrap">
      <a href="/sale" class="btn btn--secondary btn--lg s10-promos__btn">
        Explore all sales
      </a>
    </div>

  </div>
</section>

<style>
  .s10-promos {
    background-color: var(--color-cta);
    text-align: center;
  }

  .s10-promos__heading {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0 0 var(--space-md);
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .s10-promos__list {
    list-style: none;
    margin: 0 0 var(--space-md);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: center;
  }

  .s10-promos__item {
    display: flex;
    justify-content: center;
  }

  .s10-promos__name {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1.4;
  }

  .s10-promos__cta-wrap {
    display: flex;
    justify-content: center;
  }

  /* White-surface button on sand/CTA background for contrast */
  .s10-promos__btn {
    background-color: #fff;
    border-color: #fff;
  }

  .s10-promos__btn:hover {
    background-color: rgba(255, 255, 255, 0.88);
    border-color: rgba(255, 255, 255, 0.88);
  }

  @media (max-width: 768px) {
    .s10-promos__heading {
      font-size: var(--text-h2);
    }

    .s10-promos__name {
      font-size: var(--text-base);
    }
  }
</style>
