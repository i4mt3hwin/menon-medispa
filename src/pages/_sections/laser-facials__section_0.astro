---
import { site } from "@/lib/site";
import heroBg from "@/assets/images/651c7c197b52.webp";
import laserPhoto from "@/assets/images/3be5824bfbc0.jpg";
import avatar1 from "@/assets/images/90411e0041df.webp";
import avatar2 from "@/assets/images/305afeda5f9a.webp";
import avatar3 from "@/assets/images/b95880091b44.webp";
---

<!-- Section 0: Hero, Clearlift /DYE-VL Laser Facial -->
<section class="media-bg section s1-hero" style="--scrim-strength:0.60">
  <img class="media-bg__img media-bg__img--blur" src={heroBg.src} alt="" aria-hidden="true"
       loading="eager" decoding="async" width="1440" height="596" />
  <span class="media-bg__scrim media-bg__scrim--l"></span>

  <div class="media-bg__inner container on-media">
    <div class="s1-hero__layout">

      <div class="s1-hero__text">
        <h1 class="s1-hero__heading">Clearlift /DYE-VL Laser Facial</h1>

        <p class="s1-hero__body">
          At Menon Medispa in Millburn, NJ, we offer ClearLift and DYE-VL laser facials, advanced,
          non-invasive treatments that tighten skin, reduce pigmentation, and restore a youthful
          appearance with zero downtime.
        </p>

        <div class="s1-hero__ctas">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Schedule Clearlift Today
          </a>
          <a
            href="tel:(973) 494-8431"
            class="btn btn--secondary btn--on-dark btn--lg"
          >
            Call For Free Consultation
          </a>
        </div>

        <div class="s1-hero__social-proof">
          <div class="s1-hero__social-icons">
            <img
              src={avatar1.src}
              alt="Reviewer"
              class="s1-hero__social-icon"
              loading="lazy"
              decoding="async"
              width="40"
              height="40"
            />
            <img
              src={avatar2.src}
              alt="Reviewer"
              class="s1-hero__social-icon"
              loading="lazy"
              decoding="async"
              width="40"
              height="40"
            />
            <img
              src={avatar3.src}
              alt="Reviewer"
              class="s1-hero__social-icon"
              loading="lazy"
              decoding="async"
              width="40"
              height="40"
            />
          </div>
          <div class="s1-hero__stars-block">
            <p class="s1-hero__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="s1-hero__review-count">
              <a href="https://g.co/kgs/sfVLqpA" target="_blank" rel="noopener noreferrer">
                100+ 5 Star Reviews
              </a>
            </p>
          </div>
        </div>
      </div>

      <div class="s1-hero__img-col">
        <img
          src={laserPhoto.src}
          alt="Laser facial treatment at Menon Medispa Millburn NJ"
          class="s1-hero__img"
          loading="eager"
          decoding="async"
          width="403"
          height="403"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s1-hero {
    min-height: 596px;
  }

  .media-bg__inner.container {
    padding-block: var(--section-py);
  }

  .s1-hero__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .s1-hero__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 620px;
  }

  .s1-hero__heading {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.2;
  }

  .s1-hero__body {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.6;
  }

  .s1-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .s1-hero__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .s1-hero__social-icons {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .s1-hero__social-icon {
    display: block;
    border-radius: 50%;
    object-fit: cover;
    filter: brightness(1.15);
  }

  .s1-hero__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .s1-hero__stars {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1;
  }

  .s1-hero__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    margin: 0;
    line-height: 1.3;
  }

  .s1-hero__review-count a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .s1-hero__img-col {
    flex-shrink: 0;
    width: 403px;
  }

  .s1-hero__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.35);
  }

  @media (max-width: 1024px) {
    .s1-hero__img-col {
      width: 320px;
    }
  }

  @media (max-width: 768px) {
    .s1-hero {
      min-height: auto;
    }

    .s1-hero__layout {
      flex-direction: column-reverse;
    }

    .s1-hero__text {
      max-width: 100%;
    }

    .s1-hero__img-col {
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }

    .s1-hero__ctas {
      flex-direction: column;
    }

    .s1-hero__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .s1-hero__social-proof {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
