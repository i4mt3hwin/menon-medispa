---
---

<section class="section section--tint s6-faq">
  <div class="container--narrow">

    <h2 class="s6-faq__heading">Frequently asked questions</h2>

    <div class="s6-faq__list">

      <details class="s6-faq__item">
        <summary class="s6-faq__question">How painful are Juvéderm injections?</summary>
        <div class="s6-faq__answer"></div>
      </details>

      <details class="s6-faq__item">
        <summary class="s6-faq__question">How long do Juvéderm results last and when will I see them?</summary>
        <div class="s6-faq__answer"></div>
      </details>

      <details class="s6-faq__item">
        <summary class="s6-faq__question">What's the downtime and what side effects should I expect?</summary>
        <div class="s6-faq__answer"></div>
      </details>

      <details class="s6-faq__item">
        <summary class="s6-faq__question">Who shouldn't get Juvéderm injections?</summary>
        <div class="s6-faq__answer"></div>
      </details>

      <details class="s6-faq__item">
        <summary class="s6-faq__question">How much does Juvéderm cost and how many syringes will I need?</summary>
        <div class="s6-faq__answer"></div>
      </details>

    </div>

  </div>
</section>

<style>
  .s6-faq .container--narrow {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .s6-faq__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
  }

  .s6-faq__list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .s6-faq__item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .s6-faq__item:first-child {
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .s6-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) 0;
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    line-height: 1.4;
    gap: var(--space-sm);
  }

  .s6-faq__question::-webkit-details-marker {
    display: none;
  }

  .s6-faq__question::after {
    content: '+';
    font-size: var(--text-lg);
    font-weight: var(--weight-regular);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .s6-faq__item[open] .s6-faq__question::after {
    content: '−';
  }

  .s6-faq__answer {
    padding-bottom: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
  }
</style>
