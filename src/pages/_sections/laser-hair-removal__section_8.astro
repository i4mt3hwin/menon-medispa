      bookHref: `/request-appointment?service=${encodeURIComponent('Laser Hair Removal')}`,
      bookLabel: `Choose your area & book`,
    },
  ]}
/>

<PackageTable slug="laser-hair-removal" heading="Laser Hair Removal Pricing" />
