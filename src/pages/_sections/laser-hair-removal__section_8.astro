---
import ServiceBookingCta from '@/components/ServiceBookingCta.astro';
import PackageTable from '@/components/PackageTable.astro';
import packageImg from '@/assets/images/c28a6e6b3030.jpg';
---
<ServiceBookingCta
  heading={`Laser Hair Removal Packages`}
  cards={[
    {
      image: packageImg,
      imageAlt: `6 Laser Hair Removal Treatment Package at Menon Medispa`,
      title: `6-Session Treatment Package`,
      tagline: `Choose your area below — Small, Medium, Large or Extra Large. Packages are a series of 6 sessions, 4-6 weeks apart.`,
