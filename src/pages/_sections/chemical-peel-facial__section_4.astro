---
import sectionBg from '@/assets/images/30cfb9e87c60.webp';
import googleRatingImg from '@/assets/images/5be44787b3a9.webp';
---

<section class="media-bg section cpf-s4-testimonial" style="--scrim-strength:0.58">
  <img class="media-bg__img media-bg__img--blur" src={sectionBg.src} alt="" aria-hidden="true"
       loading="lazy" decoding="async" width="1440" height="585" />
  <span class="media-bg__scrim media-bg__scrim--brand"></span>

  <div class="media-bg__inner container on-media">
    <div class="cpf-s4__inner">

      <h3 class="cpf-s4__heading">What Our Clients Say</h3>

      <blockquote class="cpf-s4__quote">
        <p class="cpf-s4__quote-text">They have the best hydrafacials. Let me tell you, I've had facials before, but this was on another level. My skin felt like it had been reborn! The process was gentle yet thorough, and I could literally see the gunk being extracted (which, yes, was oddly satisfying!).</p>
        <footer class="cpf-s4__quote-footer">
          <cite class="cpf-s4__quote-author">Rathi Vijay</cite>
          <span class="cpf-s4__quote-location">Millburn Resident</span>
        </footer>
      </blockquote>

      <div class="cpf-s4__rating">
        <img
          src={googleRatingImg.src}
          alt="Google 5 star rating"
          class="cpf-s4__rating-img"
          loading="lazy"
          decoding="async"
          width="143"
          height="74"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .cpf-s4__inner {
    max-width: var(--container-narrow);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .cpf-s4__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    font-style: italic;
    margin: 0;
    line-height: 1.2;
  }

  .cpf-s4__quote {
    margin: 0;
    padding: 0;
  }

  .cpf-s4__quote-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-style: italic;
    line-height: 1.7;
    margin: 0 0 var(--space-sm);
  }

  .cpf-s4__quote-footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-style: normal;
  }

  .cpf-s4__quote-author {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    font-style: normal;
  }

  .cpf-s4__quote-location {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    opacity: 0.8;
    line-height: 1.3;
  }

  .cpf-s4__rating {
    display: flex;
    justify-content: center;
  }

  .cpf-s4__rating-img {
    width: 143px;
    height: 74px;
    object-fit: contain;
    display: block;
  }
</style>
