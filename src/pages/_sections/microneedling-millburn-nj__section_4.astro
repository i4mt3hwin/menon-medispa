---
{/* BREAKDANCE: hand-authored from structure.json */}
import sectionBg from '@/assets/images/651c7c197b52.webp';
---

<section class="section s4-videos" style={`background-image:url('${sectionBg.src}');background-size:cover;background-position:center;`}>
  <div class="s4-videos__overlay" aria-hidden="true"></div>
  <div class="container s4-videos__inner">

    <h2 class="s4-videos__heading">See Why Millburn Residents Love Their Microneedling Results</h2>

    <div class="s4-videos__grid">

      <div class="s4-videos__video-wrap">
        <video
          class="s4-videos__video"
          controls
          playsinline
          poster="/media/wix/2baa5c_58f24a697ba84e11a8e09b253d7af15cf000.jpg"
          width="355"
          height="654"
          preload="none"
        >
          <source
            src="/videos/wix/2baa5c_58f24a697ba84e11a8e09b253d7af15c.mp4"
            type="video/mp4"
          />
          Your browser does not support the video tag.
        </video>
      </div>

      <div class="s4-videos__video-wrap">
        <video
          class="s4-videos__video"
          controls
          playsinline
          poster="/media/wix/2baa5c_718952ee882e42ddb81b4142d459a749f000.jpg"
          width="355"
          height="654"
          preload="none"
        >
          <source
            src="/videos/wix/2baa5c_718952ee882e42ddb81b4142d459a749.mp4"
            type="video/mp4"
          />
          Your browser does not support the video tag.
        </video>
      </div>

    </div>

  </div>
</section>

<style>
  .s4-videos {
    position: relative;
  }

  .s4-videos__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.55);
    pointer-events: none;
    z-index: 0;
  }

  .s4-videos__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .s4-videos__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    text-align: center;
    margin: 0;
    line-height: 1.3;
  }

  .s4-videos__grid {
    display: flex;
    flex-direction: row;
    gap: var(--space-lg);
    justify-content: center;
    flex-wrap: wrap;
  }

  .s4-videos__video-wrap {
    flex-shrink: 0;
    width: 355px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .s4-videos__video {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .s4-videos__grid {
      flex-direction: column;
      align-items: center;
    }

    .s4-videos__video-wrap {
      width: 100%;
      max-width: 355px;
    }
  }
</style>
