---
import ContentSection from '@/components/ContentSection.astro';
import RichText from '@/components/RichText.astro';
import Button from '@/components/Button.astro';
import Picture from '@/components/Picture.astro';

import videoPosterImg from '@/assets/home/exceptional-experience-video-poster.webp';
---

<!-- NEW-WIDGET: video section=10 -->
<section class="home-section-10">
  <div class="home-section-10__inner">
    <div class="home-section-10__text">
      <p class="home-section-10__eyebrow">WHY CHOOSE MENON MEDISPA?</p>
      <h2 class="home-section-10__heading">An Exceptional<br />Experience</h2>
      <div class="home-section-10__body">
        <RichText html="<p>At Menon Medispa, we are passionate about enhancing people&#x27;s lives based on the belief that beauty comes from within.</p>" />
        <RichText html="<p>Founded and led by regenerative medicine specialist Dr. Aditi Menon, our medispa provides aesthetic and dermatological treatment solutions to maintain your outer glow and inner beauty.</p>" />
      </div>
      <div class="home-section-10__cta-wrap">
        <a href="/about" class="home-section-10__cta">About Menon Medispa</a>
      </div>
    </div>

    <div class="home-section-10__media">
      {/* Autoplay muted looped video, hidden on mobile per _responsive.mobile.opacity:0 */}
      <video
        class="home-section-10__video"
        src="/videos/wix/f61cce_b930b3f48aa04baa8c7f669d63cdaebd.mp4"
        autoplay
        loop
        muted
        playsinline
        poster={videoPosterImg.src}
        aria-hidden="true"
      ></video>
      {/* Poster image shown when video unavailable / on mobile */}
      <img
        src={videoPosterImg.src}
        alt=""
        class="home-section-10__poster"
        loading="lazy"
        decoding="async"
        width="717"
        height="715"
      />
    </div>
  </div>
</section>

<style>
  .home-section-10 {
    padding: var(--space-xl) var(--space-lg);
  }

  .home-section-10__inner {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .home-section-10__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 500px;
  }

  .home-section-10__eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .home-section-10__heading {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .home-section-10__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .home-section-10__cta-wrap {
    margin-top: var(--space-sm);
  }

  .home-section-10__cta {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 148px;
    height: 50px;
    background-color: var(--color-surface);
    color: var(--color-text);
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-regular);
    text-decoration: none;
    border: 1px solid var(--color-surface);
    transition: border-color 0.4s, background-color 0.4s;
  }

  .home-section-10__cta:hover {
    background-color: var(--color-cta);
    border-color: var(--color-cta);
  }

  .home-section-10__media {
    flex: 1;
    position: relative;
    max-width: 717px;
  }

  .home-section-10__video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .home-section-10__poster {
    display: none;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* On mobile: hide video (opacity:0 per _responsive), show poster */
  @media (max-width: 980px) {
    .home-section-10 {
      padding: var(--space-lg) var(--space-sm);
    }

    .home-section-10__inner {
      flex-direction: column;
    }

    .home-section-10__text {
      max-width: 100%;
    }

    .home-section-10__media {
      max-width: 549px;
      width: 100%;
    }

    .home-section-10__video {
      display: none; /* opacity:0 per responsive override = effectively hidden */
    }

    .home-section-10__poster {
      display: block;
    }
  }
</style>
