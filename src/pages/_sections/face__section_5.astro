---
import featureImg from '@/assets/images/1b966a066698.png';
import videoPosterImg from '@/assets/images/3f92ba431eb3.jpg';
---

<section class="section section--tint face-why">
  <div class="container">

    <div class="face-why__head">
      <h2 class="face-why__heading">
        Why Choose Menon MediSpa for Your Facial Treatments &amp; Enhancements?
      </h2>
      <p class="face-why__intro">
        Our comprehensive approach integrates advanced skincare with medical-grade procedures to deliver truly transformative results. We create customized treatment plans that address both immediate concerns and long-term skin wellness goals.
      </p>
    </div>

    <div class="face-why__layout">

      <div class="face-why__media-col">

        <img
          src={featureImg.src}
          alt="Menon MediSpa clinic facility"
          class="face-why__feature-img"
          loading="lazy"
          decoding="async"
          width="600"
          height="354"
        />

        {/* Video, autoplay, muted, loop. Hidden on mobile via CSS; poster shown instead. */}
        <video
          class="face-why__video"
          autoplay
          loop
          muted
          playsinline
          aria-hidden="true"
          poster={videoPosterImg.src}
          width="600"
          height="400"
        >
          <source
            src="https://video.wixstatic.com/video/2baa5c_b2d7187d8a2c49e2b6095a2d1201724c/720p/mp4/file.mp4"
            type="video/mp4"
          />
        </video>

        {/* Poster image shown on mobile in place of video */}
        <img
          src={videoPosterImg.src}
          alt="Medical aesthetics treatment at Menon Medispa Millburn NJ"
          class="face-why__video-poster"
          loading="lazy"
          decoding="async"
          width="600"
          height="400"
        />

      </div>

      <div class="face-why__text-col">

        <div class="face-why__block">
          <h3 class="face-why__block-heading">Our Integrated Treatment Philosophy</h3>
          <p class="face-why__block-body">
            At Menon MediSpa, we understand that optimal skin health often requires a multi-faceted approach. Our specialists are trained in both aesthetic skincare and advanced medical procedures, allowing us to create personalized solutions that enhance your natural beauty.
          </p>
        </div>

        <div class="face-why__block">
          <h3 class="face-why__block-heading">Advanced Technology Meets Proven Techniques</h3>
          <p class="face-why__block-body">
            We combine state-of-the-art technology with time-tested treatment methods to provide you with the most effective skincare solutions. From HydraFacial to laser treatments, each service is tailored to maximize your results while minimizing recovery time.
          </p>
        </div>

        <div class="face-why__block">
          <h3 class="face-why__block-heading">What to Expect</h3>
          <p class="face-why__block-body">
            Your experience begins with a thorough consultation to understand your skin concerns and goals. Whether you&rsquo;re receiving a facial or a more advanced treatment, you&rsquo;ll enjoy attentive care in our relaxing, clinical environment. We use only premium products and advanced techniques to ensure safe, effective results.
          </p>
        </div>

      </div>

    </div>
  </div>
</section>

<style>
  .face-why .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .face-why__head {
    max-width: 820px;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .face-why__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .face-why__intro {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .face-why__layout {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  /* Left column: image + video stacked, sticky on desktop */
  .face-why__media-col {
    position: sticky;
    top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .face-why__feature-img, .face-why__video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 28px rgb(0 0 0 / 0.12);
  }

  .face-why__video-poster {
    display: none;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }

  /* Right column: accent-ruled text blocks */
  .face-why__text-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .face-why__block {
    position: relative;
    padding-left: var(--space-md);
    border-left: 3px solid var(--color-cta);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .face-why__block-heading {
    font-family: var(--font-display);
    font-size: var(--text-subheading);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
  }

  .face-why__block-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .face-why__layout {
      grid-template-columns: 1fr;
    }

    .face-why__media-col {
      position: static;
      max-width: 560px;
      margin: 0 auto;
      width: 100%;
    }

    .face-why__video { display: none; }
    .face-why__video-poster { display: block; }
  }
</style>
