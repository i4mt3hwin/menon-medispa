---
import site from '@/lib/site';

import staffImg from '@/assets/images/b1a819f35921.webp';
---

<section class="section section--dark fi-s6-cta">
  <div class="container">
    <div class="fi-s6__layout">

      <div class="fi-s6__text">

        <h2 class="fi-s6__heading">Begin Your Transformation Today</h2>

        <p class="fi-s6__subtitle">Menon Medispa Millburn NJ</p>

        <p class="fi-s6__body">
          Ready to experience the benefits of Menon Medispa's Fillers &amp; Injectables with Dr. Aditi Menon? Take the first step toward Perfect Skin by scheduling your personal consultation at Menon Medispa in Millburn, NJ.
        </p>

        <div class="fi-s6__actions">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Schedule Consultation
          </a>
        </div>

      </div>

      <div class="fi-s6__img-col">
        <img
          src={staffImg.src}
          alt="Office staff at Menon Medispa Millburn NJ"
          class="fi-s6__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="560"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .fi-s6__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .fi-s6__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .fi-s6__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .fi-s6__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .fi-s6__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .fi-s6__actions {
    margin-top: var(--space-xs);
  }

  .fi-s6__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .fi-s6__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .fi-s6__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .fi-s6__layout {
      flex-direction: column;
    }

    .fi-s6__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .fi-s6__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
