---
import heroBg from '@/assets/images/651c7c197b52.webp';
import beforeAfterImg from '@/assets/images/1616d1e9f4e9.webp';
---

<section class="media-bg section af-s4" style="--scrim-strength:0.58">
  <img class="media-bg__img media-bg__img--blur" src={heroBg.src} alt="" aria-hidden="true" loading="lazy" decoding="async" width="1440" height="596" />
  <span class="media-bg__scrim media-bg__scrim--l"></span>

  <div class="media-bg__inner container on-media">
    <div class="af-s4__layout">

      <div class="af-s4__text-col">
        <h2 class="af-s4__heading">
          Real Results From Just One Acne Facial Treatment
        </h2>
        <p class="af-s4__body">
          This photo was taken immediately after a 70-minute session. See the dramatic improvement in skin clarity, reduced redness, and visibly smaller pores after just one treatment at Menon Medispa.
        </p>
      </div>

      <div class="af-s4__img-col">
        <img
          src={beforeAfterImg.src}
          alt="Before and after acne facial results at Menon Medispa Millburn NJ"
          class="af-s4__img"
          loading="lazy"
          decoding="async"
          width="600"
          height="600"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .media-bg__inner.container {
    padding-block: var(--section-py);
  }

  .af-s4__layout {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-lg);
  }

  .af-s4__text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .af-s4__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  .af-s4__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    margin: 0;
    line-height: 1.6;
  }

  .af-s4__img-col {
    flex-shrink: 0;
    width: 400px;
  }

  .af-s4__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.35);
  }

  @media (max-width: 1024px) {
    .af-s4__img-col {
      width: 320px;
    }
  }

  @media (max-width: 768px) {
    .af-s4__layout {
      flex-direction: column;
    }

    .af-s4__img-col {
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>
