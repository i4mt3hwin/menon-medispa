---
import site from '@/lib/site';

import staffPhoto from '@/assets/images/b1a819f35921.webp';
---

<section class="section section--dark hfk-s7-cta">
  <div class="container">
    <div class="hfk-s7__layout">

      <div class="hfk-s7__text">

        <h2 class="hfk-s7__heading">
          Not Sure If Hydrafacial Keravive Is Right For You?
        </h2>

        <p class="hfk-s7__subtitle">
          Menon Medispa Millburn NJ
        </p>

        <p class="hfk-s7__body">
          Ready to discover the path to a healthier scalp and fuller-looking hair with Hydrafacial Keravive but not sure if it's right for you? Take the first step by scheduling your FREE personal scalp consultation at Menon Medispa in Millburn, NJ.
        </p>

        <div class="hfk-s7__actions">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Schedule Free Consultation
          </a>
        </div>

      </div>

      <div class="hfk-s7__img-col">
        <img
          src={staffPhoto.src}
          alt="Menon Medispa Office Staff"
          class="hfk-s7__img"
          loading="lazy"
          decoding="async"
          width="500"
          height="400"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .hfk-s7__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .hfk-s7__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hfk-s7__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .hfk-s7__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hfk-s7__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .hfk-s7__actions {
    margin-top: var(--space-xs);
  }

  .hfk-s7__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .hfk-s7__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .hfk-s7__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .hfk-s7__layout {
      flex-direction: column;
    }

    .hfk-s7__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .hfk-s7__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
