---
import site from '@/lib/site';

import heroImg from '@/assets/images/27f029705023.jpg';
import reviewIcon1 from '@/assets/images/90411e0041df.png';
import reviewIcon2 from '@/assets/images/305afeda5f9a.png';
import reviewIcon3 from '@/assets/images/b95880091b44.png';
---

<section class="media-bg section s1-body-hero" style="--scrim-strength:0.60">
  <img
    class="media-bg__img media-bg__img--blur"
    src={heroImg.src}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    width="404"
    height="266"
  />
  <span class="media-bg__scrim media-bg__scrim--l"></span>

  <div class="media-bg__inner container on-media">
    <div class="s1-body__layout">

      <div class="s1-body__text">

        <h1 class="s1-body__heading">
          Advanced Solutions for Total Body Wellness
        </h1>

        <p class="s1-body__body">
          From radiant skin with Laser Hair Removal to renewed vitality with Semaglutide and IV Therapy, discover our physician-led approach to looking and feeling your best.
        </p>

        <div class="s1-body__ctas">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Request My Consultation
          </a>
        </div>

        <div class="s1-body__social-proof">
          <div class="s1-body__social-icons">
            <img
              src={reviewIcon1.src}
              alt="Review platform"
              class="s1-body__social-icon"
              loading="lazy"
              decoding="async"
              width="46"
              height="50"
            />
            <img
              src={reviewIcon2.src}
              alt="Review platform"
              class="s1-body__social-icon"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
            <img
              src={reviewIcon3.src}
              alt="Review platform"
              class="s1-body__social-icon"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
          </div>
          <div class="s1-body__stars-block">
            <p class="s1-body__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="s1-body__review-count">100+ 5 Star Reviews</p>
          </div>
        </div>

      </div>

      <div class="s1-body__img-col">
        <img
          src={heroImg.src}
          alt="Body treatments at Menon Medispa Millburn NJ"
          class="s1-body__img"
          loading="eager"
          decoding="async"
          width="404"
          height="266"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s1-body-hero {
    min-height: clamp(520px, 68vh, 660px);
  }

  .media-bg__inner.container {
    padding-block: clamp(58px, 8vw, 92px);
  }

  .s1-body__layout {
    display: flex;
    align-items: center;
    gap: clamp(40px, 7vw, 96px);
  }

  .s1-body__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 620px;
  }

  .s1-body__heading {
    font-family: var(--font-display);
    font-size: clamp(2.15rem, 4vw, 3.6rem);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.08;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .s1-body__body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.6;
    max-width: 58ch;
    text-wrap: pretty;
  }

  .s1-body__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: 10px;
  }

  .s1-body__social-proof {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    width: fit-content;
    margin-top: 8px;
    padding: 8px 16px 8px 10px;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.08);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .s1-body__social-icons {
    display: flex;
    align-items: center;
  }

  .s1-body__social-icon {
    display: block;
    width: 42px;
    height: 42px;
    object-fit: contain;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.86);
    margin-left: -8px;
    filter: brightness(1.15);
  }

  .s1-body__social-icon:first-child {
    margin-left: 0;
  }

  .s1-body__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .s1-body__stars {
    color: var(--color-star);
    font-size: var(--text-sm);
    letter-spacing: 2px;
    margin: 0;
    line-height: 1;
  }

  .s1-body__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    margin: 0;
    line-height: 1.3;
  }

  .s1-body__img-col {
    flex-shrink: 0;
    width: min(38vw, 454px);
    padding: 10px;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: var(--radius-sm);
    background: rgb(255 255 255 / 0.08);
    box-shadow: 0 24px 70px rgb(0 0 0 / 0.22);
  }

  .s1-body__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: none;
  }

  @media (max-width: 1024px) {
    .s1-body__img-col {
      width: 360px;
    }
  }

  @media (max-width: 768px) {
    .s1-body-hero {
      min-height: auto;
    }

    .s1-body__layout {
      flex-direction: column-reverse;
    }

    .s1-body__text {
      max-width: 100%;
    }

    .s1-body__img-col {
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }

    .s1-body__ctas {
      flex-direction: column;
      width: 100%;
    }

    .s1-body__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .s1-body__social-proof {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
      width: 100%;
      border-radius: var(--radius-sm);
    }
  }
</style>
