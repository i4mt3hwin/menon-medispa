---
import site from '@/lib/site'
import imgStaff from '@/assets/images/b1a819f35921.webp'
---

<section class="section section--dark s10-cta">
  <div class="container">
    <div class="s10-cta__layout">

      <div class="s10-cta__text">

        <h2 class="s10-cta__heading">
          Not Sure If Dermaplaning Is Right for You?
        </h2>

        <p class="s10-cta__subtitle">
          Menon Medispa Millburn NJ
        </p>

        <p class="s10-cta__body">
          Ready to experience the benefits of Menon Medispa's Dermaplaning Facial but not sure if it's right for you? Take the first step toward perfect skin by scheduling your FREE personal consultation. Our expert estheticians will assess your skin, answer all your questions, and create a personalized treatment plan just for you.
        </p>

        <div class="s10-cta__actions">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
          >
            Schedule Free Consultation
          </a>
        </div>

      </div>

      <div class="s10-cta__img-col">
        <img
          src={imgStaff.src}
          alt="Menon Office Staff"
          class="s10-cta__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="560"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s10-cta__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .s10-cta__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .s10-cta__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .s10-cta__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .s10-cta__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .s10-cta__actions {
    margin-top: var(--space-xs);
  }

  .s10-cta__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .s10-cta__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .s10-cta__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .s10-cta__layout {
      flex-direction: column;
    }

    .s10-cta__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .s10-cta__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
