---
import FaqAccordion from '@/components/FaqAccordion.astro';
import LeadForm from '@/components/LeadForm.astro';
---

<section class="section sh8-faq">
  <div class="container--narrow sh8-faq__inner">

    <h2 class="sh8-faq__heading">Frequently asked questions</h2>

    <FaqAccordion
      items={[
        {
          question: "What services does Menon Medispa in Millburn, NJ offer?",
          answer_html: "<p>Menon Medispa offers a full range of aesthetic and wellness treatments, including Botox and dermal fillers, laser hair removal, laser facials and skin rejuvenation, chemical peels, vein and vascular treatments, and IV therapy. Visit our individual service pages or contact us to find the right treatment for your goals.</p>"
        },
        {
          question: "What areas do you serve from your Millburn, New Jersey location?",
          answer_html: "<p>Our Millburn location serves clients throughout the surrounding communities, including Short Hills, Summit, Maplewood, Livingston, Springfield, Vauxhall, and West Orange. Many clients travel from across Essex and Union County for our treatments.</p>"
        },
        {
          question: "How do I schedule an appointment at Menon Medispa?",
          answer_html: "<p>You can request an appointment online through our booking system or call us at (973) 494-8431. We will help you choose a time that works for your schedule and answer any questions before your visit.</p>"
        },
        {
          question: "What makes Menon Medispa different from other medispas?",
          answer_html: "<p>Our care is led by Dr. Aditi Menon, MD, who combines medical training with an aesthetic eye. We pair modern technology with personalized treatment plans in a warm, discreet setting, so every visit is tailored to your concerns rather than a one-size-fits-all approach.</p>"
        },
        {
          question: "What should I expect during my first visit to Menon Medispa?",
          answer_html: "<p>Your first visit begins with a consultation so we can understand your goals, review your health history, and recommend the most appropriate options. From there we build a customized plan and walk you through what to expect at each step.</p>"
        }
      ]}
    />

    <!-- Wix form replaced with LeadForm per project rules -->
    <LeadForm
      heading="Have a Question?"
      subheading="Send us a message and we'll get back to you."
    />

  </div>
</section>

<style>
  .sh8-faq__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .sh8-faq__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    text-align: center;
    margin: 0;
    line-height: 1.3;
  }
</style>
