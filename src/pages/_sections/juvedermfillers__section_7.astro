---
import site from '@/lib/site';
import consultImg from '@/assets/images/b1a819f35921.webp';
---

<section class="section section--dark s9-cta">
  <div class="container">
    <div class="s9-cta__layout">

      <div class="s9-cta__text">

        <h2 class="s9-cta__heading">
          Not Sure If Juvéderm Is Right For You?
        </h2>

        <p class="s9-cta__subtitle">
          Menon Medispa Millburn NJ
        </p>

        <p class="s9-cta__body">
          Ready to discover how Juvéderm can help you achieve your aesthetic goals? Schedule your professional consultation with our board-certified doctor to discuss your options and create a personalized treatment plan at Menon Medispa in Millburn, NJ.
        </p>

        <div class="s9-cta__actions">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Schedule Consultation
          </a>
        </div>

      </div>

      <div class="s9-cta__img-col">
        <img
          src={consultImg.src}
          alt="Menon Office Staff.webp"
          class="s9-cta__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="560"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s9-cta__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .s9-cta__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .s9-cta__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .s9-cta__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .s9-cta__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .s9-cta__actions {
    margin-top: var(--space-xs);
  }

  .s9-cta__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .s9-cta__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .s9-cta__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .s9-cta__layout {
      flex-direction: column;
    }

    .s9-cta__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .s9-cta__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
