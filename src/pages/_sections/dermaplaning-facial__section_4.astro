---
import videoPosterImg from '@/assets/images/3f92ba431eb3.jpg'
---

<section class="section section--tint s4-video">
  <div class="container container--narrow">

    <div class="s4-video__intro">
      <h2 class="s4-video__heading">See How Gentle and Relaxing Dermaplaning Really Is</h2>
      <p class="s4-video__sub">Wondering what dermaplaning actually looks like? Watch this real treatment and see how our skilled esthetician gently removes dead skin and vellus hair for an instantly smoother complexion.</p>
    </div>

    <div class="s4-video__player">
      <video
        class="s4-video__el"
        data-lazy-video
        controls
        playsinline
        preload="none"
        poster={videoPosterImg.src}
        width="720"
        height="1280"
      >
        <source data-src="/videos/wix/2baa5c_b2d7187d8a2c49e2b6095a2d1201724c.mp4" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>

  </div>
</section>

<style>
  .s4-video__intro {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .s4-video__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    line-height: 1.3;
  }

  .s4-video__sub {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .s4-video__player {
    max-width: 712px;
    margin-inline: auto;
  }

  /* Portrait reel (the file is 720x1280): cap it to a phone-sized player and
     reserve the 9:16 box so there's no layout shift when the source loads. */
  .s4-video__el {
    width: 100%;
    max-width: 360px;
    aspect-ratio: 9 / 16;
    height: auto;
    display: block;
    margin-inline: auto;
    border-radius: var(--radius-sm);
    object-fit: cover;
    background: #000;
  }
</style>
