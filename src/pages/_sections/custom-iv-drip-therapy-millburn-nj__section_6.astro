---
import sectionBg from '@/assets/images/30cfb9e87c60.png';
import googleRatingImg from '@/assets/images/5be44787b3a9.png';
---

<section class="media-bg section iv-s6-testimonial" style="--scrim-strength:0.58">
  <img class="media-bg__img media-bg__img--blur" src={sectionBg.src} alt="" aria-hidden="true" loading="lazy" decoding="async" width="1440" height="585" />
  <span class="media-bg__scrim media-bg__scrim--brand"></span>

  <div class="media-bg__inner container on-media">
    <div class="iv-s6__inner">

      <h3 class="iv-s6__heading">What Our Clients Say</h3>

      <blockquote class="iv-s6__quote">
        <p class="iv-s6__quote-text">
          "I've tried generic IV drips before, but nothing compares to the custom one I got at Menon Medispa. They actually listened to what I was struggling with, low energy and recovery after workouts, and built a drip just for me. I felt recharged within hours."
        </p>
        <footer class="iv-s6__quote-footer">
          <cite class="iv-s6__quote-author">David R.</cite>
        </footer>
      </blockquote>

      <div class="iv-s6__rating">
        <img
          src={googleRatingImg.src}
          alt="Google 5 Star Rating"
          class="iv-s6__rating-img"
          loading="lazy"
          decoding="async"
          width="143"
          height="74"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .iv-s6__inner {
    max-width: var(--container-narrow);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .iv-s6__heading {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  .iv-s6__quote {
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .iv-s6__quote-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-style: italic;
    margin: 0 0 var(--space-sm);
    line-height: 1.7;
  }

  .iv-s6__quote-footer {
    font-style: normal;
  }

  .iv-s6__quote-author {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    font-style: normal;
  }

  .iv-s6__rating {
    display: flex;
    justify-content: center;
  }

  .iv-s6__rating-img {
    width: 143px;
    height: 74px;
    object-fit: contain;
    display: block;
  }
</style>
