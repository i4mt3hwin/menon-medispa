---
import baImg1 from '@/assets/images/botox-ba-1.jpg';
import baImg2 from '@/assets/images/botox-ba-2.jpg';
import baClassic1 from '@/assets/images/db796bb4e548.jpg';
import baClassic2 from '@/assets/images/6027f67c9460.jpg';
import baClassic3 from '@/assets/images/127c64f86be6.jpg';
---

<section class="section s6-gallery">
  <div class="container container--wide">

    <h2 class="s6-gallery__heading">Real Botox Results: Before and After</h2>

    <p class="s6-gallery__intro">
      See the remarkable transformations achieved by Dr. Menon's expert Botox technique
    </p>

    <div class="s6-gallery__grid">

      <div class="s6-gallery__item">
        <img
          src={baImg1.src}
          alt="Botox before and after at Menon Medispa in Millburn, NJ: deep frown lines softened to a smooth, relaxed result"
          class="s6-gallery__img"
          loading="lazy"
          decoding="async"
          width="906"
          height="686"
        />
      </div>

      <div class="s6-gallery__item">
        <img
          src={baImg2.src}
          alt="Botox before and after at Menon Medispa in Millburn, NJ: a refreshed, natural-looking result"
          class="s6-gallery__img"
          loading="lazy"
          decoding="async"
          width="906"
          height="686"
        />
      </div>

    </div>

    <div class="s6-gallery__grid s6-gallery__grid--classic">

      <div class="s6-gallery__item">
        <img
          src={baClassic1.src}
          alt="Botox before and after at Menon Medispa: forehead and under-eye lines smoothed"
          class="s6-gallery__img"
          loading="lazy"
          decoding="async"
          width="1179"
          height="1168"
        />
      </div>

      <div class="s6-gallery__item">
        <img
          src={baClassic2.src}
          alt="Botox before and after at Menon Medispa: refreshed, lifted appearance"
          class="s6-gallery__img"
          loading="lazy"
          decoding="async"
          width="1179"
          height="1180"
        />
      </div>

      <div class="s6-gallery__item">
        <img
          src={baClassic3.src}
          alt="The magic of Botox: before and after results at Menon Medispa"
          class="s6-gallery__img"
          loading="lazy"
          decoding="async"
          width="1179"
          height="1169"
        />
      </div>

    </div>

    <p class="s6-gallery__disclaimer">
      Individual results may vary. The above are real patients from the Millburn, NJ area who have consented to share their before and after photos.
    </p>

  </div>
</section>

<style>
  .s6-gallery__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    line-height: 1.3;
    text-align: center;
  }

  .s6-gallery__intro {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0 0 var(--space-md);
    line-height: 1.6;
    text-align: center;
  }

  .s6-gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
    width: 100%;
    max-width: 1000px;
    margin-inline: auto;
  }

  .s6-gallery__grid--classic {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-sm);
    max-width: 1100px;
    margin-top: var(--space-md);
  }

  .s6-gallery__item {
    border-radius: var(--radius-sm);
    overflow: hidden;
    line-height: 0;
  }

  .s6-gallery__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .s6-gallery__item:hover .s6-gallery__img {
    transform: scale(1.03);
  }

  .s6-gallery__disclaimer {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.65;
    margin: var(--space-md) auto 0;
    line-height: 1.5;
    text-align: center;
    max-width: 700px;
  }

  @media (max-width: 768px) {
    .s6-gallery__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }
    .s6-gallery__grid--classic {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: 420px;
    }
  }
</style>
