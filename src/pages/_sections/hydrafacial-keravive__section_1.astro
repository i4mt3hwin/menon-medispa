---
import site from '@/lib/site';

import heroPhoto from '@/assets/images/61235f21d512.jpeg';
import socialIcon1 from '@/assets/images/90411e0041df.png';
import socialIcon2 from '@/assets/images/305afeda5f9a.png';
import socialIcon3 from '@/assets/images/b95880091b44.png';
---

<section class="section hfk-s1-hero">
  <div class="container">
    <div class="hfk-s1__layout">

      <div class="hfk-s1__text">
        <h1 class="hfk-s1__eyebrow">HydraFacial™ Keravive™ in Millburn NJ</h1>

        <h2 class="hfk-s1__heading">
          Rejuvenate Your Scalp to Reveal Fuller, Healthier-Looking Hair and Go From Thinning to Thriving
        </h2>

        <p class="hfk-s1__body">
          Experience the innovative HydraFacial™ Keravive™ treatment at Menon Medispa in Millburn, NJ, a revolutionary three-step scalp health program designed to cleanse, stimulate, nourish, and hydrate the scalp for fuller, healthier-looking hair.
        </p>

        <div class="hfk-s1__ctas">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Schedule Your HydraFacial Keravive Today
          </a>
        </div>

        <div class="hfk-s1__social-proof">
          <div class="hfk-s1__social-icons">
            <img src={socialIcon1.src} alt="Review platform" class="hfk-s1__social-icon" loading="lazy" decoding="async" width="46" height="50" />
            <img src={socialIcon2.src} alt="Review platform" class="hfk-s1__social-icon" loading="lazy" decoding="async" width="52" height="50" />
            <img src={socialIcon3.src} alt="Review platform" class="hfk-s1__social-icon" loading="lazy" decoding="async" width="52" height="50" />
          </div>
          <div class="hfk-s1__stars-block">
            <p class="hfk-s1__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="hfk-s1__review-count">100+ 5 Star Reviews</p>
          </div>
        </div>
      </div>

      <div class="hfk-s1__img-col">
        <img
          src={heroPhoto.src}
          alt="HydraFacial Keravive scalp treatment at Menon Medispa Millburn NJ"
          class="hfk-s1__img"
          loading="eager"
          decoding="async"
          width="520"
          height="600"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .hfk-s1-hero {
    background: var(--color-bg);
  }

  .hfk-s1__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .hfk-s1__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 620px;
  }

  .hfk-s1__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .hfk-s1__heading {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
  }

  .hfk-s1__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .hfk-s1__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .hfk-s1__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .hfk-s1__social-icons {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .hfk-s1__social-icon {
    display: block;
    object-fit: contain;
  }

  .hfk-s1__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hfk-s1__stars {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1;
  }

  .hfk-s1__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .hfk-s1__img-col {
    flex-shrink: 0;
    width: 520px;
  }

  .hfk-s1__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }

  @media (max-width: 1024px) {
    .hfk-s1__img-col {
      width: 380px;
    }
  }

  @media (max-width: 768px) {
    .hfk-s1__layout {
      flex-direction: column-reverse;
    }

    .hfk-s1__text {
      max-width: 100%;
    }

    .hfk-s1__img-col {
      width: 100%;
      max-width: 340px;
      margin: 0 auto;
    }

    .hfk-s1__ctas {
      flex-direction: column;
    }

    .hfk-s1__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .hfk-s1__social-proof {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
