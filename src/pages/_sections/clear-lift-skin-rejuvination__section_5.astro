---
import testimonialBg from '@/assets/images/30cfb9e87c60.png';
import reviewIcon1 from '@/assets/images/90411e0041df.png';
import reviewIcon2 from '@/assets/images/305afeda5f9a.png';
import reviewIcon3 from '@/assets/images/b95880091b44.png';
---

<section class="media-bg section s5-testimonial" style="--scrim-strength:0.58">
  <img class="media-bg__img media-bg__img--blur" src={testimonialBg.src} alt="" aria-hidden="true"
       loading="lazy" decoding="async" width="1440" height="596" />
  <span class="media-bg__scrim media-bg__scrim--brand"></span>

  <div class="media-bg__inner container on-media">
    <div class="s5-testimonial__inner">

      <h3 class="s5-testimonial__heading">What Our Clients Say</h3>

    </div>
  </div>

  <!-- Card kept outside on-media so dark-text card reads correctly -->
  <div class="s5-testimonial__card-wrap container">
    <div class="s5-testimonial__card">
      <p class="s5-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
      <blockquote class="s5-testimonial__quote">
        "Wonderful Clearlift Laser treatment with the amazing Jennifer! My skin looks and feels amazing! Thank you RoseMarie for fitting me in to Jennifer's schedule! A beautiful facility, beautiful, professional and courteous staff! Look forward to next treatment!"
      </blockquote>
      <p class="s5-testimonial__attribution">&#8212; Colleen S.</p>
    </div>

    <div class="s5-testimonial__social-proof">
      <div class="s5-testimonial__social-icons">
        <img
          src={reviewIcon1.src}
          alt="Review platform"
          class="s5-testimonial__social-icon"
          loading="lazy"
          decoding="async"
          width="46"
          height="50"
        />
        <img
          src={reviewIcon2.src}
          alt="Review platform"
          class="s5-testimonial__social-icon"
          loading="lazy"
          decoding="async"
          width="52"
          height="50"
        />
        <img
          src={reviewIcon3.src}
          alt="Review platform"
          class="s5-testimonial__social-icon"
          loading="lazy"
          decoding="async"
          width="52"
          height="50"
        />
      </div>
      <div class="s5-testimonial__stars-block">
        <p class="s5-testimonial__review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
        <p class="s5-testimonial__review-count">100+ 5 Star Reviews</p>
      </div>
    </div>
  </div>
</section>

<style>
  .s5-testimonial__inner {
    max-width: var(--container-narrow);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .s5-testimonial__heading {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  .s5-testimonial__card-wrap {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding-bottom: var(--section-py);
  }

  .s5-testimonial__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    background: rgba(255, 255, 255, 0.92);
    border-radius: var(--radius-sm);
    padding: var(--space-lg);
    max-width: 700px;
    width: 100%;
  }

  .s5-testimonial__stars {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-cta);
    margin: 0;
    line-height: 1;
  }

  .s5-testimonial__quote {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.7;
    font-style: italic;
  }

  .s5-testimonial__attribution {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s5-testimonial__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: #fff;
  }

  .s5-testimonial__social-icons {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .s5-testimonial__social-icon {
    display: block;
    object-fit: contain;
    filter: brightness(1.15);
  }

  .s5-testimonial__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }

  .s5-testimonial__review-stars {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: #fff;
    margin: 0;
    line-height: 1;
  }

  .s5-testimonial__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .s5-testimonial__card {
      padding: var(--space-md);
    }

    .s5-testimonial__social-proof {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
