---
import site from '@/lib/site';

import staffImg from '@/assets/images/b1a819f35921.webp';
---

<section class="section section--dark s7-body-cta">
  <div class="container">
    <div class="s7-body__layout">

      <div class="s7-body__text">

        <h2 class="s7-body__heading">
          Begin Your Transformation Today
        </h2>

        <p class="s7-body__subtitle">
          Menon Medispa Millburn NJ
        </p>

        <p class="s7-body__body">
          Ready to experience the benefits of Menon Medispa's Body Treatments? Take the first step toward your body goals today by scheduling your personal consultation at Menon Medispa in Millburn, NJ.
        </p>

        <div class="s7-body__actions">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
          >
            Schedule a Consultation
          </a>
        </div>

      </div>

      <div class="s7-body__img-col">
        <img
          src={staffImg.src}
          alt="Menon Medispa office staff in Millburn NJ"
          class="s7-body__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="560"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s7-body__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .s7-body__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .s7-body__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .s7-body__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .s7-body__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .s7-body__actions {
    margin-top: var(--space-xs);
  }

  .s7-body__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .s7-body__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .s7-body__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .s7-body__layout {
      flex-direction: column;
    }

    .s7-body__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .s7-body__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
