---
import SectionHeading from '@/components/SectionHeading.astro';
---

<section class="contact-s3" aria-label="Opening Hours">
  <!-- Heading widget (h2, "Opening Hours") -->
  <SectionHeading
    text="Opening Hours"
    tag="h2"
    align="left"
  />

  <!-- Hours grid: each day/time pair is a separate text-editor widget, rendered verbatim -->
  <div class="contact-s3__hours">
    <div class="contact-s3__row">
      <!-- widget: text-editor "Mon - Fri" -->
      <span class="contact-s3__day">Mon - Fri</span>
      <!-- widget: text-editor "10:00 am – 6:00 pm" -->
      <span class="contact-s3__time">10:00 am &#x2013; 6:00 pm</span>
    </div>
    <div class="contact-s3__row">
      <!-- widget: text-editor "Saturday" -->
      <span class="contact-s3__day">Saturday</span>
      <!-- widget: text-editor "10:00 am – 4:00 pm" -->
      <span class="contact-s3__time">10:00 am &#x2013; 4:00 pm</span>
    </div>
    <div class="contact-s3__row">
      <!-- widget: text-editor "​Sunday" (verbatim zero-width space prefix preserved) -->
      <span class="contact-s3__day">&#x200B;Sunday</span>
      <!-- widget: text-editor "CLOSED" -->
      <span class="contact-s3__time">CLOSED</span>
    </div>
  </div>
</section>

<style>
  .contact-s3 {
    padding: var(--space-xl) var(--space-md);
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-s3__hours {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .contact-s3__row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    line-height: 1.8;
  }

  .contact-s3__day {
    min-width: 163px;
    flex-shrink: 0;
  }

  .contact-s3__time {
    color: var(--color-text);
  }

  @media (max-width: 980px) {
    .contact-s3 {
      padding: var(--space-lg) var(--space-sm);
    }

    .contact-s3__row {
      gap: var(--space-sm);
    }

    .contact-s3__day {
      min-width: 120px;
    }
  }
</style>
