---
const steps = [
  {
    label: 'Step 1',
    title: 'Consultation & Skin Assessment (5-10 minutes)',
    body: 'Your esthetician begins with a thorough review of your skin type, concerns, and goals. This personalized assessment ensures your cupping facial is tailored to your specific needs, identifying areas that will benefit most from the treatment.',
  },
  {
    label: 'Step 2',
    title: 'Deep Cleansing & Preparation (10-15 minutes)',
    body: 'Your skin is gently cleansed to remove makeup, sunscreen, and surface impurities. This preparation step is essential for allowing the cupping tools to glide smoothly and ensuring the treatment reaches the deeper layers of your skin for maximum benefit.',
  },
  {
    label: 'Step 3',
    title: 'Therapeutic Cupping Treatment (35-40 minutes)',
    body: 'The heart of your facial uses specialized facial cups to create gentle suction across your face, neck, and décolleté. Your esthetician uses precise techniques to lift facial tissues, stimulate circulation, and activate your lymphatic system, delivering the core lifting, firming, and detoxifying benefits of the treatment.',
  },
  {
    label: 'Step 4',
    title: 'Finishing Treatment & Aftercare (5-10 minutes)',
    body: 'Your session concludes with nourishing serums and moisturizers applied to seal in the benefits and soothe your skin. Your esthetician will also walk you through post-treatment care instructions to extend your results and prepare you for your next session.',
  },
];
---

<!-- Section 5: 60-Minute Treatment Process -->
<section class="section s5-process">
  <div class="container--narrow">

    <div class="s5-process__header">
      <h2 class="s5-process__heading">
        What To Expect During Your 60-Minute Cupping Facial Experience
      </h2>
      <p class="s5-process__intro">
        Every step is designed for your comfort and results. Here's exactly what happens during your 60-minute treatment at our Millburn spa.
      </p>
    </div>

    <ol class="s5-process__steps" role="list">
      {steps.map((step, i) => (
        <li class="s5-process__step">
          <div class="s5-process__step-number" aria-hidden="true">{i + 1}</div>
          <div class="s5-process__step-content">
            <h3 class="s5-process__step-title">{step.title}</h3>
            <p class="s5-process__step-body">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="s5-process__comfort">
      <h3 class="s5-process__comfort-heading">Completely Comfortable &amp; Safe</h3>
      <p class="s5-process__comfort-body">
        The cupping process feels like a gentle, rhythmic pulling sensation that most clients find deeply relaxing and therapeutic. There's no pain, just a unique massage-like feeling that leaves you refreshed and rejuvenated.
      </p>
    </div>

  </div>
</section>

<style>
  .s5-process .container--narrow {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: center;
  }

  .s5-process__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    width: 100%;
  }

  .s5-process__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
  }

  .s5-process__intro {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
    opacity: 0.85;
  }

  .s5-process__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    width: 100%;
  }

  .s5-process__step {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-md);
    background-color: var(--color-surface);
    border-radius: var(--radius-sm);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
  }

  .s5-process__step-number {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-cta);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    line-height: 1;
  }

  .s5-process__step-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .s5-process__step-title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s5-process__step-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.65;
    opacity: 0.9;
  }

  .s5-process__comfort {
    width: 100%;
    padding: var(--space-md);
    background-color: var(--color-surface);
    border-left: 4px solid var(--color-cta);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .s5-process__comfort-heading {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s5-process__comfort-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.65;
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .s5-process__heading {
      font-size: var(--text-h3);
    }

    .s5-process__step {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
