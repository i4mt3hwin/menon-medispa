---
import site from '@/lib/site';

import heroBg from '@/assets/images/651c7c197b52.webp';
import heroImg from '@/assets/images/f3af55f56cac.webp';
---

<section class="media-bg section s1-hero" style="--scrim-strength:0.60">
  <img class="media-bg__img media-bg__img--blur" src={heroBg.src} alt="" aria-hidden="true"
       loading="eager" decoding="async" width="1440" height="596" />
  <span class="media-bg__scrim media-bg__scrim--l"></span>

  <div class="media-bg__inner container on-media">
    <div class="s1-hero__layout">

      <div class="s1-hero__text">
        <h1 class="s1-hero__heading">
          Targeted Health Solutions IV Therapy in Millburn NJ
        </h1>

        <h2 class="s1-hero__subheading">
          Proactive nutritional support for your specific health journey.
        </h2>

        <p class="s1-hero__body">
          For those navigating specific health challenges, our Targeted Health Solutions IV Drips deliver powerful, condition-focused nutrient formulas directly into your bloodstream for maximum absorption and effect.
        </p>

        <div class="s1-hero__ctas">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Book Your IV Therapy
          </a>
        </div>
      </div>

      <div class="s1-hero__img-col">
        <img
          src={heroImg.src}
          alt="IV therapy specialist at Menon Medispa Millburn NJ"
          class="s1-hero__img"
          loading="eager"
          decoding="async"
          width="454"
          height="430"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s1-hero {
    min-height: 596px;
  }

  .media-bg__inner.container {
    padding-block: var(--section-py);
  }

  .s1-hero__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .s1-hero__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 620px;
  }

  .s1-hero__heading {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.2;
  }

  .s1-hero__subheading {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  .s1-hero__body {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.6;
  }

  .s1-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .s1-hero__img-col {
    flex-shrink: 0;
    width: 454px;
  }

  .s1-hero__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.35);
  }

  @media (max-width: 1024px) {
    .s1-hero__img-col {
      width: 360px;
    }
  }

  @media (max-width: 768px) {
    .s1-hero {
      min-height: auto;
    }

    .s1-hero__layout {
      flex-direction: column-reverse;
    }

    .s1-hero__text {
      max-width: 100%;
    }

    .s1-hero__img-col {
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }

    .s1-hero__ctas {
      flex-direction: column;
    }

    .s1-hero__ctas .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
