---
import FaqAccordion from '@/components/FaqAccordion.astro';
---

<section class="section section--tint s6-faq">
  <div class="container--narrow">

    <h2 class="s6-faq__heading">Frequently asked questions</h2>

    <FaqAccordion items={[
      { question: "What is NAD+ and why does it matter?" },
      { question: "What's the difference between NAD+ Injection and NAD+ IV Therapy?" },
      { question: "How quickly will I feel results?" },
      { question: "Does the injection hurt?" },
      { question: "How often should I get NAD+ Injections?" },
      { question: "Are there any side effects?" },
    ]} />

  </div>
</section>

<style>
  .s6-faq__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
  }
</style>
