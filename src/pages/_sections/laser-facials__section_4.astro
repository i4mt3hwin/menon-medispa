---
import { site } from "@/lib/site";
import videoPosterImg from "@/assets/images/bf60da9a2083.jpg";
---

<!-- Section 4: Why Choose, Why Choose ClearLift at Menon Medispa in Millburn? -->
<section class="section s4-why">
  <div class="container">
    <div class="s4-why__layout">

      <div class="s4-why__text-col">
        <h2 class="s4-why__heading">Why Choose ClearLift at Menon Medispa in Millburn?</h2>
        <p class="s4-why__intro">
          Experience the most advanced, comfortable, and effective skin rejuvenation treatment
          available. Here's what sets ClearLift apart from other options.
        </p>

        <div class="s4-why__features">
          <div class="s4-why__feature">
            <h3 class="s4-why__feature-title">Zero Downtime Required</h3>
            <p class="s4-why__feature-desc">Unlike traditional lasers or chemical peels, ClearLift allows you to return to all activities immediately after treatment.</p>
          </div>
          <div class="s4-why__feature">
            <h3 class="s4-why__feature-title">Completely Pain-Free</h3>
            <p class="s4-why__feature-desc">Experience gentle warming sensations instead of pain. No numbing cream or anesthesia needed for comfortable treatment.</p>
          </div>
          <div class="s4-why__feature">
            <h3 class="s4-why__feature-title">Quick 30-Minute Sessions</h3>
            <p class="s4-why__feature-desc">Fit your skin transformation into your busy schedule with efficient treatments during your lunch break.</p>
          </div>
          <div class="s4-why__feature">
            <h3 class="s4-why__feature-title">Safe for All Skin Types</h3>
            <p class="s4-why__feature-desc">ClearLift works safely on all six Fitzpatrick skin types, including darker skin tones that other treatments can't address.</p>
          </div>
          <div class="s4-why__feature">
            <h3 class="s4-why__feature-title">FDA-Approved Technology</h3>
            <p class="s4-why__feature-desc">ClearLift uses clinically proven Q-switched laser technology, backed by extensive research and safety studies.</p>
          </div>
          <div class="s4-why__feature">
            <h3 class="s4-why__feature-title">Long-Lasting Results</h3>
            <p class="s4-why__feature-desc">Results improve over time as your skin naturally produces more collagen, with effects lasting up to 2 years.</p>
          </div>
          <div class="s4-why__feature s4-why__feature--wide">
            <h3 class="s4-why__feature-title">Beyond Facial Rejuvination</h3>
            <p class="s4-why__feature-desc">
              ClearLift laser technology offers remarkable results for lip enhancement and rejuvenation.
              This gentle, non-invasive treatment stimulates collagen production in the delicate lip area,
              naturally improving lip definition, reducing fine lines around the mouth, and restoring a
              fuller, more youthful appearance.
            </p>
            <p class="s4-why__feature-desc">
              The precision of ClearLift allows us to treat the lip borders and surrounding area without
              downtime, making it an ideal solution for those seeking subtle, natural lip enhancement
              without fillers.
            </p>
          </div>
        </div>
      </div>

      <div class="s4-why__media-col">
        <video
          class="s4-why__video"
          autoplay
          loop
          muted
          playsinline
          aria-hidden="true"
          poster={videoPosterImg.src}
          width="480"
          height="270"
        >
          <source
            src="/videos/wix/2baa5c_a1e2e08938534d2a8f421b35a9a4de05.mp4"
            type="video/mp4"
          />
        </video>

        <img
          src={videoPosterImg.src}
          alt="ClearLift laser lip enhancement treatment demonstration at Menon Medispa"
          class="s4-why__poster"
          loading="lazy"
          decoding="async"
          width="480"
          height="270"
        />

        <p class="s4-why__caption">
          Watch how this innovative treatment can transform your lips while maintaining their natural beauty.
        </p>

        <div class="s4-why__cta">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Schedule ClearLift Today
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .s4-why__layout {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xl);
  }

  .s4-why__text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .s4-why__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s4-why__intro {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  .s4-why__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .s4-why__feature {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .s4-why__feature--wide {
    grid-column: 1 / -1;
  }

  .s4-why__feature-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s4-why__feature-desc {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }

  .s4-why__media-col {
    flex-shrink: 0;
    width: 480px;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .s4-why__video {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }

  .s4-why__poster {
    display: none;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }

  .s4-why__caption {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.7;
    margin: 0;
    line-height: 1.5;
  }

  .s4-why__cta {
    margin-top: var(--space-xs);
  }

  @media (max-width: 1024px) {
    .s4-why__media-col {
      width: 360px;
    }
  }

  @media (max-width: 768px) {
    .s4-why__layout {
      flex-direction: column;
    }

    .s4-why__media-col {
      width: 100%;
      max-width: 480px;
      margin: 0 auto;
    }

    .s4-why__features {
      grid-template-columns: 1fr;
    }

    .s4-why__feature--wide {
      grid-column: 1;
    }

    .s4-why__video {
      display: none;
    }

    .s4-why__poster {
      display: block;
    }
  }

  @media (max-width: 600px) {
    .s4-why__cta .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
