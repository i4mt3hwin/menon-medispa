---
import site from '@/lib/site';
import heroBg from '@/assets/images/651c7c197b52.png';
import productImg from '@/assets/images/ede51808b502.png';
import proofAvatar1 from '@/assets/images/90411e0041df.png';
import proofAvatar2 from '@/assets/images/305afeda5f9a.png';
import proofAvatar3 from '@/assets/images/b95880091b44.png';
---

<section class="sema-section-1">

  {/* Full-width background image */}
  <div class="sema-section-1__bg-wrap" aria-hidden="true">
    <img
      src={heroBg.src}
      alt=""
      class="sema-section-1__bg"
      loading="eager"
      decoding="async"
      width="1440"
      height="612"
    />
  </div>

  {/* Content overlay */}
  <div class="sema-section-1__content">

    <div class="sema-section-1__text-col">
      <h1 class="sema-section-1__eyebrow">Semaglutide Treatment in Millburn NJ</h1>

      <h2 class="sema-section-1__heading">
        Transform Your Health Through Medical Weight Loss with Semaglutide
      </h2>

      <p class="sema-section-1__body">
        Discover our physician-directed Semaglutide medical weight loss treatments in Millburn. Safe, effective, and tailored to your unique health needs for lasting results.
      </p>

      <a href={site.calcomUrl} class="sema-section-1__cta">
        Begin Your Weight Loss Journey Today!
      </a>

      <div class="sema-section-1__social-proof">
        <div class="sema-section-1__avatars">
          <img src={proofAvatar1.src} alt="Picture of a Client Who Reviewed Us" width="46" height="50" loading="lazy" />
          <img src={proofAvatar2.src} alt="Picture of a Client Who Reviewed Us" width="52" height="50" loading="lazy" />
          <img src={proofAvatar3.src} alt="Picture of a Client Who Reviewed Us" width="52" height="50" loading="lazy" />
        </div>
        <div class="sema-section-1__proof-text">
          <p class="sema-section-1__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
          <p class="sema-section-1__review-count">75+ 5 Star Reviews</p>
        </div>
      </div>
    </div>

    <div class="sema-section-1__img-col">
      <img
        src={productImg.src}
        alt="Weight Loss (2)"
        class="sema-section-1__product-img"
        loading="eager"
        decoding="async"
        width="454"
        height="430"
      />
    </div>

  </div>
</section>

<style>
  .sema-section-1 {
    position: relative;
    width: 100%;
    min-height: 612px;
    overflow: hidden;
    box-sizing: border-box;
  }

  .sema-section-1__bg-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .sema-section-1__bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 100%;
    display: block;
  }

  .sema-section-1__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-lg);
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg);
  }

  .sema-section-1__text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .sema-section-1__eyebrow {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.4;
  }

  .sema-section-1__heading {
    font-family: var(--font-display);
    font-size: 37px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
    max-width: 620px;
  }

  .sema-section-1__body {
    font-family: var(--font-body);
    font-size: 19px;
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.8;
    max-width: 432px;
  }

  .sema-section-1__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    background-color: rgb(201, 168, 118);
    color: var(--color-text);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    text-decoration: none;
    border-radius: 5px;
    box-shadow: rgba(0, 0, 0, 0.6) 0px 1px 9px 2px;
    transition: background-color 0.4s;
    max-width: 366px;
    text-align: center;
    margin-top: var(--space-xs);
  }

  .sema-section-1__cta:hover {
    background-color: color-mix(in srgb, rgb(201, 168, 118) 85%, #000 15%);
  }

  .sema-section-1__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .sema-section-1__avatars {
    display: flex;
    align-items: center;
  }

  .sema-section-1__avatars img {
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-surface);
    margin-left: -8px;
  }

  .sema-section-1__avatars img:first-child {
    margin-left: 0;
  }

  .sema-section-1__proof-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sema-section-1__stars {
    font-family: var(--font-body);
    font-size: 20px;
    color: var(--color-text);
    margin: 0;
    line-height: 1;
  }

  .sema-section-1__review-count {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .sema-section-1__img-col {
    flex-shrink: 0;
    width: 454px;
  }

  .sema-section-1__product-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 980px) {
    .sema-section-1 {
      min-height: auto;
    }

    .sema-section-1__content {
      flex-direction: column;
      padding: var(--space-lg) var(--space-sm);
    }

    .sema-section-1__img-col {
      width: 100%;
    }

    .sema-section-1__heading {
      font-size: 28px;
      max-width: 100%;
    }

    .sema-section-1__body {
      max-width: 100%;
    }
  }
</style>
