---
import RichText from '@/components/RichText.astro';
---

<section class="trust-bar">
  <div class="trust-bar__inner">
    <div class="trust-bar__item">
      <RichText
        html="Same-Week Appointments"
        font="var(--font-body)"
        size="var(--text-sm)"
      />
    </div>
    <div class="trust-bar__item">
      <RichText
        html="Medical-Grade Expertise"
        font="var(--font-body)"
        size="var(--text-sm)"
      />
    </div>
    <div class="trust-bar__item">
      <RichText
        html="State of the Art Equipment"
        font="var(--font-body)"
        size="var(--text-sm)"
      />
    </div>
  </div>
</section>

<style>
  .trust-bar {
    width: 100%;
    box-sizing: border-box;
    padding: var(--space-md) var(--space-md);
  }

  .trust-bar__inner {
    display: flex;
    flex-direction: row;
    justify-content: space-around;
    align-items: center;
    gap: var(--space-md);
    max-width: 1440px;
    margin: 0 auto;
  }

  .trust-bar__item {
    flex: 1;
    text-align: center;
  }

  @media (max-width: 980px) {
    .trust-bar__inner {
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
    }

    .trust-bar__item {
      width: 100%;
    }
  }
</style>
