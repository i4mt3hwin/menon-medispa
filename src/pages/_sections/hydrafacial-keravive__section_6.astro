---
import FaqAccordion from '@/components/FaqAccordion.astro';
import LeadForm from '@/components/LeadForm.astro';
---

<section class="section hfk-s6-faq">
  <div class="container--narrow">

    <h2 class="hfk-s6__heading">Frequently asked questions</h2>

    <LeadForm />

    <FaqAccordion
      items={[
        {
          question: "Who is a good candidate for Hydrafacial Keravive?",
          answer: "HydraFacial™ Keravive™ is ideal for anyone experiencing thinning hair, excess scalp buildup, dryness, or an unhealthy scalp environment. It is suitable for all hair types and works well alongside other hair restoration treatments such as PRP therapy or minoxidil.",
        },
        {
          question: "Is the treatment painful or uncomfortable?",
          answer: "No, HydraFacial™ Keravive™ is a gentle, non-invasive treatment. Most clients describe the sensation as relaxing and soothing. There is no pain associated with the procedure, and clients can return to normal activities immediately afterward.",
        },
        {
          question: "How many treatments will I need to see results?",
          answer: "A series of three monthly in-office treatments is recommended for optimal results, followed by maintenance sessions every 3-6 months. Many clients notice improvements in scalp health and hair texture after just one session.",
        },
        {
          question: "Is there any downtime after the treatment?",
          answer: "There is no downtime with HydraFacial™ Keravive™. You can wash and style your hair as normal and resume all daily activities immediately after your appointment.",
        },
        {
          question: "Can this treatment be combined with PRP or other hair loss solutions?",
          answer: "Yes, HydraFacial™ Keravive™ works excellently as a complement to PRP (platelet-rich plasma) injections, laser hair therapy, and other hair restoration treatments. By optimizing the scalp environment, Keravive can enhance the effectiveness of these additional therapies.",
        },
      ]}
    />

  </div>
</section>

<style>
  .hfk-s6__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
    text-align: center;
  }
</style>
