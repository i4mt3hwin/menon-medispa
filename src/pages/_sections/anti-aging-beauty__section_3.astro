---
import site from '@/lib/site';
---

<section class="section s3-formulas">
  <div class="container">

    <h2 class="s3-formulas__heading">
      Choose Your Anti-Aging &amp; Beauty Formula
    </h2>

    <div class="s3-formulas__grid">

      <div class="s3-formulas__card">
        <div class="s3-formulas__card-label eyebrow">AGE-DEFYING Signature</div>
        <p class="s3-formulas__card-desc">
          Best for a targeted boost to skin brightness and anti-aging support. A focused blend of our most powerful beauty nutrients.
        </p>
        <ul class="s3-formulas__ingredients">
          <li>Glutathione &amp; Vitamin C</li>
          <li>Biotin &amp; Taurine</li>
          <li>Minerals</li>
        </ul>
      </div>

      <div class="s3-formulas__card">
        <div class="s3-formulas__card-label eyebrow">AGE-DEFYING Deluxe</div>
        <p class="s3-formulas__card-desc">
          Best for comprehensive rejuvenation and total beauty enhancement. Everything in the Signature formula plus additional nutrients for deeper results.
        </p>
        <ul class="s3-formulas__ingredients">
          <li>Glutathione &amp; Vitamin C</li>
          <li>Biotin &amp; Taurine</li>
          <li>Minerals</li>
          <li>B-Complex</li>
          <li>Magnesium &amp; Zinc</li>
          <li>Amino Acids</li>
        </ul>
      </div>

    </div>

    <div class="s3-formulas__cta">
      <a
        href={site.calcomUrl}
        class="btn btn--primary btn--lg"
      >
        Schedule Now
      </a>
    </div>

  </div>
</section>

<style>
  .s3-formulas__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
    text-align: center;
  }

  .s3-formulas__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .s3-formulas__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  .s3-formulas__card-label {
    font-weight: var(--weight-bold);
  }

  .s3-formulas__card-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .s3-formulas__ingredients {
    list-style: disc;
    margin: 0;
    padding: 0 0 0 1.2em;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .s3-formulas__ingredients li {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .s3-formulas__cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 768px) {
    .s3-formulas__grid {
      grid-template-columns: 1fr;
    }

    .s3-formulas__cta .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
