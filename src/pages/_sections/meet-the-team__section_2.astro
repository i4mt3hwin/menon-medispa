---
import imgDrMenon from '@/assets/images/88353b502c45.png';
import imgShrutiSen from '@/assets/images/807fae7ef1f5.png';
import imgNancyC from '@/assets/images/48d39eee8013.png';
import imgJenniferRamirez from '@/assets/images/df9285b183d3.png';
import imgRosemarie from '@/assets/images/10df2823350b.png';

const team = [
  { src: imgDrMenon,        alt: 'Dr. Aditi Menon, MD',  name: 'Dr. Aditi Menon, MD', title: 'Founder & CEO'     },
  { src: imgShrutiSen,      alt: 'Shruti Sen',            name: 'Shruti Sen',           title: 'Practice Manager'  },
  { src: imgNancyC,         alt: 'Nancy C.',              name: 'Nancy C.',             title: 'Medical Assistant' },
  { src: imgJenniferRamirez,alt: 'Jennifer Ramirez',      name: 'Jennifer Ramirez',     title: 'Esthetician'       },
  { src: imgRosemarie,      alt: 'Rosemarie Boisselle',   name: 'Rosemarie Boisselle',  title: 'Receptionist'      },
];
---

<section class="section section--tint mtt-s2">
  <div class="container">

    <div class="mtt-s2__header">
      <p class="eyebrow">The People Behind Your Care</p>
      <h2 class="mtt-s2__title">Meet Our Team</h2>
      <p class="mtt-s2__intro">
        Dedicated professionals committed to enhancing your natural beauty and well-being. Our diverse team combines specialized training in skincare, health, and relaxation techniques to create personalized experiences for rejuvenation and confidence.
      </p>
    </div>

    <ul class="mtt-s2__grid" role="list" data-reveal data-reveal-children>
      {team.map((member) => (
        <li class="mtt-s2__card">
          <div class="mtt-s2__card-img-wrap">
            <img
              src={member.src.src}
              alt={member.alt}
              class="mtt-s2__card-img"
              loading="lazy"
              decoding="async"
              width="295"
              height="356"
            />
          </div>
          <div class="mtt-s2__card-body">
            <p class="mtt-s2__card-name">{member.name}</p>
            <p class="mtt-s2__card-title">{member.title}</p>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .mtt-s2 {
    /* section + section--tint handle background and vertical rhythm */
  }

  .mtt-s2__header {
    text-align: center;
    max-width: 780px;
    margin: 0 auto var(--space-lg);
  }

  .mtt-s2__title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    line-height: 1.2;
  }

  .mtt-s2__intro {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  /* Team grid, 5 cards, wraps on smaller screens */
  .mtt-s2__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
    width: 100%;
  }

  .mtt-s2__card {
    display: flex;
    flex-direction: column;
    width: 240px;
    flex-shrink: 0;
    background-color: var(--color-surface);
    border: 1px solid rgb(196 164 132 / 0.22);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 6px 20px rgb(30 24 41 / 0.07);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .mtt-s2__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 36px rgb(30 24 41 / 0.16);
  }

  .mtt-s2__card-img-wrap {
    width: 100%;
    overflow: hidden;
  }

  .mtt-s2__card-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 295 / 356;
    transition: transform 0.4s ease;
  }

  .mtt-s2__card:hover .mtt-s2__card-img {
    transform: scale(1.04);
  }

  .mtt-s2__card-body {
    padding: var(--space-sm);
    text-align: center;
  }

  .mtt-s2__card-name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  /* Gold accent rule between name and role */
  .mtt-s2__card-name::after {
    content: "";
    display: block;
    width: 28px;
    height: 2px;
    margin: 8px auto;
    background-color: var(--color-accent);
  }

  .mtt-s2__card-title {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.04em;
    margin: 0;
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .mtt-s2__card {
      width: 200px;
    }
  }

  @media (max-width: 768px) {
    .mtt-s2__card {
      width: 180px;
    }
  }

  @media (max-width: 600px) {
    .mtt-s2__grid {
      gap: var(--space-sm);
    }

    .mtt-s2__card {
      width: calc(50% - var(--space-sm) / 2);
    }
  }
</style>
