---
import heroBg from '@/assets/images/651c7c197b52.png';
import staffPhoto from '@/assets/images/35c774fbba6d.png';
import socialIcon1 from '@/assets/images/90411e0041df.png';
import socialIcon2 from '@/assets/images/305afeda5f9a.png';
import socialIcon3 from '@/assets/images/b95880091b44.png';
---

<section class="media-bg section s1-hero about-s1" style="--scrim-strength:0.55">
  <img class="media-bg__img media-bg__img--blur" src={heroBg.src} alt="" aria-hidden="true"
       loading="eager" decoding="async" width="1440" height="515" />
  <span class="media-bg__scrim media-bg__scrim--l"></span>

  <div class="media-bg__inner container on-media">
    <div class="about-s1__layout">

      <div class="about-s1__text">
        <p class="eyebrow">About Us</p>

        <h1 class="about-s1__heading">
          The Menon MediSpa Difference
        </h1>

        <p class="about-s1__body">
          At Menon MediSpa, we believe that beauty is about feeling confident in your own skin. Since 2019, we&#39;ve been Millburn&#39;s premier destination for transformative, non-surgical aesthetic treatments that enhance your natural beauty.
        </p>

        <div class="about-s1__cta">
          <a href="/contact" class="btn btn--primary btn--lg about-s1__btn-cta">
            Have Any Questions? Give Us A Call!
          </a>
        </div>

        <div class="about-s1__social-proof">
          <div class="about-s1__social-icons">
            <img
              src={socialIcon1.src}
              alt="Review platform"
              class="about-s1__social-icon"
              loading="lazy"
              decoding="async"
              width="46"
              height="50"
            />
            <img
              src={socialIcon2.src}
              alt="Review platform"
              class="about-s1__social-icon"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
            <img
              src={socialIcon3.src}
              alt="Review platform"
              class="about-s1__social-icon"
              loading="lazy"
              decoding="async"
              width="52"
              height="50"
            />
          </div>
          <div class="about-s1__stars-block">
            <p class="about-s1__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="about-s1__review-count">100+ 5 Star Reviews</p>
          </div>
        </div>
      </div>

      <div class="about-s1__img-col">
        <img
          src={staffPhoto.src}
          alt="Menon MediSpa staff"
          class="about-s1__img"
          loading="eager"
          decoding="async"
          width="472"
          height="419"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .about-s1 {
    min-height: 515px;
  }

  .media-bg__inner.container {
    padding-block: var(--section-py);
  }

  .about-s1__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .about-s1__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 620px;
  }

  .about-s1__heading {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.2;
  }

  .about-s1__body {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.6;
  }

  .about-s1__cta {
    margin-top: var(--space-xs);
  }

  .about-s1__btn-cta {
    background-color: var(--color-cta-alt);
  }

  .about-s1__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .about-s1__social-icons {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .about-s1__social-icon {
    display: block;
    object-fit: contain;
    filter: brightness(1.15);
  }

  .about-s1__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .about-s1__stars {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1;
  }

  .about-s1__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    margin: 0;
    line-height: 1.3;
  }

  .about-s1__img-col {
    flex-shrink: 0;
    width: 472px;
  }

  .about-s1__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.35);
  }

  @media (max-width: 1024px) {
    .about-s1__img-col {
      width: 360px;
    }
  }

  @media (max-width: 768px) {
    .about-s1 {
      min-height: auto;
    }

    .about-s1__layout {
      flex-direction: column;
    }

    .about-s1__text {
      max-width: 100%;
    }

    .about-s1__img-col {
      width: 100%;
      max-width: 360px;
      margin: 0 auto;
    }

    .about-s1__cta .btn {
      width: 100%;
      text-align: center;
    }

    .about-s1__social-proof {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
