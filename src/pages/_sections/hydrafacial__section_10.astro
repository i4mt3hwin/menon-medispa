---
import FeatureList from '@/components/FeatureList.astro';

import dermaplaning from '@/assets/images/2b1536dee536.webp';
import lymphatic from '@/assets/images/4bc097ff8839.webp';
import led from '@/assets/images/129e4e075fac.webp';
import boosters from '@/assets/images/fdf5fe08d1b3.webp';
import lipPerk from '@/assets/images/145f8747aa55.webp';
import eyePerk from '@/assets/images/016978cac38f.webp';
---

<section class="section s10-addons">
  <div class="container">

    <h2 class="s10-addons__heading">Add Ons</h2>

    <div class="s10-addons__grid">

      <!-- Dermaplaning -->
      <div class="s10-addons__card">
        <div class="s10-addons__card-img">
          <img src={dermaplaning.src} alt="Dermaplaning add-on" loading="lazy" decoding="async" width="340" height="280" />
        </div>
        <div class="s10-addons__card-body">
          <h3 class="s10-addons__card-title">Dermaplaning</h3>
          <FeatureList
            items={[
              "Exfoliates your skin",
              "Cleanses pores",
              "Gets rid of peach fuzz",
              "Smoothens your skin",
            ]}
          />
        </div>
      </div>

      <!-- Lymphatic Drainage -->
      <div class="s10-addons__card">
        <div class="s10-addons__card-img">
          <img src={lymphatic.src} alt="Lymphatic Drainage add-on" loading="lazy" decoding="async" width="340" height="280" />
        </div>
        <div class="s10-addons__card-body">
          <h3 class="s10-addons__card-title">Lymphatic Drainage</h3>
          <FeatureList
            items={[
              "Removes toxic buildup to reveal healthy looking skin",
              "Helps detoxify the skin",
              "Decreases inflammation",
              "Removes unwanted buildup",
              "Optimizes skin health",
            ]}
          />
        </div>
      </div>

      <!-- LED Light Therapy -->
      <div class="s10-addons__card">
        <div class="s10-addons__card-img">
          <img src={led.src} alt="LED Light Therapy add-on" loading="lazy" decoding="async" width="340" height="280" />
        </div>
        <div class="s10-addons__card-body">
          <h3 class="s10-addons__card-title">LED Light Therapy</h3>
          <FeatureList
            items={[
              "Target and disrupt p. acnes bacteria",
              "Improve the appearance of oily and congested skin",
              "Provides an excellent finishing touch to the treatment",
            ]}
          />
        </div>
      </div>

      <!-- Boosters -->
      <div class="s10-addons__card">
        <div class="s10-addons__card-img">
          <img src={boosters.src} alt="Boosters add-on" loading="lazy" decoding="async" width="340" height="280" />
        </div>
        <div class="s10-addons__card-body">
          <h3 class="s10-addons__card-title">Boosters</h3>
          <p class="s10-addons__card-desc">We offer a wide variety of boosters, where each targets a different skin concern. For more information about our boosters, please reach out.</p>
        </div>
      </div>

      <!-- Lip Perk -->
      <div class="s10-addons__card">
        <div class="s10-addons__card-img">
          <img src={lipPerk.src} alt="Lip Perk add-on" loading="lazy" decoding="async" width="340" height="280" />
        </div>
        <div class="s10-addons__card-body">
          <h3 class="s10-addons__card-title">Lip Perk</h3>
          <FeatureList
            items={[
              "Lightly plumps lips",
              "Gently exfoliates to smooth lips",
              "Reduces flaking",
              "Hydrates lips",
            ]}
          />
        </div>
      </div>

      <!-- Eye Perk -->
      <div class="s10-addons__card">
        <div class="s10-addons__card-img">
          <img src={eyePerk.src} alt="Eye Perk add-on" loading="lazy" decoding="async" width="340" height="280" />
        </div>
        <div class="s10-addons__card-body">
          <h3 class="s10-addons__card-title">Eye Perk</h3>
          <FeatureList
            items={[
              "Brightens, tones and firms the outer eye",
              "Improves skin hydration",
              "Gently removes surface layer dead skin cells",
            ]}
          />
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .s10-addons__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-xl);
    line-height: 1.3;
    text-align: center;
  }

  .s10-addons__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .s10-addons__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-bg);
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.05);
  }

  .s10-addons__card-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .s10-addons__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .s10-addons__card-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .s10-addons__card-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin: 0;
  }

  .s10-addons__card-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .s10-addons__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .s10-addons__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
