---
import site from '@/lib/site';
import heroBg from '@/assets/images/fc22050ddcb3.webp';
---

<!-- Section 1: Hero, Personalized Consultation (CRO: one primary CTA + trust strip) -->
<section class="media-bg section s1-con-hero" style="--scrim-strength:0.64">
  <img
    class="media-bg__img media-bg__img--blur"
    src={heroBg.src}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    width="1440"
    height="287"
  />
  <span class="media-bg__scrim media-bg__scrim--b"></span>
  <canvas class="s1-con-hero__particles" data-con-canvas aria-hidden="true"></canvas>

  <div class="media-bg__inner container on-media">
    <div class="s1-con-hero__content">
      <p class="eyebrow s1-con-hero__eyebrow">Your Skin Journey Starts Here</p>
      <h1 class="s1-con-hero__heading">
        Book a Personalized Skin Consultation in Millburn
      </h1>
      <p class="s1-con-hero__subtitle">
        Sit down with our team to pinpoint exactly what your skin needs, and leave with a clear,
        customized treatment plan built around your goals.
      </p>

      <div class="s1-con-hero__ctas">
        <a href="#request" class="btn btn--primary btn--lg">Request Your Consultation</a>
        <a href={site.phone.tel} class="btn btn--secondary btn--on-dark btn--lg">Call {site.phone.display}</a>
      </div>

      <ul class="s1-con-hero__trust">
        <li class="s1-con-hero__trust-item">
          <span class="s1-con-hero__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          100+ 5 Star Reviews
        </li>
        <li class="s1-con-hero__trust-item">Led by Dr. Aditi Menon, MD</li>
        <li class="s1-con-hero__trust-item">Same-Week Appointments</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .s1-con-hero {
    min-height: 64vh;
    display: flex;
    align-items: center;
  }

  /* Drifting light particles, above the scrim (z-1) but below the content (z-2) */
  .s1-con-hero__particles {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  /* Cinematic entrance, matching the service-page heroes (motion-safe) */
  @media (prefers-reduced-motion: no-preference) {
    .s1-con-hero .media-bg__img {
      animation: con-zoom 2.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes con-zoom {
      from { transform: scale(1.16); }
      to   { transform: scale(1.06); }  /* rests at the blur class's edge-hiding scale */
    }

    .s1-con-hero__content > * {
      opacity: 0;
      transform: translateY(22px);
      filter: blur(10px);
      animation: con-rise 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .s1-con-hero__content > *:nth-child(1) { animation-delay: 0.20s; }
    .s1-con-hero__content > *:nth-child(2) { animation-delay: 0.32s; }
    .s1-con-hero__content > *:nth-child(3) { animation-delay: 0.44s; }
    .s1-con-hero__content > *:nth-child(4) { animation-delay: 0.56s; }
    .s1-con-hero__content > *:nth-child(5) { animation-delay: 0.66s; }
    @keyframes con-rise { to { opacity: 1; transform: none; filter: blur(0); } }
  }

  .s1-con-hero .media-bg__inner.container {
    padding-block: var(--section-py);
  }

  .s1-con-hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }

  .s1-con-hero__eyebrow {
    margin: 0;
    color: #fff;
    opacity: 0.9;
  }

  .s1-con-hero__heading {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.16;
  }

  .s1-con-hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    margin: 0;
    line-height: 1.6;
    opacity: 0.92;
    max-width: 660px;
  }

  .s1-con-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .s1-con-hero__trust {
    list-style: none;
    margin: var(--space-sm) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-xs) var(--space-md);
  }

  .s1-con-hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.01em;
    opacity: 0.95;
  }

  .s1-con-hero__trust-item + .s1-con-hero__trust-item::before {
    content: "";
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-cta);
    margin-right: var(--space-xs);
    flex-shrink: 0;
  }

  .s1-con-hero__stars {
    color: var(--color-star);
    letter-spacing: 2px;
    font-size: 1em;
  }

  @media (max-width: 1024px) {
    .s1-con-hero {
      min-height: 56vh;
    }
  }

  @media (max-width: 768px) {
    .s1-con-hero__heading {
      font-size: var(--text-h2);
    }

    .s1-con-hero__ctas {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      max-width: 360px;
    }

    .s1-con-hero__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .s1-con-hero__trust {
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
    }

    .s1-con-hero__trust-item + .s1-con-hero__trust-item::before {
      display: none;
    }
  }
</style>

<script>
  // Autonomous drifting light particles (matches ServiceHero). Reduced-motion safe; idles offscreen.
  (function () {
    const hero = document.querySelector('.s1-con-hero');
    if (!hero) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const canvas = hero.querySelector('[data-con-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let w = 0, h = 0, dpr = 1, parts: any[] = [], raf = 0, running = false;
    function size() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = (hero as HTMLElement).clientWidth; h = (hero as HTMLElement).clientHeight;
      canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
      canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    function spawn(init: boolean) {
      return {
        x: Math.random() * w,
        y: init ? Math.random() * h : h + 14,
        r: 0.5 + Math.random() * 1.1,
        vy: 0.05 + Math.random() * 0.18,
        vx: (Math.random() - 0.5) * 0.12,
        a: 0.12 + Math.random() * 0.30,
        white: Math.random() < 0.32,
      };
    }
    function build() {
      const n = Math.max(12, Math.min(30, Math.round((w * h) / 54000)));
      parts = []; for (let i = 0; i < n; i++) parts.push(spawn(true));
    }
    function step() {
      ctx!.clearRect(0, 0, w, h);
      for (const p of parts) {
        p.y -= p.vy; p.x += p.vx;
        if (p.y < -14) Object.assign(p, spawn(false));
        const rad = p.r * 7;
        const g = ctx!.createRadialGradient(p.x, p.y, 0, p.x, p.y, rad);
        const c = p.white ? '245,239,228' : '226,186,120';
        g.addColorStop(0, 'rgba(' + c + ',' + p.a + ')');
        g.addColorStop(0.5, 'rgba(' + c + ',' + (p.a * 0.35) + ')');
        g.addColorStop(1, 'rgba(' + c + ',0)');
        ctx!.fillStyle = g;
        ctx!.beginPath(); ctx!.arc(p.x, p.y, rad, 0, 6.2832); ctx!.fill();
      }
      raf = requestAnimationFrame(step);
    }
    function start() { if (!running) { running = true; raf = requestAnimationFrame(step); } }
    function stop() { running = false; cancelAnimationFrame(raf); }

    size(); build();
    let rt: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', function () { clearTimeout(rt); rt = setTimeout(function () { size(); build(); }, 150); }, { passive: true });
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function (es) { es.forEach(function (en) { en.isIntersecting ? start() : stop(); }); }, { threshold: 0.01 }).observe(hero);
    } else { start(); }
  })();
</script>
