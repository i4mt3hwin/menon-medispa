---
import Gallery from "@/components/Gallery.astro";
import img1 from "@/assets/images/9ebaca3843d3.jpg";
import img2 from "@/assets/images/6c461885a28e.jpg";
import img3 from "@/assets/images/823792ea5ead.jpg";
import img4 from "@/assets/images/cd675890fe0d.jpg";
import img5 from "@/assets/images/2e5d1e68225a.jpg";

const galleryImages = [
  { src: img1, alt: "Customer photo 1" },
  { src: img2, alt: "Customer photo 2" },
  { src: img3, alt: "Customer photo 3" },
  { src: img4, alt: "Customer photo 4" },
  { src: img5, alt: "Customer photo 5" },
];
---

<!-- Section 4: Gallery, Hear From Our Customers -->
<section class="section section--tint s4-gallery">
  <div class="container">
    <h5 class="s4-gallery__heading">Hear From Our Customers!</h5>
    <Gallery images={galleryImages} />
  </div>
</section>

<style>
  .s4-gallery__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
    text-align: center;
  }
</style>
