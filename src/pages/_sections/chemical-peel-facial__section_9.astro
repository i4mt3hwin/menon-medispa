---
import site from '@/lib/site';

import staffImg from '@/assets/images/b1a819f35921.webp';
---

<section class="section section--dark cpf-s9">
  <div class="container">
    <div class="cpf-s9__layout">

      <div class="cpf-s9__text">

        <h2 class="cpf-s9__heading">
          Not Sure If Chemical Peel Is Right For You?
        </h2>

        <p class="cpf-s9__body">
          Ready to experience the benefits of Menon Medispa's Chemical Peel Facial but not sure if it's right for you? Take the first step toward smoother, brighter skin by scheduling your FREE personal consultation at Menon Medispa in Millburn, NJ.
        </p>

        <div class="cpf-s9__actions">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
          >
            Schedule Free Consultation
          </a>
        </div>

      </div>

      <div class="cpf-s9__img-col">
        <img
          src={staffImg.src}
          alt="Menon Medispa office staff ready to help with chemical peel facials in Millburn NJ"
          class="cpf-s9__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="560"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .cpf-s9__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .cpf-s9__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .cpf-s9__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .cpf-s9__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .cpf-s9__actions {
    margin-top: var(--space-xs);
  }

  .cpf-s9__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .cpf-s9__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .cpf-s9__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .cpf-s9__layout {
      flex-direction: column;
    }

    .cpf-s9__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .cpf-s9__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
