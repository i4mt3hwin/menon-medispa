<section class="section section--tight section--tint sema-s2-trust">
  <div class="container">
    <ul class="sema-s2__bar">
      <li class="sema-s2__item">
        <span class="sema-s2__icon" aria-hidden="true">&#10003;</span>
        Reduces Hunger &amp; Cravings
      </li>
      <li class="sema-s2__divider" aria-hidden="true"></li>
      <li class="sema-s2__item">
        <span class="sema-s2__icon" aria-hidden="true">&#10003;</span>
        Medically Supervised Weight Loss
      </li>
      <li class="sema-s2__divider" aria-hidden="true"></li>
      <li class="sema-s2__item">
        <span class="sema-s2__icon" aria-hidden="true">&#10003;</span>
        Sustainable Long-Term Results
      </li>
    </ul>
  </div>
</section>

<style>
  .sema-s2__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sema-s2__item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .sema-s2__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-cta);
    font-size: 13px;
    color: var(--color-text);
    flex-shrink: 0;
  }

  .sema-s2__divider {
    width: 1px;
    height: 24px;
    background: rgba(0, 0, 0, 0.18);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .sema-s2__bar {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .sema-s2__divider {
      display: none;
    }
  }
</style>
