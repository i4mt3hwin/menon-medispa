  heading={`Ready to Invest in Your Cellular Health?`}
  body={`This is the cutting edge of anti-aging and regenerative wellness. NAD+ IV therapy delivers a potent dose of this essential coenzyme directly into your bloodstream for maximum absorption and effect.`}
  cards={[
    {
      image: img1,
      imageAlt: `NAD+ IV Drip Therapy`,
      title: `NAD+ IV Drip Therapy`,
      tagline: `Single Dose +250mg`,
      price: `$500`,
      bookHref: `/request-appointment?service=${encodeURIComponent('NAD+ IV Drip 250mg ($500)')}`,
    },
    {
      image: img1,
      imageAlt: `NAD+ IV Drip Therapy`,
      title: `NAD+ IV Drip Therapy`,
      tagline: `Single Dose +500mg`,
      price: `$700`,
      bookHref: `/request-appointment?service=${encodeURIComponent('NAD+ IV Drip 500mg ($700)')}`,
    },
    {
      image: img1,
      imageAlt: `NAD+ IV Drip Therapy`,
      title: `NAD+ IV Drip Therapy`,
      tagline: `Single Dose +750mg`,
      price: `$850`,
      bookHref: `/request-appointment?service=${encodeURIComponent('NAD+ IV Drip 750mg ($850)')}`,
    },
  ]}
/>
