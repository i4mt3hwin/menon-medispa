---
import bgImg from '@/assets/images/960c78e88976.jpg';
import areaImg1 from '@/assets/images/f6ffb79bbe28.webp';
import areaImg2 from '@/assets/images/348290f29603.webp';
import areaImg3 from '@/assets/images/670bcb646993.webp';
import areaImg4 from '@/assets/images/12d9bda0b2d4.webp';
---

<section class="media-bg section fi-s4-juvederm" style="--scrim-strength:0.65">
  <img
    class="media-bg__img"
    src={bgImg.src}
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
    width="1440"
    height="999"
  />
  <span class="media-bg__scrim media-bg__scrim--brand"></span>

  <div class="media-bg__inner container on-media">

    <h2 class="fi-s4__heading">JUV&Eacute;DERM&reg; Fillers</h2>

    <div class="fi-s4__products">
      <div class="fi-s4__product">
        <h3 class="fi-s4__product-name">VOLLURE XC</h3>
        <p class="fi-s4__product-desc">For moderate to severe facial wrinkles and folds</p>
      </div>
      <div class="fi-s4__product">
        <h3 class="fi-s4__product-name">VOLUMA XC</h3>
        <p class="fi-s4__product-desc">For adding volume to the cheek area</p>
      </div>
      <div class="fi-s4__product">
        <h3 class="fi-s4__product-name">VOLBELLA XC</h3>
        <p class="fi-s4__product-desc">For lip augmentation and perioral lines</p>
      </div>
      <div class="fi-s4__product">
        <h3 class="fi-s4__product-name">XC</h3>
        <p class="fi-s4__product-desc">For smoothing and correcting moderate to severe facial wrinkles</p>
      </div>
      <div class="fi-s4__product">
        <h3 class="fi-s4__product-name">Ultra XC</h3>
        <p class="fi-s4__product-desc">For lip augmentation and the correction of perioral lines</p>
      </div>
    </div>

    <div class="fi-s4__areas">

      <div class="fi-s4__area-card">
        <div class="fi-s4__area-img-wrap">
          <img
            src={areaImg1.src}
            alt="Cheek filler treatment area"
            class="fi-s4__area-img"
            loading="lazy"
            decoding="async"
            width="154"
            height="154"
          />
        </div>
        <h3 class="fi-s4__area-label">CHEEKS</h3>
      </div>

      <div class="fi-s4__area-card">
        <div class="fi-s4__area-img-wrap">
          <img
            src={areaImg2.src}
            alt="Chin filler treatment area"
            class="fi-s4__area-img"
            loading="lazy"
            decoding="async"
            width="154"
            height="154"
          />
        </div>
        <h3 class="fi-s4__area-label">CHIN</h3>
      </div>

      <div class="fi-s4__area-card">
        <div class="fi-s4__area-img-wrap">
          <img
            src={areaImg3.src}
            alt="Lines filler treatment area"
            class="fi-s4__area-img"
            loading="lazy"
            decoding="async"
            width="154"
            height="154"
          />
        </div>
        <h3 class="fi-s4__area-label">LINES</h3>
      </div>

      <div class="fi-s4__area-card">
        <div class="fi-s4__area-img-wrap">
          <img
            src={areaImg4.src}
            alt="Lip filler treatment area"
            class="fi-s4__area-img"
            loading="lazy"
            decoding="async"
            width="154"
            height="154"
          />
        </div>
        <h3 class="fi-s4__area-label">LIPS</h3>
      </div>

    </div>

  </div>
</section>

<style>
  .fi-s4-juvederm {
    text-align: center;
  }

  .media-bg__inner.container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .fi-s4__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.06em;
  }

  .fi-s4__products {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-md);
    width: 100%;
  }

  .fi-s4__product {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-sm);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-sm);
    background-color: rgba(255, 255, 255, 0.06);
  }

  .fi-s4__product-name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    margin: 0;
    letter-spacing: 0.08em;
  }

  .fi-s4__product-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    line-height: 1.5;
  }

  .fi-s4__areas {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    width: 100%;
  }

  .fi-s4__area-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .fi-s4__area-img-wrap {
    width: 154px;
    height: 154px;
    flex-shrink: 0;
  }

  .fi-s4__area-img {
    width: 154px;
    height: 154px;
    object-fit: contain;
    display: block;
  }

  .fi-s4__area-label {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    margin: 0;
    letter-spacing: 0.1em;
  }

  @media (max-width: 1024px) {
    .fi-s4__areas {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .fi-s4__products {
      grid-template-columns: 1fr;
    }

    .fi-s4__areas {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm);
    }

    .fi-s4__area-img-wrap {
      width: 100px;
      height: 100px;
    }

    .fi-s4__area-img {
      width: 100px;
      height: 100px;
    }
  }
</style>
