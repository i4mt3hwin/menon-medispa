---
import img1 from '@/assets/images/9ebaca3843d3.jpg';
import img2 from '@/assets/images/6c461885a28e.jpg';
import img3 from '@/assets/images/823792ea5ead.jpg';
import img4 from '@/assets/images/cd675890fe0d.jpg';
import img5 from '@/assets/images/2e5d1e68225a.jpg';
---

<section class="section section--tint s4-gallery">
  <div class="container">

    <h2 class="s4-gallery__heading">Hear From Our Customers!</h2>

    <div class="s4-gallery__grid">
      <div class="s4-gallery__item">
        <img
          src={img1.src}
          alt="Customer photo 1"
          class="s4-gallery__img"
          loading="lazy"
          decoding="async"
          width="400"
          height="400"
        />
      </div>
      <div class="s4-gallery__item">
        <img
          src={img2.src}
          alt="Customer photo 2"
          class="s4-gallery__img"
          loading="lazy"
          decoding="async"
          width="400"
          height="400"
        />
      </div>
      <div class="s4-gallery__item">
        <img
          src={img3.src}
          alt="Customer photo 3"
          class="s4-gallery__img"
          loading="lazy"
          decoding="async"
          width="400"
          height="400"
        />
      </div>
      <div class="s4-gallery__item">
        <img
          src={img4.src}
          alt="Customer photo 4"
          class="s4-gallery__img"
          loading="lazy"
          decoding="async"
          width="400"
          height="400"
        />
      </div>
      <div class="s4-gallery__item">
        <img
          src={img5.src}
          alt="Customer photo 5"
          class="s4-gallery__img"
          loading="lazy"
          decoding="async"
          width="400"
          height="400"
        />
      </div>
    </div>

  </div>
</section>

<style>
  .s4-gallery__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
    text-align: center;
  }

  .s4-gallery__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-sm);
  }

  .s4-gallery__item {
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .s4-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .s4-gallery__item:hover .s4-gallery__img {
    transform: scale(1.04);
  }

  @media (max-width: 1024px) {
    .s4-gallery__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .s4-gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
