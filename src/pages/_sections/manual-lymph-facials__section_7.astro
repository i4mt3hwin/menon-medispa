---
import addon1 from '@/assets/images/71fd4437d1c9.png';
import addon2 from '@/assets/images/a822a2b001cc.png';
import addon3 from '@/assets/images/4bc097ff8839.png';
import addon4 from '@/assets/images/129e4e075fac.png';
import addon5 from '@/assets/images/145f8747aa55.png';
import addon6 from '@/assets/images/016978cac38f.png';

const addons = [
  { src: addon1.src, name: 'Customized Hydrogel Mask',  price: '$25' },
  { src: addon2.src, name: 'Eye Treatment',             price: '$10' },
  { src: addon3.src, name: 'Manual Lymph Drainage',     price: '$50' },
  { src: addon4.src, name: 'LED Light Therapy',         price: '$35' },
  { src: addon5.src, name: 'Hydrafacial Lip Perk',      price: '$30' },
  { src: addon6.src, name: 'Hydrafacial Eye Perk',      price: '$40' },
];
---

<!-- Section 7: Addons grid -->
<section class="section s7-addons">
  <div class="container">

    <div class="s7-addons__header">
      <h2 class="s7-addons__heading">Addons</h2>
      <p class="s7-addons__intro">
        Enhance your manual lymph drainage facial results with these powerful add-ons designed to maximize your glow and extend your benefits.
      </p>
    </div>

    <ul class="s7-addons__grid" role="list">
      {addons.map((addon) => (
        <li class="s7-addons__card">
          <div class="s7-addons__card-img-wrap">
            <img
              src={addon.src}
              alt={addon.name}
              class="s7-addons__card-img"
              loading="lazy"
              decoding="async"
              width="220"
              height="215"
            />
          </div>
          <div class="s7-addons__card-info">
            <p class="s7-addons__card-name">{addon.name}</p>
            <p class="s7-addons__card-price">{addon.price}</p>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .s7-addons__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 680px;
    margin-inline: auto;
    margin-bottom: var(--space-lg);
  }

  .s7-addons__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
  }

  .s7-addons__intro {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
    opacity: 0.85;
  }

  .s7-addons__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    width: 100%;
  }

  .s7-addons__card {
    background-color: var(--color-surface);
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
  }

  .s7-addons__card-img-wrap {
    width: 100%;
    aspect-ratio: 220 / 215;
    overflow: hidden;
  }

  .s7-addons__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .s7-addons__card:hover .s7-addons__card-img {
    transform: scale(1.03);
  }

  .s7-addons__card-info {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .s7-addons__card-name {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s7-addons__card-price {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    opacity: 0.75;
  }

  @media (max-width: 768px) {
    .s7-addons__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .s7-addons__heading {
      font-size: var(--text-h3);
    }
  }

  @media (max-width: 540px) {
    .s7-addons__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
