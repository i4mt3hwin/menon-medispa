---
import site from '@/lib/site';
---

<!-- Section 2: The offer, two consultation options (CRO: clear pricing + risk reversal) -->
<!-- id="options": site-wide "Book a Consultation" CTAs land here (the free vs $50-with-Dr.-Menon
     choice) rather than the hero, so visitors see the options before the form just below. -->
<section class="section con-offer" id="options" style="scroll-margin-top: 100px;">
  <div class="container">

    <div class="con-offer__head">
      <p class="eyebrow">How Consultations Work</p>
      <h2 class="con-offer__heading">The Right Consultation for Your Treatment</h2>
      <p class="con-offer__intro">
        Your consultation is matched to what you have in mind. Skin and facial goals start with a
        licensed esthetician, at no charge. Injectables, Semaglutide, and microneedling begin with
        a brief medical consult with Dr. Menon. Tell us what you are after below and we will confirm
        which applies. No pressure, no obligation.
      </p>
    </div>

    <div class="con-offer__cards">

      <div class="con-offer__card">
        <div class="con-offer__card-top">
          <p class="con-offer__card-label">With a Licensed Esthetician</p>
          <p class="con-offer__price"><span class="con-offer__price-num">Free</span></p>
        </div>
        <p class="con-offer__card-body">
          A 30-minute skin assessment with a licensed esthetician who maps out the right treatments
          for your skin type, concerns, and goals.
        </p>
        <ul class="con-offer__list">
          <li>Best for facials, skincare, and laser treatments</li>
          <li>Personalized treatment recommendations</li>
          <li>Completely free, no obligation</li>
        </ul>
      </div>

      <div class="con-offer__card con-offer__card--featured">
        <div class="con-offer__card-top">
          <p class="con-offer__card-label">With Dr. Aditi Menon, MD</p>
          <p class="con-offer__price"><span class="con-offer__price-num">$50</span> <span class="con-offer__price-note">applied to your treatment</span></p>
        </div>
        <p class="con-offer__card-body">
          A 30-minute medical consultation with our physician and medical director to plan your
          treatment safely.
        </p>
        <ul class="con-offer__list">
          <li>Required for injectables, Semaglutide, and microneedling</li>
          <li>Medical-grade treatment roadmap with Dr. Menon, MD</li>
          <li>The $50 fee is credited toward your treatment</li>
        </ul>
      </div>

    </div>

    <div class="con-offer__action">
      <a href="#request" class="btn btn--primary con-offer__action-cta">Request Your Consultation</a>
    </div>

    <p class="con-offer__reassure">
      Prefer to talk first? Call us at
      <a href={site.phone.tel} class="con-offer__phone">{site.phone.display}</a>, same-week appointments are usually available.
    </p>

  </div>
</section>

<style>
  .con-offer .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .con-offer__head {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .con-offer__head .eyebrow { margin: 0; color: var(--color-cta); }

  .con-offer__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
  }

  .con-offer__intro {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
    opacity: 0.85;
  }

  .con-offer__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    align-items: stretch;
  }

  .con-offer__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.10);
    border-radius: var(--radius-sm);
    box-shadow: 0 4px 18px rgb(0 0 0 / 0.05);
  }

  .con-offer__card--featured {
    border-color: var(--color-cta);
    box-shadow: 0 10px 30px rgb(0 0 0 / 0.12);
  }

  .con-offer__badge {
    position: absolute;
    top: -12px;
    right: var(--space-md);
    background: var(--color-cta);
    color: #fff;
    font-family: var(--font-cta);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: var(--radius-sm);
  }

  /* Transparent on desktop: label + price stay flex items of the card (stacked,
     inheriting the card gap). On mobile this becomes a label-left / price-right row. */
  .con-offer__card-top { display: contents; }

  .con-offer__card-label {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text);
    opacity: 0.7;
    margin: 0;
  }

  .con-offer__price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .con-offer__price-num {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1;
  }

  .con-offer__price-note {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-accent-ink);
    font-weight: 600;
  }

  .con-offer__card-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .con-offer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .con-offer__list li {
    position: relative;
    padding-left: 26px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .con-offer__list li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    top: 1px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-cta);
    color: #fff;
    font-size: 11px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .con-offer__action {
    margin-top: var(--space-xs);
    text-align: center;
  }

  .con-offer__reassure {
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    opacity: 0.85;
    margin: 0;
  }

  .con-offer__phone {
    color: var(--color-accent-ink);
    font-weight: 600;
    text-decoration: none;
  }
  .con-offer__phone:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    /* Condense both options so the Free and $50 cards are visible together,
       without forcing a full-screen scroll between them. */
    .con-offer .container { gap: var(--space-md); }

    .con-offer__intro { display: none; }

    .con-offer__cards {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
      max-width: 460px;
      margin: 0 auto;
    }

    .con-offer__card {
      padding: 22px;
      gap: 10px;
    }

    /* Label left, price right on one compact row. */
    .con-offer__card-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: var(--space-sm);
    }

    .con-offer__price-num { font-size: var(--text-h3); }

    /* Bullets carry the same info; drop the long paragraph to save height. */
    .con-offer__card-body { display: none; }

    .con-offer__list { gap: 6px; }
    .con-offer__list li { font-size: var(--text-xs); }
  }
</style>
