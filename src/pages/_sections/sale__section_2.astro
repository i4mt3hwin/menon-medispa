---
import ServicesGrid from '@/components/ServicesGrid.astro';
import { getSaleOffers, gridHeading } from '@/lib/sales';

// Data-driven: every offer (copy, price, image, Book Now deep-link) comes from
// data/sales.json via lib/sales. Each href carries ?service=<offer + price>, so the
// booking form locks to the offer and the front-desk lead shows the exact promo.
const items = getSaleOffers().map((o) => ({
  title: o.name,
  href: o.href,
  image_src: o.image,
  image_alt: o.imageAlt,
  description_html: `<p>${o.description}</p><p><strong>${o.price}</strong></p>`,
  features: o.includes,
  cta_text: o.ctaText,
}));
---

<ServicesGrid
  heading={gridHeading}
  heading_tag="h2"
  columns={3}
  items={items}
/>
