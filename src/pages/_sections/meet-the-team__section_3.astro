---
import imgClinic from '@/assets/images/68f97116134e.jpg';
---

<section class="section mtt-s3">
  <div class="container">
    <div class="mtt-s3__layout">

      <div class="mtt-s3__text-col">

        <p class="eyebrow">Meet The Founder</p>

        <h2 class="mtt-s3__name">Dr. Aditi Menon, MD</h2>
        <p class="mtt-s3__role">Founder &amp; CEO</p>

        <p class="mtt-s3__body">
          Dr. Aditi Menon, MD is Board Certified in Physical Medicine and Rehabilitation, and specializes in musculoskeletal, pain and sports medicine.
        </p>

        <p class="mtt-s3__body">
          Dr. Menon earned her medical degree at the State University of New York Brooklyn Downstate Medical Center College of Medicine. She then completed her residency in Physical Medicine and Rehabilitation at New York Presbyterian Hospital at New York-Presbyterian University Hospitals of Columbia Presbyterian and Weill Cornell with training in Hospital for Special Surgery and Memorial Sloan Kettering Cancer Center.
        </p>

        <p class="mtt-s3__body">
          Dr. Menon is trained in regenerative medicine and her passion is aesthetics.
        </p>

        <p class="mtt-s3__body">
          In her spare time, she teaches Indian classical dance and likes to spend time with her family.
        </p>

      </div>

      <div class="mtt-s3__img-col">
        <img
          src={imgClinic.src}
          alt="Clinic office"
          class="mtt-s3__img"
          loading="lazy"
          decoding="async"
          width="821"
          height="772"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .mtt-s3__layout {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xl);
  }

  .mtt-s3__text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .mtt-s3__name {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: var(--space-xs) 0 0;
    line-height: 1.2;
  }

  /* Gold accent rule under the founder name */
  .mtt-s3__name::after {
    content: "";
    display: block;
    width: 56px;
    height: 2px;
    margin-top: var(--space-sm);
    background-color: var(--color-accent);
  }

  .mtt-s3__role {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-accent-ink);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: calc(-1 * var(--space-xs)) 0 0;
  }

  .mtt-s3__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  .mtt-s3__img-col {
    flex-shrink: 0;
    width: 380px;
    position: relative;
  }

  /* Offset warm-sand accent block behind the photo */
  .mtt-s3__img-col::before {
    content: "";
    position: absolute;
    right: -16px;
    bottom: -16px;
    width: 60%;
    height: 60%;
    background-color: rgb(196 164 132 / 0.18);
    border-radius: var(--radius-md);
    z-index: 0;
  }

  .mtt-s3__img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: var(--radius-md);
    box-shadow: 0 12px 32px rgb(30 24 41 / 0.16);
    aspect-ratio: 821 / 772;
  }

  @media (max-width: 1024px) {
    .mtt-s3__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .mtt-s3__layout {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .mtt-s3__img-col {
      width: 100%;
      max-width: 480px;
      margin: 0 auto;
    }

    .mtt-s3__img-col::before {
      right: -10px;
      bottom: -10px;
    }
  }
</style>
