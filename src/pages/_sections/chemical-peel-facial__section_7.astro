---
import addon1Img from '@/assets/images/71fd4437d1c9.webp';
import addon2Img from '@/assets/images/a822a2b001cc.webp';
import addon3Img from '@/assets/images/4bc097ff8839.webp';
import addon4Img from '@/assets/images/129e4e075fac.webp';
import addon5Img from '@/assets/images/145f8747aa55.webp';
import addon6Img from '@/assets/images/016978cac38f.webp';
---

<section class="section cpf-s7">
  <div class="container">

    <h2 class="cpf-s7__heading">Addons</h2>

    <p class="cpf-s7__intro">
      Enhance your chemical peel results with these powerful add-ons designed to maximize your skin transformation and speed healing.
    </p>

    <div class="cpf-s7__grid">

      <div class="cpf-s7__card">
        <div class="cpf-s7__card-img-wrap">
          <img
            src={addon1Img.src}
            alt="Customized Hydrogel Mask add-on at Menon Medispa"
            class="cpf-s7__card-img"
            loading="lazy"
            decoding="async"
            width="110"
            height="110"
          />
        </div>
        <div class="cpf-s7__card-body">
          <h3 class="cpf-s7__card-title">Customized Hydrogel Mask</h3>
          <p class="cpf-s7__card-price">$25</p>
        </div>
      </div>

      <div class="cpf-s7__card">
        <div class="cpf-s7__card-img-wrap">
          <img
            src={addon2Img.src}
            alt="Eye Treatment add-on at Menon Medispa"
            class="cpf-s7__card-img"
            loading="lazy"
            decoding="async"
            width="110"
            height="110"
          />
        </div>
        <div class="cpf-s7__card-body">
          <h3 class="cpf-s7__card-title">Eye Treatment</h3>
          <p class="cpf-s7__card-price">$10</p>
        </div>
      </div>

      <div class="cpf-s7__card">
        <div class="cpf-s7__card-img-wrap">
          <img
            src={addon3Img.src}
            alt="Manual Lymph Drainage add-on at Menon Medispa"
            class="cpf-s7__card-img"
            loading="lazy"
            decoding="async"
            width="110"
            height="110"
          />
        </div>
        <div class="cpf-s7__card-body">
          <h3 class="cpf-s7__card-title">Manual Lymph Drainage</h3>
          <p class="cpf-s7__card-price">$50</p>
        </div>
      </div>

      <div class="cpf-s7__card">
        <div class="cpf-s7__card-img-wrap">
          <img
            src={addon4Img.src}
            alt="LED Light Therapy add-on at Menon Medispa"
            class="cpf-s7__card-img"
            loading="lazy"
            decoding="async"
            width="110"
            height="110"
          />
        </div>
        <div class="cpf-s7__card-body">
          <h3 class="cpf-s7__card-title">LED Light Therapy</h3>
          <p class="cpf-s7__card-price">$35</p>
        </div>
      </div>

      <div class="cpf-s7__card">
        <div class="cpf-s7__card-img-wrap">
          <img
            src={addon5Img.src}
            alt="Hydrafacial Lip Perk add-on at Menon Medispa"
            class="cpf-s7__card-img"
            loading="lazy"
            decoding="async"
            width="110"
            height="110"
          />
        </div>
        <div class="cpf-s7__card-body">
          <h3 class="cpf-s7__card-title">Hydrafacial Lip Perk</h3>
          <p class="cpf-s7__card-price">$30</p>
        </div>
      </div>

      <div class="cpf-s7__card">
        <div class="cpf-s7__card-img-wrap">
          <img
            src={addon6Img.src}
            alt="Hydrafacial Eye Perk add-on at Menon Medispa"
            class="cpf-s7__card-img"
            loading="lazy"
            decoding="async"
            width="110"
            height="110"
          />
        </div>
        <div class="cpf-s7__card-body">
          <h3 class="cpf-s7__card-title">Hydrafacial Eye Perk</h3>
          <p class="cpf-s7__card-price">$40</p>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .cpf-s7 .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .cpf-s7__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
    text-align: center;
  }

  .cpf-s7__intro {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
    text-align: center;
    max-width: 700px;
    align-self: center;
  }

  .cpf-s7__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .cpf-s7__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    text-align: center;
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.05);
  }

  .cpf-s7__card-img-wrap {
    width: 110px;
    height: 110px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    flex-shrink: 0;
  }

  .cpf-s7__card-img {
    width: 110px;
    height: 110px;
    object-fit: cover;
    display: block;
  }

  .cpf-s7__card-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cpf-s7__card-title {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .cpf-s7__card-price {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .cpf-s7__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .cpf-s7__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .cpf-s7__grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin-inline: auto;
    }
  }
</style>
