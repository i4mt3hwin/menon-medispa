---
---

<section class="section cpf-s8">
  <div class="container--narrow">

    <h2 class="cpf-s8__heading">Frequently asked questions</h2>

    <div class="cpf-s8__faq">

      <details class="cpf-s8__item">
        <summary class="cpf-s8__question">Will the chemical peel hurt or cause significant discomfort?</summary>
      </details>

      <details class="cpf-s8__item">
        <summary class="cpf-s8__question">How often can I get chemical peels and when will I see results?</summary>
      </details>

      <details class="cpf-s8__item">
        <summary class="cpf-s8__question">Who shouldn't get chemical peels?</summary>
      </details>

      <details class="cpf-s8__item">
        <summary class="cpf-s8__question">How is this different from at-home peels or facials?</summary>
      </details>

    </div>

    <div class="cpf-s8__lead-form">
      <h3 class="cpf-s8__form-heading">Have more questions? Send us a message.</h3>
      <form class="cpf-s8__form" name="chemical-peel-inquiry" method="POST" action="#">
        <div class="cpf-s8__form-row">
          <label class="cpf-s8__label" for="cpf-name">Name</label>
          <input
            class="cpf-s8__input"
            type="text"
            id="cpf-name"
            name="name"
            placeholder="Your name"
            required
          />
        </div>
        <div class="cpf-s8__form-row">
          <label class="cpf-s8__label" for="cpf-email">Email</label>
          <input
            class="cpf-s8__input"
            type="email"
            id="cpf-email"
            name="email"
            placeholder="Your email"
            required
          />
        </div>
        <div class="cpf-s8__form-row">
          <label class="cpf-s8__label" for="cpf-phone">Phone</label>
          <input
            class="cpf-s8__input"
            type="tel"
            id="cpf-phone"
            name="phone"
            placeholder="Your phone number"
          />
        </div>
        <div class="cpf-s8__form-row cpf-s8__form-row--hidden" aria-hidden="true">
          <input
            type="hidden"
            id="cpf-service"
            name="service"
            value="Chemical Peel Facial"
          />
        </div>
        <div class="cpf-s8__form-row">
          <label class="cpf-s8__label" for="cpf-message">Message</label>
          <textarea
            class="cpf-s8__textarea"
            id="cpf-message"
            name="message"
            rows="4"
            placeholder="Your message or question"
          ></textarea>
        </div>
        <div class="cpf-s8__form-submit">
          <button class="btn btn--primary" type="submit">Send Message</button>
        </div>
      </form>
    </div>

  </div>
</section>

<style>
  .cpf-s8 .container--narrow {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .cpf-s8__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
    text-align: center;
  }

  .cpf-s8__faq {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .cpf-s8__item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .cpf-s8__item[open] .cpf-s8__question {
    font-weight: var(--weight-bold);
  }

  .cpf-s8__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    line-height: 1.5;
    gap: var(--space-sm);
  }

  .cpf-s8__question::-webkit-details-marker {
    display: none;
  }

  .cpf-s8__question::after {
    content: '+';
    font-size: var(--text-lg);
    font-weight: var(--weight-regular);
    flex-shrink: 0;
    line-height: 1;
    color: var(--color-text);
    opacity: 0.6;
  }

  .cpf-s8__item[open] .cpf-s8__question::after {
    content: '\2212';
  }

  /* Lead Form */
  .cpf-s8__lead-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cpf-s8__form-heading {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
    text-align: center;
  }

  .cpf-s8__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .cpf-s8__form-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cpf-s8__form-row--hidden {
    display: none;
  }

  .cpf-s8__label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    letter-spacing: 0.03em;
  }

  .cpf-s8__input, .cpf-s8__textarea {
    width: 100%;
    box-sizing: border-box;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: var(--radius-sm);
    outline: none;
    transition: border-color 0.2s;
    appearance: none;
  }

  .cpf-s8__input:focus, .cpf-s8__textarea:focus {
    border-color: var(--color-cta);
  }

  .cpf-s8__textarea {
    resize: vertical;
    min-height: 100px;
  }

  .cpf-s8__form-submit {
    margin-top: var(--space-xs);
  }

  @media (max-width: 768px) {
    .cpf-s8__form-submit .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
