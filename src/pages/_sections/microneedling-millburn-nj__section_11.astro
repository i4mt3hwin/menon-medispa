---
{/* BREAKDANCE: hand-authored from structure.json */}
{/*
  Section 11, _is_lightbox "June SALES"
  Rendered as static CtaBanner + deal cards (lightbox suppressed in static output).
*/}
import site from '@/lib/site';

import imgBrotox from '@/assets/images/56a3e3ac1335.jpg';
import imgHydrafacial from '@/assets/images/86072f9cbd9c.jpg';
import imgCustomIv from '@/assets/images/dd355e57f3dd.jpg';
---

<section class="section section--tint s11-promos">
  <div class="container">

    <div class="s11-promos__banner">
      <h2 class="s11-promos__heading">June SALES</h2>
      <p class="s11-promos__subtext">Limited-time specials on our most popular treatments. Book today before they're gone.</p>
      <a href="/sale" class="btn btn--primary btn--lg s11-promos__top-cta">Explore all sales</a>
    </div>

    <div class="s11-promos__grid">

      <div class="s11-promos__card">
        <div class="s11-promos__card-img-wrap">
          <img
            src={imgBrotox.src}
            alt="BRO-tox Fathers Day Special"
            class="s11-promos__card-img"
            loading="lazy"
            decoding="async"
            width="400"
            height="300"
          />
        </div>
        <div class="s11-promos__card-body">
          <h3 class="s11-promos__card-title">BRO-tox Fathers Day Special</h3>
          <ul class="s11-promos__card-list">
            <li>Botox $12 Per Unit</li>
            <li>Smooths forehead, frown lines &amp; crow's feet</li>
            <li>Personalized Treatment Plan with Dr. Menon</li>
          </ul>
        </div>
        <div class="s11-promos__card-cta">
          <a
            href={site.calcomUrl}
            class="btn btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Book Now
          </a>
        </div>
      </div>

      <div class="s11-promos__card">
        <div class="s11-promos__card-img-wrap">
          <img
            src={imgHydrafacial.src}
            alt="Summer Glow HydraFacial"
            class="s11-promos__card-img"
            loading="lazy"
            decoding="async"
            width="400"
            height="300"
          />
        </div>
        <div class="s11-promos__card-body">
          <h3 class="s11-promos__card-title">Summer Glow HydraFacial</h3>
          <ul class="s11-promos__card-list">
            <li>Vitamin C Booster +</li>
            <li>Discount Dermaplaning $25</li>
            <li>($285 Value for $225)</li>
          </ul>
        </div>
        <div class="s11-promos__card-cta">
          <a
            href={site.calcomUrl}
            class="btn btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Book Now
          </a>
        </div>
      </div>

      <div class="s11-promos__card">
        <div class="s11-promos__card-img-wrap">
          <img
            src={imgCustomIv.src}
            alt="Custom Hydrating IV"
            class="s11-promos__card-img"
            loading="lazy"
            decoding="async"
            width="400"
            height="300"
          />
        </div>
        <div class="s11-promos__card-body">
          <h3 class="s11-promos__card-title">Custom Hydrating IV</h3>
          <ul class="s11-promos__card-list">
            <li>$99 Special Price</li>
            <li>Includes any two vitamins</li>
            <li>Hydrate, recharge, glow</li>
          </ul>
        </div>
        <div class="s11-promos__card-cta">
          <a
            href={site.calcomUrl}
            class="btn btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Book Now
          </a>
        </div>
      </div>

    </div>

    <div class="s11-promos__footer-cta">
      <a href="/sale" class="btn btn--primary btn--lg">Explore all sales</a>
    </div>

  </div>
</section>

<style>
  .s11-promos__banner {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .s11-promos__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    line-height: 1.3;
  }

  .s11-promos__subtext {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0 0 var(--space-md);
    line-height: 1.6;
  }

  .s11-promos__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    width: 100%;
  }

  .s11-promos__card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-bg);
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.05);
  }

  .s11-promos__card-img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .s11-promos__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .s11-promos__card:hover .s11-promos__card-img {
    transform: scale(1.04);
  }

  .s11-promos__card-body {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .s11-promos__card-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s11-promos__card-list {
    list-style: disc;
    margin: 0;
    padding: 0 0 0 1.2em;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .s11-promos__card-list li {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .s11-promos__card-cta {
    padding: var(--space-sm);
    margin-top: auto;
  }

  .s11-promos__footer-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 900px) {
    .s11-promos__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .s11-promos__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }

    .s11-promos__footer-cta .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
