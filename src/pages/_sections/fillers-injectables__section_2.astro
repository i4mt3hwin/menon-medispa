<section class="section section--tight section--tint fi-s2-trust">
  <div class="container">
    <ul class="fi-s2__bar" role="list">
      <li class="fi-s2__item">Customized Treatment Plans</li>
      <li class="fi-s2__divider" aria-hidden="true"></li>
      <li class="fi-s2__item">Medical-Grade</li>
      <li class="fi-s2__divider" aria-hidden="true"></li>
      <li class="fi-s2__item">Led by Dr. Aditi Menon, MD</li>
    </ul>
  </div>
</section>

<style>
  .fi-s2__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .fi-s2__item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .fi-s2__divider {
    width: 1px;
    height: 24px;
    background: rgba(0, 0, 0, 0.18);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .fi-s2__bar {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .fi-s2__divider {
      display: none;
    }
  }
</style>
