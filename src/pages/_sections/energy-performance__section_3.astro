---
import site from '@/lib/site'
---

<section class="section section--tint ep3-formulas">
  <div class="container">

    <h2 class="ep3-formulas__heading">Choose Your Energy &amp; Performance Formula</h2>

    <div class="ep3-formulas__grid">

      <div class="ep3-formulas__card">
        <p class="ep3-formulas__card-title"><strong>ENERGY (Signature)</strong></p>
        <p class="ep3-formulas__card-desc">Best for a fast-acting, targeted boost to fight fatigue and sharpen mental focus.</p>
        <ul class="ep3-formulas__card-list">
          <li>B12 &amp; Taurine</li>
          <li>Vitamin C &amp; Glutathione</li>
          <li>Minerals</li>
        </ul>
      </div>

      <div class="ep3-formulas__card">
        <p class="ep3-formulas__card-title"><strong>ENERGY (Deluxe)</strong></p>
        <p class="ep3-formulas__card-desc">Best for comprehensive metabolic support, sustained athletic performance, and faster recovery.</p>
        <ul class="ep3-formulas__card-list">
          <li>Everything in Signature</li>
          <li>Complete B-Complex (B5, Niacin &amp; more)</li>
          <li>Magnesium &amp; Zinc</li>
          <li>Amino Acids</li>
        </ul>
      </div>

    </div>

    <div class="ep3-formulas__cta">
      <a href={site.calcomUrl} class="btn btn--primary btn--lg">Schedule Now</a>
    </div>

  </div>
</section>

<style>
  .ep3-formulas__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
    text-align: center;
  }

  .ep3-formulas__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .ep3-formulas__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    padding: var(--space-md);
    background: var(--color-bg);
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.05);
  }

  .ep3-formulas__card-title {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .ep3-formulas__card-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .ep3-formulas__card-list {
    list-style: disc;
    margin: var(--space-xs) 0 0;
    padding: 0 0 0 1.2em;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ep3-formulas__card-list li {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .ep3-formulas__cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 768px) {
    .ep3-formulas__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }

    .ep3-formulas__cta .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
