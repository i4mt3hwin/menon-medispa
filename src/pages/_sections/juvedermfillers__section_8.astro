---
import img1 from '@/assets/images/56a3e3ac1335.jpg';
import img2 from '@/assets/images/86072f9cbd9c.jpg';
import img3 from '@/assets/images/dd355e57f3dd.jpg';
---

<section class="section section--tint s11-promos">
  <div class="container">

    <h2 class="s11-promos__heading">June SALES</h2>

    <div class="s11-promos__grid">

      <div class="s11-promos__card">
        <div class="s11-promos__card-img-wrap">
          <img
            src={img1.src}
            alt="shutterstock_2193199469.jpg"
            class="s11-promos__card-img"
            loading="lazy"
            decoding="async"
            width="150"
            height="147"
          />
        </div>
        <div class="s11-promos__card-body">
          <h3 class="s11-promos__card-title">BRO-tox Fathers Day Special</h3>
          <p class="s11-promos__card-label">Includes:</p>
          <ul class="s11-promos__card-list">
            <li>Botox $12 Per Unit</li>
            <li>Smooths forehead, frown lines &amp; crow's feet</li>
            <li>Personalized Treatment Plan with Dr. Menon</li>
          </ul>
        </div>
      </div>

      <div class="s11-promos__card">
        <div class="s11-promos__card-img-wrap">
          <img
            src={img2.src}
            alt="Hydrafacial.jpg"
            class="s11-promos__card-img"
            loading="lazy"
            decoding="async"
            width="150"
            height="147"
          />
        </div>
        <div class="s11-promos__card-body">
          <h3 class="s11-promos__card-title">Summer Glow HydraFacial</h3>
          <ul class="s11-promos__card-list">
            <li>Vitamin C Booster +&#8203;</li>
            <li>Discount Dermaplaning $25</li>
            <li>($285 Value for $225)</li>
          </ul>
        </div>
      </div>

      <div class="s11-promos__card">
        <div class="s11-promos__card-img-wrap">
          <img
            src={img3.src}
            alt="shutterstock_2578361641.jpg"
            class="s11-promos__card-img"
            loading="lazy"
            decoding="async"
            width="150"
            height="147"
          />
        </div>
        <div class="s11-promos__card-body">
          <h3 class="s11-promos__card-title">Custom Hydrating IV</h3>
          <ul class="s11-promos__card-list">
            <li>$99 Special Price&#8203;</li>
            <li>Includes any two vitamins</li>
            <li>Hydrate, recharge, glow</li>
          </ul>
        </div>
      </div>

    </div>

    <div class="s11-promos__cta">
      <a href="/sale" class="btn btn--primary btn--lg">
        Explore all sales
      </a>
    </div>

  </div>
</section>

<style>
  .s11-promos__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    line-height: 1.3;
    text-align: center;
  }

  .s11-promos__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    width: 100%;
  }

  .s11-promos__card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-bg);
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.05);
  }

  .s11-promos__card-img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .s11-promos__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .s11-promos__card:hover .s11-promos__card-img {
    transform: scale(1.04);
  }

  .s11-promos__card-body {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .s11-promos__card-title {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .s11-promos__card-label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.5;
  }

  .s11-promos__card-list {
    list-style: disc;
    margin: 0;
    padding: 0 0 0 1.2em;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .s11-promos__card-list li {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .s11-promos__cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 900px) {
    .s11-promos__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .s11-promos__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }

    .s11-promos__cta .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
