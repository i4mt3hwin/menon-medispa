---
import site from '@/lib/site';

import heroPhoto from '@/assets/images/fc3ca8a7bdf0.jpg';
import socialIcon1 from '@/assets/images/90411e0041df.webp';
import socialIcon2 from '@/assets/images/305afeda5f9a.webp';
import socialIcon3 from '@/assets/images/b95880091b44.webp';
---

<section class="section is1-hero">
  <div class="container">
    <div class="is1-hero__layout">

      <div class="is1-hero__text">
        <h1 class="is1-hero__h1">Immune Support IV Therapy in Millburn NJ</h1>

        <h2 class="is1-hero__subheading">
          Live life uninterrupted by seasonal bugs and illness.
        </h2>

        <p class="is1-hero__body">
          Feeling run down, constantly catching colds, or preparing for travel? Our Immune Support IV drips deliver a powerful blend of vitamins, antioxidants, and minerals directly to your bloodstream. This bypasses the gut, ensuring 100% absorption to help you recover faster, feel stronger, and maintain peak wellness year-round.
        </p>

        <div class="is1-hero__ctas">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
          >
            Book Your IV Therapy
          </a>
        </div>

        <div class="is1-hero__social-proof">
          <div class="is1-hero__social-icons">
            <img src={socialIcon1.src} alt="Review platform" class="is1-hero__social-icon" loading="lazy" decoding="async" width="46" height="50" />
            <img src={socialIcon2.src} alt="Review platform" class="is1-hero__social-icon" loading="lazy" decoding="async" width="52" height="50" />
            <img src={socialIcon3.src} alt="Review platform" class="is1-hero__social-icon" loading="lazy" decoding="async" width="52" height="50" />
          </div>
          <div class="is1-hero__stars-block">
            <p class="is1-hero__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            <p class="is1-hero__review-count">100+ 5 Star Reviews</p>
          </div>
        </div>
      </div>

      <div class="is1-hero__img-col">
        <img
          src={heroPhoto.src}
          alt="IV therapy immune support at Menon Medispa Millburn NJ"
          class="is1-hero__img"
          loading="eager"
          decoding="async"
          width="520"
          height="600"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .is1-hero__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .is1-hero__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 620px;
  }

  .is1-hero__h1 {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .is1-hero__subheading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .is1-hero__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .is1-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .is1-hero__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
    flex-wrap: wrap;
  }

  .is1-hero__social-icons {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .is1-hero__social-icon {
    display: block;
    object-fit: contain;
  }

  .is1-hero__stars-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .is1-hero__stars {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1;
  }

  .is1-hero__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .is1-hero__img-col {
    flex-shrink: 0;
    width: 520px;
  }

  .is1-hero__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }

  @media (max-width: 1024px) {
    .is1-hero__img-col {
      width: 380px;
    }
  }

  @media (max-width: 768px) {
    .is1-hero__layout {
      flex-direction: column;
    }

    .is1-hero__text {
      max-width: 100%;
    }

    .is1-hero__img-col {
      width: 100%;
    }

    .is1-hero__ctas {
      flex-direction: column;
    }

    .is1-hero__ctas .btn {
      width: 100%;
      text-align: center;
    }

    .is1-hero__social-proof {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
