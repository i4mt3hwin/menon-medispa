---
import sectionBg from '@/assets/images/30cfb9e87c60.png';
import googleRatingImg from '@/assets/images/5be44787b3a9.png';
---

<section class="media-bg section prp-h-s6" style="--scrim-strength:0.58">
  <img class="media-bg__img media-bg__img--blur" src={sectionBg.src} alt="" aria-hidden="true" loading="lazy" decoding="async" width="1440" height="585" />
  <span class="media-bg__scrim media-bg__scrim--brand"></span>

  <div class="media-bg__inner container on-media">
    <div class="prp-h-s6__inner">

      <h3 class="prp-h-s6__label">What Our Clients Say</h3>

      <blockquote class="prp-h-s6__quote">
        <p class="prp-h-s6__quote-text">
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
        </p>
        <footer class="prp-h-s6__footer">
          <cite class="prp-h-s6__cite">Alexa C.</cite>
        </footer>
      </blockquote>

      <div class="prp-h-s6__stars">
        <img
          src={googleRatingImg.src}
          alt="Google 5 star rating"
          class="prp-h-s6__stars-img"
          loading="lazy"
          decoding="async"
          width="143"
          height="74"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .prp-h-s6__inner {
    max-width: var(--container-narrow);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .prp-h-s6__label {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  .prp-h-s6__quote {
    margin: 0;
    padding: 0;
  }

  .prp-h-s6__quote-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    margin: 0 0 var(--space-sm);
    line-height: 1.7;
    font-style: italic;
  }

  .prp-h-s6__footer {
    font-style: normal;
  }

  .prp-h-s6__cite {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    font-style: normal;
  }

  .prp-h-s6__stars {
    display: flex;
    justify-content: center;
  }

  .prp-h-s6__stars-img {
    display: block;
    height: auto;
    width: 143px;
    object-fit: contain;
  }
</style>
