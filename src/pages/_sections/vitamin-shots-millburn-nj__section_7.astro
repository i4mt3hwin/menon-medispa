---
import site from '@/lib/site';
import staffImg from '@/assets/images/b1a819f35921.webp';
---

<!-- Section 7: Final CTA, Begin Your Vitamin Shot Routine Today -->
<section class="section section--dark vs-s7">
  <div class="container">
    <div class="vs-s7__layout">

      <div class="vs-s7__text">
        <h2 class="vs-s7__heading">Begin Your Vitamin Shot Routine Today</h2>
        <p class="vs-s7__subtitle">Menon Medispa Millburn NJ</p>
        <p class="vs-s7__body">
          Ready to experience the fast, revitalizing benefits of our Vitamin Shots? Take the first step toward boosting your energy, immunity, and overall wellness by booking your personalized vitamin injection at Menon Medispa in Millburn, NJ.
        </p>
        <div class="vs-s7__actions">
          <a href={site.calcomUrl} class="btn btn--primary btn--lg">Schedule Consultation</a>
        </div>
      </div>

      <div class="vs-s7__img-col">
        <img
          src={staffImg.src}
          alt="Menon Medispa Office Staff"
          class="vs-s7__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="560"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .vs-s7__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .vs-s7__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .vs-s7__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .vs-s7__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .vs-s7__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .vs-s7__actions {
    margin-top: var(--space-xs);
  }

  .vs-s7__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .vs-s7__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .vs-s7__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .vs-s7__layout {
      flex-direction: column;
    }

    .vs-s7__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .vs-s7__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
