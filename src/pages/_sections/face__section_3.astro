---
import TreatmentCard from '@/components/TreatmentCard.astro';

import imgMenonFacials from '@/assets/images/04bf461982db.jpg';
import imgHydrafacial from '@/assets/images/34ef44b50a1c.jpg';
import imgLaserFacials from '@/assets/images/3be5824bfbc0.jpg';
import imgFillers from '@/assets/images/db8d4e94db1e.jpg';
import imgMicroneedling from '@/assets/images/cebad624861f.jpg';

const treatments = [
  {
    name: 'Menon Facials',
    href: '/menon-facials',
    img: imgMenonFacials,
    alt: 'Menon signature facial treatment',
    descriptor: 'Visible results from your very first treatment',
  },
  {
    name: 'HydraFacial',
    href: '/hydrafacial',
    img: imgHydrafacial,
    alt: 'HydraFacial treatment at Menon Medispa',
    descriptor: 'Smooth, youthful skin with zero downtime',
  },
  {
    name: 'Laser Facials',
    href: '/laser-facials',
    img: imgLaserFacials,
    alt: 'ClearLift / DYE-VL laser facial treatment',
    descriptor: 'Tighten skin and reduce pigmentation, zero downtime',
  },
  {
    name: 'Fillers & Injectables',
    href: '/fillers-injectables',
    img: imgFillers,
    alt: 'Fillers and injectables at Menon Medispa',
    descriptor: 'Botox & Juvéderm for a naturally refreshed look',
  },
  {
    name: 'Microneedling',
    href: '/microneedling-millburn-nj',
    img: imgMicroneedling,
    alt: 'SkinPen microneedling treatment',
    descriptor: "Stimulate your skin's natural healing power",
  },
];
---

<section class="section face-grid">
  <div class="container">

    <div class="face-grid__intro">
      <h2 class="face-grid__heading">Comprehensive Facial Treatments &amp; Enhancements</h2>
      <p class="face-grid__body">
        We specialize in comprehensive facial treatments, using medical-grade techniques and the latest technology to address your unique skin concerns. Whether you&rsquo;re seeking rejuvenation, correction, or enhancement, our expert team will guide you to the perfect treatment plan.
      </p>
    </div>

    <div class="face-grid__cards">
      {treatments.map((t) => (
        <TreatmentCard
          name={t.name}
          href={t.href}
          img={t.img}
          alt={t.alt}
          descriptor={t.descriptor}
        />
      ))}
    </div>

    <div class="face-grid__sub-cta">
      <h3 class="face-grid__sub-heading">Don&rsquo;t Know Which Treatment is Best For You?</h3>
      <p class="face-grid__sub-body">
        Book a Consultation! Get 30 minutes with the esthetician for FREE or 30 minutes with Dr. Menon for $50 (applied towards treatment!)
      </p>
      <a href="/consultation" class="btn btn--primary btn--lg">Book a Consultation</a>
    </div>

  </div>
</section>

<style>
  .face-grid .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .face-grid__intro {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .face-grid__intro .eyebrow { margin: 0; color: var(--color-cta); }

  .face-grid__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .face-grid__body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: var(--space-xs) 0 0;
    line-height: 1.6;
  }

  /* Overlay-card grid: 3-up desktop, 2 tablet, 1 phone */
  .face-grid__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  /* Sub-CTA block */
  .face-grid__sub-cta {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: rgba(196, 164, 132, 0.08);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(0, 0, 0, 0.07);
  }

  .face-grid__sub-heading {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .face-grid__sub-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .face-grid__cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .face-grid__cards {
      grid-template-columns: 1fr;
      /* explicit width: the cards are aspect-ratio boxes with all-absolute content (0 intrinsic
         width), and `margin:0 auto` cancels flex-stretch in the column — without this the grid
         collapses to 0 width and the cards vanish on mobile. */
      width: 100%;
      max-width: 360px;
      margin: 0 auto;
    }

    .face-grid__sub-cta {
      padding: var(--space-md) var(--space-sm);
    }

    .face-grid__sub-cta .btn {
      align-self: stretch;
      text-align: center;
    }
  }
</style>
