---
import SectionHeading from '@/components/SectionHeading.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import LeadForm from '@/components/LeadForm.astro';
---

<section class="home-section-12">
  <SectionHeading
    text="Frequently asked questions"
    tag="h2"
    align="center"
    font="display"
  />

  <FaqAccordion
    items={[
      {
        question: 'What services does Menon Medispa offer?',
        answer_html: '<p>Please contact us or visit our services pages to learn about our full range of aesthetic and wellness treatments.</p>',
      },
      {
        question: 'What areas do you serve?',
        answer_html: '<p>Menon Medispa is located in Millburn, NJ and serves surrounding communities including Short Hills, Summit, Maplewood, Livingston, Springfield, Vauxhall, and West Orange.</p>',
      },
      {
        question: 'How do I schedule?',
        answer_html: '<p>You can schedule a consultation or treatment online through our booking system, or call us at (973) 494-8431.</p>',
      },
      {
        question: 'What makes Menon Medispa different?',
        answer_html: '<p>We combine medical excellence, cutting-edge technology, and personalized care led by Dr. Aditi Menon, MD, delivering superior aesthetic results in a warm, discreet environment.</p>',
      },
      {
        question: 'What should I expect first visit?',
        answer_html: '<p>Your first visit begins with a comprehensive consultation so we can understand your goals and design a customized treatment plan tailored to your unique needs.</p>',
      },
    ]}
  />

  <div class="home-section-12__lead-form">
    <LeadForm
      heading="Contact Us"
      fields={['name', 'email', 'phone', 'message']}
      submit_label="Send Message"
      success_url="/thank-you"
    />
  </div>
</section>

<style>
  .home-section-12 {
    width: 100%;
    box-sizing: border-box;
    padding: var(--space-xl) var(--space-lg);
  }

  .home-section-12 .section-heading {
    margin-bottom: var(--space-md);
  }

  /* FaqAccordion has its own padding, trim it inside this section */
  .home-section-12 :global(.faq-accordion) {
    padding: 0;
  }

  .home-section-12__lead-form {
    margin-top: var(--space-lg);
  }

  /* LeadForm has its own padding, trim it */
  .home-section-12__lead-form :global(.lead-form) {
    padding: 0;
  }

  @media (max-width: 980px) {
    .home-section-12 {
      padding: var(--space-lg) var(--space-sm);
    }
  }
</style>
