---
import TreatmentCard from '@/components/TreatmentCard.astro';

import svcImg1 from '@/assets/images/02127013d183.jpg';
import svcImg2 from '@/assets/images/e6d509254f0c.jpg';

const treatments = [
  {
    name: 'HydraFacial Keravive',
    href: '/hydrafacial-keravive',
    img: svcImg1,
    alt: 'HydraFacial Keravive scalp treatment at Menon Medispa',
    descriptor: 'Rejuvenate Your Scalp to Reveal Fuller, Healthier-Looking Hair',
  },
  {
    name: 'PRP Hair Restoration',
    href: '/platelet-rich-plasma-hair-millburn',
    img: svcImg2,
    alt: 'PRP hair restoration treatment at Menon Medispa',
    descriptor: 'Stimulate natural hair growth using your body\'s own healing factors',
  },
];
---

<section class="section hair-grid">
  <div class="container">

    <div class="hair-grid__cards-section">
      <h2 class="hair-grid__cards-heading">Treatments for Thinning Hair &amp; Scalp Health</h2>
      <p class="hair-grid__cards-sub">
        Physician-led treatments for thinning hair and scalp health, from PRP hair therapy to HydraFacial Keravive.
      </p>

      <div class="hair-grid__cards">
        {treatments.map((t) => (
          <TreatmentCard
            name={t.name}
            href={t.href}
            img={t.img}
            alt={t.alt}
            descriptor={t.descriptor}
            ratio="3 / 4"
          />
        ))}
      </div>
    </div>

    <div class="hair-grid__sub-cta">
      <h3 class="hair-grid__sub-heading">Not Sure Which Hair Treatment Is Right for You?</h3>
      <p class="hair-grid__sub-body">
        Book a consultation and our medical team will recommend a scalp and hair plan built around your goals.
      </p>
      <a href="/consultation" class="btn btn--primary btn--lg">Book a Consultation</a>
    </div>

  </div>
</section>

<style>
  .hair-grid .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  /* Mid-page consultation CTA */
  .hair-grid__sub-cta {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: rgba(196, 164, 132, 0.08);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(0, 0, 0, 0.07);
  }

  .hair-grid__sub-heading {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .hair-grid__sub-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  /* Cards section */
  .hair-grid__cards-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .hair-grid__cards-heading {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    text-align: center;
    line-height: 1.3;
  }

  .hair-grid__cards-sub {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    text-align: center;
    line-height: 1.6;
    max-width: 640px;
  }

  /* 2-column grid; wider max-width so cards are large side-by-side */
  .hair-grid__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    width: 100%;
    max-width: 860px;
  }

  @media (max-width: 600px) {
    /* 2-up on phones so the cards are compact (was 1-up at 380px = oversized).
       minmax(0,1fr) is required: aspect-ratio cards have 0 intrinsic width, so a
       bare 1fr track collapses them to 0. */
    .hair-grid__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-sm);
      max-width: 100%;
    }
    /* tighten the overlay text so the smaller 2-up cards don't feel cramped */
    .hair-grid__cards :global(.tcard__body) { padding: var(--space-sm); gap: 3px; }
    .hair-grid__cards :global(.tcard__name) { font-size: var(--text-base); line-height: 1.1; }
    .hair-grid__cards :global(.tcard__desc) { font-size: var(--text-xs); line-height: 1.3; }
    .hair-grid__cards :global(.tcard__cue) { display: none; }

    .hair-grid__sub-cta {
      padding: var(--space-md) var(--space-sm);
    }

    .hair-grid__sub-cta .btn {
      align-self: stretch;
      text-align: center;
    }
  }
</style>
