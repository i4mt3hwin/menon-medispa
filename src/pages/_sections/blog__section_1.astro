<section class="blog-s1">
  <div class="blog-s1__inner">

    <h1 class="blog-s1__heading">Menon Medispa &amp; Wellness Blog</h1>

    <p class="blog-s1__intro">
      Expert insights on skincare, wellness, and aesthetics from the team at Menon Medispa in Millburn, NJ.
    </p>

    <div class="blog-s1__list-placeholder">
      <p class="blog-s1__placeholder-text">
        Browse our latest articles below. From skincare tips and treatment guides to wellness advice and seasonal promotions, our blog keeps you informed and inspired.
      </p>
    </div>

  </div>
</section>

<style>
  .blog-s1 {
    width: 100%;
    box-sizing: border-box;
    padding: var(--space-xl) var(--space-lg);
  }

  .blog-s1__inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: center;
    text-align: center;
  }

  .blog-s1__heading {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .blog-s1__intro {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
    max-width: 640px;
  }

  .blog-s1__list-placeholder {
    width: 100%;
    padding: var(--space-xl) var(--space-md);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  .blog-s1__placeholder-text {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .blog-s1 {
      padding: var(--space-lg) var(--space-sm);
    }
