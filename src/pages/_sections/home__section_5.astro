---
import SectionHeading from '@/components/SectionHeading.astro';
import RichText from '@/components/RichText.astro';
import ServicesGrid from '@/components/ServicesGrid.astro';
import Button from '@/components/Button.astro';
import hydrafacialImg from '@/assets/images/86072f9cbd9c.jpg';
import ivImg from '@/assets/images/dd355e57f3dd.jpg';
import brotoxImg from '@/assets/images/56a3e3ac1335.jpg';
---

<section class="monthly-specials">
  <div class="monthly-specials__header">
    <RichText
      html="MUST TRY"
      font="var(--font-ui)"
      size="var(--text-xs)"
      class="monthly-specials__eyebrow"
    />
    <SectionHeading
      text="Monthly Specials"
      tag="h2"
      align="center"
      font="display"
    />
  </div>

  <div class="monthly-specials__list">

    {/* Card 1, Summer Glow Hydrafacial */}
    <div class="specials-card">
      <div class="specials-card__img-wrap">
        <img
          src={hydrafacialImg.src}
          alt="Hydrafacial.jpg"
          class="specials-card__img"
          width="110"
          height="110"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="specials-card__body">
        <div class="specials-card__title-row">
          <a
            href="/request-appointment?service=Summer%20Glow%20Hydrafacial"
            class="specials-card__title-link"
          >Summer Glow Hydrafacial</a>
          <a
            href="/request-appointment?service=Summer%20Glow%20Hydrafacial"
            class="specials-card__read-more"
          >Read More</a>
        </div>
        <p class="specials-card__price">$225</p>
      </div>
      <div class="specials-card__cta-wrap">
        <Button
          text="Book Now"
          href="/request-appointment?service=Summer%20Glow%20Hydrafacial"
          variant="primary"
        />
      </div>
    </div>

    {/* Card 2, Custom Hydrating IV */}
    <div class="specials-card">
      <div class="specials-card__img-wrap">
        <img
          src={ivImg.src}
          alt="shutterstock_2578361641.jpg"
          class="specials-card__img"
          width="110"
          height="110"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="specials-card__body">
        <div class="specials-card__title-row">
          <a
            href="/request-appointment?service=Custom%20Hydrating%20IV"
            class="specials-card__title-link"
          >Custom Hydrating IV</a>
          <a
            href="/request-appointment?service=Custom%20Hydrating%20IV"
            class="specials-card__read-more"
          >Read More</a>
        </div>
        <p class="specials-card__price">$99</p>
      </div>
      <div class="specials-card__cta-wrap">
        <Button
          text="Book Now"
          href="/request-appointment?service=Custom%20Hydrating%20IV"
          variant="primary"
        />
      </div>
    </div>

    {/* Card 3, BRO-Tox Father's Day Special */}
    <div class="specials-card">
      <div class="specials-card__img-wrap">
        <img
          src={brotoxImg.src}
          alt="shutterstock_2193199469.jpg"
          class="specials-card__img"
          width="110"
          height="110"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="specials-card__body">
        <div class="specials-card__title-row">
          <a
            href="/request-appointment?service=BRO-Tox%20Father%27s%20Day%20Special"
            class="specials-card__title-link"
          >BRO-Tox Father's Day Special</a>
          <a
            href="/request-appointment?service=BRO-Tox%20Father%27s%20Day%20Special"
            class="specials-card__read-more"
          >Read More</a>
        </div>
        <p class="specials-card__price">$12 Per Unit</p>
      </div>
      <div class="specials-card__cta-wrap">
        <Button
          text="Book Now"
          href="/request-appointment?service=BRO-Tox%20Father%27s%20Day%20Special"
          variant="primary"
        />
      </div>
    </div>

  </div>
</section>

<style>
  .monthly-specials {
    width: 100%;
    box-sizing: border-box;
    padding: var(--space-xl) var(--space-lg);
  }

  .monthly-specials__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .monthly-specials__eyebrow {
    text-align: center;
    letter-spacing: 0.1em;
  }

  .monthly-specials__list {
    max-width: 940px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Each specials card, horizontal row: image | body | cta */
  .specials-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .specials-card:last-child {
    border-bottom: none;
  }

  .specials-card__img-wrap {
    flex-shrink: 0;
    width: 110px;
    height: 110px;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .specials-card__img {
    width: 110px;
    height: 110px;
    object-fit: cover;
    object-position: 50% 50%;
    display: block;
  }

  .specials-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .specials-card__title-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .specials-card__title-link {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.4;
  }

  .specials-card__title-link:hover {
    text-decoration: underline;
  }

  .specials-card__read-more {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    line-height: 1.5;
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .specials-card__price {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    line-height: 2;
    margin: 0;
  }

  .specials-card__cta-wrap {
    flex-shrink: 0;
  }

  /* Override btn width for this context, match Wix 151px */
  .specials-card__cta-wrap .btn {
    background-color: var(--color-accent);
    border: 1px solid rgba(117, 77, 77, 0.6);
    min-width: 151px;
    text-align: center;
  }

  @media (max-width: 980px) {
    .monthly-specials {
      padding: var(--space-lg) var(--space-sm);
    }

    .specials-card {
      flex-wrap: wrap;
    }

    .specials-card__cta-wrap {
      width: 100%;
    }

    .specials-card__cta-wrap .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
