---
import { site } from "@/lib/site";
import officeStaffImg from "@/assets/images/b1a819f35921.webp";
---

<!-- Section 6: Final CTA, Begin Your Transformation Today -->
<section class="section section--dark s6-cta">
  <div class="container">
    <div class="s6-cta__layout">

      <div class="s6-cta__text">
        <h2 class="s6-cta__heading">Begin Your Transformation Today</h2>
        <p class="s6-cta__subtitle"><strong>Menon Medispa Millburn NJ</strong></p>
        <p class="s6-cta__body">
          Ready to experience the benefits of Menon Medispa's Laser Facials? Take the first step
          toward Perfect Skin by scheduling your personal consultation at Menon Medispa in Millburn, NJ.
        </p>
        <div class="s6-cta__actions">
          <a
            href={site.calcomUrl}
            class="btn btn--primary btn--lg"
          >
            Schedule Consultation
          </a>
          <a
            href="tel:+19734948431"
            class="btn btn--secondary btn--on-dark btn--lg"
          >
            Call (973) 494-8431
          </a>
        </div>
      </div>

      <div class="s6-cta__img-col">
        <img
          src={officeStaffImg.src}
          alt="Menon Medispa office staff in Millburn NJ"
          class="s6-cta__img"
          loading="lazy"
          decoding="async"
          width="431"
          height="560"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .s6-cta__layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .s6-cta__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .s6-cta__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .s6-cta__subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .s6-cta__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    line-height: 1.6;
  }

  .s6-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .s6-cta__img-col {
    flex-shrink: 0;
    width: 380px;
  }

  .s6-cta__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 1024px) {
    .s6-cta__img-col {
      width: 300px;
    }
  }

  @media (max-width: 768px) {
    .s6-cta__layout {
      flex-direction: column;
    }

    .s6-cta__img-col {
      width: 100%;
      max-width: 300px;
      margin: 0 auto;
    }

    .s6-cta__actions {
      flex-direction: column;
    }

    .s6-cta__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
