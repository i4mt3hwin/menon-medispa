---
/**
 * HydraFacial™ Keravive™ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/hydrafacial-keravive/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="HydraFacial Keravive | Menon Medispa & Wellness | Millburn, NJ"
  description="HydraFacial Keravive scalp treatment in Millburn NJ. Cleanse, exfoliate, and nourish your scalp for healthier hair growth."
>
  <main class="sp" data-slug="hydrafacial-keravive">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="HydraFacial™ Keravive™">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">HydraFacial™ Keravive™</h1>
            <p class="sp-hero__eyebrow">The Only HydraFacial Treatment for Your Scalp</p>
            <p class="sp-hero__lead">HydraFacial Keravive is the world's first HydraFacial treatment designed specifically for your scalp. This 3-step treatment cleanses, exfoliates, and nourishes your scalp to promote healthier, fuller-looking hair.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/02127013d183.jpg" alt="HydraFacial™ Keravive™" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Scalp Deep Cleanse</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Promotes Hair Growth</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> No Downtime</p>
      </div>
    </section>

    
    {/* ===== THE 3-STEP KERAVIVE TREATMENT ===== */}
    <section class="sp-plain" aria-label="The 3-Step Keravive Treatment">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">The 3-Step Keravive Treatment</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Healthy hair starts with a healthy scalp. The HydraFacial Keravive treatment uses the patented HydraFacial vortex technology to deep-clean your scalp, removing buildup, excess oil, and dead skin cells that can clog follicles and hinder hair growth.</p>
<div style="display:flex;flex-direction:column;gap:0.85rem;margin:1.25rem 0;">
<div style="background:#f8f4f0;padding:1rem 1.25rem;border-radius:var(--radius-sm);"><strong style="font-family:var(--font-display);color:var(--color-ink);">Step 1: Cleanse &amp; Exfoliate</strong><p style="font-family:var(--font-ui);color:#5e5e5e;margin:0.25rem 0 0;font-size:var(--text-sm);line-height:1.6;">The HydraFacial tip deeply cleanses and exfoliates your scalp, removing buildup and dead skin cells.</p></div>
<div style="background:#f8f4f0;padding:1rem 1.25rem;border-radius:var(--radius-sm);"><strong style="font-family:var(--font-display);color:var(--color-ink);">Step 2: Hydrate</strong><p style="font-family:var(--font-ui);color:#5e5e5e;margin:0.25rem 0 0;font-size:var(--text-sm);line-height:1.6;">A specially formulated peptide-rich growth factor solution is infused into your scalp to nourish follicles.</p></div>
<div style="background:#f8f4f0;padding:1rem 1.25rem;border-radius:var(--radius-sm);"><strong style="font-family:var(--font-display);color:var(--color-ink);">Step 3: Extend at Home</strong><p style="font-family:var(--font-ui);color:#5e5e5e;margin:0.25rem 0 0;font-size:var(--text-sm);line-height:1.6;">You'll take home the Keravive Peptide Complex Spray to continue nourishing your scalp between treatments.</p></div>
</div>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How is Keravive different from regular scalp treatments?</summary>
              <div class="sp-faq__answer"><p>Unlike conventional scalp treatments that only work at the surface, HydraFacial Keravive uses vortex technology to deeply cleanse follicles and infuse nourishing ingredients directly into the scalp. The proprietary growth factor blend contains HGF, VEGF, and 8 other key growth factors that conventional products don't contain.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How many Keravive treatments do I need?</summary>
              <div class="sp-faq__answer"><p>We recommend a series of 3 monthly in-office treatments, followed by at-home use of the Keravive Peptide Complex Spray. Maintenance treatments every 3-6 months help sustain results.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Who is a good candidate for Keravive?</summary>
              <div class="sp-faq__answer"><p>Keravive is ideal for anyone concerned about scalp health, hair quality, or hair thinning. It's suitable for all hair and scalp types. Clients with psoriasis, active scalp infections, or open wounds should consult with us before treatment.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Nourish Your Scalp, Transform Your Hair">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Nourish Your Scalp, Transform Your Hair</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Book your HydraFacial Keravive treatment at Menon Medispa in Millburn, NJ and start your journey to a healthier scalp and fuller hair.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
