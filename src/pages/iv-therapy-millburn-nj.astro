---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceHero from '@/components/ServiceHero.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import SalePopup from '@/components/SalePopup.astro';

import { getRelatedPosts } from '@/lib/relatedPosts';
import { buildServiceSchema } from '@/lib/serviceSchema';

// Kept full-width experiential bands (reused verbatim from the original build)
import PromoBanner from '@/pages/_sections/iv-therapy-millburn-nj__section_1.astro';
import Gallery from '@/pages/_sections/iv-therapy-millburn-nj__section_2.astro';
import IvCategories from '@/pages/_sections/iv-therapy-millburn-nj__section_3.astro';
import DripsMenuHeading from '@/pages/_sections/iv-therapy-millburn-nj__section_6.astro';
import DripsMenu from '@/pages/_sections/iv-therapy-millburn-nj__section_7.astro';
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import ServiceReviews from '@/components/ServiceReviews.astro';
import FinalCta from '@/pages/_sections/iv-therapy-millburn-nj__section_9.astro';

import heroImg from '@/assets/images/fc3ca8a7bdf0.jpg';

const slug = 'iv-therapy-millburn-nj';
const posts = getRelatedPosts(slug);

// FAQ: built from the on-page drip menu/pricing + common IV-therapy search questions.
const faqs = [
  {
    question: 'How much does IV therapy cost at Menon Medispa?',
    answer:
      'Our signature 500ml IV drips start at $200, with deluxe and targeted blends at $250. NAD+ IV therapy ranges from $500 to $850 depending on the dose (250mg, 500mg, or 750mg). Dr. Menon’s team will help you choose the right drip for your goals at your visit.',
  },
  {
    question: 'What types of IV drips do you offer?',
    answer:
      'We offer a full IV drip menu, including Immune Support, Energy & Performance, Anti-Aging & Beauty, Recovery & Detox, NAD+ therapy, the classic Myers’ Cocktail, and targeted health blends for specific concerns. Each formula supports a different goal, and we can help you choose the right one.',
  },
  {
    question: 'What is NAD+ IV therapy?',
    answer:
      'NAD+ (nicotinamide adenine dinucleotide) is a coenzyme found in every cell that supports energy production and cellular repair. Our NAD+ IV therapy delivers it directly into the bloodstream and is offered in 250mg, 500mg, and 750mg doses. Many clients choose it for energy, focus, and anti-aging support.',
  },
  {
    question: 'Who administers IV therapy, and is it safe?',
    answer:
      'All IV therapy at Menon Medispa is provided in our Millburn, NJ medical office under the direction of Dr. Aditi Menon, MD. Your drip is selected based on your goals and health history for a safe, comfortable experience.',
  },
  {
    question: 'Does insurance cover IV therapy?',
    answer:
      'IV vitamin and wellness therapy is an elective service and is generally not covered by insurance. We provide clear, upfront pricing so you know exactly what to expect before your treatment.',
  },
];
const faqItems = [
  {
    question: 'How much does IV therapy cost at Menon Medispa?',
    answer_html:
      '<p>Our signature 500ml IV drips start at $200, with deluxe and targeted blends at $250. NAD+ IV therapy ranges from $500 to $850 depending on the dose (250mg, 500mg, or 750mg). Dr. Menon&rsquo;s team will help you choose the right drip for your goals at your visit.</p>',
  },
  {
    question: 'What types of IV drips do you offer?',
    answer_html:
      '<p>We offer a full IV drip menu, including:</p><ul><li>Immune Support</li><li>Energy &amp; Performance</li><li>Anti-Aging &amp; Beauty</li><li>Recovery &amp; Detox</li><li>NAD+ therapy</li><li>The classic Myers&rsquo; Cocktail</li><li>Targeted health blends for specific concerns</li></ul><p>Each formula supports a different goal, and we can help you choose the right one.</p>',
  },
  {
    question: 'What is NAD+ IV therapy?',
    answer_html:
      '<p>NAD+ (nicotinamide adenine dinucleotide) is a coenzyme found in every cell that supports energy production and cellular repair. Our NAD+ IV therapy delivers it directly into the bloodstream and is offered in 250mg, 500mg, and 750mg doses. Many clients choose it for energy, focus, and anti-aging support.</p>',
  },
  {
    question: 'Who administers IV therapy, and is it safe?',
    answer_html:
      '<p>All IV therapy at Menon Medispa is provided in our Millburn, NJ medical office under the direction of Dr. Aditi Menon, MD. Your drip is selected based on your goals and health history for a safe, comfortable experience.</p>',
  },
  {
    question: 'Does insurance cover IV therapy?',
    answer_html:
      '<p>IV vitamin and wellness therapy is an elective service and is generally not covered by insurance. We provide clear, upfront pricing so you know exactly what to expect before your treatment.</p>',
  },
];

const jsonld = buildServiceSchema({
  name: 'IV Therapy & Hydration in Millburn, NJ',
  description:
    'IV therapy and hydration in Millburn, NJ at Menon Medispa: customized vitamin infusions for immunity, energy, recovery, hydration, and NAD+. Call (973) 494-8431 to book.',
  url: '/iv-therapy-millburn-nj',
  image: heroImg.src,
  type: 'Service',
  category: 'IV Therapy',
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Body', url: '/body' },
    { name: 'IV Therapy', url: '/iv-therapy-millburn-nj' },
  ],
  faqs,
});
---

<BaseLayout
  title="IV Therapy & Hydration in Millburn NJ | Menon Medispa"
  description="IV therapy and hydration in Millburn, NJ at Menon Medispa: customized vitamin infusions for immunity, energy, recovery, hydration, and NAD+. Call (973) 494-8431 to book."
  canonical="https://www.menonmedispa.com/iv-therapy-millburn-nj"
  jsonld={jsonld}
>

  <ServiceHero
    eyebrow="IV THERAPY & HYDRATION · MILLBURN, NJ"
    h1="Boost Your Energy and Wellness with IV Therapy in Millburn, NJ"
    subhead="Customized infusions that deliver essential nutrients directly to your bloodstream, whether you're recovering from fatigue, stress, or simply want to feel your best every day."
    image={heroImg}
    imageAlt="IV Therapy at Menon Medispa Millburn NJ"
    price="Starting at $200"
    note="Free consultation available. Call (973) 494-8431."
    trust={{ stars: true, reviewText: '100+ 5 Star Reviews' }}
  />

  <PromoBanner />

  <!-- Social proof pulled high (research: ~81% of attention is in the first 3 screenfuls) -->
  <ServiceTestimonial slug="iv-therapy-millburn-nj" />

  <ServiceLayout>
    <!-- MAIN COLUMN — benefits/solution first (front-load value), the problem context below -->
    <div class="svc-block">
      <h2>Transform Your Health with IV Therapy</h2>
      <p class="svc-lead">Experience rapid nutrient absorption and immediate energy restoration through our advanced IV vitamin therapy treatments.</p>

      <ul class="svc-features">
        <li>
          <h3>Instant Energy and Mental Clarity</h3>
          <p>Our IV energy therapy delivers B vitamins and nutrients directly to your bloodstream, bypassing digestive absorption issues for immediate focus and productivity enhancement.</p>
        </li>
        <li>
          <h3>100% Bioavailable Nutrients</h3>
          <p>Unlike oral supplements, IV nutrient therapy ensures complete absorption of essential vitamins, minerals, and antioxidants your body desperately needs.</p>
        </li>
        <li>
          <h3>Optimal Hydration &amp; Recovery</h3>
          <p>Our IV hydration therapy rapidly replenishes fluids and electrolytes while supporting faster recovery from stress, workouts, illness, and travel fatigue.</p>
        </li>
      </ul>
    </div>

    <div class="svc-block">
      <h2>Stop Struggling with Low Energy and Nutrient Deficiency</h2>
      <p class="svc-lead">Feeling constantly tired, foggy, or run down can make it hard to enjoy daily life.</p>

      <p>While energy drinks, supplements, and quick fixes offer temporary relief, they often fall short of addressing the real issue:</p>

      <ul class="svc-checks">
        <li>Daily fatigue and sluggishness impact focus, productivity, and mood</li>
        <li>Over-the-counter supplements may not absorb well or meet your body's needs</li>
        <li>Stress, poor diet, and dehydration drain essential vitamins and minerals</li>
        <li>Recovery from workouts, illness, or travel becomes slower and more difficult</li>
      </ul>

      <p>Many people delay treatment because they're unsure what their body really needs. The result? Ongoing burnout, poor immunity, and a cycle of short-term fixes that never fully restore how you want to feel.</p>

      <p class="svc-eyebrow">IV Therapy Changes This</p>

      <p>IV Therapy at Menon Medispa bypasses the digestive system entirely, delivering vitamins, minerals, and nutrients directly into your bloodstream for immediate, complete absorption. Join countless clients in Millburn and Short Hills who trust Menon Medispa's IV Therapy to revitalize their body from the inside out.</p>
    </div>

    <!-- SIDEBAR -->
    <Fragment slot="aside">
      <QuickFacts
        cta
        reviewText="100+ 5 Star Reviews"
        items={[
          { label: 'Starting price', value: '$200 per drip' },
          { label: 'Volume', value: '500ml (upgrade to 1000ml +$25)' },
          { label: 'Infusion types', value: 'Immunity, Energy, Recovery, Anti-Aging, NAD+, and more' },
          { label: 'Location', value: 'Millburn, NJ' },
        ]}
      />
    </Fragment>
  </ServiceLayout>

  <!-- Mid-scroll CTA (repeat the Book CTA after the persuasion content; below-fold CTAs
       convert better for high-consideration treatments) -->
  <section class="section section--tint">
    <div class="container svc-midcta">
      <h2>Ready to feel your best?</h2>
      <p>Book your IV therapy visit, or call us for a free consultation, and we'll match you to the right drip for your goals.</p>
      <a href="/request-appointment?service=IV%20Therapy" class="btn btn--primary">Book Your IV Therapy</a>
    </div>
  </section>

  <Gallery />

  <IvCategories />

  <DripsMenuHeading />
  <DripsMenu />

  <!-- Deeper social proof: more real 5-star reviews from our clients -->
  <ServiceReviews slug="iv-therapy-millburn-nj" excludeFirst heading="More 5-star reviews from our clients" />

  <FaqAccordion heading="Frequently asked questions" items={faqItems} bg_color="rgb(196 164 132 / 0.14)" />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

  <style>
    .svc-midcta { max-width: 680px; margin-inline: auto; text-align: center; }
    .svc-midcta h2 {
      font-family: var(--font-display);
      font-size: var(--text-h2);
      font-weight: var(--weight-regular);
      color: var(--color-text);
      line-height: 1.2;
      margin: 0 0 var(--space-sm);
      text-wrap: balance;
    }
    .svc-midcta p {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      line-height: 1.6;
      margin: 0 0 var(--space-md);
      opacity: 0.9;
    }
  </style>

</BaseLayout>
<!-- redesign: service-page template (hero + 2-col body + sticky sidebar). Bands 1/2/3/6/7/9 kept verbatim. Sections 4+5 re-flowed into main column prose. Section 10 (June SALES promo) removed; replaced by SalePopup. Section 8 (testimonial) swapped to <ServiceTestimonial slug="iv-therapy-millburn-nj" /> (provider-safe curated reviews). -->
