---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
import ServiceHero from '@/components/ServiceHero.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import SalePopup from '@/components/SalePopup.astro';
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import ServiceReviews from '@/components/ServiceReviews.astro';

import { getRelatedPosts } from '@/lib/relatedPosts';
import { buildServiceSchema } from '@/lib/serviceSchema';

// Kept full-width experiential bands (reused verbatim from the original build)
import TrustBar from '@/pages/_sections/laser-hair-removal__section_2.astro';
import Pricing from '@/pages/_sections/laser-hair-removal__section_8.astro';
import Process from '@/pages/_sections/laser-hair-removal__section_9.astro';
import FinalCta from '@/pages/_sections/laser-hair-removal__section_11.astro';

import heroImg from '@/assets/images/laser-hair-removal-hero.jpg';
import videoPosterImg from '@/assets/images/7627e3d6ea08.jpg';
import problemImg from '@/assets/images/82c8c6459d7d.webp';

const slug = 'laser-hair-removal';
const posts = getRelatedPosts(slug);

// FAQ, single source for the on-page accordion AND the FAQPage schema.
const faqs = [
  {
    question: 'Is laser hair removal effective for all treatment areas?',
    answer:
      'Yes. We treat the face (upper lip, chin, sideburns), underarms, the bikini area and Brazilian, legs, back, chest, and other areas with unwanted hair. Session length depends on the size of the area, and we map out your areas and a personalized plan at your free consultation.',
  },
  {
    question: 'Does laser hair removal work on all hair colors?',
    answer:
      'Laser only targets hair that contains pigment, so it works best on dark hair and does not work on gray, white, or red hair. If your hair has little or no pigment, we will let you know at your consultation and patch test.',
  },
  {
    question: 'Is laser hair removal safe for all skin tones?',
    answer:
      'Yes, our laser is suitable for all skin types. Darker skin tones can be a little more sensitive, which is exactly why we always perform a patch test with your aesthetician first to make sure your skin responds well before starting a full session.',
  },
  {
    question: 'Does laser hair removal hurt?',
    answer:
      'Most clients describe laser hair removal as a mild, quick sensation, often compared to the snap of a rubber band against the skin. Comfort depends on the area, so sensitive spots like the bikini line or upper lip can feel a little more than larger areas like the legs, and most people find it far more tolerable than waxing. If you have concerns about comfort, tell us at your free consultation and we will tailor the treatment to your sensitivity.',
  },
  {
    question: 'How should I prepare for my laser hair removal session?',
    answer:
      'Always shave the area beforehand. If you have waxed, wait about 4 weeks first so there is hair in the follicle for the laser to target. Avoid heavy sun exposure and self-tanner before your visit. Once you start laser hair removal you should only shave between sessions, never wax or pluck, because removing the hair from the follicle defeats the purpose of the treatment. Tell us about your skincare routine and any medications at your free consultation so we can tailor your prep.',
  },
  {
    question: 'How many treatments will I need, and will I need maintenance?',
    answer:
      'Most clients do a series of 6 sessions spaced 4-6 weeks apart. About 6-8 weeks after your series we check how the hair is growing back. Some clients are happy after 6 sessions, while others choose a few maintenance sessions. It varies from person to person depending on your hair and how much grows back.',
  },
  {
    question: 'Will my results be permanent?',
    answer:
      'Yes. Laser hair removal provides permanent hair reduction. Many clients see their unwanted hair stay gone for good, while others keep it dramatically reduced with occasional maintenance. Because everyone\'s hair grows on its own cycle, results vary from person to person, and your provider personalizes your plan.',
  },
  {
    question: 'How long does it take to see results?',
    answer:
      'You will typically notice treated hairs shedding over the one to two weeks after each session, and the more sessions you complete the smoother the skin looks. Because hair grows in cycles, each session targets the follicles that are in their active growth phase, which is why a series of about 6 sessions spaced 4 to 6 weeks apart gives the best result. Many clients see a clear reduction partway through their series, with the fullest results after the full series is complete.',
  },
  {
    question: 'Who is not a good candidate for laser hair removal?',
    answer:
      'We do not perform laser hair removal during pregnancy, on gray, white, or red hair (which has no pigment to target), or right after waxing. It also tends to be less effective for clients with PCOS, and if your skin reacts to the patch test laser is not the right fit. Your free consultation and patch test confirm whether laser hair removal is right for you.',
  },
  {
    question: 'What aftercare is recommended following treatment?',
    answer:
      'Wear SPF before and after your sessions and limit sun exposure, especially in the first 24-48 hours, and skip self-tanner. Mild redness or sensitivity is normal and usually settles within a day or two. Between sessions, shave only, never wax or pluck. We will give you complete aftercare guidance tailored to your treatment areas.',
  },
  {
    question: 'Is laser hair removal safe, and what are the side effects?',
    answer:
      'Laser hair removal has a strong safety record when performed by a trained provider, and at Menon Medispa every treatment is under the medical direction of Dr. Aditi Menon, MD. The most common side effects are mild and temporary, such as redness, slight swelling around the hair follicles, or sensitivity in the treated area, which usually settles within a day or two. We always start with a patch test to make sure your skin responds well before a full session. To protect your skin, wear SPF and limit sun exposure before and after your visits.',
  },
  {
    question: "What's the difference between laser hair removal and other methods?",
    answer:
      'Unlike shaving, waxing, or threading that only remove hair temporarily, laser hair removal targets the follicle to reduce future growth for long-lasting results. Compared to electrolysis it treats larger areas much more quickly, and our medical-grade equipment delivers stronger, more consistent energy than at-home devices, under physician supervision.',
  },
];
const faqItems = faqs.map((f) => ({ question: f.question, answer_html: `<p>${f.answer}</p>` }));

const jsonld = buildServiceSchema({
  name: 'Laser Hair Removal in Millburn, NJ',
  description:
    'Physician-supervised laser hair removal in Millburn NJ for permanent hair reduction and smoother skin. Suitable for all skin types, with a free consultation and patch test. Book today.',
  url: '/laser-hair-removal',
  image: heroImg.src,
  type: 'MedicalProcedure',
  category: 'Laser',
  breadcrumb: [
    { name: 'Home', url: '/' },
    { name: 'Body', url: '/body' },
    { name: 'Laser Hair Removal', url: '/laser-hair-removal' },
  ],
  faqs,
});
---

<BaseLayout
  title="Laser Hair Removal in Millburn, NJ | Menon Medispa"
  description="Physician-supervised laser hair removal in Millburn NJ for permanent hair reduction and smoother skin. Suitable for all skin types, with a free consultation and patch test. Book today."
  canonical="https://www.menonmedispa.com/laser-hair-removal"
  jsonld={jsonld}
>

  <ServiceHero
    eyebrow="LASER HAIR REMOVAL · MILLBURN, NJ"
    h1="Lasting Smooth Skin with Laser Hair Removal in Millburn, NJ"
    subhead="Physician-supervised laser hair removal for permanent hair reduction and smoother, lower-maintenance skin. Suitable for all skin tones, with a complimentary consultation and patch test."
    image={heroImg}
    imageAlt="Laser hair removal treatment on smooth skin at Menon Medispa Millburn NJ"
    imagePosition="center"
    price="From $40 per session · packages from $200"
    note="Packages are a series of 6 sessions, 4-6 weeks apart. See full pricing by area below."
    trust={{ stars: true, reviewText: '100+ 5 Star Reviews' }}
  />

  <TrustBar />

  <!-- Social proof pulled high (research: ~81% of attention is in the first 3 screenfuls) -->
  <ServiceTestimonial slug="laser-hair-removal" />

  <ServiceLayout>
    <!-- MAIN COLUMN — benefits first (front-load value), the problem trimmed below -->
    <div class="svc-block">
      <h2>End Your Hair Removal Struggle with Physician-Supervised Laser Treatment</h2>

      <p class="svc-lead">We understand the frustration of dealing with unwanted hair, the constant shaving, painful waxing, and disappointment with temporary results. Under the medical direction of Dr. Aditi Menon, MD, our team has helped thousands of patients achieve lasting hair reduction tailored to their unique skin and hair type.</p>

      <ul class="svc-checks">
        <li>Say goodbye to daily maintenance routines</li>
        <li>Experience freedom from ingrown hairs and skin irritation</li>
        <li>Enjoy lasting results without ongoing expense</li>
      </ul>

      <p>Our advanced laser targets the pigment in each hair, heating the follicle to reduce future growth while leaving the surrounding skin undamaged. After a full series most clients enjoy a dramatic, long-lasting reduction in unwanted hair, and for many it is permanent. Because everyone's hair grows on its own cycle, your provider tailors your plan for the best possible result.</p>

      <p>Our procedure works effectively on all major treatment areas including the bikini line, face, underarms, and legs. Unlike electrolysis, our technology treats larger areas quickly with minimal discomfort, making it the preferred choice for permanent hair reduction in Millburn, NJ.</p>

      <p class="svc-eyebrow">A Real Look at Our Advanced Laser Hair Removal</p>

      <figure>
        <video
          data-lazy-video
          autoplay
          loop
          muted
          playsinline
          preload="none"
          aria-hidden="true"
          poster={videoPosterImg.src}
          width="366"
          height="585"
          style="display:block;width:100%;max-width:366px;height:auto;border-radius:var(--radius-sm);object-fit:cover;"
        >
          <source
            data-src="/videos/wix/2baa5c_627beb6d372449c5998c4994c539eeb9.mp4"
            type="video/mp4"
          />
        </video>
        <figcaption>Curious about what a laser hair removal session actually looks like? Watch a real treatment from our Millburn, NJ medispa to see our advanced, virtually painless technology in action.</figcaption>
      </figure>

      <ul class="svc-features">
        <li>
          <h3>Medical-Grade Technology</h3>
          <p>Advanced lasers calibrated for your unique skin tone and hair type</p>
        </li>
        <li>
          <h3>Physician-Supervised</h3>
          <p>Under the medical direction of Dr. Aditi Menon, MD for safe, effective treatment</p>
        </li>
        <li>
          <h3>All Treatment Areas</h3>
          <p>Face, bikini line, underarms, legs, back, chest, and more</p>
        </li>
        <li>
          <h3>Permanent Hair Reduction</h3>
          <p>Dramatically less unwanted hair after your treatment series, with results that last</p>
        </li>
      </ul>
    </div>

    <div class="svc-block">
      <h2>Why Traditional Hair Removal Falls Short</h2>

      <p class="svc-lead">Dealing with unwanted hair is a constant battle. Traditional hair removal methods only offer temporary relief while creating ongoing problems.</p>

      <ul class="svc-checks">
        <li>Daily shaving leaves skin irritated and stubble returns within days</li>
        <li>Painful waxing sessions for bikini areas and sensitive zones require regular maintenance</li>
        <li>Ingrown hairs and skin tone irregularities develop from repeated treatments</li>
        <li>At-home laser devices rarely deliver the permanent hair reduction results they promise</li>
      </ul>

      <figure>
        <img src={problemImg.src} alt="Woman frustrated with traditional hair removal methods" width="415" height="415" loading="lazy" decoding="async" />
      </figure>

      <p>Meanwhile, hair growth continues relentlessly, creating a frustrating cycle of time spent on temporary fixes that never deliver the smooth, lasting results you deserve.</p>
    </div>

    <!-- SIDEBAR -->
    <Fragment slot="aside">
      <QuickFacts
        cta
        reviewText="100+ 5 Star Reviews"
        items={[
          { label: 'Price', value: 'From $40/session · pkgs from $200' },
          { label: 'Sessions needed', value: '6 sessions' },
          { label: 'Session spacing', value: '4-6 weeks apart' },
          { label: 'Results', value: 'Permanent hair reduction' },
          { label: 'Consultation', value: 'Free + patch test' },
          { label: 'Supervised by', value: 'Dr. Aditi Menon, MD' },
          { label: 'Location', value: 'Millburn, NJ' },
        ]}
      />
    </Fragment>
  </ServiceLayout>

  <!-- Mid-scroll CTA (research: repeat the same Book CTA after the persuasion content;
       below-fold CTAs convert better for high-consideration treatments) -->
  <section class="section section--tint">
    <div class="container svc-midcta">
      <h2>Ready to book your laser hair removal?</h2>
      <p>Book a consultation and our team will build a plan for your skin, your areas, and your goals.</p>
      <a href="/request-appointment?service=Laser Hair Removal" class="btn btn--primary">Book Your Consultation</a>
    </div>
  </section>

  <Process />

  <Pricing />

  <!-- Deeper social proof: more real 5-star reviews for this service -->
  <ServiceReviews slug="laser-hair-removal" excludeFirst heading="More 5-star reviews from our clients" />

  <FaqAccordion heading="Frequently asked questions" items={faqItems} bg_color="rgb(196 164 132 / 0.14)" />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

  <style>
    .svc-midcta { max-width: 680px; margin-inline: auto; text-align: center; }
    .svc-midcta h2 {
      font-family: var(--font-display);
      font-size: var(--text-h2);
      font-weight: var(--weight-regular);
      color: var(--color-text);
      line-height: 1.2;
      margin: 0 0 var(--space-sm);
      text-wrap: balance;
    }
    .svc-midcta p {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      line-height: 1.6;
      margin: 0 0 var(--space-md);
      opacity: 0.9;
    }
  </style>

</BaseLayout>
<!-- redesign v2 (CRO+SEO reference, structure-only): benefits-first body, social proof pulled high
     (ServiceTestimonial) + a 3-up real-reviews strip (ServiceReviews) lower, a mid-scroll Book CTA,
     and Process-before-Pricing. Copy is unchanged verbatim from the prior build; keyword-driven copy
     (device, skin tones, cost FAQ, prep) is deferred until the medispa confirms facts. -->
