  <!-- Mid-scroll CTA (repeat the Book CTA after the persuasion content; below-fold CTAs
       convert better for high-consideration treatments) -->
  <section class="section section--tint">
    <div class="container svc-midcta">
      <h2>Ready to start medical weight loss with Semaglutide or Tirzepatide?</h2>
      <p>Book a consultation with Dr. Menon for a medical review and a plan built around your health history and goals.</p>
      <a href="/request-appointment?service=Medical%20Weight%20Loss" class="btn btn--primary">Book Your Consultation</a>
    </div>
  </section>

  <Pricing />

  <!-- Deeper social proof: more real 5-star reviews from our clients -->
  <ServiceReviews slug="semaglutide" excludeFirst heading="More 5-star reviews from our clients" />

  <FaqAccordion heading="Frequently asked questions" items={faqItems} bg_color="rgb(196 164 132 / 0.14)" />

  <FinalCta />

  <RelatedPosts posts={posts} layout="band" />

  <MobileCtaBar ctaLabel="Book Online" />
  <SalePopup />

  <style>
    .svc-midcta { max-width: 680px; margin-inline: auto; text-align: center; }
    .svc-midcta h2 {
      font-family: var(--font-display);
      font-size: var(--text-h2);
      font-weight: var(--weight-regular);
      color: var(--color-text);
      line-height: 1.2;
      margin: 0 0 var(--space-sm);
      text-wrap: balance;
    }
    .svc-midcta p {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      line-height: 1.6;
      margin: 0 0 var(--space-md);
      opacity: 0.9;
    }
  </style>

</BaseLayout>
<!-- redesign: service-page template (hero + 2-col body + sticky sidebar). Bands kept: section_2 (TrustBar), section_7 (Pricing), section_9 (FinalCta). Inlined: section_3 (problem prose), section_5 (difference prose), section_6 (mid-page CTA copy folded into section_5 block). FAQ lifted: section_8 to FaqColumn. Hero section_1 extracted to ServiceHero. No promo band found. section_4 (Testimonial) swapped to <ServiceTestimonial slug="semaglutide" /> (original scraped quote named departed staff; replaced by the provider-safe reviews DB). -->
