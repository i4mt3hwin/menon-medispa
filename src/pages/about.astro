---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';

import AboutSection1 from './_sections/about__section_1.astro';
import AboutSection2 from './_sections/about__section_2.astro';
import AboutSection3 from './_sections/about__section_3.astro';
import AboutSection4 from './_sections/about__section_4.astro';

// SEO (2026-06-22 audit): AboutPage node referencing the business entity (@id) for
// stronger entity signals. The full MedicalBusiness node lives on home + contact.
const aboutPage = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Menon Medispa & Wellness',
  url: `${site.url}/about/`,
  about: { '@id': site.schemaId },
};
---

<BaseLayout
  title="About | Menon Medispa & Wellness | Millburn, NJ"
  description="Learn about Menon Medispa & Wellness in Millburn, NJ, our approach, our team, and why Millburn residents trust us for their aesthetic goals."
  jsonld={aboutPage}
>
  <AboutSection1 />
  <AboutSection2 />
  <AboutSection3 />
  <AboutSection4 />
</BaseLayout>
