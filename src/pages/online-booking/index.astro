---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
---
<BaseLayout title="Online Booking | Menon Medispa &amp; Wellness | Millburn, NJ" description="Book your appointment online at Menon Medispa in Millburn, NJ.">
  <main class="sp" data-slug="online-booking">
    <section class="sp-hero sp-hero--center" aria-label="Online Booking">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Online <em>Booking</em></h1>
      </div>
    </section>
    <section class="sp-plain" aria-label="Schedule">
      <div class="sp-container">
        <div class="sp-plain__inner">
          <p class="sp-plain__body">Schedule your appointment at Menon Medispa in Millburn, NJ.</p>
          <a class="sp-btn sp-btn--gold" href={site.calcomUrl} rel="noopener" target="_blank">Schedule An Appointment</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
