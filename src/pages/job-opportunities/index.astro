---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
---
<BaseLayout title="Job Opportunities | Menon Medispa &amp; Wellness | Millburn, NJ" description="Career opportunities at Menon Medispa in Millburn, NJ. Join our team of dedicated beauty and wellness professionals.">
  <main class="sp" data-slug="job-opportunities">
    <section class="sp-hero sp-hero--center" aria-label="Job Opportunities">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Join Our <em>Team</em></h1>
        <p class="sp-hero__lead" style="text-align:center;margin:0 auto;max-width:560px;">We're looking for dedicated beauty and wellness professionals to join the Menon Medispa family.</p>
      </div>
    </section>
    <section class="sp-plain" aria-label="Career Info">
      <div class="sp-container">
        <div class="sp-plain__inner">
          <h2 class="sp-plain__title">Work With Us</h2>
          <div class="sp-plain__body">
            <p>At Menon Medispa, we're committed to creating an environment where talented professionals can thrive. We offer competitive compensation, ongoing training and education, and the opportunity to work alongside our exceptional team led by Dr. Aditi Menon.</p>
            <p>We are always looking for passionate estheticians, medical assistants, and customer service professionals who share our commitment to excellence and patient care.</p>
          </div>
          <a class="sp-btn sp-btn--gold" href="mailto:admin@menonregen.com">Send Your Resume</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
