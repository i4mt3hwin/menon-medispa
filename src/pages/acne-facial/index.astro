---
/**
 * Acne Facial — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/acne-facial/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Acne Facial In Millburn NJ | Menon Medispa & Wellness"
  description="Our gentle acne facial uses medical-grade Korean skincare to calm inflammation, control oil, and heal breakouts naturally. Get clearer skin in just one treatment."
>
  <main class="sp" data-slug="acne-facial">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Acne Facial">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Acne Facial In Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Finally Achieve Clear, Confident Skin With Professional-Strength Treatment</p>
            <p class="sp-hero__lead">Our gentle acne facial uses medical-grade Korean skincare to calm inflammation, control oil, and heal breakouts naturally. Get clearer skin in just one treatment—no harsh peels or long recovery needed.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/acne-facial">Book Your Acne Facial</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/853360c33f23.jpg" alt="Acne Facial Treatment" width="290" height="194" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Medical-Grade Deep Cleansing</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Anti-Inflammatory &amp; Healing</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Long-Lasting Clear Skin</p>
      </div>
    </section>

    {/* ===== WHY IT WORKS ===== */}
    <section class="sp-plain" aria-label="Why Our Acne Facial Works">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 0.75rem;">Why Our Acne Facial Works When Other Treatments Haven't</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0 0 1.5rem;font-style:italic;">Medical-grade ingredients that target acne at the source without damaging your skin barrier.</p>
          <div style="display:flex;flex-direction:column;gap:1.25rem;">
            <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
              <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--color-ink);margin:0 0 0.4rem;">Targets Root Causes, Not Just Symptoms</h3>
              <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0;line-height:1.7;">Our Acne Facial uses medical-grade actives like Salicylic Acid and Tea Tree to penetrate deep into pores, control oil at the source, and prevent future breakouts.</p>
            </div>
            <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
              <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--color-ink);margin:0 0 0.4rem;">Balances Oil Without Stripping Your Skin</h3>
              <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0;line-height:1.7;">Say goodbye to that tight, uncomfortable feeling. Our treatment controls excess sebum naturally, so your skin stays balanced and breakout-free without the dryness.</p>
            </div>
            <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
              <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--color-ink);margin:0 0 0.4rem;">Reduces Inflammation and Accelerates Healing</h3>
              <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0;line-height:1.7;">Centella Asiatica and Houttuynia Cordata calm redness, soothe irritation, and speed healing of active breakouts—without harsh chemicals or over-drying your skin.</p>
            </div>
            <div style="background:#f8f4f0;padding:1.25rem;border-radius:var(--radius-sm);">
              <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--color-ink);margin:0 0 0.4rem;">Safe &amp; Gentle for All Skin Types</h3>
              <p style="font-family:var(--font-ui);color:#5e5e5e;margin:0;line-height:1.7;">Unlike harsh chemical peels or abrasive treatments, our acne facial is suitable for sensitive skin. No irritation, no downtime—just clearer, healthier skin after every visit.</p>
            </div>
          </div>
          <p style="margin-top:2rem;"><a class="sp-btn sp-btn--gold" href="/acne-facial">Schedule Your Acne Facial Today</a></p>
        </div>
      </div>
    </section>

    {/* ===== REAL RESULTS ===== */}
    <section class="sp-photos" aria-label="Real Results">
      <div class="sp-container">
        <div class="sp-photos__head">
          <h2>Real Results From Just One Acne Facial Treatment</h2>
          <p>This photo was taken immediately after a 70-minute session. Notice how inflammation and redness are already reduced—and your skin will continue to improve over the next 3-5 days as active breakouts heal faster.</p>
        </div>
        <div class="sp-photos__grid" style="max-width:640px;margin:0 auto;">
          <img src="/images/1616d1e9f4e9.png" alt="Acne Facial Result" width="600" height="600" loading="lazy" />
        </div>
      </div>
    </section>

    {/* ===== PROCESS STEPS ===== */}
    <section class="sp-steps" aria-label="What To Expect">
      <div class="sp-container">
        <div class="sp-steps__head">
          <h2>What To Expect During Your 70-Minute Acne Facial Experience</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;max-width:680px;margin:0 auto;line-height:1.65;">Every step is designed for your comfort and results. Here's exactly what happens during your 70-minute treatment at our Millburn spa.</p>
        </div>
        <div class="sp-steps__list">
          <div class="sp-step">
            <div class="sp-step__num">01</div>
            <h3 class="sp-step__title">Consultation &amp; Skin Analysis</h3>
            <p class="sp-step__body">5-10 minutes. We start with a thorough consultation to understand your skin concerns and acne triggers. Our expert esthetician analyzes your skin type and creates a customized treatment plan just for you.</p>
          </div>
          <div class="sp-step">
            <div class="sp-step__num">02</div>
            <h3 class="sp-step__title">Deep Cleansing &amp; Preparation</h3>
            <p class="sp-step__body">10-15 minutes. Your skin is gently cleansed using the Corthe Dermo Cleansing Foam to remove makeup, oils, and impurities. This prepares your pores for deep treatment and ensures maximum product absorption.</p>
          </div>
          <div class="sp-step">
            <div class="sp-step__num">03</div>
            <h3 class="sp-step__title">Tea Tree Ampoule Treatment</h3>
            <p class="sp-step__body">10-15 minutes. We apply the Corthe Dermo Pure Tea Tree Ampoule, infused with 50% pure tea tree water. This powerful formula penetrates deep into pores to control oil production and fight acne-causing bacteria.</p>
          </div>
          <div class="sp-step">
            <div class="sp-step__num">04</div>
            <h3 class="sp-step__title">Purifying Mask Application</h3>
            <p class="sp-step__body">20-25 minutes. The Corthe Dermo Pure Purifying Mask is applied to absorb excess oil, reduce inflammation, and accelerate healing.</p>
          </div>
          <div class="sp-step">
            <div class="sp-step__num">05</div>
            <h3 class="sp-step__title">Toner &amp; Moisturizer Application</h3>
            <p class="sp-step__body">5-10 minutes. We finish with the First Aid Toner and First Aid Lotion to balance your skin, lock in hydration, and protect against future breakouts.</p>
          </div>
        </div>
        <p style="text-align:center;margin-top:2.5rem;"><a class="sp-btn sp-btn--gold" href="/acne-facial">Schedule Now</a></p>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          They have the best hydrafacials. Let me tell you, I've had facials before, but this was on another level. My skin felt like it had been reborn! The process was gentle yet thorough, and I could literally see the gunk being extracted (which, yes, was oddly satisfying!).
          <cite>Rathi Vijay<span class="sp-quote__sub"> — Millburn Resident</span></cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    {/* ===== PRICING ===== */}
    <section class="sp-pricing" aria-label="Ready to Experience Clear Skin">
      <div class="sp-container">
        <div class="sp-pricing__head">
          <h2>Ready to Experience Clear, Confident Skin?</h2>
          <p>Book your acne facial today and experience the difference our expert estheticians can make. Located conveniently in Millburn, NJ.</p>
        </div>
        <div class="sp-pricelist">
          <div class="sp-priceitem">
            <img class="sp-priceitem__thumb" src="/images/853360c33f23.jpg" alt="Acne Facial" loading="lazy" />
            <div class="sp-priceitem__main">
              <a class="sp-priceitem__title" href="/booking-calendar/acne-facial">Acne Facial</a>
              <p class="sp-priceitem__sub">Medical-Grade Treatment for Clear, Confident Skin</p>
              <a class="sp-priceitem__readmore" href="/service-page/acne-facial">Read More</a>
              <p class="sp-priceitem__sub" style="margin-top:0.25rem;">1 hr 10 min</p>
            </div>
            <div class="sp-priceitem__price">$165</div>
            <a class="sp-btn sp-btn--gold sp-priceitem__cta" href="/booking-calendar/acne-facial">Request to Book</a>
          </div>
        </div>
      </div>
    </section>

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            <details class="sp-faq__item" open>
              <summary>Will the acne facial hurt?</summary>
              <div class="sp-faq__answer"><p>Not at all! Our acne facial is designed to be gentle and relaxing. You may feel a light tingling sensation from the active ingredients like tea tree and salicylic acid, but there's no pain or discomfort. Most clients find the treatment soothing and calming.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How soon will I see results?</summary>
              <div class="sp-faq__answer"><p>You'll notice calmer, less red skin immediately after your first treatment. Active breakouts will continue to heal over the next 3-5 days. For best results, we recommend a series of treatments spaced 2-3 weeks apart to control oil production and prevent future breakouts.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How often should I get acne facials?</summary>
              <div class="sp-faq__answer"><p>For active acne, we recommend treatments every 2-3 weeks until your skin clears. Once your breakouts are under control, monthly maintenance facials help keep your skin balanced and prevent new acne from forming.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is there any downtime after the treatment?</summary>
              <div class="sp-faq__answer"><p>No downtime at all! Your skin may look slightly pink for 30-60 minutes after treatment, but you can return to your normal activities immediately. You can even apply makeup right away if needed.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Who is a good candidate for the acne facial?</summary>
              <div class="sp-faq__answer"><p>Our acne facial is perfect for anyone dealing with breakouts, oily skin, clogged pores, or inflammation. It's safe for teens and adults, and gentle enough for sensitive skin. We'll customize the treatment during your consultation to match your specific skin needs.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Ready to Get Clear Skin">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Ready to Get Clear, Confident Skin?</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Join hundreds of clients from Millburn, Short Hills, and Livingston who've transformed their skin with our gentle acne facial. Limited appointment slots available.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Free Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
