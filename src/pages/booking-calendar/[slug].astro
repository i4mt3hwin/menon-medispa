---
/**
 * /booking-calendar/[slug].astro
 * Dynamic route — 81 booking pages (one per visible service).
 * Replaces Wix Bookings date-picker with Cal.com SchedulerEmbed via BookingCalendarTemplate.
 * Content verbatim from src/data/services.json (no fabrication).
 */
import BookingCalendarTemplate from '@/components/BookingCalendarTemplate.astro';
import servicesData from '@/data/services.json';

export async function getStaticPaths() {
  return servicesData.map((service: Record<string, string>) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Service {
  slug: string;
  name: string;
  category?: string;
  price?: string;
  duration?: string;
  tagLine?: string;
}

const { service } = Astro.props as { service: Service };
---

<BookingCalendarTemplate
  service_title={service.name}
  service_slug={service.slug}
  category={service.category}
  description={service.tagLine || undefined}
  duration_note={service.duration}
  price_note={service.price}
/>
