---
/**
 * /booking-calendar/[slug].astro
 * Dynamic route, 5 booking pages matching slugs confirmed in original Wix site-inventory.
 * Slugs: botox-injectables, forever-radiant-experience, give-the-gift-of-glow,
 *        hydrafacial-keravive, the-timeless-beauty-experience.
 * The full 81 service-page routes are at /service-page/[slug].
 */
import BookingCalendarTemplate from '@/components/BookingCalendarTemplate.astro';
import servicesData from '@/data/services.json';

export async function getStaticPaths() {
  // Only the 5 booking-calendar slugs that existed on the original Wix site
  const BOOKING_SLUGS = new Set([
    'botox-injectables',
    'forever-radiant-experience',
    'give-the-gift-of-glow',
    'hydrafacial-keravive',
    'the-timeless-beauty-experience',
  ]);
  return servicesData
    .filter((service: Record<string, string>) => BOOKING_SLUGS.has(service.slug))
    .map((service: Record<string, string>) => ({
      params: { slug: service.slug },
      props: { service },
    }));
}

interface Service {
  slug: string;
  name: string;
  category?: string;
  price?: string;
  duration?: string;
  tagLine?: string;
}

const { service } = Astro.props as { service: Service };
---

<BookingCalendarTemplate
  service_title={service.name}
  service_slug={service.slug}
  category={service.category}
  description={service.tagLine || undefined}
  duration_note={service.duration}
  price_note={service.price}
/>
