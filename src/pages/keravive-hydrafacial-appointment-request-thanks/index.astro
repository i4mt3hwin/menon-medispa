---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Thank You | Keravive Appointment Request | Menon Medispa" description="Thank you for requesting your HydraFacial Keravive appointment at Menon Medispa." noindex={true}>
  <main class="sp" data-slug="keravive-hydrafacial-appointment-request-thanks">
    <section class="sp-hero sp-hero--center" aria-label="Thank You">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Thank You!</h1>
        <p class="sp-hero__lead" style="text-align:center;margin:0 auto;max-width:560px;">Your HydraFacial Keravive appointment request has been received. Our team will be in touch shortly to confirm your appointment.</p>
        <div style="text-align:center;margin-top:2rem;"><a class="sp-btn sp-btn--gold" href="/">Return to Home</a></div>
      </div>
    </section>
  </main>
</BaseLayout>
