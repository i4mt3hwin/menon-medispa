---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
---
<BaseLayout title="Book Online | Menon Medispa &amp; Wellness | Millburn, NJ" description="Book your appointment at Menon Medispa in Millburn, NJ. Browse our full range of services and schedule online.">
  <main class="sp" data-slug="book-online">
    <section class="sp-hero sp-hero--center" aria-label="Book Online">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Book <em>Online</em></h1>
        <p class="sp-hero__lead" style="text-align:center;margin:0 auto;max-width:560px;">Browse our full range of services and schedule your appointment today.</p>
      </div>
    </section>
    <section class="sp-plain" aria-label="Services">
      <div class="sp-container">
        <div class="sp-plain__inner">
          <p class="sp-plain__body">Please select a service below to book your appointment. If you have questions, call us at (973) 494-8431 or <a href="/consultation">schedule a free consultation</a>.</p>
          <p><a class="sp-btn sp-btn--gold" href={site.calcomUrl} rel="noopener" target="_blank">Schedule An Appointment</a></p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
