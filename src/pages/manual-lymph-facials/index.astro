---
/**
 * Manual Lymph Drainage Facial — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/manual-lymph-facials/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Manual Lymph Drainage Facial | Menon Medispa | Millburn, NJ"
  description="Manual lymphatic drainage facial in Millburn NJ. Reduce puffiness, detoxify skin, and achieve a natural glow with this gentle therapeutic technique."
>
  <main class="sp" data-slug="manual-lymph-facials">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Manual Lymph Drainage Facial">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Manual Lymph Drainage Facial</h1>
            <p class="sp-hero__eyebrow">Detoxify, De-Puff, and Reveal Your Natural Glow</p>
            <p class="sp-hero__lead">Our Manual Lymphatic Drainage (MLD) facial uses gentle, rhythmic massage techniques to stimulate the lymphatic system, reduce facial puffiness, and detoxify your skin. Perfect for those with chronic puffiness, dull skin, or post-procedure swelling.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/651c7c197b52.png" alt="Manual Lymph Drainage Facial" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Reduces Puffiness</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Natural Detox</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Immediate Results</p>
      </div>
    </section>

    
    {/* ===== HOW MANUAL LYMPH DRAINAGE WORKS ===== */}
    <section class="sp-plain" aria-label="How Manual Lymph Drainage Works">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">How Manual Lymph Drainage Works</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Manual Lymphatic Drainage uses light, rhythmic strokes to encourage the movement of lymph fluid through the lymphatic vessels. By stimulating this system, we help your body remove waste products, toxins, and excess fluid from facial tissues.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">The result is immediate visible reduction in puffiness, improved skin tone, and a healthy natural glow. MLD is also excellent for reducing post-procedure swelling after injectables or other facial treatments.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Benefits</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0;"><li>Immediate reduction in facial puffiness</li><li>Improved skin tone and clarity</li><li>Enhanced natural glow and radiance</li><li>Reduced post-injectable swelling</li><li>Deep relaxation and stress relief</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How is MLD different from a regular facial massage?</summary>
              <div class="sp-faq__answer"><p>Manual Lymphatic Drainage uses specific, very light pressure techniques that are fundamentally different from regular massage. MLD works at the surface of the skin, following specific lymphatic pathways, while regular massage uses deeper pressure to work muscle tissue.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Who benefits most from MLD facials?</summary>
              <div class="sp-faq__answer"><p>MLD facials are especially beneficial for clients with chronic facial puffiness, dull skin, post-procedure swelling, sinusitis, or those seeking deep detoxification. It's also excellent as a relaxation treatment for all skin types.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How often should I get MLD facials?</summary>
              <div class="sp-faq__answer"><p>For specific conditions, weekly sessions may be recommended initially. For general wellness and glow maintenance, monthly sessions are ideal. Many clients incorporate MLD into their regular skincare routine for ongoing benefits.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Begin Your Skin Detox Today">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Begin Your Skin Detox Today</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Schedule your Manual Lymph Drainage Facial at Menon Medispa in Millburn, NJ and experience the transformative power of lymphatic health.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
