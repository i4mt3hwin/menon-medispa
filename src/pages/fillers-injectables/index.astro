---
/**
 * Fillers &amp; Injectables in Millburn NJ — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/fillers-injectables/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Fillers & Injectables | Menon Medispa & Wellness | Millburn, NJ"
  description="Dermal fillers and injectable treatments in Millburn NJ. Physician-administered Juvederm, Botox, and other injectables for natural-looking results."
>
  <main class="sp" data-slug="fillers-injectables">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Fillers &amp; Injectables in Millburn NJ">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Fillers &amp; Injectables in Millburn NJ</h1>
            <p class="sp-hero__eyebrow">Natural-Looking Results with Physician Expertise</p>
            <p class="sp-hero__lead">Our physician-administered injectable treatments restore volume, smooth lines, and enhance facial contours with natural-looking precision. Led by Dr. Menon, our team of experts ensures every treatment is tailored to your unique facial anatomy and aesthetic goals.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/8ec275b96db1.jpeg" alt="Fillers &amp; Injectables in Millburn NJ" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Physician Administered</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Natural-Looking Results</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Same-Day Treatment</p>
      </div>
    </section>

    
    {/* ===== INJECTABLE TREATMENTS WE OFFER ===== */}
    <section class="sp-plain" aria-label="Injectable Treatments We Offer">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">Injectable Treatments We Offer</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">At Menon Medispa, we offer a comprehensive range of injectable treatments performed by our medical team. Each treatment is customized to address your specific concerns while maintaining natural facial harmony.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Botox® &amp; Neurotoxins</h3>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Relax facial muscles that cause expression lines and wrinkles. Results last 3-4 months with proper maintenance.</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Juvederm® Dermal Fillers</h3>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Restore lost volume to cheeks, lips, and under-eye areas. Juvederm fillers use hyaluronic acid for natural-looking, long-lasting results of 12-24 months.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">All injectable treatments are performed in our clinical setting with the highest standards of safety and hygiene. We use only FDA-approved products from leading manufacturers.</p>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>Are dermal fillers and Botox the same thing?</summary>
              <div class="sp-faq__answer"><p>No, they work differently. Botox (and similar neurotoxins) relax facial muscles to smooth expression lines. Dermal fillers add volume to areas that have lost fullness due to aging. Many clients benefit from using both treatments together for comprehensive facial rejuvenation.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How long do fillers last?</summary>
              <div class="sp-faq__answer"><p>Duration varies by product and treatment area. Lip fillers typically last 6-12 months, cheek fillers 12-18 months, and under-eye fillers 12-24 months. Results also depend on your metabolism, lifestyle, and the amount injected.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is there downtime after fillers?</summary>
              <div class="sp-faq__answer"><p>Most clients can return to normal activities immediately. Some bruising, swelling, and tenderness at injection sites is normal and typically resolves within 3-7 days. We recommend avoiding strenuous exercise and alcohol for 24 hours after treatment.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Enhance Your Natural Beauty">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Enhance Your Natural Beauty</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Schedule your injectable consultation with Dr. Menon at Menon Medispa in Millburn, NJ and discover the art of natural-looking enhancement.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
