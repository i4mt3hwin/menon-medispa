---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import HeroSection from '@/components/HeroSection.astro';
import RichText from '@/components/RichText.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import Button from '@/components/Button.astro';
import ServicesGrid from '@/components/ServicesGrid.astro';
import BlogList from '@/components/BlogList.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import FeatureList from '@/components/FeatureList.astro';
import LeadForm from '@/components/LeadForm.astro';
import site from '@/lib/site';
import { buildLocalBusiness } from '@/lib/businessSchema';
import { getReview } from '@/lib/reviews';
import { getAllPosts, formatDate } from '@/lib/blog';
import { getSaleOffers } from '@/lib/sales';

// Homepage testimonial, pulled from the curated provider-safe reviews pool.
const homeReview = getReview('general');

// Recent Posts section, the 3 newest real posts (valid slugs + topic chips).
const recentPosts = getAllPosts().slice(0, 3).map((p) => ({
  slug: p.slug,
  title: p.title,
  excerpt: p.excerpt,
  date: formatDate(p.date),
  featured_image: p.coverImage,
  category: p.topic.label,
  categorySlug: p.topic.slug,
}));

import posterImg from '@/assets/images/f2a8f8988125.jpg';
import botoxImg from '@/assets/services/botox-injectables-card.webp';
import juvedermImg from '@/assets/services/juvederm-fillers-card.webp';
import keraviveImg from '@/assets/services/hydrafacial-keravive-card.webp';
import testimonialsBg from '@/assets/testimonials/what-our-clients-say-bg.webp';
import avatar1 from '@/assets/testimonials/reviewer-avatar-1.webp';
import avatar2 from '@/assets/testimonials/reviewer-avatar-2.webp';
import avatar3 from '@/assets/testimonials/reviewer-avatar-3.webp';
import faceTreatmentsImg from '@/assets/services/face-treatments.webp';
import naturalBeautyImg from '@/assets/services/natural-beauty-body.webp';
import modelCurlyHairImg from '@/assets/services/model-curly-hair.webp';
import skinFirstBg from '@/assets/home/your-skin-comes-first-bg.webp';
import videoPosterImg from '@/assets/home/exceptional-experience-video-poster.webp';
import staffImg from '@/assets/images/b1a819f35921.webp';

// Service columns (FACE / BODY / HAIR). Each tile is a simple image + category
// label that links to the pillar page.
const serviceColumns = [
  { label: 'FACE', href: '/face', img: faceTreatmentsImg, alt: 'Face treatments at Menon Medispa' },
  { label: 'BODY', href: '/body', img: naturalBeautyImg, alt: 'Body treatments at Menon Medispa' },
  { label: 'HAIR', href: '/hair', img: modelCurlyHairImg, alt: 'Hair restoration at Menon Medispa' },
];

// Monthly specials + the June SALES dialog both read from data/sales.json (ONE
// source of truth — edit that file to change every sale surface on the site).
const saleOffers = getSaleOffers();
const specials = saleOffers.map((o) => ({
  title: o.name,
  price: o.price,
  img: o.image?.src,
  alt: o.imageAlt,
  book: o.href,
  more: '/sale',
  includes: o.includes,
}));

// FAQ, single source for both the on-page accordion and the FAQPage schema (verbatim copy).
const faqs = [
  { question: 'What services does Menon Medispa offer?', answer: 'We offer HydraFacial and medical facials, Botox and dermal fillers, laser hair removal and laser skin resurfacing, IV therapy and vitamin injections, microneedling, and medical weight loss, all under the care of Dr. Aditi Menon, MD.' },
  { question: 'What areas do you serve?', answer: 'Menon Medispa is located in Millburn, NJ and serves surrounding communities including Short Hills, Summit, Maplewood, Livingston, Springfield, Vauxhall, and West Orange.' },
  { question: 'How do I schedule?', answer: 'You can schedule a consultation or treatment online through our booking system, or call us at (973) 494-8431.' },
  { question: 'What makes Menon Medispa different?', answer: 'We combine medical excellence, cutting-edge technology, and personalized care led by Dr. Aditi Menon, MD, delivering superior aesthetic results in a warm, discreet environment.' },
  { question: 'What should I expect first visit?', answer: 'Your first visit begins with a comprehensive consultation so we can understand your goals and design a customized treatment plan tailored to your unique needs.' },
];

// ── Invisible SEO: LocalBusiness + FAQPage JSON-LD (built from site.ts + the on-page FAQ) ──
// MedicalBusiness node now lives in lib/businessSchema.ts so the contact page reuses the
// exact same node + @id (see 2026-06-22 SEO audit). Pass the hero poster as the image.
const localBusiness = buildLocalBusiness({ image: posterImg.src });
const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<BaseLayout
  title="Medical Spa in Millburn, NJ | Menon Medispa & Wellness"
  description="Menon Medispa & Wellness in Millburn, NJ offers HydraFacial, Botox, fillers, laser and IV therapy led by Dr. Aditi Menon. Book a consultation today."
  canonical="https://www.menonmedispa.com"
  jsonld={[localBusiness, faqPage]}
>

  {/* ════════ 1 · HERO ════════ */}
  <HeroSection
    eyebrow="Millburn NJ's Premier Medical Spa & Wellness Center"
    eyebrowTag="h1"
    heading="Give Yourself the Glow Up You Deserve"
    headingTag="h2"
    body="Advanced Botox, facials, and body treatments delivered by medical experts. Discover why Millburn residents choose us for their aesthetic goals."
    bg_video_url="/videos/wix/2baa5c_feca9a60fac643698798ede1260cd291-720.mp4"
    bg_video_url_mobile="/videos/wix/2baa5c_feca9a60fac643698798ede1260cd291-480.mp4"
    bg_image_url={posterImg.src}
    bg_image_alt=""
    ctas={[
      { text: "Schedule An Appointment", href: site.calcomUrl, variant: "primary", book: "request" }
    ]}
    social_proof={[
      { image_key: "90411e0041df", alt: "" },
      { image_key: "305afeda5f9a", alt: "" },
      { image_key: "b95880091b44", alt: "" }
    ]}
    stars_text="★★★★★"
    review_count_text="100+ 5 Star Reviews"
    height="599px"
    layout="centered"
  />

  {/* ════════ 2 · TRUST STRIP ════════ */}
  <section class="trust-bar section section--tight">
    <div class="container trust-bar__inner">
      <div class="trust-bar__item">
        <RichText html="Same-Week Appointments" font="var(--font-body)" size="var(--text-sm)" color="#FFFFFF" />
      </div>
      <div class="trust-bar__item">
        <RichText html="Led by Dr. Aditi Menon, MD" font="var(--font-body)" size="var(--text-sm)" color="#FFFFFF" />
      </div>
      <div class="trust-bar__item">
        <RichText html="State of the Art Equipment" font="var(--font-body)" size="var(--text-sm)" color="#FFFFFF" />
      </div>
    </div>
  </section>

  <style>
    .trust-bar {
      background-color: #584B63; /* brand plum-purple, breaks up hero from intro band */
      color: #fff;
    }
    .trust-bar__inner {
      display: flex;
      flex-direction: row;
      justify-content: space-around;
      align-items: center;
      gap: var(--space-md);
    }
    .trust-bar__item { flex: 1; text-align: center; }
    @media (max-width: 600px) {
      .trust-bar__inner { flex-direction: column; align-items: center; gap: var(--space-sm); }
      .trust-bar__item { width: 100%; }
    }
  </style>

  {/* ════════ 3 · INTRO BAND (image + text, Welcome + Expert Medispa) ════════ */}
  <section class="intro-band section section--tint">
    <div class="container intro-band__inner">
      <div class="intro-band__media">
        <img src={staffImg.src} alt="Menon Medispa office staff in Millburn, NJ" class="intro-band__img" width="431" height="540" loading="lazy" decoding="async" />
      </div>
      <div class="intro-band__text">
        <p class="intro-band__eyebrow">Welcome To</p>
        <h2 class="intro-band__title">Menon Medispa &amp; Wellness</h2>
        <div class="intro-band__lede">
          <p>Not sure which treatment is right for you? Schedule a complimentary consultation with one of our experts to talk through your goals and build a plan that fits.</p>
        </div>
        <h2 class="intro-band__subhead">Expert Medispa and Skin Care Clinic in Millburn, NJ</h2>
        <p class="intro-band__about">Menon Medispa has been at the forefront of medical aesthetics and anti-aging innovations since 2019. Our team of esteemed medical experts is committed to providing outstanding care and achieving lasting outcomes that not only improve your looks but also boost your overall wellness. We are proud to care for patients across Millburn, NJ and the surrounding communities.</p>
        <a href="/consultation" class="btn btn--primary">Schedule a Consultation</a>
      </div>
    </div>
  </section>

  <style>
    .intro-band__inner {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: var(--space-xl);
    }
    .intro-band__media { flex: 0 0 42%; }
    .intro-band__img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: var(--radius-md);
      display: block;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.14);
    }
    .intro-band__text {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
      max-width: 600px;
    }
    .intro-band__eyebrow {
      font-family: var(--font-ui);
      font-size: var(--text-sm);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-text);
      margin: 0;
    }
    .intro-band__title {
      font-family: var(--font-display);
      font-size: var(--text-display);
      font-weight: 400;
      margin: 0;
      line-height: 1.12;
    }
    .intro-band__lede { display: flex; flex-direction: column; gap: var(--space-sm); }
    .intro-band__lede p {
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: 1.7;
      margin: 0;
    }
    .intro-band__subhead {
      font-family: var(--font-display);
      font-size: var(--text-h3);
      font-weight: 400;
      margin: var(--space-sm) 0 0;
      line-height: 1.25;
    }
    .intro-band__about {
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: 1.85;
      margin: 0;
    }
    .intro-band__text .btn { margin-top: var(--space-sm); align-self: flex-start; }

    @media (max-width: 1024px) {
      .intro-band__inner { flex-direction: column; align-items: stretch; gap: var(--space-lg); }
      .intro-band__media { flex: none; width: 100%; max-width: 460px; margin-inline: auto; }
      .intro-band__img { aspect-ratio: 16 / 10; }
      .intro-band__text { max-width: 640px; margin-inline: auto; }
    }
  </style>

  {/* ════════ 4 · CATEGORIES (FACE / BODY / HAIR) ════════ */}
  <section class="home-section-8 section">
    <div class="container">
      <SectionHeading text="Our Services" tag="h2" align="center" font="display" size="lg" />

      <div class="service-tiles">
        {serviceColumns.map((col) => (
          <a class="service-tile" href={col.href} aria-label={`${col.label} treatments`}>
            <div class="service-tile__media">
              <Image
                src={col.img}
                alt={col.alt}
                class="service-tile__img"
                widths={[360, 520, 670, 800]}
                sizes="(max-width: 768px) 335px, 33vw"
                loading="lazy"
                decoding="async"
              />
              <span class="service-tile__overlay" aria-hidden="true"></span>
            </div>
            <span class="service-tile__label">{col.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .home-section-8 .container { display: flex; flex-direction: column; gap: var(--space-md); }
    .service-tiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
    .service-tile {
      position: relative;
      display: block;
      border-radius: var(--radius-md);
      overflow: hidden;
      box-shadow: 0 4px 18px rgba(0, 0, 0, 0.12);
      text-decoration: none;
    }
    .service-tile__media { position: relative; aspect-ratio: 2 / 3; overflow: hidden; }
    .service-tile__img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    .service-tile__overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(30, 24, 41, 0.60) 0%, rgba(30, 24, 41, 0.22) 55%, rgba(30, 24, 41, 0.14) 100%);
      transition: background 0.45s ease;
    }
    .service-tile__label {
      position: absolute; inset: 0; z-index: 2;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-size: var(--text-display); line-height: 1;
      color: #fff; letter-spacing: 0.04em; text-align: center;
      text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
    }

    /* Hover-capable devices: subtle image zoom + lighter scrim on hover/focus */
    @media (hover: hover) {
      .service-tile:hover .service-tile__img, .service-tile:focus-visible .service-tile__img { transform: scale(1.06); }
      .service-tile:hover .service-tile__overlay, .service-tile:focus-visible .service-tile__overlay {
        background: linear-gradient(to top, rgba(30, 24, 41, 0.50) 0%, rgba(30, 24, 41, 0.18) 60%, rgba(30, 24, 41, 0.10) 100%);
      }
    }
    .service-tile:focus-visible { outline: 3px solid var(--color-cta); outline-offset: 2px; }
    @media (prefers-reduced-motion: reduce) {
      .service-tile__img { transition: none; }
    }
    @media (max-width: 768px) {
      .service-tiles { grid-template-columns: 1fr; gap: var(--space-md); max-width: 460px; margin-inline: auto; }
      .service-tile__label { font-size: var(--text-h1); }
    }
  </style>

  {/* ════════ 4.5 · FIND YOUR GLOW (interactive quiz teaser) ════════ */}
  <section class="glow-teaser section">
    <div class="container glow-teaser__inner">
      <div class="glow-teaser__text">
        <p class="glow-teaser__eyebrow">Your skin, decoded</p>
        <h2 class="glow-teaser__heading">Not sure where to start?</h2>
        <p class="glow-teaser__body">
          Take our 2-minute <strong>Find Your Glow</strong> quiz and get treatments matched to your skin,
          plus a personalized at-home routine you can start tonight.
        </p>
        <a href="/find-your-glow" class="btn btn--primary btn--lg">Find your glow</a>
      </div>
      <div class="glow-teaser__badges" aria-hidden="true">
        <span class="glow-teaser__badge">Personalized to you</span>
        <span class="glow-teaser__badge">About 2 minutes</span>
        <span class="glow-teaser__badge">Expert-backed</span>
      </div>
    </div>
  </section>

  <style>
    .glow-teaser {
      position: relative;
      isolation: isolate;
      overflow: hidden;
      background: linear-gradient(135deg, var(--color-header-bg) 0%, #584b63 100%);
      color: #fff;
    }
    .glow-teaser::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background: radial-gradient(42% 90% at 86% 8%, rgb(201 168 118 / 0.42), rgb(201 168 118 / 0) 70%);
    }
    .glow-teaser__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-xl);
    }
    .glow-teaser__text { max-width: 620px; display: flex; flex-direction: column; gap: var(--space-sm); }
    .glow-teaser__eyebrow {
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #ecd9b8;
      margin: 0;
    }
    .glow-teaser__heading {
      font-family: var(--font-display);
      font-size: var(--text-display);
      font-weight: 400;
      margin: 0;
      line-height: 1.12;
    }
    .glow-teaser__body {
      font-family: var(--font-body);
      font-size: var(--text-lg);
      line-height: 1.6;
      color: rgb(255 255 255 / 0.9);
      margin: 0;
    }
    .glow-teaser__text .btn { align-self: flex-start; margin-top: var(--space-xs); }
    .glow-teaser__badges { display: flex; flex-direction: column; gap: var(--space-sm); flex: 0 0 auto; }
    .glow-teaser__badge {
      font-family: var(--font-ui);
      font-size: var(--text-sm);
      letter-spacing: 0.04em;
      color: #fff;
      background: rgb(255 255 255 / 0.1);
      border: 1px solid rgb(255 255 255 / 0.25);
      border-radius: 999px;
      padding: 11px 22px;
      text-align: center;
      backdrop-filter: blur(4px);
    }
    @media (max-width: 1024px) {
      .glow-teaser__inner { flex-direction: column; align-items: flex-start; gap: var(--space-lg); }
      .glow-teaser__badges { flex-direction: row; flex-wrap: wrap; }
    }
    @media (max-width: 600px) {
      .glow-teaser__text .btn { align-self: stretch; text-align: center; }
      /* Let the pills size to their text and wrap as tidy tags, instead of being
         crushed into equal-width columns (which broke the long "Personalized to you"). */
      .glow-teaser__badges { gap: 8px; }
      .glow-teaser__badge { flex: 0 0 auto; padding: 8px 16px; }
    }
  </style>

  {/* ════════ 5 · POPULAR TREATMENTS ════════ */}
  <section class="home-section-6 section section--tint">
    <div class="container">
      <div class="home-section-6__header">
        <p class="eyebrow" style="text-align: center;">MUST TRY</p>
        <SectionHeading text="Popular Treatments" tag="h2" align="center" font="display" size="md" />
      </div>

      <ServicesGrid
        columns={3}
        items={[
          {
            title: "BOTOX® Injectables",
            href: `/request-appointment?service=${encodeURIComponent("BOTOX® Injectables")}`,
            image_src: botoxImg,
            image_alt: "BOTOX® Injectables at Menon Medispa",
            description_html: "<p>$14 per unit</p>",
            cta_text: "Request to Book",
          },
          {
            title: "Juvéderm Fillers",
            href: `/request-appointment?service=${encodeURIComponent("Juvéderm Fillers")}`,
            image_src: juvedermImg,
            image_alt: "Juvéderm dermal filler treatment at Menon Medispa",
            description_html: "<p>From $750</p>",
            cta_text: "Request to Book",
          },
          {
            title: "HydraFacial™ Keravive™",
            href: `/request-appointment?service=${encodeURIComponent("HydraFacial™ Keravive™")}`,
            image_src: keraviveImg,
            image_alt: "HydraFacial Keravive scalp treatment at Menon Medispa",
            description_html: "<p>$500</p>",
            cta_text: "Request to Book",
          },
        ]}
      />
    </div>
  </section>

  <style>
    .home-section-6__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
      margin-bottom: var(--space-md);
    }
  </style>

  {/* ════════ 6 · YOUR SKIN COMES FIRST (philosophy band) ════════ */}
  <section class="media-bg section" style="--scrim-strength:0.55">
    <img
      class="media-bg__img media-bg__img--blur"
      src={skinFirstBg.src}
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      width={skinFirstBg.width}
      height={skinFirstBg.height}
    />
    <span class="media-bg__scrim media-bg__scrim--brand"></span>
    <div class="media-bg__inner container on-media home-section-9__inner">
      <div class="home-section-9__left">
        <p class="home-section-9__eyebrow eyebrow">WE BELIEVE</p>
        <h2 class="home-section-9__heading">Your Skin <br />Comes First</h2>
      </div>
      <div class="home-section-9__right">
        <RichText html="<p>Menon Medispa &amp; Wellness Brings Together Beauty &amp; Wellness.</p>" />
        <RichText html="<p>Our physicians and staff specialize in a wide range of facial and body treatments using the latest technology in lasers, fillers, and top rated facials. Whatever your skin type or concern, Menon Medispa will ensure you have the best experience possible.</p>" />
        <RichText html="<p>The health, rejuvenation and body confidence that patients get from their treatments are at the heart of what we do. We want them to feel and look their best, inside and out.&#8203;</p>" />
      </div>
    </div>
  </section>

  <style>
    .home-section-9__inner { display: flex; gap: var(--space-lg); align-items: flex-start; }
    .home-section-9__left {
      flex: 0 0 auto;
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
      max-width: 420px;
    }
    .home-section-9__heading {
      font-family: var(--font-display);
      font-size: var(--text-display);
      font-weight: var(--weight-bold);
      margin: 0;
      line-height: 1.2;
    }
    .home-section-9__right {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
      max-width: 466px;
    }
    @media (max-width: 1024px) {
      .home-section-9__inner { flex-direction: column; }
      .home-section-9__left { max-width: 100%; }
      .home-section-9__right { max-width: 100%; }
    }
  </style>

  {/* ════════ 7 · AN EXCEPTIONAL EXPERIENCE (Dr. Menon) ════════ */}
  <section class="home-section-10 section">
    <div class="container home-section-10__inner">
      <div class="home-section-10__text">
        <p class="home-section-10__eyebrow eyebrow">WHY CHOOSE MENON MEDISPA?</p>
        <h2 class="home-section-10__heading">An Exceptional<br />Experience</h2>
        <div class="home-section-10__body">
          <RichText html="<p>At Menon Medispa, we are passionate about enhancing people&#x27;s lives based on the belief that beauty comes from within.</p>" />
          <RichText html="<p>Founded and led by regenerative medicine specialist Dr. Aditi Menon, our medispa provides aesthetic and dermatological treatment solutions to maintain your outer glow and inner beauty.</p>" />
        </div>
        <div class="home-section-10__cta-wrap">
          <a href="/about" class="btn btn--secondary">About Menon Medispa</a>
        </div>
      </div>

      <div class="home-section-10__media">
        <video
          class="home-section-10__video"
          data-lazy-video
          data-src="/videos/wix/f61cce_b930b3f48aa04baa8c7f669d63cdaebd.mp4"
          autoplay
          loop
          muted
          playsinline
          preload="none"
          poster={videoPosterImg.src}
          aria-hidden="true"
        ></video>
        <img
          src={videoPosterImg.src}
          alt=""
          class="home-section-10__poster"
          loading="lazy"
          decoding="async"
          width="717"
          height="715"
        />
      </div>
    </div>
  </section>

  <style>
    .home-section-10__inner { display: flex; gap: var(--space-lg); align-items: center; }
    .home-section-10__text { flex: 1; display: flex; flex-direction: column; gap: var(--space-sm); }
    .home-section-10__heading {
      font-family: var(--font-display);
      font-size: var(--text-display);
      font-weight: var(--weight-regular);
      color: var(--color-text);
      margin: 0;
      line-height: 1.2;
    }
    .home-section-10__body { display: flex; flex-direction: column; gap: var(--space-sm); }
    .home-section-10__cta-wrap { margin-top: var(--space-sm); }
    .home-section-10__media { flex: 1; position: relative; max-width: 717px; }
    .home-section-10__video { width: 100%; height: auto; display: block; object-fit: cover; }
    .home-section-10__poster { display: none; width: 100%; height: auto; object-fit: cover; }
    @media (max-width: 1024px) {
      .home-section-10__inner { flex-direction: column; }
      .home-section-10__text { max-width: 100%; }
      .home-section-10__media { max-width: 549px; width: 100%; }
      .home-section-10__video { display: none; }
      .home-section-10__poster { display: block; }
    }
  </style>

  {/* ════════ 8 · MONTHLY SPECIALS ════════ */}
  <section class="specials section section--tint">
    <div class="container">
      <div class="specials__header">
        <p class="specials__eyebrow">MUST TRY</p>
        <SectionHeading text="Monthly Specials" tag="h2" align="center" font="display" />
      </div>

      <div class="specials-grid" aria-label="Monthly specials">
        {specials.map((s) => (
          <article class="special-card">
            <a href={s.more} class="special-card__media" aria-label={`Learn more about ${s.title}`}>
              {s.img && <img src={s.img} alt={s.alt} class="special-card__img" loading="lazy" decoding="async" width="420" height="320" />}
            </a>
            <div class="special-card__body">
              <div class="special-card__copy">
                <a href={s.more} class="special-card__title">{s.title}</a>
                <p class="special-card__price">{s.price}</p>
              </div>
              {s.includes.length > 0 && (
                <FeatureList items={s.includes} icon="check" font_size="var(--text-sm)" />
              )}
              <div class="special-card__links">
                <a href={s.book} class="btn btn--primary btn--sm">Book Now</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    .specials__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
      margin-bottom: var(--space-lg);
    }
    .specials__eyebrow {
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      letter-spacing: 0.08em;
      color: rgb(26 26 46 / 0.72);
      margin: 0;
    }
    .specials-grid {
      --specials-gap: clamp(18px, 2vw, 32px);
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--specials-gap);
      align-items: stretch;
    }
    .special-card {
      display: flex;
      flex-direction: column;
      background: var(--color-surface);
      border-radius: var(--radius-md);
      overflow: hidden;
      box-shadow: 0 8px 8px rgb(26 26 46 / 0.08);
      min-width: 0;
    }
    .special-card__media {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      background: rgb(26 26 46 / 0.06);
    }
    .special-card__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.35s ease;
    }
    .special-card:hover .special-card__img,
    .special-card:focus-within .special-card__img {
      transform: scale(1.04);
    }
    .special-card__body {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
      padding: 22px;
      flex: 1;
    }
    .special-card__copy {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .special-card__title {
      font-family: var(--font-display);
      font-size: var(--text-subheading);
      color: var(--color-text);
      line-height: 1.25;
      text-decoration: none;
      text-wrap: balance;
    }
    .special-card__title:hover { color: var(--color-brand-plum); }
    .special-card__price {
      font-family: var(--font-body);
      font-size: var(--text-lg);
      font-weight: var(--weight-bold);
      color: var(--color-brand-plum);
      margin: 0;
    }
    .special-card__links {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: var(--space-sm);
      margin-top: auto;
    }
    @media (max-width: 1024px) {
      .specials-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .special-card:nth-child(3) {
        grid-column: 1 / -1;
        justify-self: center;
        width: calc((100% - var(--specials-gap)) / 2);
      }
    }
    @media (max-width: 680px) {
      .specials-grid { grid-template-columns: 1fr; }
      .special-card:nth-child(3) {
        grid-column: auto;
        width: 100%;
      }
      .special-card__media { aspect-ratio: 16 / 11; }
      .special-card__body { padding: var(--space-md); }
      .special-card__links { align-items: stretch; flex-direction: column; }
      .special-card__links .btn { width: 100%; }
    }
    @media (prefers-reduced-motion: reduce) {
      .special-card__img { transition: none; }
      .special-card:hover .special-card__img,
      .special-card:focus-within .special-card__img { transform: none; }
    }
  </style>

  {/* ════════ 9 · TESTIMONIALS ════════ */}
  <section class="media-bg section" style="--scrim-strength:0.6">
    <img
      class="media-bg__img media-bg__img--blur"
      src={testimonialsBg.src}
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      width="1440"
      height="626"
    />
    <span class="media-bg__scrim media-bg__scrim--b"></span>
    <div class="media-bg__inner container home-section-7__content">
      <h2 class="home-section-7__heading">What Our Clients Say</h2>

      {homeReview && (
        <figure class="review-card">
          <p class="review-card__stars stars" aria-label="Rated 5 out of 5 stars">★★★★★</p>
          <blockquote class="review-card__quote">
            <p>{`“${homeReview.quote}”`}</p>
          </blockquote>
          <figcaption class="review-card__author">{homeReview.author}</figcaption>
        </figure>
      )}

      <a class="home-section-7__social-proof" href={site.reviewsUrl} target="_blank" rel="noopener noreferrer" aria-label="Read our reviews on Google">
        <div class="home-section-7__avatars">
          <img src={avatar1.src} alt="" class="home-section-7__avatar" loading="lazy" decoding="async" width="46" height="50" />
          <img src={avatar2.src} alt="" class="home-section-7__avatar" loading="lazy" decoding="async" width="52" height="50" />
          <img src={avatar3.src} alt="" class="home-section-7__avatar" loading="lazy" decoding="async" width="52" height="50" />
        </div>
        <div class="home-section-7__stars-block">
          <p class="home-section-7__stars stars">★★★★★</p>
          <p class="home-section-7__review-count">100+ 5 Star Reviews</p>
        </div>
      </a>
    </div>
  </section>

  <style>
    .home-section-7__content { display: flex; flex-direction: column; align-items: center; gap: var(--space-md); }
    .home-section-7__heading {
      font-family: var(--font-display);
      font-size: var(--text-h2);
      font-weight: 400;
      color: #fff;
      text-align: center;
      margin: 0;
      text-shadow: 0 2px 14px rgba(0, 0, 0, 0.5);
    }
    .review-card {
      max-width: 720px;
      margin: 0;
      background: rgba(255, 255, 255, 0.96);
      border-radius: var(--radius-md);
      padding: var(--space-lg);
      box-shadow: 0 12px 44px rgba(0, 0, 0, 0.24);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
      text-align: center;
    }
    .review-card__quote {
      margin: 0;
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-lg);
      line-height: 1.6;
      color: var(--color-text);
    }
    .review-card__quote p { margin: 0; }
    .review-card__author { font-family: var(--font-body); font-size: var(--text-sm); font-weight: 700; color: var(--color-text); }
    .home-section-7__social-proof { display: flex; align-items: center; gap: var(--space-md); justify-content: center; color: inherit; text-decoration: none; cursor: pointer; width: fit-content; transition: opacity 0.2s ease; }
    .home-section-7__social-proof:hover { opacity: 0.85; }
    .home-section-7__avatars { display: flex; align-items: center; }
    .home-section-7__avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid #fff;
      margin-left: -8px;
      flex-shrink: 0;
    }
    .home-section-7__avatar:first-child { margin-left: 0; }
    .home-section-7__stars-block { display: flex; flex-direction: column; gap: 4px; align-items: flex-start; }
    .home-section-7__stars { margin: 0; line-height: 1; font-size: 1.25rem; letter-spacing: 2px; color: var(--color-star); }
    .home-section-7__review-count {
      font-family: var(--font-display);
      font-size: var(--text-sm);
      font-weight: 700;
      color: #fff;
      margin: 0;
      line-height: 1.3;
      text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
    }
    @media (max-width: 600px) {
      .home-section-7__social-proof { flex-direction: column; gap: var(--space-sm); }
      .home-section-7__stars-block { align-items: center; }
    }
  </style>

  {/* ════════ 10 · FAQ ════════ */}
  <section class="home-faq section section--tint">
    <div class="container container--narrow">
      <SectionHeading text="Frequently asked questions" tag="h2" align="center" font="display" />
      <FaqAccordion items={faqs.map((f) => ({ question: f.question, answer_html: `<p>${f.answer}</p>` }))} />
    </div>
  </section>

  <style>
    .home-faq .section-heading { margin-bottom: var(--space-lg); }
    .home-faq :global(.faq-accordion) { padding: 0; }
  </style>

  {/* ════════ 11 · RECENT POSTS ════════ */}
  <section class="home-section-11 section">
    <div class="container">
      <SectionHeading text="Insights" tag="h2" align="center" font="display" />

      <BlogList
        heading=""
        posts={recentPosts}
      />

      <div class="home-section-11__more">
        <a href="/blog" class="btn btn--secondary btn--lg">View all articles</a>
      </div>
    </div>
  </section>

  <style>
    .home-section-11 .container .section-heading { margin-bottom: var(--space-xl); }
    .home-section-11 :global(.blog-list) { padding: 0; }
    .home-section-11__more { text-align: center; margin-top: var(--space-lg); }
  </style>

  {/* ════════ 12 · BEGIN YOUR TRANSFORMATION + CONTACT ════════ */}
  <section class="home-cta-contact section section--tint">
    <div class="container home-cta-contact__inner">
      <div class="home-cta-contact__text">
        <SectionHeading text="Begin Your Transformation Today" tag="h2" align="left" font="display" />
        <RichText html="<p>Menon Medispa Millburn NJ</p>" font="var(--font-body)" size="var(--text-sm)" color="var(--color-text)" />
        <RichText html="<p>Ready to experience the benefits of Menon Medispa? Take the first step toward Perfect Skin and Hair  by scheduling your personal consultation at Menon Medispa in Millburn, NJ.</p>" font="var(--font-body)" size="var(--text-sm)" color="var(--color-text)" />
        <div class="home-cta-contact__cta">
          <Button text="Schedule a Consultation" href={site.calcomUrl} variant="primary" />
        </div>
      </div>

      <div class="home-cta-contact__form">
        <div class="contact-card">
          <LeadForm
            heading="Contact Us"
            fields={['name', 'email', 'phone', 'message']}
            submit_label="Send Message"
            success_url="/thank-you"
          />
        </div>
      </div>
    </div>
  </section>

  <style>
    .home-cta-contact__inner {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-xl);
    }
    .home-cta-contact__text {
      flex: 0 0 42%;
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }
    .home-cta-contact__cta { margin-top: var(--space-xs); }
    .home-cta-contact__form { flex: 1; min-width: 0; }

    .contact-card {
      background: rgb(196 164 132 / 0.10);
      border: 1px solid rgb(196 164 132 / 0.35);
      border-radius: var(--radius-md);
      padding: var(--space-lg);
    }
    .contact-card :global(.lead-form) { padding: 0; }
    .contact-card :global(.lead-form > h2) { margin: 0 0 var(--space-md); }
    .contact-card :global(.lead-form__form) {
      max-width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-sm);
    }
    .contact-card :global(.lead-form__form > .lead-form__field:nth-child(3)), .contact-card :global(.lead-form__form > .lead-form__field:nth-child(4)), .contact-card :global(.lead-form__form > button) { grid-column: 1 / -1; }
    .contact-card :global(.lead-form__form > button) { justify-self: start; margin-top: var(--space-xs); }

    @media (max-width: 1024px) {
      .home-cta-contact__inner { flex-direction: column; }
      .home-cta-contact__text { flex: none; }
      .home-cta-contact__text .section-heading { text-align: center; }
    }
    @media (max-width: 600px) {
      .contact-card { padding: var(--space-md); }
      .contact-card :global(.lead-form__form) { grid-template-columns: 1fr; }
    }
  </style>

</BaseLayout>
