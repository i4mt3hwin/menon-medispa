---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import RichText from '@/components/RichText.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import Gallery from '@/components/Gallery.astro';
import Button from '@/components/Button.astro';
import ContentSection from '@/components/ContentSection.astro';
import ServicesGrid from '@/components/ServicesGrid.astro';
import TestimonialStrip from '@/components/TestimonialStrip.astro';
import Picture from '@/components/Picture.astro';
import BlogList from '@/components/BlogList.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import LeadForm from '@/components/LeadForm.astro';
import site from '@/lib/site';

import posterImg from '@/assets/images/f2a8f8988125.jpg';
import vogueImg from '@/assets/images/abe70978be24.jpg';
import cosmoImg from '@/assets/images/a907a2a5b193.jpg';
import bazaarImg from '@/assets/images/c1cefa7e9c95.jpg';
import fortuneImg from '@/assets/images/349d72d3c082.webp';
import hydrafacialImg from '@/assets/images/86072f9cbd9c.jpg';
import ivImg from '@/assets/images/dd355e57f3dd.jpg';
import brotoxImg from '@/assets/images/56a3e3ac1335.jpg';
import botoxImg from '@/assets/services/botox-injectables-card.webp';
import juvedermImg from '@/assets/services/juvederm-fillers-card.webp';
import keraviveImg from '@/assets/services/hydrafacial-keravive-card.webp';
import testimonialsBg from '@/assets/testimonials/what-our-clients-say-bg.webp';
import avatar1 from '@/assets/testimonials/reviewer-avatar-1.webp';
import avatar2 from '@/assets/testimonials/reviewer-avatar-2.webp';
import avatar3 from '@/assets/testimonials/reviewer-avatar-3.webp';
import faceTreatmentsImg from '@/assets/services/face-treatments.webp';
import naturalBeautyImg from '@/assets/services/natural-beauty-body.webp';
import modelCurlyHairImg from '@/assets/services/model-curly-hair.webp';
import skinFirstBg from '@/assets/home/your-skin-comes-first-bg.webp';
import videoPosterImg from '@/assets/home/exceptional-experience-video-poster.webp';
import post1Img from '@/assets/images/2c734ddea5ed.png';
import post2Img from '@/assets/images/cdeb1a3077ee.jpg';
import post3Img from '@/assets/images/0b093327272f.png';
import staffImg from '@/assets/images/b1a819f35921.webp';
---

<BaseLayout
  title="Medical Spa | Menon Medispa & Wellness | Millburn, NJ"
  description="Experience the top-rated services at Menon Medispa in Millburn, NJ, including HydraFacial, Botox, and more. Book today!"
  canonical="https://www.menonmedispa.com"
>

  <!-- Section 1 -->
  <HeroSection
    eyebrow="Millburn NJ's Premier Medispa & Wellness Center"
    heading="Give Yourself the Glow Up You Deserve"
    body="Advanced Botox, facials, and body treatments delivered by medical experts. Discover why Millburn residents choose us for their aesthetic goals."
    bg_video_url="https://video.wixstatic.com/video/2baa5c_feca9a60fac643698798ede1260cd291/1080p/mp4/file.mp4"
    bg_image_url={posterImg.src}
    bg_image_alt=""
    ctas={[
      { text: "Schedule An Appointment", href: site.calcomUrl, variant: "primary" }
    ]}
    social_proof={[
      { image_key: "90411e0041df", alt: "Picture of a Client Who Reviewed Us" },
      { image_key: "305afeda5f9a", alt: "Picture of a Client Who Reviewed Us" },
      { image_key: "b95880091b44", alt: "Picture of a Client Who Reviewed Us" }
    ]}
    stars_text="★★★★★"
    review_count_text="100+ 5 Star Reviews"
    height="599px"
    layout="left-overlay"
  />

  <!-- Section 2 -->
  <section class="trust-bar">
    <div class="trust-bar__inner">
      <div class="trust-bar__item">
        <RichText
          html="Same-Week Appointments"
          font="var(--font-body)"
          size="var(--text-sm)"
        />
      </div>
      <div class="trust-bar__item">
        <RichText
          html="Medical-Grade Expertise"
          font="var(--font-body)"
          size="var(--text-sm)"
        />
      </div>
      <div class="trust-bar__item">
        <RichText
          html="State of the Art Equipment"
          font="var(--font-body)"
          size="var(--text-sm)"
        />
      </div>
    </div>
  </section>

  <style>
    .trust-bar {
      width: 100%;
      box-sizing: border-box;
      padding: var(--space-md) var(--space-md);
    }

    .trust-bar__inner {
      display: flex;
      flex-direction: row;
      justify-content: space-around;
      align-items: center;
      gap: var(--space-md);
      max-width: 1440px;
      margin: 0 auto;
    }

    .trust-bar__item {
      flex: 1;
      text-align: center;
    }

    @media (max-width: 980px) {
      .trust-bar__inner {
        flex-direction: column;
        align-items: center;
        gap: var(--space-sm);
      }

      .trust-bar__item {
        width: 100%;
      }
    }
  </style>

  <!-- Section 3 -->
  <section class="featured-in">
    <div class="featured-in__inner">
      <SectionHeading
        text="We Offer Skincare Treatments Featured In"
        tag="h2"
        align="center"
        font="display"
      />
      <div class="featured-in__logos">
        <div class="featured-in__logo-item">
          <img src={vogueImg.src} alt="Vogue" class="featured-in__logo-img" loading="lazy" decoding="async" width="200" height="100" />
        </div>
        <div class="featured-in__logo-item">
          <img src={cosmoImg.src} alt="Cosmopolitan" class="featured-in__logo-img" loading="lazy" decoding="async" width="200" height="100" />
        </div>
        <div class="featured-in__logo-item">
          <img src={bazaarImg.src} alt="Harper's Bazaar" class="featured-in__logo-img" loading="lazy" decoding="async" width="200" height="100" />
        </div>
        <div class="featured-in__logo-item">
          <img src={fortuneImg.src} alt="Fortune" class="featured-in__logo-img" loading="lazy" decoding="async" width="200" height="100" />
        </div>
      </div>
    </div>
  </section>

  <style>
    .featured-in {
      width: 100%;
      box-sizing: border-box;
      padding: var(--space-lg) var(--space-md);
    }

    .featured-in__inner {
      max-width: 1440px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    .featured-in__logos {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: var(--space-xl);
      flex-wrap: wrap;
    }

    .featured-in__logo-item {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-sm) var(--space-md);
    }

    .featured-in__logo-img {
      display: block;
      max-width: 160px;
      max-height: 80px;
      width: auto;
      height: auto;
      object-fit: contain;
      filter: grayscale(100%);
      opacity: 0.65;
      transition: opacity 0.2s, filter 0.2s;
    }

    .featured-in__logo-item:hover .featured-in__logo-img {
      opacity: 1;
      filter: grayscale(0%);
    }

    @media (max-width: 980px) {
      .featured-in {
        padding: var(--space-md) var(--space-sm);
      }

      .featured-in__logos {
        gap: var(--space-md);
      }

      .featured-in__logo-img {
        max-width: 110px;
        max-height: 60px;
      }
    }
  </style>

  <!-- Section 4 -->
  <section class="welcome-section">
    <div class="welcome-section__inner">

      {/* Left column — decorative welcome block */}
      <div class="welcome-section__left">
        <SectionHeading
          text="Welcome To"
          tag="h3"
          align="center"
          font="body"
        />
        <SectionHeading
          text="Menon Medispa &amp; Wellness"
          tag="h3"
          align="center"
          font="body"
        />
        <RichText
          html="If you're ever unsure which service is right for you, we're here to help!"
          font="var(--font-body)"
          size="var(--text-xs)"
        />
        <RichText
          html="Schedule a complimentary consultation with one of our experts to discuss your goals and find the perfect treatment."
          font="var(--font-body)"
          size="var(--text-xs)"
        />
        <RichText
          html="Click below to book your session and start your journey to looking and feeling your best."
          font="var(--font-body)"
          size="var(--text-xs)"
        />
        <Button
          text="Schedule Consultation"
          href="/consultation"
          variant="primary"
        />
      </div>

      {/* Right column — about / SEO copy */}
      <div class="welcome-section__right">
        <ContentSection
          heading="Expert Medispa and Skin Care Clinic in Millburn, NJ"
          heading_tag="h2"
          body_paragraphs={[
            "Menon Medispa has been at the forefront of medical aesthetics and anti-aging innovations since 2019. Our team of esteemed medical experts is committed to providing outstanding care and achieving lasting outcomes that not only improve your looks but also boost your overall wellness. We take pride in our recognition as the top-rated medispa in Millburn NJ."
          ]}
          image_position="none"
          padding="sm"
        />
      </div>

    </div>
  </section>

  <style>
    .welcome-section {
      width: 100%;
      box-sizing: border-box;
      padding: var(--space-xl) var(--space-lg);
    }

    .welcome-section__inner {
      max-width: 1440px;
      margin: 0 auto;
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-lg);
    }

    .welcome-section__left {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
      text-align: center;
    }

    .welcome-section__left .section-heading {
      font-family: var(--font-accent);
    }

    .welcome-section__right {
      flex: 1;
    }

    @media (max-width: 980px) {
      .welcome-section {
        padding: var(--space-lg) var(--space-sm);
      }

      .welcome-section__inner {
        flex-direction: column;
      }

      .welcome-section__left,
      .welcome-section__right {
        width: 100%;
        flex: none;
      }
    }
  </style>

  <!-- Section 5 -->
  <section class="monthly-specials">
    <div class="monthly-specials__header">
      <RichText
        html="MUST TRY"
        font="var(--font-ui)"
        size="var(--text-xs)"
        class="monthly-specials__eyebrow"
      />
      <SectionHeading
        text="Monthly Specials"
        tag="h2"
        align="center"
        font="display"
      />
    </div>

    <div class="monthly-specials__list">

      {/* Card 1 — Summer Glow Hydrafacial */}
      <div class="specials-card">
        <div class="specials-card__img-wrap">
          <img
            src={hydrafacialImg.src}
            alt="Hydrafacial.jpg"
            class="specials-card__img"
            width="110"
            height="110"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="specials-card__body">
          <div class="specials-card__title-row">
            <a
              href="https://www.menonmedispa.com/booking-calendar/summer-glow-hydrafacial"
              class="specials-card__title-link"
            >Summer Glow Hydrafacial</a>
            <a
              href="https://www.menonmedispa.com/service-page/summer-glow-hydrafacial"
              class="specials-card__read-more"
            >Read More</a>
          </div>
          <p class="specials-card__price">$225</p>
        </div>
        <div class="specials-card__cta-wrap">
          <Button
            text="Book Now"
            href="https://www.menonmedispa.com/booking-calendar/summer-glow-hydrafacial"
            variant="primary"
          />
        </div>
      </div>

      {/* Card 2 — Custom Hydrating IV */}
      <div class="specials-card">
        <div class="specials-card__img-wrap">
          <img
            src={ivImg.src}
            alt="shutterstock_2578361641.jpg"
            class="specials-card__img"
            width="110"
            height="110"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="specials-card__body">
          <div class="specials-card__title-row">
            <a
              href="https://www.menonmedispa.com/booking-calendar/custom-hydrating-iv"
              class="specials-card__title-link"
            >Custom Hydrating IV</a>
            <a
              href="https://www.menonmedispa.com/service-page/custom-hydrating-iv"
              class="specials-card__read-more"
            >Read More</a>
          </div>
          <p class="specials-card__price">$99</p>
        </div>
        <div class="specials-card__cta-wrap">
          <Button
            text="Book Now"
            href="https://www.menonmedispa.com/booking-calendar/custom-hydrating-iv"
            variant="primary"
          />
        </div>
      </div>

      {/* Card 3 — BRO-Tox Father's Day Special */}
      <div class="specials-card">
        <div class="specials-card__img-wrap">
          <img
            src={brotoxImg.src}
            alt="shutterstock_2193199469.jpg"
            class="specials-card__img"
            width="110"
            height="110"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="specials-card__body">
          <div class="specials-card__title-row">
            <a
              href="https://www.menonmedispa.com/booking-calendar/bro-tox-father-s-day-special"
              class="specials-card__title-link"
            >BRO-Tox Father's Day Special</a>
            <a
              href="https://www.menonmedispa.com/service-page/bro-tox-father-s-day-special"
              class="specials-card__read-more"
            >Read More</a>
          </div>
          <p class="specials-card__price">$12 Per Unit</p>
        </div>
        <div class="specials-card__cta-wrap">
          <Button
            text="Book Now"
            href="https://www.menonmedispa.com/booking-calendar/bro-tox-father-s-day-special"
            variant="primary"
          />
        </div>
      </div>

    </div>
  </section>

  <style>
    .monthly-specials {
      width: 100%;
      box-sizing: border-box;
      padding: var(--space-xl) var(--space-lg);
    }

    .monthly-specials__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
      margin-bottom: var(--space-md);
    }

    .monthly-specials__eyebrow {
      text-align: center;
      letter-spacing: 0.1em;
    }

    .monthly-specials__list {
      max-width: 940px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    /* Each specials card — horizontal row: image | body | cta */
    .specials-card {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: var(--space-md);
      padding: var(--space-sm) 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }

    .specials-card:last-child {
      border-bottom: none;
    }

    .specials-card__img-wrap {
      flex-shrink: 0;
      width: 110px;
      height: 110px;
      overflow: hidden;
      border-radius: var(--radius-sm);
    }

    .specials-card__img {
      width: 110px;
      height: 110px;
      object-fit: cover;
      object-position: 50% 50%;
      display: block;
    }

    .specials-card__body {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .specials-card__title-row {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .specials-card__title-link {
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      font-weight: var(--weight-bold);
      color: var(--color-text);
      text-decoration: none;
      line-height: 1.4;
    }

    .specials-card__title-link:hover {
      text-decoration: underline;
    }

    .specials-card__read-more {
      font-family: var(--font-body);
      font-size: var(--text-xs);
      color: var(--color-text);
      text-decoration: underline;
      text-underline-offset: 2px;
      line-height: 1.5;
      margin-top: 8px;
      margin-bottom: 8px;
    }

    .specials-card__price {
      font-family: var(--font-body);
      font-size: var(--text-xs);
      color: var(--color-text);
      line-height: 2;
      margin: 0;
    }

    .specials-card__cta-wrap {
      flex-shrink: 0;
    }

    /* Override btn width for this context — match Wix 151px */
    .specials-card__cta-wrap .btn {
      background-color: var(--color-accent);
      border: 1px solid rgba(117, 77, 77, 0.6);
      min-width: 151px;
      text-align: center;
    }

    @media (max-width: 980px) {
      .monthly-specials {
        padding: var(--space-lg) var(--space-sm);
      }

      .specials-card {
        flex-wrap: wrap;
      }

      .specials-card__cta-wrap {
        width: 100%;
      }

      .specials-card__cta-wrap .btn {
        width: 100%;
        text-align: center;
      }
    }
  </style>

  <!-- Section 6 -->
  <section class="home-section-6">
    <div class="home-section-6__header">
      <SectionHeading
        text="MUST TRY"
        tag="h5"
        align="center"
        font="ui"
        size="sm"
      />
      <SectionHeading
        text="Popular Treatments"
        tag="h3"
        align="center"
        font="display"
        size="md"
      />
    </div>

    <ServicesGrid
      columns={3}
      items={[
        {
          title: "BOTOX® Injectables",
          href: "/service-page/botox-injectables",
          image_src: botoxImg.src,
          image_alt: "BOTOX® Injectables at Menon Medispa",
          description_html: "<p>$14 per unit</p>",
          cta_text: "Request to Book",
        },
        {
          title: "Juvéderm Fillers",
          href: "/service-page/juvéderm-fillers",
          image_src: juvedermImg.src,
          image_alt: "Injection cosmetology",
          description_html: "<p>From $750</p>",
          cta_text: "Request to Book",
        },
        {
          title: "HydraFacial™ Keravive™",
          href: "/service-page/hydrafacial-keravive",
          image_src: keraviveImg.src,
          image_alt: "The Benefits of Hair Restoration Therapy",
          description_html: "<p>$500</p>",
          cta_text: "Request to Book",
        },
      ]}
    />
  </section>

  <style>
    .home-section-6 {
      padding: var(--space-lg) var(--space-md);
    }

    .home-section-6__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
      margin-bottom: var(--space-md);
    }

    @media (max-width: 980px) {
      .home-section-6 {
        padding: var(--space-md) var(--space-sm);
      }
    }
  </style>

  <!-- Section 7 -->
  <section class="home-section-7">
    <div class="home-section-7__bg-wrap">
      <img
        src={testimonialsBg.src}
        alt="Untitled-4.png"
        class="home-section-7__bg"
        loading="lazy"
        decoding="async"
        width="1440"
        height="626"
      />
    </div>

    <div class="home-section-7__content">
      <TestimonialStrip
        heading="What Our Clients Say"
        layout="carousel"
        testimonials={[
          {
            quote: `"Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.`,
            author: "Alexa C.",
            rating: "★★★★★",
          },
        ]}
      />

      <div class="home-section-7__social-proof">
        <div class="home-section-7__avatars">
          <img
            src={avatar1.src}
            alt="Picture of a Client Who Reviewed Us"
            class="home-section-7__avatar"
            loading="lazy"
            decoding="async"
            width="46"
            height="50"
          />
          <img
            src={avatar2.src}
            alt="Picture of a Client Who Reviewed Us"
            class="home-section-7__avatar"
            loading="lazy"
            decoding="async"
            width="52"
            height="50"
          />
          <img
            src={avatar3.src}
            alt="Picture of a Client Who Reviewed Us"
            class="home-section-7__avatar"
            loading="lazy"
            decoding="async"
            width="52"
            height="50"
          />
        </div>
        <div class="home-section-7__stars-block">
          <p class="home-section-7__stars">★★★★★</p>
          <p class="home-section-7__review-count">100+ 5 Star Reviews</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .home-section-7 {
      position: relative;
      overflow: hidden;
    }

    .home-section-7__bg-wrap {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .home-section-7__bg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .home-section-7__content {
      position: relative;
      z-index: 1;
      padding: var(--space-lg) var(--space-md);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-md);
    }

    .home-section-7__social-proof {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      justify-content: center;
    }

    .home-section-7__avatars {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
    }

    .home-section-7__avatar {
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }

    .home-section-7__stars-block {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .home-section-7__stars {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      margin: 0;
      line-height: 1;
    }

    .home-section-7__review-count {
      font-family: var(--font-display);
      font-size: var(--text-xs);
      color: var(--color-text);
      margin: 0;
      line-height: 1.3;
    }

    @media (max-width: 980px) {
      .home-section-7__bg {
        width: 980px;
        max-width: 980px;
      }

      .home-section-7__content {
        padding: var(--space-md) var(--space-sm);
      }

      .home-section-7__social-proof {
        flex-direction: column;
        gap: var(--space-sm);
      }
    }
  </style>

  <!-- Section 8 -->
  <section class="home-section-8">
    <SectionHeading
      text="Our Services"
      tag="h2"
      align="center"
      font="display"
      size="lg"
    />

    <div class="home-section-8__gallery-wrap">
      <Gallery
        columns={3}
        aspect="portrait"
        images={[
          {
            src: faceTreatmentsImg.src,
            alt: "Face Treatments Menon Medispa",
            width: 385,
            height: 675,
          },
