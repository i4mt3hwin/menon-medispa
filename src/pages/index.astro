    .specials-marquee__track { display: flex; width: max-content; animation: specials-scroll 38s linear infinite; }
    .specials-marquee:hover .specials-marquee__track { animation-play-state: paused; }
    .specials-marquee__group {
      display: flex;
      align-items: stretch;
      flex: 0 0 auto;
      gap: var(--space-md);
      padding-right: var(--space-md);
    }
    @keyframes specials-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .special-card {
