---
/**
 * ClearLift Skin Rejuvenation — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/clear-lift-skin-rejuvination/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="ClearLift Skin Rejuvenation | Menon Medispa & Wellness | Millburn, NJ"
  description="ClearLift non-ablative laser skin rejuvenation in Millburn NJ. Tighten skin, reduce wrinkles, and improve texture with zero downtime."
>
  <main class="sp" data-slug="clear-lift-skin-rejuvination">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="ClearLift Skin Rejuvenation">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">ClearLift Skin Rejuvenation</h1>
            <p class="sp-hero__eyebrow">Non-Ablative Laser Skin Tightening with Zero Downtime</p>
            <p class="sp-hero__lead">ClearLift is the revolutionary non-ablative laser that delivers deep tissue remodeling to tighten skin, reduce wrinkles, and improve overall skin quality—all without any downtime or discomfort.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">100+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/651c7c197b52.png" alt="ClearLift Skin Rejuvenation" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Zero Downtime</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Safe for All Skin Types</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Immediate Results</p>
      </div>
    </section>

    
    {/* ===== HOW CLEARLIFT WORKS ===== */}
    <section class="sp-plain" aria-label="How ClearLift Works">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">How ClearLift Works</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">ClearLift uses fractional Q-switched Nd:YAG laser energy to create a controlled injury in the deep dermal layers without damaging the surface of your skin. This stimulates your body's natural collagen production process, resulting in gradual skin tightening and rejuvenation.</p>
<p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Unlike traditional ablative lasers that remove the top layer of skin, ClearLift works beneath the surface. You can return to your normal activities immediately after treatment, making it the perfect "lunchtime laser."</p>
<h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Benefits of ClearLift</h3>
<ul style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.8;padding-left:1.5rem;margin:0 0 1rem;"><li>Tightens and lifts sagging skin</li><li>Reduces fine lines and wrinkles</li><li>Improves skin texture and tone</li><li>Safe for all skin types including darker skin tones</li><li>No redness, peeling, or recovery time</li></ul>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            
            <details class="sp-faq__item" open>
              <summary>How many ClearLift sessions do I need?</summary>
              <div class="sp-faq__answer"><p>Most clients see best results with 4-6 treatments spaced 2-4 weeks apart, followed by maintenance treatments every 3-6 months. Results are gradual and cumulative, with visible improvement seen after each session.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Is ClearLift safe for sensitive skin?</summary>
              <div class="sp-faq__answer"><p>Yes! ClearLift is specifically designed to be safe for all skin types, including sensitive skin and darker skin tones that may not tolerate other laser treatments. The non-ablative approach minimizes the risk of post-inflammatory hyperpigmentation.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>What results can I expect from ClearLift?</summary>
              <div class="sp-faq__answer"><p>You'll notice gradual improvement in skin tightness, texture, and overall quality. Most clients see visible results within 4-6 weeks as collagen production increases. Full results develop over 3-6 months of regular treatments.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Begin Your Skin Rejuvenation Today">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Begin Your Skin Rejuvenation Today</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Experience the future of non-invasive skin tightening with ClearLift at Menon Medispa in Millburn, NJ.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
