---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout>
  <main class="pg" data-slug="patient-resources">
<section class="pg-section" data-section="Patient Resources">
  <h1 class="pg-h">Patient Resources</h1>
  <p class="pg-text">On your first visit, you will be asked to fill out a ‘New Patient’ form. If you already filled out the form from the website please bring the physical copy with you to submit at the front desk. You will have a personable consultation with Dr. Menon as she gets to know you and go over your skin history.</p>
  <p class="pg-text">In the time spent at Menon Regenerative, we encourage you to ask questions, express your concerns and share anything you want us to know to help make your care as individualized as possible.</p>
  <a class="pg-btn" href="/_files/ugd/f61cce_5f9f728230b54574bada5ea7c05f6f53.pdf">NEW PATIENT FORM</a>
</section>
  </main>
</BaseLayout>
