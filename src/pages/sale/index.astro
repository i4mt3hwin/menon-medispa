---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
---
<BaseLayout title="Current Sales &amp; Specials | Menon Medispa | Millburn, NJ" description="Explore current sales and specials at Menon Medispa in Millburn, NJ. Limited-time offers on our most popular treatments.">
  <main class="sp" data-slug="sale">
    <section class="sp-hero sp-hero--center" aria-label="Sales &amp; Specials">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Current <em>Sales &amp; Specials</em></h1>
        <p class="sp-hero__lead" style="text-align:center;margin:0 auto;max-width:560px;">Limited-time offers on our most popular treatments.</p>
      </div>
    </section>
    <section class="sp-rows" aria-label="Current Specials">
      <div class="sp-container">
        <div class="sp-rows__head">
          <h2 class="sp-script-title">Current <em>Specials</em></h2>
        </div>
        <div class="sp-rows__list">
          <div class="sp-row">
            <img class="sp-row__thumb" src="/images/acb8f1a74f7d.jpg" alt="The Timeless Beauty Experience" loading="lazy" />
            <div class="sp-row__main">
              <a class="sp-row__title" href="/booking-calendar/the-timeless-beauty-experience">THE TIMELESS BEAUTY EXPERIENCE</a>
              <a class="sp-row__more" href="/service-page/the-timeless-beauty-experience">Read More</a>
            </div>
            <div class="sp-row__price">$450</div>
            <a class="sp-btn sp-btn--gold sp-row__cta" href="/booking-calendar/the-timeless-beauty-experience">Request to Book</a>
          </div>
          <div class="sp-row">
            <img class="sp-row__thumb" src="/images/b629e8e1a741.jpg" alt="Give the Gift of Glow" loading="lazy" />
            <div class="sp-row__main">
              <a class="sp-row__title" href="/booking-calendar/give-the-gift-of-glow">GIVE THE GIFT OF GLOW</a>
              <a class="sp-row__more" href="/service-page/give-the-gift-of-glow">Read More</a>
            </div>
            <div class="sp-row__price">Call us to book</div>
            <a class="sp-btn sp-btn--gold sp-row__cta" href="/booking-calendar/give-the-gift-of-glow">Request to Book</a>
          </div>
          <div class="sp-row">
            <img class="sp-row__thumb" src="/images/6493a64ea586.jpg" alt="Forever Radiant Experience" loading="lazy" />
            <div class="sp-row__main">
              <a class="sp-row__title" href="/booking-calendar/forever-radiant-experience">Forever Radiant Experience</a>
              <a class="sp-row__more" href="/service-page/forever-radiant-experience">Read More</a>
            </div>
            <div class="sp-row__price">$500</div>
            <a class="sp-btn sp-btn--gold sp-row__cta" href="/booking-calendar/forever-radiant-experience">Request to Book</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
