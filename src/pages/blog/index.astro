---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Blog | Menon Medispa &amp; Wellness | Millburn, NJ" description="Read the latest articles and tips on skincare, wellness, and aesthetics from the team at Menon Medispa in Millburn, NJ.">
  <main class="sp" data-slug="blog">
    <section class="sp-hero sp-hero--center" aria-label="Blog">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Our <em>Blog</em></h1>
        <p class="sp-hero__lead" style="text-align:center;margin:0 auto;max-width:560px;">Expert insights on skincare, wellness, and aesthetics from the Menon Medispa team.</p>
      </div>
    </section>
    <section class="sp-plain" aria-label="Blog Posts">
      <div class="sp-container">
        <div style="max-width:960px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:2rem;">
          <article style="background:#fff;box-shadow:var(--shadow-soft);display:flex;flex-direction:column;">
            <img src="/images/2c734ddea5ed.png" alt="Is Botox Safe?" style="width:100%;aspect-ratio:3/2;object-fit:cover;" loading="lazy" />
            <div style="padding:1.25rem 1.4rem 1.5rem;">
              <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);margin:0 0 0.75rem;"><a href="/post/is-botox-safe-risks-side-effects-what-research-says-in-millburn-nj" style="color:var(--color-ink);text-decoration:none;">Is Botox Safe? Risks, Side Effects &amp; What Research Says in Millburn, NJ</a></h2>
              <p style="font-family:var(--font-ui);color:#5e5e5e;font-size:var(--text-sm);line-height:1.6;margin:0;">Wondering if Botox is truly safe? We break down FDA approval, common side effects, rare risks, and how to ensure your treatment is in expert hands.</p>
            </div>
          </article>
          <article style="background:#fff;box-shadow:var(--shadow-soft);display:flex;flex-direction:column;">
            <img src="/images/cdeb1a3077ee.jpg" alt="First Botox Appointment" style="width:100%;aspect-ratio:3/2;object-fit:cover;" loading="lazy" />
            <div style="padding:1.25rem 1.4rem 1.5rem;">
              <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);margin:0 0 0.75rem;"><a href="/post/first-botox-appointment-a-step-by-step-guide" style="color:var(--color-ink);text-decoration:none;">First Botox Appointment: A Step-by-Step Guide</a></h2>
              <p style="font-family:var(--font-ui);color:#5e5e5e;font-size:var(--text-sm);line-height:1.6;margin:0;">A complete walkthrough of your first Botox appointment, from consultation to results.</p>
            </div>
          </article>
          <article style="background:#fff;box-shadow:var(--shadow-soft);display:flex;flex-direction:column;">
            <img src="/images/0b093327272f.png" alt="HydraFacial" style="width:100%;aspect-ratio:3/2;object-fit:cover;" loading="lazy" />
            <div style="padding:1.25rem 1.4rem 1.5rem;">
              <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);margin:0 0 0.75rem;"><a href="/post/why-millburn-nj-residents-are-choosing-hydrafacial-for-skin-rejuvenation" style="color:var(--color-ink);text-decoration:none;">Why Millburn NJ Residents Are Choosing HydraFacial™ for Skin Rejuvenation</a></h2>
              <p style="font-family:var(--font-ui);color:#5e5e5e;font-size:var(--text-sm);line-height:1.6;margin:0;">Discover why Millburn residents are choosing HydraFacial treatments at Menon Medispa.</p>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
