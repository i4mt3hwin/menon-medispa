---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout>
  <main class="pg" data-slug="hair">
<section class="pg-section" data-section="Rediscover the Full, Natural Hair You Love">
  <img class="pg-img" src="/images/651c7c197b52.png" alt="k.1757_serene_relaxing_nature_very_slight_purple_hue_very_relax_f9c18564-0ba0-42a6-8e7c-27" width="1440" height="547" loading="lazy" />
  <h1 class="pg-h">Rediscover the Full, Natural Hair You Love</h1>
  <p class="pg-text">Combat thinning and stimulate new growth with our advanced, non-surgical therapies. Our medical experts create a personalized plan to restore your hair's vitality—and your confidence.</p>
  <img class="pg-img" src="/images/cf8274396252.jpg" alt="shutterstock_377630146.jpg" width="480" height="268" loading="lazy" />
  <a class="pg-btn" href="/consultation">Request My Consultation</a>
  <img class="pg-img" src="/images/90411e0041df.png" alt="Picture of a Client Who Reviewed Us" width="46" height="50" loading="lazy" />
  <img class="pg-img" src="/images/305afeda5f9a.png" alt="Picture of a Client Who Reviewed Us" width="52" height="50" loading="lazy" />
  <img class="pg-img" src="/images/b95880091b44.png" alt="Picture of a Client Who Reviewed Us" width="52" height="50" loading="lazy" />
