---
/**
 * Body — faithful Path-2 reconstruction.
 * Source: 01-discovery/pages/body/
 * Visual target: 01-discovery/screenshots/body-desktop-full.png
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
const CALCOM = site.calcomUrl;
---
<BaseLayout
  title="Body Treatments | Menon Medispa & Wellness | Millburn, NJ"
  description="Advanced solutions for total body wellness. Physician-led Laser Hair Removal, IV Therapy, Vascular Treatments, and Medical Weight Loss in Millburn, NJ."
>
  <main class="sp" data-slug="body">

    {/* ===== HERO ===== */}
    <section class="sp-hero" aria-label="Body Treatments">
      <div class="sp-container">
        <div class="sp-hero__grid">
          <div class="sp-hero__content">
            <h1 class="sp-hero__title">Advanced Solutions for Total Body <em>Wellness</em></h1>
            <p class="sp-hero__lead">From radiant skin with Laser Hair Removal to renewed vitality with Semaglutide and IV Therapy, discover our physician-led approach to looking and feeling your best.</p>
            <div class="sp-hero__actions">
              <a class="sp-btn sp-btn--gold" href="/consultation">Request My Consultation</a>
            </div>
            <div class="sp-reviews">
              <div class="sp-reviews__avatars">
                <img src="/images/90411e0041df.png" alt="Client review" width="44" height="44" />
                <img src="/images/305afeda5f9a.png" alt="Client review" width="44" height="44" />
                <img src="/images/b95880091b44.png" alt="Client review" width="44" height="44" />
              </div>
              <div class="sp-reviews__text">
                <span class="sp-reviews__stars">★★★★★</span>
                <span class="sp-reviews__count">75+ 5 Star Reviews</span>
              </div>
            </div>
          </div>
          <div>
            <img class="sp-hero__img" src="/images/27f029705023.jpg" alt="Body Treatments" width="404" height="266" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ===== BADGES ===== */}
    <section class="sp-badges" aria-label="Highlights">
      <div class="sp-container sp-badges__row">
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Same-Week Appointments</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> Medical-Grade Expertise</p>
        <p class="sp-badge"><span class="sp-badge__check">✓</span> State of the Art Equipment</p>
      </div>
    </section>

    {/* ===== TREATMENT GRID ===== */}
    <section class="sp-tgrid" aria-label="Body Treatments">
      <div class="sp-container">
        <div class="sp-tgrid__head">
          <h2 class="sp-script-title">Comprehensive Body Treatments &amp; <em>Enhancements</em></h2>
          <p class="sp-tgrid__desc">Experience our comprehensive range of advanced body treatments, expertly tailored to reveal your best self. Click To See More!</p>
        </div>
        <div class="sp-tgrid__cols">
          <a href="http://www.ivmenonwelldrip.com" class="sp-tcard" rel="noopener" target="_blank" style="text-decoration:none;">
            <img src="/images/914772453481.jpg" alt="IV Vitamin Therapy" loading="lazy" />
            <div class="sp-tcard__tint"></div>
            <div class="sp-tcard__label">
              <span class="sp-tcard__title">IV VITAMIN THERAPY</span>
            </div>
          </a>
          <a href="/laser-hair-removal" class="sp-tcard" style="text-decoration:none;">
            <img src="/images/67c41f4e43f3.jpeg" alt="Laser Hair Removal" loading="lazy" />
            <div class="sp-tcard__tint"></div>
            <div class="sp-tcard__label">
              <span class="sp-tcard__title">LASER HAIR REMOVAL</span>
            </div>
          </a>
          <a href="/vascular-treatments" class="sp-tcard" style="text-decoration:none;">
            <img src="/images/40c58ae9b34c.jpg" alt="Vascular Treatments" loading="lazy" />
            <div class="sp-tcard__tint"></div>
            <div class="sp-tcard__label">
              <span class="sp-tcard__title">VASCULAR TREATMENTS</span>
            </div>
          </a>
          <a href="/semaglutide" class="sp-tcard" style="text-decoration:none;">
            <img src="/images/cd90aa0cbbcb.jpg" alt="Semaglutide" loading="lazy" />
            <div class="sp-tcard__tint"></div>
            <div class="sp-tcard__label">
              <span class="sp-tcard__title">SEMAGLUTIDE</span>
            </div>
          </a>
        </div>
        <div class="sp-tgrid__copy">
          <h3>Transformative Body Treatments &amp; Wellness</h3>
          <p>At Menon MediSpa, we blend clinical expertise with luxury to deliver transformative body treatments, IV vitamin therapy, laser hair removal, and medically supervised weight management.</p>
          <p>Our medical-grade services address specific body concerns using proven technologies and pharmaceutical-grade products. Led by expert medical professionals, each treatment is tailored to your unique needs and goals.</p>
          <p>From enhancing wellness with IV therapy to removing unwanted hair with advanced laser technology, our cutting-edge treatments provide visible, long-lasting results. Experience the difference of clinically-effective treatments in our serene Millburn, NJ medical spa.</p>
        </div>
      </div>
    </section>

    {/* ===== TESTIMONIAL ===== */}
    <section class="sp-testimonial" aria-label="What Our Clients Say">
      <img class="sp-testimonial__bg" src="/images/30cfb9e87c60.png" alt="" width="1440" height="626" loading="lazy" />
      <div class="sp-testimonial__overlay"></div>
      <div class="sp-container sp-testimonial__inner">
        <h2 class="sp-script-title sp-script-title--light" style="margin-bottom:2rem;">What Our <em>Clients</em> Say</h2>
        <blockquote class="sp-quote">
          <span class="sp-quote__mark">"</span>
          Jennifer is amazing. Her aura and energy makes you feel welcomed and comfortable. Love our sessions! And my girl Rose Marie, the receptionist, is just lovely! I always leave with great joy after seeing them.
          <cite>Alexa C.</cite>
        </blockquote>
        <img src="/images/5be44787b3a9.png" alt="5 Star Google Reviews" width="143" height="74" loading="lazy" style="margin-top:1.75rem;" />
      </div>
    </section>

    {/* ===== WHY CHOOSE ===== */}
    <section class="sp-plain" aria-label="Why Choose Menon MediSpa">
      <div class="sp-container">
        <div style="max-width:900px;margin:0 auto;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.75rem,3vw,2.25rem);color:var(--color-ink);margin:0 0 1.25rem;">Why Choose Menon MediSpa for Your Body Treatments &amp; Enhancements?</h2>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Our comprehensive approach integrates advanced wellness with medical-grade procedures to deliver truly transformative results. We create customized treatment plans that address both immediate concerns and long-term aesthetic and health goals.</p>
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">Our Integrated Treatment Philosophy</h3>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">At Menon MediSpa, we understand that optimal body wellness and aesthetics often require a multi-faceted approach. Our specialists are trained in both traditional treatments and advanced procedures like IV therapy and laser treatments, allowing us to create personalized combinations that enhance your natural beauty and improve overall wellness.</p>
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--color-ink);margin:1.5rem 0 0.5rem;">What to Expect</h3>
          <p style="font-family:var(--font-ui);color:#5e5e5e;line-height:1.75;margin:0 0 1rem;">Your experience begins with a thorough consultation to understand your goals. Whether you're receiving IV vitamin therapy, laser hair removal, or semaglutide treatments, you'll enjoy attentive care in our relaxing, clinical environment. We use only premium products and advanced techniques to ensure safe, beautiful results.</p>
        </div>
      </div>
    </section>

    {/* ===== FAQ ===== */}
    <section class="sp-faq" aria-label="Frequently asked questions">
      <div class="sp-container">
        <div class="sp-faq__card">
          <div class="sp-faq__head">
            <h2 class="sp-faq__title">Frequently asked questions</h2>
          </div>
          <div class="sp-faq__list">
            <details class="sp-faq__item" open>
              <summary>Which treatment is right for me?</summary>
              <div class="sp-faq__answer"><p>During your consultation, we'll evaluate your concerns and wellness goals to recommend the ideal combination of treatments.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How do treatments complement each other?</summary>
              <div class="sp-faq__answer"><p>IV therapy enhances internal wellness, laser treatments address external concerns, while semaglutide can support weight management goals.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Who performs my treatment?</summary>
              <div class="sp-faq__answer"><p>Our medical-grade treatments are performed by licensed professionals with specialized training in aesthetic and wellness procedures. <a href="/meet-the-team">Check our TEAM page</a> for more information.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>How many sessions will I need?</summary>
              <div class="sp-faq__answer"><p>Treatment plans vary based on individual goals and concerns. During your consultation, we'll outline a recommended treatment schedule for optimal results.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>Are the treatments painful?</summary>
              <div class="sp-faq__answer"><p>We prioritize your comfort during all procedures. Most treatments involve minimal discomfort, and we offer various techniques to ensure a pleasant experience.</p></div>
            </details>
            <details class="sp-faq__item">
              <summary>What kind of results can I expect?</summary>
              <div class="sp-faq__answer"><p>Results vary based on the treatment and individual factors. We'll discuss realistic expectations during your consultation and track your progress throughout your treatment journey.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="sp-cta" aria-label="Begin Your Transformation Today">
      <div class="sp-container sp-cta__grid">
        <div class="sp-cta__copy">
          <h2 class="sp-cta__title">Begin Your Transformation Today</h2>
          <p class="sp-cta__sub">Menon Medispa Millburn NJ</p>
          <p>Ready to experience the benefits of Menon Medispa's Body Treatments? Take the first step toward your body goals today by scheduling your personal consultation at Menon Medispa in Millburn, NJ.</p>
          <a class="sp-btn sp-btn--gold" href="/consultation">Schedule Consultation</a>
        </div>
        <div class="sp-cta__media">
          <img src="/images/b1a819f35921.webp" alt="Menon Office Staff" width="431" height="560" loading="lazy" />
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
