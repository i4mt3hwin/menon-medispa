---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '@/lib/site';
---
<BaseLayout title="Coming Soon | Menon Medispa &amp; Wellness | Millburn, NJ" description="Something exciting is coming soon to Menon Medispa in Millburn, NJ. Stay tuned!" noindex={true}>
  <main class="sp" data-slug="coming-soon">
    <section class="sp-hero sp-hero--center" aria-label="Coming Soon">
      <div class="sp-container">
        <h1 class="sp-hero__title" style="color:#fff;font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,4vw,3rem);text-align:center;margin:0 0 1rem;">Coming <em>Soon</em></h1>
        <p class="sp-hero__lead" style="text-align:center;margin:0 auto;max-width:560px;">Something exciting is coming. Stay tuned!</p>
        <div style="text-align:center;margin-top:2rem;"><a class="sp-btn sp-btn--gold" href="/">Return to Home</a></div>
      </div>
    </section>
  </main>
</BaseLayout>
