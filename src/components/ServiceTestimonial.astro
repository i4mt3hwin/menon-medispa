---
/**
 * ServiceTestimonial.astro, data-driven "What Our Clients Say" band.
 *
 * Reproduces the s4-testimonial pattern (see _sections/hydrafacial__section_4.astro)
 * but pulls a curated, provider-safe review for the given page via getReview(). Pass
 * a service slug (preferred) or a raw tag; an unmatched page falls back to a general
 * review, so this never renders a pain-management quote or a departed provider's name.
 *
 * Usage:  <ServiceTestimonial slug="botox-millburn-nj" />
 */
import { getReview } from '@/lib/reviews';
import site from '@/lib/site';
import sectionBg from '@/assets/images/30cfb9e87c60.webp';
import avatar1 from '@/assets/testimonials/reviewer-avatar-1.webp';
import avatar2 from '@/assets/testimonials/reviewer-avatar-2.webp';
import avatar3 from '@/assets/testimonials/reviewer-avatar-3.webp';

interface Props {
  slug: string;
  heading?: string;
}

const { slug, heading = 'What Our Clients Say' } = Astro.props;
const review = getReview(slug);
---

{review && (
  <section class="media-bg section svc-testimonial" style="--scrim-strength:0.58">
    <img class="media-bg__img media-bg__img--blur" src={sectionBg.src} alt="" aria-hidden="true"
         loading="lazy" decoding="async" width="1440" height="500" />
    <span class="media-bg__scrim media-bg__scrim--brand"></span>

    <div class="media-bg__inner container on-media">
      <div class="svc-testimonial__inner">

        <h3 class="svc-testimonial__label">{heading}</h3>

        <blockquote class="svc-testimonial__quote">
          <p class="svc-testimonial__quote-text">{`“${review.quote}”`}</p>
          <footer class="svc-testimonial__footer">
            <cite class="svc-testimonial__cite">{review.author}</cite>
            {review.location && (
              <p class="svc-testimonial__location">{review.location}</p>
            )}
          </footer>
        </blockquote>

        <a class="svc-testimonial__proof" href={site.reviewsUrl} target="_blank" rel="noopener noreferrer" aria-label="Read our reviews on Google">
          <div class="svc-testimonial__avatars">
            <img src={avatar1.src} alt="Menon Medispa client" class="svc-testimonial__avatar" loading="lazy" decoding="async" width="52" height="52" />
            <img src={avatar2.src} alt="Menon Medispa client" class="svc-testimonial__avatar" loading="lazy" decoding="async" width="52" height="52" />
            <img src={avatar3.src} alt="Menon Medispa client" class="svc-testimonial__avatar" loading="lazy" decoding="async" width="52" height="52" />
          </div>
          <div class="svc-testimonial__proof-text">
            <span class="svc-testimonial__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span class="svc-testimonial__count">100+ 5 Star Reviews</span>
          </div>
        </a>

      </div>
    </div>
  </section>
)}

<style>
  .svc-testimonial__inner {
    max-width: var(--container-narrow);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .svc-testimonial__label {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  .svc-testimonial__quote {
    margin: 0;
    padding: 0;
  }

  .svc-testimonial__quote-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    margin: 0 0 var(--space-sm);
    line-height: 1.7;
    font-style: italic;
  }

  .svc-testimonial__footer {
    font-style: normal;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .svc-testimonial__cite {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    font-style: normal;
  }

  .svc-testimonial__location {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.3;
  }

  /* Faces social-proof: avatars + gold stars + 100+ count (replaces the Google badge) */
  .svc-testimonial__proof {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    width: fit-content;
    margin-inline: auto;
    transition: opacity 0.2s ease;
  }
  .svc-testimonial__proof:hover { opacity: 0.85; }
  .svc-testimonial__avatars { display: flex; align-items: center; }
  .svc-testimonial__avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #fff;
    margin-left: -10px;
  }
  .svc-testimonial__avatar:first-child { margin-left: 0; }
  .svc-testimonial__proof-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
  /* scoped selector beats `.on-media :where(span){color:#fff}` so the stars stay gold */
  .svc-testimonial__stars {
    margin: 0;
    line-height: 1;
    font-size: 1.2rem;
    letter-spacing: 2px;
    color: var(--color-star);
  }
  .svc-testimonial__count {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    line-height: 1.2;
  }
</style>
