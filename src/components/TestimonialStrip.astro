---
// Phase 3 Pass 1, TestimonialStrip.astro
// Discovered from home/sections/07.json (What Our Clients Say).
// Wix source had a single blockquote (Alexa C.) with reviewer avatar images and ★★★★★.
// This component renders ALL testimonials passed in, zero summarization.

interface TestimonialItem {
  quote: string;         // verbatim, 400-word quotes stay 400 words
  author?: string;
  rating?: string;       // e.g. "★★★★★"
  image_src?: string;    // reviewer avatar
  image_alt?: string;
}

interface Props {
  heading?: string;
  testimonials: TestimonialItem[];
  bg_color?: string;
  layout?: 'strip' | 'grid' | 'carousel';
}

const {
  heading,
  testimonials = [],
  bg_color,
  layout = 'strip',
} = Astro.props;
---

<section
  class={`testimonial-strip testimonial-strip--${layout} section`}
  style={bg_color ? `background-color: ${bg_color};` : 'background-color: var(--color-surface);'}
>
  <div class="container">
    {heading && (
      <h2 class="testimonial-strip__heading">{heading}</h2>
    )}

    <div class="testimonial-strip__items">
      {testimonials.map((t) => (
        <article class="testimonial-card">
          {t.rating && (
            <p class="testimonial-card__rating" aria-label={`Rating: ${t.rating}`}>
              {t.rating}
            </p>
          )}

          <blockquote class="testimonial-card__quote">
            <p set:html={t.quote} />
          </blockquote>

          <footer class="testimonial-card__footer">
            {t.image_src && (
              <img
                src={t.image_src}
                alt={t.image_alt ?? (t.author ? `Photo of ${t.author}` : 'Reviewer photo')}
                class="testimonial-card__avatar"
                loading="lazy"
                decoding="async"
                width="50"
                height="50"
              />
            )}
            {t.author && (
              <cite class="testimonial-card__author">{t.author}</cite>
            )}
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonial-strip__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 400;
    color: var(--color-text);
    text-align: center;
    margin: 0 0 var(--space-md);
    line-height: 1.25;
    text-wrap: balance;
  }

  /* Strip layout: horizontal scroll on desktop, stacked on mobile */
  .testimonial-strip--strip .testimonial-strip__items {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--space-md);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: var(--space-sm); /* space for scrollbar */
  }

  .testimonial-strip--strip .testimonial-card {
    flex: 0 0 clamp(280px, 40vw, 520px);
    scroll-snap-align: start;
  }

  /* Grid layout, 3 cols desktop, 2 tablet, 1 phone */
  .testimonial-strip--grid .testimonial-strip__items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  /* Carousel layout, same as strip for now; JS enhancement can be layered on */
  .testimonial-strip--carousel .testimonial-strip__items {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--space-md);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: var(--space-sm);
  }

  .testimonial-strip--carousel .testimonial-card {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }

  /* Card */
  .testimonial-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
  }

  .testimonial-card__rating {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-cta);
    margin: 0;
    line-height: 1;
  }

  .testimonial-card__quote {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 400;
    font-style: italic;
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
    text-align: center;
  }

  .testimonial-card__quote p {
    margin: 0;
  }

  .testimonial-card__footer {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: auto;
  }

  .testimonial-card__avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonial-card__author {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    color: var(--color-text);
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .testimonial-strip--grid .testimonial-strip__items {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Phone */
  @media (max-width: 600px) {
    .testimonial-strip--grid .testimonial-strip__items {
      grid-template-columns: 1fr;
    }

    .testimonial-strip--strip .testimonial-strip__items {
      flex-wrap: wrap;
      overflow-x: visible;
    }

    .testimonial-strip--strip .testimonial-card {
      flex: 1 1 100%;
    }
  }
</style>
