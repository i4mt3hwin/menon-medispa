---
/**
 * SiteFooter.astro, Phase 3 Pass 1 COMPLETE
 *
 * Sources:
 *   structure.json §14, is_master="footer", FOOTER tag, bbox h=1069px
 *   Columns captured:
 *     "Services & Shop", Book Treatment(/), Face(/face), Body(/body), Hair(/hair),
 *                         Sale(/sale), Shop Products(/)
 *     "Our Medispa", NAP: Menon Medispa, 45 Essex Street Suite 202, Millburn NJ 07041
 *                         Hours (Mon-Fri 10am-6pm, Sat 10am-2pm per site.ts authoritative)
 *     "Information", Shipping & Returns, Store Policy (+ Terms of Use)
 *   Footer also includes: newsletter sign-up "Are you on the list?" section
 *   image-map.slice:    ig=d85622e84ef0, fb=482f7439ea47, tt=de7ef3d7c470
 *   site.ts:            legalName, address, phone (973) 494-8431, email, social, hours
 *
 * Phone everywhere: (973) 494-8431 / tel:+19734948431
 */

import { Image } from 'astro:assets';
import site from '@/lib/site.js';
import igImg from '@/assets/images/d85622e84ef0.png';
import fbImg from '@/assets/images/482f7439ea47.png';
import ttImg from '@/assets/images/de7ef3d7c470.png';

const year = new Date().getFullYear();
---

<footer class="site-footer" aria-label="Site footer">

  <!-- Newsletter band: "Are you on the list?" -->
  <div class="footer-newsletter">
    <div class="footer-newsletter__inner">
      <div class="footer-newsletter__text">
        <h2 class="footer-newsletter__heading">Are you on the list?</h2>
        <p class="footer-newsletter__sub">Join to get exclusive monthly offers and expert skincare tips.</p>
      </div>
      <div class="footer-newsletter__actions">
        <form
          class="footer-newsletter__form"
          action="#"
          method="post"
          aria-label="Newsletter signup"
          novalidate
        >
          <label for="footer-email" class="sr-only">Enter your email address</label>
          <input
            type="email"
            id="footer-email"
            name="email"
            placeholder="Email"
            required
            autocomplete="email"
            class="footer-newsletter__input"
            aria-required="true"
          />
          <button type="submit" class="footer-newsletter__btn">Submit</button>
        </form>
        <!-- Social icons in newsletter band -->
        <ul class="footer-newsletter__social" role="list" aria-label="Follow us">
          <li>
            <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <Image src={igImg} alt="Instagram" width={28} height={28} loading="lazy" />
            </a>
          </li>
          <li>
            <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <Image src={fbImg} alt="Facebook" width={28} height={28} loading="lazy" />
            </a>
          </li>
          <li>
            <a href={site.social.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <Image src={ttImg} alt="TikTok" width={28} height={28} loading="lazy" />
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Main footer columns -->
  <div class="footer-main">
    <div class="footer-main__inner">

      <!-- Column 1: Services & Shop -->
      <nav class="footer-col" aria-label="Services and shop links">
        <p class="footer-col__heading">Services &amp; Shop</p>
        <ul class="footer-col__list" role="list">
          <li><a href="/">Book Treatment</a></li>
          <li><a href="/face">Face</a></li>
          <li><a href="/body">Body</a></li>
          <li><a href="/hair">Hair</a></li>
          <li><a href="/sale">Sale</a></li>
          <li><a href="/">Shop Products</a></li>
        </ul>
      </nav>

      <!-- Column 2: Our Medispa (NAP + Hours) -->
      <div class="footer-col footer-col--nap">
        <p class="footer-col__heading">Our Medispa</p>
        <address class="footer-nap" style="font-style: normal;">
          <p>{site.legalName}</p>
          <p>45 Essex Street, Suite 202</p>
          <p>Millburn, NJ 07041</p>
          <p>
            <a href="tel:+19734948431">(973) 494-8431</a>
          </p>
          <p>
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </p>
        </address>

        <div class="footer-hours" aria-label="Business hours">
          <p class="footer-hours__line">Monday &ndash; 10am&ndash;6pm</p>
          <p class="footer-hours__line">Tuesday &ndash; 10am&ndash;6pm</p>
          <p class="footer-hours__line">Wednesday &ndash; 10am&ndash;6pm</p>
          <p class="footer-hours__line">Thursday &ndash; 10am&ndash;6pm</p>
          <p class="footer-hours__line">Friday &ndash; 10am&ndash;6pm</p>
          <p class="footer-hours__line">Saturday &ndash; 10am&ndash;4pm</p>
        </div>
      </div>

      <!-- Column 3: Information -->
      <nav class="footer-col" aria-label="Information links">
        <p class="footer-col__heading">Information</p>
        <ul class="footer-col__list" role="list">
          <li><a href="/shipping-and-returns">Shipping &amp; Returns</a></li>
          <li><a href="/store-policy">Store Policy</a></li>
          <li><a href="/terms-of-use">Terms of Use</a></li>
          <li><a href="/patient-resources">Patient Resources</a></li>
          <li><a href="/blog">Blog</a></li>
          <li>
            <a href="http://www.menonregen.com" target="_blank" rel="noopener noreferrer">
              Menon Regenerative Institute
            </a>
          </li>
        </ul>
      </nav>

      <!-- Column 4: Customer Service -->
      <div class="footer-col footer-col--customer-service">
        <p class="footer-col__heading">Customer Service</p>
        <ul class="footer-col__list footer-contact-list" role="list">
          <li>
            <a href="tel:+19734948431" aria-label="Call us">(973) 494-8431</a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} aria-label="Email us">{site.email}</a>
          </li>
          <li>
            <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <Image src={igImg} alt="Instagram" width={20} height={20} loading="lazy" class="footer-social-icon" />
              Instagram
            </a>
          </li>
          <li>
            <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <Image src={fbImg} alt="Facebook" width={20} height={20} loading="lazy" class="footer-social-icon" />
              Facebook
            </a>
          </li>
          <li>
            <a href={site.social.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <Image src={ttImg} alt="TikTok" width={20} height={20} loading="lazy" class="footer-social-icon" />
              TikTok
            </a>
          </li>
        </ul>
      </div>

    </div><!-- /.footer-main__inner -->
  </div><!-- /.footer-main -->

  <!-- Copyright bar -->
  <div class="footer-bar">
    <div class="footer-bar__inner">
      <p class="footer-bar__copy">
        &copy; {year} {site.legalName}. All rights reserved.
      </p>
      <ul class="footer-bar__links" role="list">
        <li><a href="/privacy-policy">Privacy Policy</a></li>
        <li><a href="/terms-of-use">Terms of Use</a></li>
        <li><a href="/shipping-and-returns">Shipping &amp; Returns</a></li>
      </ul>
    </div>
  </div>

</footer>

<style>
/* ===== Site Footer ===== */
.site-footer {
  background-color: var(--color-footer-bg);
  color: var(--color-footer-text);
  border-top: none;
}

/* ── Newsletter band ── */
.footer-newsletter {
  background-color: var(--color-footer-newsletter-bg);
  border-top: 1px solid rgba(26, 26, 46, 0.08);
  border-bottom: 1px solid rgba(26, 26, 46, 0.14);
  padding: 34px 24px;
}

.footer-newsletter__inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-lg);
}

.footer-newsletter__text {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.footer-newsletter__heading {
  font-family: var(--font-display);
  font-size: var(--text-h3);
  font-weight: 400;
  color: var(--color-footer-bg);
  margin: 0;
  line-height: 1.15;
}

.footer-newsletter__sub {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: rgba(26, 26, 46, 0.76);
  margin: 0;
}

.footer-newsletter__actions {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  flex-wrap: wrap;
}

.footer-newsletter__form {
  display: flex;
  flex-direction: row;
  align-items: stretch;
}

.footer-newsletter__input {
  width: 240px;
  padding: 10px 14px;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  color: var(--color-footer-bg);
  background-color: var(--color-surface);
  border: 1px solid rgba(26, 26, 46, 0.18);
  border-radius: var(--radius-sm) 0 0 var(--radius-sm);
  box-sizing: border-box;
  outline: none;
}

.footer-newsletter__input::placeholder {
  color: rgba(26, 26, 46, 0.62);
}

.footer-newsletter__input:focus {
  border-color: var(--color-cta);
  box-shadow: 0 0 0 3px rgba(196, 164, 132, 0.24);
}

.footer-newsletter__btn {
  padding: 10px 22px;
  background-color: var(--color-cta);
  color: var(--color-footer-bg);
  font-family: var(--font-cta);
  font-size: var(--text-xs);
  font-weight: 600;
  border: 1px solid var(--color-cta);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  cursor: pointer;
  transition: background-color 0.2s, border-color 0.2s;
  letter-spacing: 0.01em;
  white-space: nowrap;
}

.footer-newsletter__btn:hover {
  background-color: var(--color-accent);
  border-color: var(--color-accent);
}

.footer-newsletter__social {
  display: flex;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 14px;
}

.footer-newsletter__social li a {
  display: flex;
  align-items: center;
  opacity: 0.74;
  filter: brightness(0) saturate(100%) invert(8%) sepia(15%) saturate(1085%) hue-rotate(202deg) brightness(94%) contrast(96%);
  transition: opacity 0.15s;
}

.footer-newsletter__social li a:hover {
  opacity: 1;
}

/* ── Main columns ── */
.footer-main {
  padding: 60px 24px;
  background-color: var(--color-footer-bg);
}

.footer-main__inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
}

/* Footer column shared */
.footer-col__heading {
  font-family: var(--font-display);
  font-size: var(--text-subheading);
  font-weight: 400;
  color: var(--color-footer-text);
  margin: 0 0 16px 0;
}

.footer-col__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.footer-col__list li a {
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 400;
  color: var(--color-footer-text-muted);
  text-decoration: none;
  line-height: 1.8;
  transition: color 0.12s;
}

.footer-col__list li a:hover {
  color: var(--color-footer-text);
}

/* Customer service column with social icons */
.footer-contact-list li a {
  display: flex;
  align-items: center;
  gap: 6px;
}

.footer-social-icon {
  display: inline-block;
  width: 20px;
  height: 20px;
  object-fit: contain;
  opacity: 0.8;
}

/* NAP column */
.footer-nap {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-bottom: 20px;
}

.footer-nap p {
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.8;
  margin: 0;
  color: var(--color-footer-text-muted);
}

.footer-nap a {
  color: var(--color-footer-text-muted);
  text-decoration: none;
  transition: color 0.12s;
}

.footer-nap a:hover {
  color: var(--color-footer-text);
}

.footer-hours {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.footer-hours__line {
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.8;
  margin: 0;
  color: var(--color-footer-text-muted);
}

/* ── Copyright bar ── */
.footer-bar {
  background-color: rgba(0, 0, 0, 0.3);
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  padding: 20px 24px;
}

.footer-bar__inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}

.footer-bar__copy {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--color-footer-text-muted);
  margin: 0;
}

.footer-bar__links {
  display: flex;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 20px;
}

.footer-bar__links li a {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--color-footer-text-muted);
  text-decoration: none;
  transition: color 0.12s;
}

.footer-bar__links li a:hover {
  color: var(--color-footer-text);
}

/* ── Accessibility ── */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* ── Tablet (≤1024px): 3-col intermediate layout ── */
@media (max-width: 1024px) {
  .footer-main {
    padding: 52px 20px;
  }

  .footer-main__inner {
    /* 3 columns: services | nap | info+customer stacked */
    grid-template-columns: repeat(3, 1fr);
    gap: 36px;
  }

  /* Customer service slots beneath the Information column (col 3, row 2) */
  .footer-col--customer-service {
    grid-column: 3;
    grid-row: 2;
  }
}

/* ── Mobile (≤768px): 2-col layout ── */
@media (max-width: 768px) {
  .footer-newsletter {
    padding: 24px 16px;
  }

  .footer-newsletter__inner {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .footer-newsletter__actions {
    width: 100%;
    justify-content: space-between;
  }

  .footer-newsletter__form {
    flex: 1;
  }

  .footer-newsletter__input {
    width: auto;
    flex: 1;
  }

  .footer-main {
    padding: 40px 16px;
  }

  .footer-main__inner {
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .footer-col--nap {
    grid-column: 1 / -1;
    grid-row: auto;
  }

  .footer-col--customer-service {
    grid-column: 1 / -1;
    grid-row: auto;
  }

  .footer-bar__inner {
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .footer-bar__links {
    flex-wrap: wrap;
    gap: 12px;
  }
}

/* ── Phone (≤480px): single column ── */
@media (max-width: 480px) {
  .footer-main__inner {
    grid-template-columns: 1fr;
  }

  .footer-col--nap, .footer-col--customer-service {
    grid-column: auto;
  }
}

/* ── Centered footer (operator request) ── */
.footer-newsletter__inner { flex-direction: column; align-items: center; justify-content: center; text-align: center; }
.footer-newsletter__text { align-items: center; }
.footer-newsletter__actions { justify-content: center; width: min(100%, 460px); }
.footer-newsletter__form { flex: 1; min-width: 0; }
.footer-newsletter__input { min-width: 0; }
.footer-main__inner { justify-items: center; }
.footer-col { text-align: center; }
.footer-col__list { align-items: center; }
.footer-contact-list li a { justify-content: center; }
.footer-nap, .footer-hours { align-items: center; }
.footer-bar__inner { flex-direction: column; align-items: center; justify-content: center; text-align: center; }
.footer-bar__links { justify-content: center; }
</style>
