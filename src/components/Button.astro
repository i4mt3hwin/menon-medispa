---
interface Props {
  text?: string;
  label?: string;
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  target?: '_blank' | '_self';
  rel?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}
const {
  text,
  label,
  href,
  variant = 'primary',
  target,
  rel,
  type = 'button',
  class: className = '',
} = Astro.props;

// Resolve label: prefer explicit text/label prop, else fall through to slot children
const resolvedText = text ?? label;
const variantClass = `btn--${variant}`;
---
{href ? (
  <a
    href={href}
    target={target}
    rel={rel ?? (target === '_blank' ? 'noopener noreferrer' : undefined)}
    class={`btn ${variantClass} ${className}`}
  >{resolvedText ?? <slot />}</a>
) : (
  <button
    type={type}
    class={`btn ${variantClass} ${className}`}
  >{resolvedText ?? <slot />}</button>
)}

<!-- Button styling is the global .btn system in base.css (single source of truth,
     shared with inline `<a class="btn">` usages). No scoped styles needed here. -->
