---
/**
 * SocialProofToast.astro, small rotating "recent activity" toast (bottom-left).
 *
 * Native replacement for the old Wix ProveSrc widget: shows a compact
 * "FirstName L. booked <generalized service>" card. No third-party script, no tracking, fully ours.
 *
 * Data is LIVE: the client fetches /api/recent-activity (functions/api/recent-activity.js), which
 * returns REAL recent appointment requests from D1, DE-IDENTIFIED (first name + last initial, a
 * generalized service category, soft relative time — never the specific procedure, no PII). During
 * the launch window it pads with a fading seed (see recent-activity.js SEED/SEED_UNTIL). The widget
 * shows nothing if the endpoint returns []. The unused seed array in src/lib/social-proof.ts is
 * legacy (only its ProofCategory type is still used for the category->image map below).
 *
 * Placement: mounted once globally in BaseLayout (after the page, before chat).
 * Position: bottom-LEFT (never fights the bottom-right ChatAssistant launcher). On phones (<=900px)
 * it sits in the bottom-left corner at ~60vw wide (see the media query in <style>).
 *
 * Behavior: first toast after `initialDelayMs`, each visible `showMs`, then a randomized gap before
 * the next; loops through a shuffled order. Dismiss (X) silences it for the session. Reduced-motion
 * safe (fade only).
 */
import type { ImageMetadata } from 'astro';
import type { ProofCategory } from '@/lib/social-proof';

// Category -> representative CATEGORY photo (a facial / an IV drip / a laser),
// reusing brand images already on the site. Never procedure-specific or
// identifying — keep these generic to honor the privacy guardrail.
import imgFacial   from '@/assets/images/04bf461982db.jpg'; // facial treatment
import imgSkin     from '@/assets/images/34ef44b50a1c.jpg'; // hydrafacial / glow skin
import imgIv       from '@/assets/images/914772453481.jpg'; // IV drip
import imgLaser    from '@/assets/images/67c41f4e43f3.jpeg'; // laser
import imgHair     from '@/assets/images/02127013d183.jpg'; // hair restoration
import imgBody     from '@/assets/images/cd90aa0cbbcb.jpg'; // body wellness

const categoryImg: Record<ProofCategory, ImageMetadata> = {
  facial:   imgFacial,
  skin:     imgSkin,
  iv:       imgIv,
  wellness: imgIv, // wellness/drip shares the IV visual
  laser:    imgLaser,
  hair:     imgHair,
  body:     imgBody,
};

interface Props {
  /** Wait this long after load before the first toast. */
  initialDelayMs?: number;
  /** How long each toast stays on screen. */
  showMs?: number;
  /** Min/max idle gap between toasts (randomized for a natural cadence). */
  minGapMs?: number;
  maxGapMs?: number;
}
const {
  initialDelayMs = 8000,
  showMs = 6000,
  minGapMs = 14000,
  maxGapMs = 26000,
} = Astro.props;

// Category -> optimized image URL, resolved at build time for the client to attach by category.
const categoryImgUrls: Record<string, string> = Object.fromEntries(
  Object.entries(categoryImg).map(([k, v]) => [k, v.src])
);
---

<div
  class="proof-toast"
  data-proof-toast
  data-initial-delay={initialDelayMs}
  data-show={showMs}
  data-min-gap={minGapMs}
  data-max-gap={maxGapMs}
  aria-hidden="true"
>
  <button class="proof-toast__close" data-proof-close type="button" aria-label="Dismiss">&times;</button>
  <span class="proof-toast__media" aria-hidden="true">
    <img class="proof-toast__thumb" data-proof-img alt="" width="48" height="48" loading="lazy" decoding="async" />
  </span>
  <div class="proof-toast__body">
    <span class="proof-toast__line" data-proof-line></span>
    <span class="proof-toast__meta" data-proof-meta></span>
  </div>
</div>

<script type="application/json" data-proof-imgs set:html={JSON.stringify(categoryImgUrls)} />

<style>
  .proof-toast {
    position: fixed;
    left: 20px;
    bottom: 20px;
    bottom: calc(20px + env(safe-area-inset-bottom, 0px));
    z-index: 120; /* below the sale lightbox (200), above page chrome */
    display: flex;
    align-items: flex-start;
    gap: 12px;
    width: min(330px, calc(100vw - 40px));
    padding: 14px 34px 14px 14px;
    background: var(--color-surface);
    border: 1px solid rgb(0 0 0 / 0.07);
    border-left: 3px solid var(--color-cta);
    border-radius: var(--radius-md);
    box-shadow: 0 16px 44px rgb(18 13 24 / 0.20);
    opacity: 0;
    visibility: hidden;
    transform: translateY(14px);
    transition: opacity 0.4s ease, transform 0.4s ease, visibility 0.4s ease;
  }
  .proof-toast.is-shown { opacity: 1; visibility: visible; transform: none; }

  .proof-toast__close {
    position: absolute;
    top: 6px;
    right: 8px;
    background: none;
    border: none;
    font-size: 20px;
    line-height: 1;
    color: var(--color-text);
    opacity: 0.4;
    cursor: pointer;
    padding: 4px 6px;
  }
  .proof-toast__close:hover { opacity: 0.9; }

  .proof-toast__media {
    position: relative;
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
  }
  .proof-toast__thumb {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    display: block;
  }
  .proof-toast__body { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .proof-toast__line {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.35;
  }
  .proof-toast__line strong { font-weight: var(--weight-bold); }
  .proof-toast__meta {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: color-mix(in srgb, var(--color-text) 85%, transparent);
    line-height: 1.35;
  }
  /* On phones: bottom-left corner, ~60% of the screen width. (No mobile Call/Book bar anymore,
     so it can sit at the bottom edge.) */
  @media (max-width: 900px) {
    .proof-toast {
      left: 12px;
      right: auto;
      width: 78vw;
      bottom: calc(16px + env(safe-area-inset-bottom, 0px));
      padding: 9px 28px 9px 11px;
      align-items: center;
      gap: 10px;
    }
    .proof-toast__media, .proof-toast__thumb { width: 38px; height: 38px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .proof-toast { transition: opacity 0.3s ease, visibility 0.3s ease; transform: none; }
    .proof-toast.is-shown { transform: none; }
  }
</style>

<script>
  (function () {
    var el = document.querySelector('[data-proof-toast]');
    var imgsEl = document.querySelector('[data-proof-imgs]');
    if (!el) return;

    // Respect a session dismissal.
    try { if (sessionStorage.getItem('menonProofClosed')) return; } catch (e) {}

    var imgMap = {};
    try { imgMap = JSON.parse((imgsEl && imgsEl.textContent) || '{}'); } catch (e) { imgMap = {}; }

    var initialDelay = parseInt(el.getAttribute('data-initial-delay') || '8000', 10);
    var showMs = parseInt(el.getAttribute('data-show') || '6000', 10);
    var minGap = parseInt(el.getAttribute('data-min-gap') || '14000', 10);
    var maxGap = parseInt(el.getAttribute('data-max-gap') || '26000', 10);

    var lineEl = el.querySelector('[data-proof-line]');
    var metaEl = el.querySelector('[data-proof-meta]');
    var imgEl = el.querySelector('[data-proof-img]');
    var closeBtn = el.querySelector('[data-proof-close]');

    var order = [];
    var idx = 0;
    var stopped = false;
    var timer = null;

    function rand(a, b) { return a + Math.floor(Math.random() * (b - a + 1)); }

    function render(entry) {
      lineEl.innerHTML = '<strong>' + entry.name + '</strong> booked ' + entry.service;
      metaEl.textContent = entry.when ? (entry.when.charAt(0).toUpperCase() + entry.when.slice(1)) : '';
      var src = imgMap[entry.category] || imgMap.facial;
      if (imgEl && src) imgEl.setAttribute('src', src);
    }

    function hide() {
      el.classList.remove('is-shown');
      el.setAttribute('aria-hidden', 'true');
    }

    function showNext() {
      if (stopped || !order.length) return;
      render(order[idx % order.length]);
      idx++;
      el.removeAttribute('aria-hidden');
      el.classList.add('is-shown');
      timer = setTimeout(function () {
        hide();
        timer = setTimeout(showNext, rand(minGap, maxGap));
      }, showMs);
    }

    function stop() {
      stopped = true;
      if (timer) clearTimeout(timer);
      hide();
      try { sessionStorage.setItem('menonProofClosed', '1'); } catch (e) {}
    }

    if (closeBtn) closeBtn.addEventListener('click', stop);

    // Pause the cycle while the tab is hidden so toasts don't pile up unseen.
    document.addEventListener('visibilitychange', function () {
      if (document.hidden && timer) { clearTimeout(timer); timer = null; }
      else if (!document.hidden && !stopped && !timer && idx > 0) { timer = setTimeout(showNext, rand(minGap, maxGap)); }
    });

    function loadActivity() {
      if (stopped || order.length) return;
      fetch('/api/recent-activity', { headers: { accept: 'application/json' } })
        .then(function (r) { return r.ok ? r.json() : []; })
        .then(function (data) {
          if (stopped || !Array.isArray(data) || !data.length) return;
          order = data;
          for (var i = order.length - 1; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var t = order[i]; order[i] = order[j]; order[j] = t;
          }
          timer = setTimeout(showNext, initialDelay);
        })
        .catch(function () {});
    }

    // The toast is non-critical; keep its API call out of the initial render waterfall.
    setTimeout(function () {
      if ('requestIdleCallback' in window) window.requestIdleCallback(loadActivity, { timeout: 2500 });
      else loadActivity();
    }, Math.max(6000, initialDelay - 1000));
  })();
</script>
