---
// Scaffold stub, phase-2-synthesize. Phase 3 completes.
// Carries over analytics/tracking verbatim per operator decision (2026-06-02).
// Injected at end of <body> in BaseLayout.astro.
import site from '../lib/site';

const { integrations } = site;
const { analytics } = integrations;
---

<!-- Meta Pixel -->
{analytics.metaPixelId && (
  <Fragment>
    <script define:vars={{ metaPixelId: analytics.metaPixelId }}>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', metaPixelId);
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${analytics.metaPixelId}&ev=PageView&noscript=1`} alt="" /></noscript>
  </Fragment>
)}

<!-- Google tag (GA4 analytics + Google Ads conversions).
     Decoupled gates: load gtag.js when EITHER id is set, then config each one that
     exists. This lets the Ads conversion tag (AW-…) fire even while the GA4
     measurement id is still null (operator pastes GA4 pre-go-live). -->
{(analytics.ga4 || analytics.googleAdsConversionId) && (
  <Fragment>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${analytics.ga4 ?? `AW-${analytics.googleAdsConversionId}`}`} />
    <script define:vars={{ ga4: analytics.ga4, gadsId: analytics.googleAdsConversionId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (ga4) gtag('config', ga4);
      if (gadsId) gtag('config', `AW-${gadsId}`);
    </script>
  </Fragment>
)}

<!-- Microsoft Clarity -->
{analytics.microsoftClarityId && (
  <script define:vars={{ clarityId: analytics.microsoftClarityId }}>
    (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
    t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
    y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script",clarityId);
  </script>
)}

