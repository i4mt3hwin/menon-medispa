---
interface Props {
  text_html: string;
  author?: string;
}
const { text_html, author } = Astro.props;
---
<blockquote class="site-quote">
  <div class="site-quote__text" set:html={text_html} />
  {author && (
    <footer class="site-quote__footer">
      <cite class="site-quote__author">{author}</cite>
    </footer>
  )}
</blockquote>

<style>
  .site-quote {
    margin: var(--space-md) 0;
    padding: var(--space-md) var(--space-md) var(--space-md) var(--space-lg);
    border-left: 4px solid var(--color-cta);
    background-color: transparent;
    max-width: 65ch;
  }

  .site-quote__text {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-style: italic;
    color: var(--color-text);
    line-height: 1.5;
  }

  .site-quote__text p {
    margin: 0 0 0.5em;
  }

  .site-quote__text p:last-child {
    margin-bottom: 0;
  }

  .site-quote__footer {
    margin-top: var(--space-sm);
  }

  .site-quote__author {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-style: normal;
    color: rgba(0, 0, 0, 0.6);
    letter-spacing: 0.04em;
  }

  .site-quote__author::before {
    content: '\2014\00A0';
  }

  @media (max-width: 600px) {
    .site-quote {
      padding: var(--space-sm) var(--space-sm) var(--space-sm) var(--space-md);
    }

    .site-quote__text {
      font-size: var(--text-base);
    }
  }
</style>
