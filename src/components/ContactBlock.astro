---
import site from '../lib/site';

interface HoursRow {
  label: string;
  value: string;
}
interface Props {
  heading?: string;
  address?: string;
  phone_display?: string;
  phone_tel?: string;
  email?: string;
  hours?: HoursRow[];
  map_embed_url?: string;
  show_form?: boolean;
  bg_color?: string;
}

const {
  heading,
  address      = site.address.formatted,
  phone_display = site.phone.display,
  phone_tel    = site.phone.tel,
  email        = site.email,
  hours,
  map_embed_url,
  show_form    = false,
  bg_color,
} = Astro.props;

// Default hours derived from site.ts structured data
const defaultHours: HoursRow[] = [
  { label: 'Mon – Fri', value: '10:00 am – 6:00 pm' },
  { label: 'Saturday',  value: '10:00 am – 4:00 pm' },
  { label: 'Sunday',    value: 'Closed' },
];
const displayHours = hours ?? defaultHours;
---
<section class="contact-block section" style={bg_color ? `background-color: ${bg_color};` : ''}>
  <div class="container">
    {heading && <h2 class="contact-block__heading">{heading}</h2>}

    <div class="contact-block__inner">
      <!-- NAP + hours -->
      <div class="contact-block__nap">
        <strong class="contact-block__name">{site.displayName}</strong>

        <address class="contact-block__address">
          {address}
        </address>

        <div class="contact-block__phone">
          <a href={`tel:${phone_tel}`}>{phone_display}</a>
        </div>

        {email && (
          <div class="contact-block__email">
            <a href={`mailto:${email}`}>{email}</a>
          </div>
        )}

        <div class="contact-block__hours">
          <strong class="contact-block__hours-label">Hours</strong>
          <table class="contact-block__hours-table">
            {displayHours.map((row) => (
              <tr>
                <td class="contact-block__hours-day">{row.label}</td>
                <td class="contact-block__hours-val">{row.value}</td>
              </tr>
            ))}
          </table>
        </div>

        {show_form && (
          <div class="contact-block__form-link">
            <a href="/contact" class="btn btn--primary btn--sm">Send us a message</a>
          </div>
        )}
      </div>

      <!-- Map embed -->
      {map_embed_url && (
        <div class="contact-block__map">
          <iframe
            src={map_embed_url}
            width="100%"
            height="400"
            style="border: 0; border-radius: var(--radius-md); display: block;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`${site.displayName} location map`}
          />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .contact-block__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-text);
    text-align: center;
    margin: 0 0 var(--space-md);
    text-wrap: balance;
  }

  .contact-block__inner {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
  }

  .contact-block__nap {
    flex: 0 0 320px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
  }

  .contact-block__name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .contact-block__address {
    font-style: normal;
    margin-bottom: var(--space-xs);
  }

  .contact-block__phone, .contact-block__email {
    margin-bottom: var(--space-xs);
  }

  .contact-block__phone a, .contact-block__email a {
    color: inherit;
    text-decoration: none;
  }

  .contact-block__phone a:hover, .contact-block__email a:hover {
    text-decoration: underline;
  }

  .contact-block__hours {
    margin-top: var(--space-md);
  }

  .contact-block__hours-label {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-xs);
  }

  .contact-block__hours-table {
    border-collapse: collapse;
    width: 100%;
  }

  .contact-block__hours-table tr + tr td {
    padding-top: 2px;
  }

  .contact-block__hours-day {
    padding-right: var(--space-sm);
    white-space: nowrap;
  }

  .contact-block__hours-val {
    color: var(--color-text);
  }

  .contact-block__form-link {
    margin-top: var(--space-md);
  }

  .contact-block__map {
    flex: 1;
    min-width: 0;
  }

  /* Tablet: stack */
  @media (max-width: 1024px) {
    .contact-block__inner {
      flex-direction: column;
      gap: var(--space-md);
    }

    .contact-block__nap {
      flex: none;
      width: 100%;
    }

    .contact-block__map {
      width: 100%;
    }
  }
</style>
