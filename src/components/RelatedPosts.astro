---
/**
 * RelatedPosts.astro, related blog posts.
 *
 * Two layouts:
 *   - 'sidebar' (default): compact thumbnail+title rows (legacy; rarely used now).
 *   - 'band': a full-width "From our blog" section with a responsive card grid, 
 *     used at the bottom of service pages so it doesn't lengthen the sticky rail.
 *
 * Posts come from service-blog-map.json via lib/relatedPosts.ts. Renders nothing
 * when there are no posts. Links to /post/{slug}.
 */
interface Post {
  slug: string;
  title: string;
  coverImage?: string;
}
interface Props {
  heading?: string;
  posts?: Post[];
  max?: number;
  layout?: 'sidebar' | 'band';
}
const { heading = 'From our blog', posts = [], max = 3, layout = 'sidebar' } = Astro.props;
const list = posts.slice(0, max);
---
{list.length > 0 && layout === 'band' && (
  <section class="section related-band">
    <div class="container">
      <h2 class="related-band__heading">{heading}</h2>
      <ul class="related-band__grid">
        {list.map((p) => (
          <li class="related-band__item">
            <a href={`/post/${p.slug}`} class="related-band__card">
              {p.coverImage && (
                <span class="related-band__thumb">
                  <img src={p.coverImage} alt="" loading="lazy" decoding="async" width="400" height="250" />
                </span>
              )}
              <span class="related-band__title">{p.title}</span>
              <span class="related-band__cue">Read more &rarr;</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

{list.length > 0 && layout === 'sidebar' && (
  <div class="related-posts">
    <p class="related-posts__heading">{heading}</p>
    <ul class="related-posts__items">
      {list.map((p) => (
        <li class="related-posts__item">
          <a href={`/post/${p.slug}`} class="related-posts__link">
            {p.coverImage && (
              <span class="related-posts__thumb">
                <img src={p.coverImage} alt="" loading="lazy" decoding="async" width="64" height="48" />
              </span>
            )}
            <span class="related-posts__title">{p.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}

<style>
  /* ── Band layout ── */
  .related-band__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    text-align: center;
    margin: 0 0 var(--space-lg);
    line-height: 1.25;
  }
  .related-band__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  .related-band__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid rgb(0 0 0 / 0.08);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
    text-decoration: none;
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.05);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .related-band__card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgb(0 0 0 / 0.12); }
  .related-band__thumb { display: block; aspect-ratio: 16 / 10; overflow: hidden; }
  .related-band__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.3s ease; }
  .related-band__card:hover .related-band__thumb img { transform: scale(1.05); }
  .related-band__title {
    font-family: var(--font-display);
    font-size: var(--text-subheading);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1.3;
    padding: var(--space-sm) var(--space-md) 0;
  }
  .related-band__cue {
    font-family: var(--font-cta);
    font-size: var(--text-sm);
    color: var(--color-cta);
    padding: var(--space-xs) var(--space-md) var(--space-md);
    margin-top: auto;
  }
  @media (max-width: 860px) { .related-band__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; } }

  /* ── Sidebar layout (legacy) ── */
  .related-posts { border: 1px solid rgb(0 0 0 / 0.08); border-radius: var(--radius-md); padding: var(--space-md); }
  .related-posts__heading {
    font-family: var(--font-display);
    font-size: var(--text-subheading);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    line-height: 1.2;
  }
  .related-posts__items { list-style: none; margin: 0; padding: 0; }
  .related-posts__item { border-bottom: 1px solid rgb(0 0 0 / 0.06); }
  .related-posts__item:last-child { border-bottom: none; }
  .related-posts__link { display: flex; align-items: center; gap: var(--space-sm); padding: 10px 0; text-decoration: none; }
  .related-posts__item:first-child .related-posts__link { padding-top: 0; }
  .related-posts__item:last-child .related-posts__link { padding-bottom: 0; }
  .related-posts__thumb { flex: 0 0 auto; width: 64px; height: 48px; border-radius: var(--radius-sm); overflow: hidden; }
  .related-posts__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .related-posts__title { flex: 1; font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-text); line-height: 1.35; }
  .related-posts__link:hover .related-posts__title { color: var(--color-cta); }
</style>
