---
/**
 * SalePopup.astro, the site's single smart popup (subscribe OR sale, never both).
 *
 * One popup slot. A visitor who is NOT on the email list yet gets the newsletter
 * signup; everyone else (subscribers + anyone who already dismissed the signup)
 * gets the "this month's specials" sale. Shows ~15s after landing, then stays
 * quiet for COOLDOWN_DAYS so it never nags. Dismiss via X / backdrop / Esc.
 * Reduced-motion safe (no transform).
 *
 * Frequency rules (localStorage):
 *   menonPopupLastShown  - timestamp of the last popup; suppresses ALL popups for ~7 days
 *   menonSubscribeShown  - the subscribe variant was already shown once -> next time show the sale
 *   menonSubscribed      - the visitor joined the list (here OR via the footer) -> never ask again
 *
 * Subscribe reuses the existing newsletter pipeline (enhanceNewsletterForm ->
 * /api/lead -> Resend audience + welcome email). Sale content comes from
 * data/sales.json (same source as the /sale page), so they can never drift.
 */
import type { ImageMetadata } from 'astro';
import { getSaleOffers, popupHeading } from '@/lib/sales';
import Turnstile from './Turnstile.astro';

interface SaleItem { name: string; offer: string; image?: ImageMetadata; imageAlt?: string; }
interface Props {
  heading?: string;
  items?: SaleItem[];
  ctaHref?: string;
  delayMs?: number;
  subscribeHeading?: string;
  subscribeSubcopy?: string;
}
const {
  heading = popupHeading,
  items = getSaleOffers().map((o) => ({
    name: o.name,
    offer: o.popupOffer,
    image: o.image,
    imageAlt: o.imageAlt,
  })),
  ctaHref = '/sale',
  delayMs = 15000,
  subscribeHeading = 'Are you on the list?',
  subscribeSubcopy = 'Join to get exclusive monthly offers and expert skincare tips.',
} = Astro.props;

const hasSale = items.length > 0;
---

<div class="sale-popup" data-sale-popup data-sale-delay={delayMs} data-has-sale={hasSale ? '1' : '0'} aria-hidden="true">
  <div class="sale-popup__backdrop" data-sale-close></div>

  <!-- SUBSCRIBE variant (shown to visitors who are not on the list yet) -->
  <div class="sale-popup__dialog" data-popup-variant="subscribe" role="dialog" aria-modal="true" aria-labelledby="sale-popup-sub-title" hidden>
    <button class="sale-popup__close" data-sale-close type="button" aria-label="Close">&times;</button>
    <p class="sale-popup__eyebrow">Join the list</p>
    <h2 class="sale-popup__title" id="sale-popup-sub-title">{subscribeHeading}</h2>
    <p class="sale-popup__sub">{subscribeSubcopy}</p>
    <form class="sale-popup__form" data-newsletter-form aria-label="Newsletter signup" novalidate>
      <input
        type="email"
        name="email"
        placeholder="Email"
        required
        autocomplete="email"
        class="sale-popup__input"
        aria-label="Email address"
        aria-required="true"
      />
      <input type="hidden" name="type" value="newsletter" />
      <input type="text" name="company_website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />
      <button type="submit" class="btn btn--primary sale-popup__submit">Join</button>
      <Turnstile class="sale-popup__turnstile" />
    </form>
    <p class="sale-popup__msg" data-newsletter-msg role="alert" hidden></p>
  </div>

  <!-- SALE variant (shown to subscribers + anyone who already declined the signup) -->
  <div class="sale-popup__dialog" data-popup-variant="sale" role="dialog" aria-modal="true" aria-labelledby="sale-popup-title" hidden>
    <button class="sale-popup__close" data-sale-close type="button" aria-label="Close">&times;</button>
    <p class="sale-popup__eyebrow">Limited time</p>
    <h2 class="sale-popup__title" id="sale-popup-title">{heading}</h2>
    <ul class="sale-popup__list">
      {items.map((s) => (
        <li class="sale-popup__item">
          {s.image && (
            <img
              class="sale-popup__thumb"
              src={s.image.src}
              alt={s.imageAlt ?? s.name}
              width="84"
              height="84"
              loading="lazy"
              decoding="async"
            />
          )}
          <div class="sale-popup__copy">
            <span class="sale-popup__name">{s.name}</span>
            <span class="sale-popup__offer">{s.offer}</span>
          </div>
        </li>
      ))}
    </ul>
    <a href={ctaHref} class="btn btn--primary btn--block sale-popup__cta">See all specials</a>
  </div>
</div>

<style>
  .sale-popup {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .sale-popup.is-open { opacity: 1; visibility: visible; pointer-events: auto; }

  .sale-popup__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(18 13 24 / 0.6);
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
  }

  .sale-popup__dialog {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 420px;
    background: var(--color-surface);
    border-top: 3px solid var(--color-cta);
    border-radius: var(--radius-md);
    padding: 30px 28px;
    box-shadow: 0 30px 80px rgb(18 13 24 / 0.4);
    max-height: calc(100vh - 40px);
    overflow-y: auto;
    transform: translateY(14px);
    transition: transform 0.3s ease;
  }
  .sale-popup.is-open .sale-popup__dialog { transform: none; }

  .sale-popup__close {
    position: absolute;
    top: 10px;
    right: 12px;
    background: none;
    border: none;
    font-size: 26px;
    line-height: 1;
    color: var(--color-text);
    opacity: 0.5;
    cursor: pointer;
    padding: 6px 10px;
  }
  .sale-popup__close:hover { opacity: 1; }

  .sale-popup__eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0 0 6px;
  }
  .sale-popup__title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-md);
    line-height: 1.2;
  }

  /* ── Subscribe variant ── */
  .sale-popup__sub {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    opacity: 0.85;
    line-height: 1.5;
    margin: -6px 0 var(--space-md);
  }
  .sale-popup__form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .sale-popup__input {
    flex: 1 1 180px;
    min-width: 0;
    padding: 11px 14px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    background: #fff;
    border: 1px solid rgb(0 0 0 / 0.18);
    border-radius: var(--radius-sm);
  }
  .sale-popup__input::placeholder { color: rgb(26 26 46 / 0.55); }
  .sale-popup__input:focus {
    outline: none;
    border-color: var(--color-cta);
    box-shadow: 0 0 0 3px rgb(196 164 132 / 0.24);
  }
  .sale-popup__submit { flex: 0 0 auto; white-space: nowrap; }
  /* Turnstile (only shown when Cloudflare challenges) drops onto its own row below the input + Join,
     never splitting them. :global because the .cf-turnstile div is rendered by the child component. */
  .sale-popup__form :global(.sale-popup__turnstile) { flex-basis: 100%; }
  .sale-popup__msg {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    margin: 12px 0 0;
  }
  .sale-popup__msg[data-state='ok'] { color: var(--color-accent-ink); }
  .sale-popup__msg[data-state='error'] { color: #c0392b; }

  /* ── Sale variant ── */
  .sale-popup__list { list-style: none; margin: 0 0 var(--space-md); padding: 0; }
  .sale-popup__item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid rgb(0 0 0 / 0.08);
  }
  .sale-popup__item:last-child { border-bottom: none; }
  .sale-popup__thumb {
    flex: 0 0 auto;
    width: 84px;
    height: 84px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    display: block;
  }
  .sale-popup__copy { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .sale-popup__name { font-family: var(--font-body); font-size: var(--text-base); color: var(--color-text); line-height: 1.3; }
  .sale-popup__offer { font-family: var(--font-body); font-size: var(--text-sm); font-weight: var(--weight-bold); color: var(--color-accent-ink); }

  @media (max-width: 420px) {
    .sale-popup__submit { flex: 1 1 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sale-popup, .sale-popup__dialog { transition: opacity 0.2s ease, visibility 0.2s ease; transform: none; }
  }
</style>

<script>
  import { enhanceNewsletterForm } from '@/lib/leadForm';

  (function () {
    const pop = document.querySelector('[data-sale-popup]');
    if (!pop) return;

    const COOLDOWN_MS = 7 * 24 * 60 * 60 * 1000; // quiet for ~7 days after any popup
    function lsGet(k) { try { return localStorage.getItem(k); } catch (e) { return null; } }
    function lsSet(k, v) { try { localStorage.setItem(k, v); } catch (e) {} }

    // Frequency cap: at most one popup per cooldown window.
    const last = parseInt(lsGet('menonPopupLastShown') || '0', 10);
    if (Date.now() - last < COOLDOWN_MS) return;

    // Decide which variant (if any) to show.
    const subscribed = lsGet('menonSubscribed') === '1';
    const subscribeShown = lsGet('menonSubscribeShown') === '1';
    const hasSale = pop.getAttribute('data-has-sale') === '1';
    let variant = null;
    if (!subscribed && !subscribeShown) variant = 'subscribe';
    else if (hasSale) variant = 'sale';
    if (!variant) return; // subscribed/declined and no active sale -> show nothing

    const dialog = pop.querySelector('[data-popup-variant="' + variant + '"]');
    if (!dialog) return;

    const delay = parseInt(pop.getAttribute('data-sale-delay') || '15000', 10);
    let shown = false;
    let previousFocus = null;

    function getFocusable() {
      return Array.from(dialog.querySelectorAll(
        'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )).filter(function (el) { return el.offsetParent !== null || el === document.activeElement; });
    }

    function trapTab(e) {
      if (e.key !== 'Tab') return;
      const focusable = getFocusable();
      if (!focusable.length) { e.preventDefault(); return; }
      const first = focusable[0];
      const lastEl = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); lastEl.focus(); }
      } else {
        if (document.activeElement === lastEl) { e.preventDefault(); first.focus(); }
      }
    }

    function onKey(e) {
      if (e.key === 'Escape') close();
      trapTab(e);
    }

    function show() {
      if (shown) return;
      shown = true;
      previousFocus = document.activeElement;
      dialog.hidden = false;
      pop.removeAttribute('aria-hidden');
      pop.classList.add('is-open');
      lsSet('menonPopupLastShown', String(Date.now()));
      if (variant === 'subscribe') lsSet('menonSubscribeShown', '1');
      const closeBtn = dialog.querySelector('.sale-popup__close');
      if (closeBtn) closeBtn.focus();
      document.addEventListener('keydown', onKey);
    }

    function close() {
      pop.classList.remove('is-open');
      pop.setAttribute('aria-hidden', 'true');
      document.removeEventListener('keydown', onKey);
      if (previousFocus && typeof previousFocus.focus === 'function') previousFocus.focus();
    }

    pop.querySelectorAll('[data-sale-close]').forEach(function (el) { el.addEventListener('click', close); });

    // Subscribe variant: wire the email form to the existing newsletter pipeline.
    if (variant === 'subscribe') {
      const subForm = dialog.querySelector('[data-newsletter-form]');
      if (subForm) {
        enhanceNewsletterForm(subForm, {
          onSuccess: function () {
            lsSet('menonSubscribed', '1');     // never ask this browser again
            setTimeout(close, 1800);           // let them read the confirmation, then close
          },
        });
      }
    }

    setTimeout(show, delay);
  })();
</script>
