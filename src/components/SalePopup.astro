---
/**
 * SalePopup.astro, elegant, compact "this month's specials" lightbox.
 *
 * Replaces the large full-width promo card band that ate space on every page.
 * Shows once per session after ~15s on the page (timed popups convert best when
 * the visitor has engaged, ~10–20s / mid-scroll; pure-time is the simplest
 * reliable trigger and works on mobile where exit-intent doesn't). Dismiss via
 * X / backdrop / Esc. Reduced-motion safe (no transform).
 *
 * Site-wide promo content (the current "specials"); update here when promos change.
 */
import type { ImageMetadata } from 'astro';

// Sale creatives, reused from the /sale page so the popup matches the specials page.
import imgBrotox from '@/assets/images/56a3e3ac1335.jpg';
import imgHydrafacial from '@/assets/images/86072f9cbd9c.jpg';
import imgCustomIv from '@/assets/images/dd355e57f3dd.jpg';

interface SaleItem { name: string; offer: string; image?: ImageMetadata; imageAlt?: string; }
interface Props {
  heading?: string;
  items?: SaleItem[];
  ctaHref?: string;
  delayMs?: number;
}
const {
  heading = "This Month's Specials",
  items = [
    { name: 'BRO-tox Father’s Day Special', offer: 'Botox $12 / unit', image: imgBrotox, imageAlt: 'BRO-tox Father’s Day Botox special at Menon Medispa' },
    { name: 'Summer Glow HydraFacial', offer: '$285 value for $225', image: imgHydrafacial, imageAlt: 'Summer Glow HydraFacial special at Menon Medispa' },
    { name: 'Custom Hydrating IV', offer: '$99, any two vitamins', image: imgCustomIv, imageAlt: 'Custom hydrating IV drip special at Menon Medispa' },
  ],
  ctaHref = '/sale',
  delayMs = 15000,
} = Astro.props;
---

<div class="sale-popup" data-sale-popup data-sale-delay={delayMs}>
  <div class="sale-popup__backdrop" data-sale-close></div>
  <div class="sale-popup__dialog" role="dialog" aria-modal="true" aria-labelledby="sale-popup-title">
    <button class="sale-popup__close" data-sale-close type="button" aria-label="Close">&times;</button>
    <p class="sale-popup__eyebrow">Limited time</p>
    <h2 class="sale-popup__title" id="sale-popup-title">{heading}</h2>
    <ul class="sale-popup__list">
      {items.map((s) => (
        <li class="sale-popup__item">
          {s.image && (
            <img
              class="sale-popup__thumb"
              src={s.image.src}
              alt={s.imageAlt ?? s.name}
              width="84"
              height="84"
              loading="lazy"
              decoding="async"
            />
          )}
          <div class="sale-popup__copy">
            <span class="sale-popup__name">{s.name}</span>
            <span class="sale-popup__offer">{s.offer}</span>
          </div>
        </li>
      ))}
    </ul>
    <a href={ctaHref} class="btn btn--primary btn--block sale-popup__cta">See all specials</a>
  </div>
</div>

<style>
  .sale-popup {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .sale-popup.is-open { opacity: 1; visibility: visible; pointer-events: auto; }

  .sale-popup__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(18 13 24 / 0.6);
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
  }

  .sale-popup__dialog {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 420px;
    background: var(--color-surface);
    border-top: 3px solid var(--color-cta);
    border-radius: var(--radius-md);
    padding: 30px 28px;
    box-shadow: 0 30px 80px rgb(18 13 24 / 0.4);
    max-height: calc(100vh - 40px);
    overflow-y: auto;
    transform: translateY(14px);
    transition: transform 0.3s ease;
  }
  .sale-popup.is-open .sale-popup__dialog { transform: none; }

  .sale-popup__close {
    position: absolute;
    top: 10px;
    right: 12px;
    background: none;
    border: none;
    font-size: 26px;
    line-height: 1;
    color: var(--color-text);
    opacity: 0.5;
    cursor: pointer;
    padding: 6px 10px;
  }
  .sale-popup__close:hover { opacity: 1; }

  .sale-popup__eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0 0 6px;
  }
  .sale-popup__title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-md);
    line-height: 1.2;
  }

  .sale-popup__list { list-style: none; margin: 0 0 var(--space-md); padding: 0; }
  .sale-popup__item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid rgb(0 0 0 / 0.08);
  }
  .sale-popup__item:last-child { border-bottom: none; }
  .sale-popup__thumb {
    flex: 0 0 auto;
    width: 84px;
    height: 84px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    display: block;
  }
  .sale-popup__copy { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .sale-popup__name { font-family: var(--font-body); font-size: var(--text-base); color: var(--color-text); line-height: 1.3; }
  .sale-popup__offer { font-family: var(--font-body); font-size: var(--text-sm); font-weight: var(--weight-bold); color: var(--color-cta); }

  @media (prefers-reduced-motion: reduce) {
    .sale-popup, .sale-popup__dialog { transition: opacity 0.2s ease, visibility 0.2s ease; transform: none; }
  }
</style>

<script>
  (function () {
    const pop = document.querySelector('[data-sale-popup]');
    if (!pop) return;
    try { if (sessionStorage.getItem('menonSaleSeen')) return; } catch (e) {}
    const delay = parseInt(pop.getAttribute('data-sale-delay') || '15000', 10);
    let shown = false;
    function onKey(e) { if (e.key === 'Escape') close(); }
    function show() {
      if (shown) return;
      shown = true;
      pop.classList.add('is-open');
      document.addEventListener('keydown', onKey);
    }
    function close() {
      pop.classList.remove('is-open');
      try { sessionStorage.setItem('menonSaleSeen', '1'); } catch (e) {}
      document.removeEventListener('keydown', onKey);
    }
    pop.querySelectorAll('[data-sale-close]').forEach(function (el) { el.addEventListener('click', close); });
    setTimeout(show, delay);
  })();
</script>
