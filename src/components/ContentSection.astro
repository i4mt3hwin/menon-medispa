---
/**
 * ContentSection.astro — Generated by path-2-rebuild/02-synthesize (scaffold stub).
 * Token-driven faithful stub: correct prop shape + styling hooks wired to the
 * @theme tokens (see 03-design/design-tokens.md). The first Phase 3 subagent to
 * render this pattern completes it with VERBATIM captured content. Do NOT put
 * page-specific content here.
 */
interface Props {
  heading?: string;
  body?: string[];
  html?: string;
  image?: { src: string; alt: string };
  layout?: "left" | "right" | "stacked";
  background?: string;
  class?: string;
}
const { heading, body = [], html, image, layout = "left", background } = Astro.props;
---

<section class={`content-section content-section--${layout}`} style={background ? `background:${background}` : undefined}>
  <div class="content-section__text">
    {heading && <h2>{heading}</h2>}
    {html ? <div set:html={html} /> : body.map((p) => <p>{p}</p>)}
  </div>
  {image && <img src={image.src} alt={image.alt} loading="lazy" />}
</section>

<style>
  .content-section { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-gap-lg); align-items: center; max-width: var(--container-max); margin: 0 auto; padding: var(--spacing-section) 1.5rem; }
  .content-section--stacked { grid-template-columns: 1fr; }
  .content-section img { width: 100%; height: auto; border-radius: var(--radius-md); }
  @media (max-width: 767px) { .content-section { grid-template-columns: 1fr; } }
</style>
