---
interface Props {
  heading?: string;
  heading_tag?: 'h1' | 'h2' | 'h3';
  body_html?: string;
  body_paragraphs?: string[];
  image_src?: string;
  image_alt?: string;
  image_position?: 'left' | 'right' | 'none';
  ctas?: Array<{ text: string; href: string; variant?: 'primary' | 'secondary' }>;
  bg_color?: string;
  bg_image_url?: string;
  padding?: 'sm' | 'md' | 'lg' | 'xl';
}

const {
  heading,
  heading_tag = 'h2',
  body_html,
  body_paragraphs = [],
  image_src,
  image_alt = '',
  image_position = 'right',
  ctas = [],
  bg_color,
  bg_image_url,
  padding = 'lg',
} = Astro.props;

const Tag = heading_tag as 'h1' | 'h2' | 'h3';

// Determine heading font based on tag
const headingFont =
  heading_tag === 'h3' ? 'var(--font-body)' : 'var(--font-display)';

const headingSize =
  heading_tag === 'h1'
    ? 'var(--text-h1)'
    : heading_tag === 'h2'
      ? 'var(--text-h2)'
      : 'var(--text-h3)';

// Does this section have a background image requiring scrim treatment?
const hasBgImage = Boolean(bg_image_url);

// Build inline background style, always add a fallback color so a 404 image
// degrades to a warm brand tint rather than a pure black void.
const bgStyle = bg_image_url
  ? `background-color: var(--color-header-bg); background-image: url('${bg_image_url}'); background-size: cover; background-position: center;`
  : bg_color
    ? `background-color: ${bg_color};`
    : '';
---

<section
  class:list={[
    'content-section',
    `content-section--image-${image_position}`,
    `content-section--pad-${padding}`,
    hasBgImage ? 'u-scrim' : '',
  ]}
  style={bgStyle || undefined}
>
  <div class:list={['content-section__inner', 'container', hasBgImage ? 'u-scrim__content' : '']}>
    {/* Text column */}
    <div class="content-section__text">
      {heading && (
        <Tag
          class="content-section__heading"
          style={`font-family: ${headingFont}; font-size: ${headingSize};`}
        >
          {heading}
        </Tag>
      )}

      {body_html && (
        <div class="content-section__body" set:html={body_html} />
      )}

      {body_paragraphs.length > 0 && body_paragraphs.map((p) => (
        <p class="content-section__para">{p}</p>
      ))}

      {ctas.length > 0 && (
        <div class="content-section__ctas">
          {ctas.map((cta) => (
            <a
              href={cta.href}
              class:list={['btn', cta.variant === 'secondary' ? 'btn--secondary' : 'btn--primary']}
            >
              {cta.text}
            </a>
          ))}
        </div>
      )}
    </div>

    {/* Image column */}
    {image_position !== 'none' && image_src && (
      <div class="content-section__image">
        <img
          src={image_src}
          alt={image_alt}
          loading="lazy"
          decoding="async"
        />
      </div>
    )}
  </div>
</section>

<style>
  .content-section {
    width: 100%;
    box-sizing: border-box;
  }

  /* Padding variants, applied to the outer section; inner .container gets inline padding */
  .content-section--pad-sm  { padding-block: var(--space-md); }
  .content-section--pad-md  { padding-block: var(--space-lg); }
  .content-section--pad-lg  { padding-block: var(--section-py); }
  .content-section--pad-xl  { padding-block: calc(var(--section-py) * 1.25); }

  /* Inner flex row */
  .content-section__inner {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  /* Image position, default image right (text left) */
  .content-section--image-right  .content-section__inner { flex-direction: row; }
  .content-section--image-left   .content-section__inner { flex-direction: row-reverse; }
  .content-section--image-none   .content-section__inner { flex-direction: row; }

  .content-section__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .content-section__image {
    flex: 1;
    display: flex;
    align-items: stretch;
  }

  .content-section__image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }

  /* Heading */
  .content-section__heading {
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
    text-wrap: balance;
  }

  /* Body from HTML or paragraphs */
  .content-section__body, .content-section__para {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  /* CTA row */
  .content-section__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  /* Tablet: stack image below text */
  @media (max-width: 1024px) {
    .content-section__inner {
      gap: var(--space-md);
    }
  }

  /* Phone: always stack */
  @media (max-width: 600px) {
    .content-section__inner {
      flex-direction: column !important;
    }

    .content-section__text, .content-section__image {
      flex: none;
      width: 100%;
    }
  }
</style>
