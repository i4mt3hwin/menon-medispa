---
interface Props {
  heading?: string;
  heading_tag?: 'h1' | 'h2' | 'h3';
  body_html?: string;
  body_paragraphs?: string[];
  image_src?: string;
  image_alt?: string;
  image_position?: 'left' | 'right' | 'none';
  ctas?: Array<{ text: string; href: string; variant?: 'primary' | 'secondary' }>;
  bg_color?: string;
  bg_image_url?: string;
  padding?: 'sm' | 'md' | 'lg' | 'xl';
}

const {
  heading,
  heading_tag = 'h2',
  body_html,
  body_paragraphs = [],
  image_src,
  image_alt = '',
  image_position = 'right',
  ctas = [],
  bg_color,
  bg_image_url,
  padding = 'lg',
} = Astro.props;

const Tag = heading_tag as 'h1' | 'h2' | 'h3';

// Determine heading font based on tag
const headingFont =
  heading_tag === 'h3' ? 'var(--font-body)' : 'var(--font-display)';

const headingSize =
  heading_tag === 'h1'
    ? 'var(--text-h1)'
    : heading_tag === 'h2'
      ? 'var(--text-h2)'
      : 'var(--text-h3)';

// Build inline background style — always add a fallback color so a 404 image
// degrades to a warm brand tint rather than a pure black void.
const bgStyle = bg_image_url
  ? `background-color: var(--color-header-bg); background-image: url('${bg_image_url}'); background-size: cover; background-position: center;`
  : bg_color
    ? `background-color: ${bg_color};`
    : '';
---

<section
  class={`content-section content-section--image-${image_position} content-section--pad-${padding}`}
  style={bgStyle || undefined}
>
  {/* Text column */}
  <div class="content-section__text">
    {heading && (
      <Tag
        class="content-section__heading"
        style={`font-family: ${headingFont}; font-size: ${headingSize};`}
      >
        {heading}
      </Tag>
    )}

    {body_html && (
      <div class="content-section__body" set:html={body_html} />
    )}

    {body_paragraphs.length > 0 && body_paragraphs.map((p) => (
      <p class="content-section__para">{p}</p>
    ))}

    {ctas.length > 0 && (
      <div class="content-section__ctas">
        {ctas.map((cta) => (
          <a
            href={cta.href}
            class={`content-section__cta content-section__cta--${cta.variant ?? 'primary'}`}
          >
            {cta.text}
          </a>
        ))}
      </div>
    )}
  </div>

  {/* Image column */}
  {image_position !== 'none' && image_src && (
    <div class="content-section__image">
      <img
        src={image_src}
        alt={image_alt}
        loading="lazy"
        decoding="async"
      />
    </div>
  )}
</section>

<style>
  .content-section {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    width: 100%;
    box-sizing: border-box;
  }

  /* Padding variants */
  .content-section--pad-sm  { padding: var(--space-md)  var(--space-md); }
  .content-section--pad-md  { padding: var(--space-lg)  var(--space-md); }
  .content-section--pad-lg  { padding: var(--space-xl)  var(--space-lg); }
  .content-section--pad-xl  { padding: var(--space-2xl) var(--space-xl); }

  /* Image position — default image right (text left) */
  .content-section--image-right  { flex-direction: row; }
  .content-section--image-left   { flex-direction: row-reverse; }
  .content-section--image-none   { flex-direction: row; }

  .content-section__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .content-section__image {
    flex: 1;
    display: flex;
    align-items: stretch;
  }

  .content-section__image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Heading */
  .content-section__heading {
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  /* Body from HTML or paragraphs */
  .content-section__body,
  .content-section__para {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  /* CTA row */
  .content-section__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .content-section__cta {
    display: inline-block;
    padding: 8px 16px;
    font-family: var(--font-ui);
    font-size: 14px;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: opacity 0.2s;
    text-align: center;
  }

  .content-section__cta:hover {
    opacity: 0.88;
  }

  .content-section__cta--primary {
    background-color: var(--color-cta);
    color: var(--color-text);
    box-shadow: var(--shadow-btn);
  }

  .content-section__cta--secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-cta);
  }

  /* Mobile: always stack */
  @media (max-width: 980px) {
    .content-section {
      flex-direction: column !important;
      padding: var(--space-lg) var(--space-sm);
    }

    .content-section__text,
    .content-section__image {
      flex: none;
      width: 100%;
    }
  }
</style>
