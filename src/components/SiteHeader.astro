/* ── Mobile breakpoint ── */
@media (max-width: 1240px) {
  .header-inner {
    height: 64px;
    padding: 0 16px;
  }

  .header-logo img {
    width: 160px;
    height: auto;
  }

  .header-nav, .header-right {
