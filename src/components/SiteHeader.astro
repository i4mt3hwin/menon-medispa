---
/**
 * SiteHeader.astro — global site header / nav.
 * Built fully in 02-synthesize: nav + logo + Call-Now CTA are consistent across
 * all 61 captured pages. Copy is VERBATIM from the captured original
 * (01-discovery/pages/home/structure.json HEADER section). Internal links are
 * site-relative (Wix absolute URLs rewritten to local paths). 03-build may add
 * the mobile-menu toggle behavior + active-state; copy stays verbatim.
 *
 * Layout from structure.json: header = 1440×135px.
 * - Top row (y:13, h:46): social icons far right (Instagram, Facebook, TikTok)
 * - Bottom row (y:48-109): logo left, nav centre, Call-Now button right
 *
 * FIDELITY NOTES (from captured original):
 *  - Background: white (#ffffff) — no explicit bg-color in capture; page bg shows
 *    through but the header IS sticky on a white bg. Nav text colour is #000000.
 *  - Social icons: 46×46px image icons (Instagram, Facebook, TikTok). Replaced
 *    with inline SVGs at the correct visual weight to avoid external img fetches.
 *  - Call Now CTA: the captured button (StylableButton) carries the brand
 *    primary (#754d4d) styling from the Wix theme. Operator confirmed phone
 *    (973) 494-8431; the cal.com placeholder constant is used for any Book CTA.
 */
import site from '../lib/site';

const nav = [
  { label: 'HOME', href: '/' },
  { label: 'ABOUT', href: '/about' },
  { label: 'FACE', href: '/face' },
  { label: 'BODY', href: '/body' },
  { label: 'HAIR', href: '/hair' },
  { label: 'CONTACT', href: '/contact' },
  { label: 'MENON REGENERATIVE INSTITUTE', href: 'http://www.menonregen.com', external: true },
  { label: 'SALES', href: '/sale' },
];

// Logo: original hotlinked wixstatic; 03-build rehosts the captured copy locally.
const logoSrc = '/images/medispa-logo-horizontal.png';
---

<header class="site-header">
  {/* Top bar: social icons */}
  <div class="site-header__topbar">
    <div class="site-header__social">
      <a href={site.social.instagram} class="site-header__social-link" aria-label="Instagram" rel="noopener" target="_blank">
        <!-- Instagram icon -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
      </a>
      <a href={site.social.facebook} class="site-header__social-link" aria-label="Facebook" rel="noopener" target="_blank">
        <!-- Facebook icon -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>
      <a href={site.social.tiktok} class="site-header__social-link" aria-label="TikTok" rel="noopener" target="_blank">
        <!-- TikTok icon -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
          <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
        </svg>
      </a>
    </div>
  </div>

  {/* Main nav row */}
  <div class="site-header__inner">
    <a class="site-header__logo" href="/" aria-label={site.displayName}>
      <img src={logoSrc} alt={`${site.displayName} logo`} width="212" height="51" />
    </a>
    <nav class="site-header__nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          class="site-header__link"
          href={item.href}
          {...(item.external ? { rel: 'noopener', target: '_blank' } : {})}
        >{item.label}</a>
      ))}
    </nav>
    <a class="site-header__call" href={`tel:${site.phone.tel}`}>
      Call Now: {site.phone.display}
    </a>
  </div>
</header>

<style>
  /* ---- Header shell ---- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 55;
    background: #ffffff;
    border-bottom: 1px solid var(--color-border);
  }

  /* ---- Top bar (social icons row) ---- */
  .site-header__topbar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0.45rem 1.5rem 0;
  }
  .site-header__social {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .site-header__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    color: #2c2632;
    text-decoration: none;
    border-radius: 50%;
    transition: color 0.2s, background 0.2s;
  }
  .site-header__social-link:hover {
    color: var(--color-primary);
  }
  .site-header__social-link svg {
    display: block;
    flex-shrink: 0;
  }

  /* ---- Main nav row ---- */
  .site-header__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: var(--spacing-gap-lg);
    padding: 0.65rem 1.5rem 0.75rem;
  }
  .site-header__logo img {
    display: block;
    height: auto;
  }
  .site-header__nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-gap-md);
    margin-left: auto;
  }
  .site-header__link {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #000000;
    text-decoration: none;
  }
  .site-header__link:hover {
    color: var(--color-primary);
  }

  /* Call Now CTA — brand primary background, white text */
  .site-header__call {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 700;
    color: #ffffff;
    background: var(--color-primary);
    padding: 0.55rem 1.1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    box-shadow: var(--shadow-soft);
  }
  .site-header__call:hover {
    background: var(--color-secondary);
    color: #ffffff;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1200px) {
    .site-header__link {
      font-size: 0.75rem;
    }
    .site-header__inner {
      gap: 1rem;
    }
    .site-header__nav {
      gap: 0.75rem;
    }
  }
  @media (max-width: 1024px) {
    .site-header__topbar {
      display: none; /* hide social row on tablet/mobile */
    }
    .site-header__inner {
      flex-wrap: wrap;
      padding: 0.75rem 1rem;
    }
    .site-header__nav {
      width: 100%;
      margin-left: 0;
      order: 3;
      gap: 0.5rem;
    }
    .site-header__call {
      order: 2;
    }
  }
</style>
