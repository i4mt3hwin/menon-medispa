        <!-- CONTACT (1 child) -->
        <li class="nav-item has-dropdown">
          <a href="/contact" class="nav-link">CONTACT</a>
          <ul class="dropdown" role="list">
            <li><a href="/consultation">CONSULTATION</a></li>
          </ul>
        </li>

        <!-- SALES -->
        <li class="nav-item">
          <a href="/sale" class="nav-link">SALES</a>
        </li>

      </ul>
    </nav>

    <!-- Right cluster: social icons + Call Now CTA -->
    <div class="header-right">
      <ul class="social-icons" role="list" aria-label="Social media links">
        <li>
          <a href="https://www.instagram.com/menonmedispa/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <Image src={igImg} alt="Instagram" width={36} height={36} loading="eager" />
          </a>
        </li>
        <li>
          <a href="https://www.facebook.com/menonmedispa/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <Image src={fbImg} alt="Facebook" width={36} height={36} loading="eager" />
          </a>
        </li>
        <li>
          <a href="https://www.tiktok.com/@menonregen" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <Image src={ttImg} alt="TikTok" width={36} height={36} loading="eager" />
          </a>
        </li>
      </ul>

      <a href="tel:+19734948431" class="header-cta" aria-label="Call (973) 494-8431">
        <svg class="header-cta__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6.5 3.5h3l1.5 4-2 1.5a12 12 0 0 0 5.5 5.5l1.5-2 4 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 4.5 5.5a2 2 0 0 1 2-2Z" fill="currentColor"/>
        </svg>
        <span>(973) 494-8431</span>
      </a>
    </div>

    <!-- Mobile hamburger (hidden on desktop) -->
    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

  </div><!-- /.header-inner -->

  <!-- Mobile nav drawer (display:block on mobile, off-canvas via transform) -->
  <nav
    class="mobile-nav"
    id="mobile-nav"
    aria-label="Mobile navigation"
    aria-hidden="true"
  >
    <button class="mobile-nav-close" id="mobile-nav-close" aria-label="Close navigation menu">
      &#x2715;
    </button>

    <ul class="mobile-nav-list" role="list">

      <li><a href="/">HOME</a></li>

      <!-- ABOUT accordion -->
      <li class="mobile-has-sub">
        <button class="mobile-sub-toggle" aria-expanded="false">
          ABOUT <span class="mobile-sub-arrow" aria-hidden="true">+</span>
        </button>
        <ul class="mobile-sub" role="list" aria-hidden="true">
          <li><a href="/about">About</a></li>
          <li><a href="/meet-the-team">Meet the Team</a></li>
          <li><a href="/patient-resources">Patient Resources</a></li>
        </ul>
      </li>

      <!-- FACE accordion (grouped sub-categories) -->
      <li class="mobile-has-sub">
        <button class="mobile-sub-toggle" aria-expanded="false">
          FACE <span class="mobile-sub-arrow" aria-hidden="true">+</span>
        </button>
        <ul class="mobile-sub" role="list" aria-hidden="true">
          <li><a href="/face">Face Overview</a></li>
          <li class="mobile-sub__cat">
            <a href="/menon-facials" class="mobile-sub__cat-link">Facials</a>
            <ul class="mobile-sub__kids" role="list">
              <li><a href="/acne-facial">Acne Facial</a></li>
              <li><a href="/chemical-peel-facial">Chemical Peel Facial</a></li>
              <li><a href="/cupping-facial">Cupping Facial</a></li>
              <li><a href="/dermaplaning-facial">Dermaplaning Facial</a></li>
              <li><a href="/hydrafacial">HydraFacial</a></li>
              <li><a href="/manual-lymph-facials">Manual Lymph Facials</a></li>
              <li><a href="/vitamin-c-facial">Vitamin C Facial</a></li>
            </ul>
          </li>
          <li><a href="/microneedling-millburn-nj">Microneedling</a></li>
          <li class="mobile-sub__cat">
            <a href="/laser-facials" class="mobile-sub__cat-link">Laser Facials</a>
            <ul class="mobile-sub__kids" role="list">
              <li><a href="/clear-lift-skin-rejuvination">ClearLift Skin Rejuvenation</a></li>
            </ul>
          </li>
          <li class="mobile-sub__cat">
            <a href="/fillers-injectables" class="mobile-sub__cat-link">Fillers &amp; Injectables</a>
            <ul class="mobile-sub__kids" role="list">
              <li><a href="/botox-millburn-nj">Botox</a></li>
              <li><a href="/juvedermfillers">Juvederm Fillers</a></li>
            </ul>
          </li>
        </ul>
      </li>

      <!-- BODY accordion (grouped sub-categories) -->
      <li class="mobile-has-sub">
        <button class="mobile-sub-toggle" aria-expanded="false">
          BODY <span class="mobile-sub-arrow" aria-hidden="true">+</span>
        </button>
        <ul class="mobile-sub" role="list" aria-hidden="true">
          <li><a href="/body">Body Overview</a></li>
          <li class="mobile-sub__cat">
            <a href="/iv-therapy-millburn-nj" class="mobile-sub__cat-link">IV Therapy</a>
            <ul class="mobile-sub__kids" role="list">
              <li><a href="/custom-iv-drip-therapy-millburn-nj">Customized IV Drip</a></li>
              <li><a href="/energy-performance">Energy &amp; Performance</a></li>
              <li><a href="/immunity-support">Immunity Support</a></li>
              <li><a href="/myers-cocktail-iv-therapy">Myers Cocktail</a></li>
              <li><a href="/nad-iv-drip-therapy">NAD+ IV Drip Therapy</a></li>
              <li><a href="/recovery-detox">Recovery &amp; Detox</a></li>
              <li><a href="/targeted-health-solutions-iv">Targeted Health Solutions</a></li>
              <li><a href="/anti-aging-beauty">Anti-Aging &amp; Beauty</a></li>
            </ul>
          </li>
          <li class="mobile-sub__cat">
            <a href="/vitamin-shots-millburn-nj" class="mobile-sub__cat-link">Vitamin Shots</a>
            <ul class="mobile-sub__kids" role="list">
              <li><a href="/nad-injection">NAD+ Injection</a></li>
            </ul>
          </li>
          <li><a href="/semaglutide">Semaglutide</a></li>
          <li><a href="/vascular-treatments">Vascular Treatments</a></li>
          <li><a href="/laser-hair-removal">Laser Hair Removal</a></li>
        </ul>
      </li>

      <!-- HAIR accordion -->
      <li class="mobile-has-sub">
        <button class="mobile-sub-toggle" aria-expanded="false">
          HAIR <span class="mobile-sub-arrow" aria-hidden="true">+</span>
        </button>
        <ul class="mobile-sub" role="list" aria-hidden="true">
          <li><a href="/hair">Hair Overview</a></li>
          <li><a href="/hydrafacial-keravive">HydraFacial Keravive</a></li>
          <li><a href="/platelet-rich-plasma-hair-millburn">PRP Hair Restoration</a></li>
        </ul>
      </li>

      <li><a href="/blog">INSIGHTS</a></li>

      <!-- CONTACT accordion -->
      <li class="mobile-has-sub">
        <button class="mobile-sub-toggle" aria-expanded="false">
          CONTACT <span class="mobile-sub-arrow" aria-hidden="true">+</span>
        </button>
        <ul class="mobile-sub" role="list" aria-hidden="true">
          <li><a href="/contact">Contact</a></li>
          <li><a href="/consultation">Consultation</a></li>
        </ul>
      </li>

      <li><a href="/sale">SALES</a></li>

      <li class="mobile-cta-item">
        <a href="tel:+19734948431" class="mobile-cta-phone">
          Call Now: (973) 494-8431
        </a>
      </li>

    </ul>
  </nav>

</header>

<style>
/* ===== Site Header ===== */
.site-header {
  position: sticky;
  top: 0;
  z-index: 55;
  width: 100%;
  background-color: var(--color-header-bg);
  transition: top 0.32s ease, box-shadow 0.2s ease, background-color 0.2s ease;
}

.site-header.scrolled {
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.09);
}

/* hide-on-scroll-down (revealed again on scroll up).
   Animate `top` (not transform) so the header doesn't become a containing block
   for the fixed .mobile-nav drawer it contains (which would cause overflow). */
.site-header--hidden {
  top: -110px;
}

.header-inner {
  display: flex;
  align-items: center;
  height: 92px;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 24px;
  gap: 16px;
  box-sizing: border-box;
}

/* ── Logo ── */
.header-logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  text-decoration: none;
}

.header-logo img {
  display: block;
  width: 212px;
  height: 51px;
  object-fit: contain;
}

/* ── Desktop Nav ── */
.header-nav {
  flex: 1;
  min-width: 0;
}

.nav-list {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: nowrap;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 6px;
}

.nav-item {
  position: relative;
}

.nav-link {
  display: block;
  padding: 8px 14px;
  font-family: var(--font-ui);
  font-size: clamp(15px, 1.1vw, 17px);
  font-weight: 600;
  color: var(--color-header-text);
  text-decoration: none;
  letter-spacing: 0.04em;
  white-space: nowrap;
  margin: 0;
  transition: color 0.15s ease;
}

.nav-link:hover, .nav-link:focus-visible {
  color: var(--color-brand-plum);
  outline: none;
}

/* Active / current page nav item */
.nav-link[aria-current="page"] {
  color: var(--color-header-active);
}

/* ── Dropdown Menus (CSS hover) ── */
.dropdown {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 220px;
  background-color: var(--color-dropdown-surface);
  border: 1px solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
  list-style: none;
  margin: 0;
  padding: 6px 0;
  z-index: 100;
}

.has-dropdown:hover > .dropdown,
.has-dropdown:focus-within > .dropdown {
  display: block;
}

.dropdown li a {
  display: block;
  padding: 10px 20px;
  font-family: var(--font-body);
  font-size: 15.5px;
  font-weight: 700;
  color: #1a1320;
  /* page sets -webkit-font-smoothing:antialiased globally which thins text on
     the light dropdown panel; force normal smoothing so menu items render solid */
  -webkit-font-smoothing: auto;
  -moz-osx-font-smoothing: auto;
  text-decoration: none;
  white-space: nowrap;
  transition: background-color 0.1s, color 0.1s;
}

.dropdown li a:hover, .dropdown li a:focus-visible {
  background-color: rgba(130, 121, 138, 0.12);
  color: var(--color-brand-plum);
  outline: none;
}

/* ── Second-level flyout (category → treatments) ── */
.dropdown li.has-sub { position: relative; }

.dropdown li.has-sub > a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
}

.sub-caret {
  font-size: 18px;
  line-height: 1;
  opacity: 0.55;
}

.subdropdown {
  display: none;
  position: absolute;
  top: -6px; /* align first child with parent row (.dropdown padding is 6px) */
  left: 100%;
  min-width: 230px;
  background-color: var(--color-dropdown-surface);
  border: 1px solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
  list-style: none;
  margin: 0;
  padding: 6px 0;
  z-index: 110;
}

.dropdown li.has-sub:hover > .subdropdown,
.dropdown li.has-sub:focus-within > .subdropdown {
  display: block;
}

/* ── Right Cluster ── */
.header-right {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.social-icons {
  display: flex;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 10px;
}

.social-icons li a {
  display: flex;
  align-items: center;
  opacity: 0.85;
  transition: opacity 0.15s;
}

.social-icons li a:hover {
  opacity: 1;
}

.social-icons img {
  display: block;
  width: 36px;
  height: 36px;
  object-fit: contain;
}

/* Call Now CTA, solid gold pill, dark text + phone icon (brand-matched) */
.header-cta {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  padding: 13px 24px;
  background-color: var(--color-cta-alt);
  color: var(--color-text);
  font-family: var(--font-cta);
  font-size: 16px;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  border: 1px solid transparent;
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-btn-alt);
  letter-spacing: 0.02em;
  transition: background-color 0.2s ease, box-shadow 0.2s ease;
}

.header-cta:hover, .header-cta:focus-visible {
  background-color: #BD9A64;
  outline: none;
}

.header-cta__icon {
  width: 21px;
  height: 21px;
  flex-shrink: 0;
}

/* ── Hamburger (hidden on desktop) ── */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 40px;
  height: 40px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  flex-shrink: 0;
}

.hamburger-line {
  display: block;
  width: 24px;
  height: 2px;
  background-color: var(--color-header-text);
  border-radius: 2px;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}
.hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
}
.hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* ── Mobile Nav Drawer ── */
.mobile-nav {
  display: none;
  position: fixed;
  inset: 0;
  background-color: var(--color-surface);
  z-index: 200;
  overflow-y: auto;
  overscroll-behavior: contain;
  padding: 64px 24px 40px;
  transform: translateX(100%);
  transition: transform 0.25s ease;
}

.mobile-nav.is-open {
  transform: translateX(0);
}

.mobile-nav-close {
  position: absolute;
  top: 14px;
  right: 18px;
  background: none;
  border: none;
  font-size: 28px;
  line-height: 1;
  cursor: pointer;
  color: var(--color-text);
  padding: 6px 10px;
}

.mobile-nav-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.mobile-nav-list > li {
  border-bottom: 1px solid rgba(0, 0, 0, 0.07);
}

.mobile-nav-list > li > a {
  display: block;
  padding: 14px 0;
  font-family: var(--font-ui);
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text);
  text-decoration: none;
  letter-spacing: 0.05em;
}

.mobile-has-sub .mobile-sub-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 14px 0;
  background: none;
  border: none;
  font-family: var(--font-ui);
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text);
  cursor: pointer;
  letter-spacing: 0.05em;
  text-align: left;
}

.mobile-sub-arrow {
  display: inline-block;
  font-size: 20px;
  line-height: 1;
  transition: transform 0.2s ease;
  flex-shrink: 0;
}

.mobile-has-sub .mobile-sub-toggle[aria-expanded="true"] .mobile-sub-arrow {
  transform: rotate(45deg);
}

.mobile-sub {
  list-style: none;
  margin: 0;
  padding: 0 0 8px 16px;
  display: none;
}

.mobile-sub.is-open {
  display: block;
}

.mobile-sub li a {
  display: block;
  padding: 9px 0;
  font-family: var(--font-body);
  font-size: 15.5px;
  font-weight: 700;
  color: var(--color-text);
  -webkit-font-smoothing: auto;
  -moz-osx-font-smoothing: auto;
  text-decoration: none;
  opacity: 1;
  transition: opacity 0.12s, color 0.12s;
}

.mobile-sub li a:hover {
  opacity: 1;
  color: var(--color-cta-alt);
}

/* Grouped sub-categories inside a mobile accordion (category → its treatments) */
.mobile-sub__cat-link { font-weight: 700; }

.mobile-sub__kids {
  list-style: none;
  margin: 2px 0 4px;
  padding: 0 0 0 16px;
  border-left: 2px solid rgba(0, 0, 0, 0.08);
}

.mobile-sub__kids li a {
  font-weight: 600;
  font-size: 14.5px;
}

.mobile-cta-item {
  border-bottom: none !important;
  padding: 20px 0 0;
}

/* Full-width CTA pill. Selector is more specific than `.mobile-nav-list > li > a`
   (0,2,0 vs 0,1,2) so it wins display/padding and the label can center. */
.mobile-cta-item .mobile-cta-phone {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 14px 20px;
  background-color: var(--color-cta-alt);
  color: var(--color-text);
  font-family: var(--font-cta);
  font-size: 15px;
  font-weight: 600;
