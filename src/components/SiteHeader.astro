<style>
/* ===== Site Header ===== */
.site-header {
  position: sticky;
  top: 0;
  z-index: 55;
  width: 100%;
  background-color: var(--color-header-bg);
  transition: box-shadow 0.2s ease, background-color 0.2s ease;
}

.site-header.scrolled {
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.09);
}

.header-inner {
  display: flex;
  align-items: center;
  height: 135px;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 24px;
  gap: 12px;
  box-sizing: border-box;
}

/* ── Logo ── */
.header-logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  text-decoration: none;
}

.header-logo img {
  display: block;
  width: 212px;
  height: 51px;
  object-fit: contain;
}

/* ── Desktop Nav ── */
.header-nav {
  flex: 1;
  min-width: 0;
}

.nav-list {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 0;
}

.nav-item {
  position: relative;
}

.nav-link {
  display: block;
  padding: 10px 8px;
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 400;
  color: var(--color-header-text);
  text-decoration: none;
  letter-spacing: 0.04em;
  white-space: nowrap;
  margin: 4px 0;
  transition: color 0.08s cubic-bezier(0, 0, 1, 1);
}

.nav-link:hover,
.nav-link:focus-visible {
  color: var(--color-brand-plum);
  outline: none;
}

/* Active / current page nav item */
.nav-link[aria-current="page"] {
  color: var(--color-header-active);
}

.nav-link--external {
  font-size: 9px;
}

/* ── Dropdown Menus (CSS hover) ── */
.dropdown {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 220px;
  background-color: var(--color-dropdown-surface);
  border: 1px solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
  list-style: none;
  margin: 0;
  padding: 6px 0;
  z-index: 100;
}

.has-dropdown:hover > .dropdown,
.has-dropdown:focus-within > .dropdown {
  display: block;
}

.dropdown li a {
  display: block;
  padding: 8px 16px;
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 400;
  color: var(--color-brand-plum-2);
  text-decoration: none;
  white-space: nowrap;
  transition: background-color 0.1s, color 0.1s;
}

.dropdown li a:hover,
.dropdown li a:focus-visible {
  background-color: rgba(130, 121, 138, 0.12);
  color: var(--color-brand-plum);
  outline: none;
}

/* ── Right Cluster ── */
.header-right {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.social-icons {
  display: flex;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 6px;
}

.social-icons li a {
  display: flex;
  align-items: center;
  opacity: 0.85;
  transition: opacity 0.15s;
}

.social-icons li a:hover {
  opacity: 1;
}

.social-icons img {
  display: block;
  width: 28px;
  height: 28px;
  object-fit: contain;
}

/* Call Now CTA — white pill, black text (faithful to original) */
.header-cta {
  display: inline-flex;
  align-items: center;
  padding: 10px 14px;
  background-color: #FFFFFF;
  color: #000000;
  font-family: var(--font-cta);
  font-size: 11px;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-btn-alt);
  letter-spacing: 0.02em;
  transition: background-color 0.2s, box-shadow 0.2s;
}

.header-cta:hover {
  background-color: rgba(255,255,255,0.88);
}

/* ── Hamburger (hidden on desktop) ── */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 40px;
  height: 40px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  flex-shrink: 0;
}

.hamburger-line {
  display: block;
  width: 24px;
  height: 2px;
  background-color: var(--color-header-text);
  border-radius: 2px;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}
.hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
}
.hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* ── Mobile Nav Drawer ── */
.mobile-nav {
  display: none;
  position: fixed;
  inset: 0;
  background-color: var(--color-surface);
  z-index: 200;
  overflow-y: auto;
  overscroll-behavior: contain;
  padding: 64px 24px 40px;
  transform: translateX(100%);
  transition: transform 0.25s ease;
}

.mobile-nav.is-open {
  transform: translateX(0);
}

.mobile-nav-close {
  position: absolute;
  top: 14px;
  right: 18px;
  background: none;
  border: none;
  font-size: 28px;
  line-height: 1;
  cursor: pointer;
  color: var(--color-text);
  padding: 6px 10px;
}

.mobile-nav-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.mobile-nav-list > li {
  border-bottom: 1px solid rgba(0, 0, 0, 0.07);
}

.mobile-nav-list > li > a {
  display: block;
  padding: 14px 0;
  font-family: var(--font-ui);
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text);
  text-decoration: none;
  letter-spacing: 0.05em;
}

.mobile-has-sub .mobile-sub-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 14px 0;
  background: none;
  border: none;
  font-family: var(--font-ui);
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text);
  cursor: pointer;
  letter-spacing: 0.05em;
  text-align: left;
}

.mobile-sub-arrow {
  display: inline-block;
  font-size: 20px;
  line-height: 1;
  transition: transform 0.2s ease;
  flex-shrink: 0;
}

.mobile-has-sub .mobile-sub-toggle[aria-expanded="true"] .mobile-sub-arrow {
  transform: rotate(45deg);
}

.mobile-sub {
  list-style: none;
  margin: 0;
  padding: 0 0 8px 16px;
  display: none;
}

.mobile-sub.is-open {
  display: block;
}

.mobile-sub li a {
  display: block;
  padding: 8px 0;
  font-family: var(--font-ui);
  font-size: 13px;
  color: var(--color-text);
  text-decoration: none;
  opacity: 0.78;
  transition: opacity 0.12s, color 0.12s;
}

.mobile-sub li a:hover {
  opacity: 1;
  color: var(--color-cta-alt);
}

.mobile-cta-item {
  border-bottom: none !important;
  padding: 20px 0 0;
}

.mobile-cta-phone {
  display: inline-flex;
  align-items: center;
  padding: 12px 20px;
  background-color: var(--color-cta-alt);
  color: var(--color-text);
  font-family: var(--font-cta);
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  border-radius: var(--radius-sm);
  letter-spacing: 0.02em;
}

/* ── Mobile breakpoint (<=980px) ── */
@media (max-width: 980px) {
  .header-inner {
    height: 72px;
    padding: 0 16px;
  }

  .header-logo img {
    width: 160px;
    height: auto;
  }

  .header-nav,
  .header-right {
    display: none;
  }

  .hamburger {
    display: flex;
    margin-left: auto;
  }

  .mobile-nav {
    display: block;
  }
}
</style>

<script>
// ── Sticky scroll state ──
(function () {
  const header = document.getElementById('site-header');
  if (!header) return;
  const onScroll = () => {
    header.classList.toggle('scrolled', window.scrollY > 0);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();

// ── Mobile nav toggle ──
(function () {
  const btn      = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
  const nav      = document.getElementById('mobile-nav') as HTMLElement | null;
  const closeBtn = document.getElementById('mobile-nav-close') as HTMLButtonElement | null;

  if (!btn || !nav) return;

  const open = () => {
    nav.classList.add('is-open');
    nav.setAttribute('aria-hidden', 'false');
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const close = () => {
    nav.classList.remove('is-open');
    nav.setAttribute('aria-hidden', 'true');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  btn.addEventListener('click', () => {
    btn.getAttribute('aria-expanded') === 'true' ? close() : open();
  });

  closeBtn?.addEventListener('click', close);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });

  // ── Mobile accordion sub-menus ──
  const toggles = nav.querySelectorAll<HTMLButtonElement>('.mobile-sub-toggle');
  toggles.forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      const sub = toggle.nextElementSibling as HTMLElement | null;

      // Collapse sibling accordions
      toggles.forEach((other) => {
        if (other !== toggle) {
          other.setAttribute('aria-expanded', 'false');
          const otherSub = other.nextElementSibling as HTMLElement | null;
          otherSub?.classList.remove('is-open');
          otherSub?.setAttribute('aria-hidden', 'true');
        }
      });

      // Toggle this one
      const next = !expanded;
      toggle.setAttribute('aria-expanded', String(next));
      if (sub) {
        sub.classList.toggle('is-open', next);
        sub.setAttribute('aria-hidden', String(!next));
      }
    });
  });
