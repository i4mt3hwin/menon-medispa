---
/**
 * SiteHeader.astro, Phase 3 Pass 1 COMPLETE
 *
 * Sources:
 *   nav.json, 8 top-level items, verbatim labels + hrefs
 *   structure.json §0, is_master="header", sticky, z-index:55, h=135px, transition:0.2s
 *   image-map.slice, logo=02a84c58deec, ig=d85622e84ef0, fb=482f7439ea47, tt=de7ef3d7c470
 *   site.ts, phone (973) 494-8431 / tel:+19734948431
 *   tokens.css, CSS custom properties
 *
 * Desktop (1440px): [Logo left] [Nav center-right] [Social icons] [Call Now CTA]
 * Sticky: position:sticky, z-index:55, transition:0.2s (from capture)
 * .scrolled added via scroll listener when scrollY > 0
 * Mobile (<=980px): hamburger toggle, full drawer with accordion sub-menus
 *
 * Phone: (973) 494-8431 / tel:+19734948431, operator-confirmed canonical
 */

import { Image } from 'astro:assets';
import logoImg from '@/assets/images/02a84c58deec.png';
import igImg   from '@/assets/images/d85622e84ef0.png';
import fbImg   from '@/assets/images/482f7439ea47.png';
import ttImg   from '@/assets/images/de7ef3d7c470.png';
---

<header id="site-header" class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="header-logo" aria-label="Menon Medispa home">
      <Image
        src={logoImg}
        alt="Medispa Logo"
        width={212}
        height={51}
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="header-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">

        <!-- HOME -->
        <li class="nav-item">
          <a href="/" class="nav-link">HOME</a>
        </li>

        <!-- ABOUT (3 children) -->
        <li class="nav-item has-dropdown">
          <a href="/about" class="nav-link">ABOUT</a>
          <ul class="dropdown" role="list">
            <li><a href="/meet-the-team">MEET THE TEAM</a></li>
            <li><a href="/patient-resources">PATIENT RESOURCES</a></li>
          </ul>
        </li>

        <!-- FACE (nested: Facials / Laser Facials / Fillers & Injectables have children) -->
        <li class="nav-item has-dropdown">
          <a href="/face" class="nav-link">FACE</a>
          <ul class="dropdown" role="list">
            <li class="has-sub">
              <a href="/menon-facials">FACIALS<span class="sub-caret" aria-hidden="true">&rsaquo;</span></a>
