---
/**
 * ServiceHero.astro, cinematic service-page hero.
 *
 * Full-bleed photo (subject pushed to the RIGHT, away from the text) under a
 * strong dark overlay, with soft drifting light particles (autonomous, no mouse
 * interaction, no parallax) and a one-time zoom-in + staggered blur-rise text
 * entrance. Conversion elements over the scrim: outcome H1, subhead, trust
 * (stars + gold review count), "Starting at $X", one CTA + tap-to-call.
 *
 * Carries the page's ONLY <h1> + the literal `hero` class so scroll-reveal skips
 * it and the H1 paints immediately (LCP). Motion gated on prefers-reduced-motion
 * (reduced = crisp static photo, no particles); particles idle when offscreen.
 */
import type { ImageMetadata } from 'astro';
import site from '@/lib/site';

interface CtaLink { label: string; href: string; }
interface Props {
  eyebrow?: string;
  h1: string;
  subhead?: string;
  image: ImageMetadata;
  imageAlt: string;
  imagePosition?: string;   // object-position; default keeps the subject on the right
  price?: string;
  note?: string;
  primaryCta?: CtaLink;     // default: Book Your Consultation → site.calcomUrl
  showPhone?: boolean;
  trust?: { stars?: boolean; reviewText?: string };
}

const {
  eyebrow, h1, subhead, image, imageAlt, imagePosition = 'center',
  price, note,
  primaryCta = { label: 'Book Your Consultation', href: site.calcomUrl },
  showPhone = true,
  trust,
} = Astro.props;

const isExternal = primaryCta.href.startsWith('http');
---

<section class="service-hero hero" data-hero>
  <div class="service-hero__media">
    <img
      class="service-hero__img"
      src={image.src}
      alt={imageAlt}
      style={`object-position:${imagePosition};`}
      loading="eager"
      decoding="async"
      width={image.width}
      height={image.height}
    />
  </div>

  <span class="service-hero__scrim" aria-hidden="true"></span>
  <canvas class="service-hero__particles" data-hero-canvas aria-hidden="true"></canvas>

  <div class="container service-hero__inner on-media">
    <div class="service-hero__text">
      {eyebrow && <p class="eyebrow service-hero__eyebrow">{eyebrow}</p>}
      <h1 class="service-hero__h1">{h1}</h1>
      {subhead && <p class="service-hero__subhead">{subhead}</p>}

      {trust && (trust.stars || trust.reviewText) && (
        <div class="service-hero__trust">
          {trust.stars && <span class="stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>}
          {trust.reviewText && <span class="service-hero__trust-text">{trust.reviewText}</span>}
        </div>
      )}

      {price && <p class="service-hero__price">{price}</p>}

      <div class="service-hero__ctas">
        <a
          href={primaryCta.href}
          class="btn btn--primary btn--lg"
          {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >{primaryCta.label}</a>
        {showPhone && (
          <a href={site.phone.tel} class="btn btn--secondary btn--on-dark btn--lg service-hero__call">
            Call {site.phone.display}
          </a>
        )}
      </div>

      {note && <p class="service-hero__note">{note}</p>}
    </div>
  </div>
</section>

<style>
  .service-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: clamp(520px, 80vh, 760px);
    display: flex;
    align-items: center;
    background: #1b1522;
  }

  /* photo occupies the RIGHT portion → subject/face sits to the right, away from the text.
     The left edge is masked to transparent so it dissolves into the dark panel (no hard seam). */
  .service-hero__media {
    position: absolute;
    top: 0; bottom: 0; right: 0; left: auto;
    width: 64%;
    z-index: 0;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 32%);
    mask-image: linear-gradient(90deg, transparent 0%, #000 32%);
  }
  .service-hero__img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* strong dark overlay; solid on the left so it reads as a dark text panel, blending into the photo */
  .service-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(90deg, #1b1522 0%, #1b1522 35%, rgb(27 21 34 / 0.88) 47%, rgb(27 21 34 / 0.5) 74%, rgb(27 21 34 / 0.32) 100%),
      linear-gradient(0deg, rgb(27 21 34 / 0.5) 0%, transparent 50%);
  }

  .service-hero__particles { position: absolute; inset: 0; z-index: 2; pointer-events: none; }

  .service-hero__inner { position: relative; z-index: 3; padding-block: var(--section-py); }
  .service-hero__text { display: flex; flex-direction: column; gap: var(--space-sm); max-width: 640px; }

  .service-hero__eyebrow { color: var(--color-cta); opacity: 1; }
  .service-hero__h1 {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: var(--weight-regular);
    line-height: 1.06;
    margin: 0;
    text-wrap: balance;
    text-shadow: 0 2px 24px rgb(0 0 0 / 0.45);
  }
  .service-hero__subhead { font-family: var(--font-body); font-size: var(--text-lg); line-height: 1.4; margin: 0; max-width: 46ch; opacity: 0.95; }

  /* review badge, glassy pill with gold stars + count */
  .service-hero__trust {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    width: fit-content;
    margin-top: var(--space-sm);
    padding: 7px 15px;
    background: rgb(255 255 255 / 0.08);
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: 999px;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }
  /* re-assert gold on the stars, .on-media forces white on spans, which would override .stars */
  .service-hero__trust .stars { color: var(--color-star); font-size: 1.05em; letter-spacing: 2px; }
  .service-hero__trust-text { font-family: var(--font-ui); font-size: var(--text-sm); font-weight: 600; color: #fff; }

  .service-hero__price { font-family: var(--font-body); font-size: var(--text-base); font-weight: var(--weight-bold); color: #fff; margin: 0; }
  .service-hero__price::before { content: ''; display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--color-cta); margin-right: 9px; vertical-align: middle; }
  .service-hero__ctas { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-sm); }
  .service-hero__note { font-family: var(--font-ui); font-size: var(--text-xs); color: #fff; opacity: 0.78; margin: var(--space-xs) 0 0; }

  @media (max-width: 900px) {
    .service-hero__media { left: 0; width: 100%; -webkit-mask-image: none; mask-image: none; }
    .service-hero__scrim {
      background:
        linear-gradient(90deg, rgb(27 21 34 / 0.92) 0%, rgb(27 21 34 / 0.74) 48%, rgb(27 21 34 / 0.55) 100%),
        linear-gradient(0deg, rgb(27 21 34 / 0.55) 0%, transparent 55%);
    }
  }

  @media (max-width: 600px) {
    .service-hero { min-height: clamp(460px, 84vh, 620px); }
    .service-hero__ctas { flex-direction: column; align-items: stretch; }
    .service-hero__ctas .btn { width: 100%; }
  }

  /* ── Motion (only when allowed) ── */
  @media (prefers-reduced-motion: no-preference) {
    .service-hero__media { animation: sh-zoom 2s cubic-bezier(0.16, 1, 0.3, 1) forwards; transform: scale(1.1); }
    @keyframes sh-zoom { to { transform: scale(1); } }

    .service-hero__text > * { opacity: 0; transform: translateY(22px); filter: blur(10px); animation: sh-rise 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .service-hero__text > *:nth-child(1) { animation-delay: 0.20s; }
    .service-hero__text > *:nth-child(2) { animation-delay: 0.32s; }
    .service-hero__text > *:nth-child(3) { animation-delay: 0.44s; }
    .service-hero__text > *:nth-child(4) { animation-delay: 0.56s; }
    .service-hero__text > *:nth-child(5) { animation-delay: 0.66s; }
    .service-hero__text > *:nth-child(6) { animation-delay: 0.76s; }
    .service-hero__text > *:nth-child(7) { animation-delay: 0.86s; }
    @keyframes sh-rise { to { opacity: 1; transform: none; filter: blur(0); } }
  }
</style>

<script>
  // Autonomous drifting light particles (no mouse, no parallax). Reduced-motion safe; idles offscreen.
  (function () {
    const hero = document.querySelector('[data-hero]');
    if (!hero) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const canvas = hero.querySelector('[data-hero-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let w = 0, h = 0, dpr = 1, parts = [], raf = 0, running = false;
    function size() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = hero.clientWidth; h = hero.clientHeight;
      canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
      canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    function spawn(init) {
      return {
        x: Math.random() * w,
        y: init ? Math.random() * h : h + 14,
        r: 0.5 + Math.random() * 1.1,
        vy: 0.05 + Math.random() * 0.18,
        vx: (Math.random() - 0.5) * 0.12,
        a: 0.12 + Math.random() * 0.30,
        white: Math.random() < 0.32,
      };
    }
    function build() {
      const n = Math.max(12, Math.min(30, Math.round((w * h) / 54000)));
      parts = []; for (let i = 0; i < n; i++) parts.push(spawn(true));
    }
    function step() {
      ctx.clearRect(0, 0, w, h);
      for (const p of parts) {
        p.y -= p.vy; p.x += p.vx;
        if (p.y < -14) Object.assign(p, spawn(false));
        const rad = p.r * 7;
        const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, rad);
        const c = p.white ? '245,239,228' : '226,186,120';
        g.addColorStop(0, 'rgba(' + c + ',' + p.a + ')');
        g.addColorStop(0.5, 'rgba(' + c + ',' + (p.a * 0.35) + ')');
        g.addColorStop(1, 'rgba(' + c + ',0)');
        ctx.fillStyle = g;
        ctx.beginPath(); ctx.arc(p.x, p.y, rad, 0, 6.2832); ctx.fill();
      }
      raf = requestAnimationFrame(step);
    }
    function start() { if (!running) { running = true; raf = requestAnimationFrame(step); } }
    function stop() { running = false; cancelAnimationFrame(raf); }

    size(); build();
    let rt;
    window.addEventListener('resize', function () { clearTimeout(rt); rt = setTimeout(function () { size(); build(); }, 150); }, { passive: true });
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function (es) { es.forEach(function (en) { en.isIntersecting ? start() : stop(); }); }, { threshold: 0.01 }).observe(hero);
    } else { start(); }
  })();
</script>
