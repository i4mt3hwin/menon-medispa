---
// Scaffold stub, phase-2-synthesize. Phase 3 completes.
// Wix Forms → D1/Resend. Endpoint /api/lead deferred to Phase 3.
interface Props {
  heading?: string;
  fields?: Array<'name' | 'email' | 'phone' | 'service' | 'message'>;
  submit_label?: string;
  success_url?: string;
  background?: string;
  /** Render an SMS opt-in checkbox inside the form (captured + consent-logged). */
  sms_consent?: boolean;
}
const {
  heading = 'Request a Consultation',
  fields = ['name', 'email', 'phone', 'message'],
  submit_label = 'Send Message',
  success_url = '/thank-you',
  background,
  sms_consent = false,
} = Astro.props;

const SMS_CONSENT_TEXT =
  'I agree to receive SMS messages from Menon Medispa through an automatic telephone dialing system. Message and data rates may apply. Reply STOP to opt out.';
---
<section class="lead-form" style={background ? `background-color: ${background};` : ''}>
  {heading && <h2 style="font-family: var(--font-display); font-size: var(--text-h2);">{heading}</h2>}
  <!-- POST target /api/lead wired in Phase 3 (Cloudflare Worker + D1 + Resend) -->
  <form class="lead-form__form" method="POST" action="/api/lead" data-success-url={success_url}>
    {fields.includes('name') && (
      <div class="lead-form__field">
        <label for="lf-name" style="font-family: var(--font-body); font-size: var(--text-sm);">Name</label>
        <input id="lf-name" name="name" type="text" required autocomplete="name" />
      </div>
    )}
    {fields.includes('email') && (
      <div class="lead-form__field">
        <label for="lf-email" style="font-family: var(--font-body); font-size: var(--text-sm);">Email</label>
        <input id="lf-email" name="email" type="email" required autocomplete="email" />
      </div>
    )}
    {fields.includes('phone') && (
      <div class="lead-form__field">
        <label for="lf-phone" style="font-family: var(--font-body); font-size: var(--text-sm);">Phone</label>
        <input id="lf-phone" name="phone" type="tel" autocomplete="tel" />
      </div>
    )}
    {fields.includes('service') && (
      <div class="lead-form__field">
        <label for="lf-service" style="font-family: var(--font-body); font-size: var(--text-sm);">Service of Interest</label>
        <input id="lf-service" name="service_interest" type="text" />
      </div>
    )}
    {fields.includes('message') && (
      <div class="lead-form__field">
        <label for="lf-message" style="font-family: var(--font-body); font-size: var(--text-sm);">Message</label>
        <textarea id="lf-message" name="message" rows="4"></textarea>
      </div>
    )}
    {sms_consent && (
      <label class="lead-form__consent" style="display:flex;gap:8px;align-items:flex-start;font-family:var(--font-body);font-size:var(--text-xs);line-height:1.4;opacity:0.85;">
        <input type="checkbox" name="consent_sms" value="on" style="margin-top:3px;flex:none;" />
        <span>{SMS_CONSENT_TEXT}</span>
      </label>
      <input type="hidden" name="consent_sms_text" value={SMS_CONSENT_TEXT} />
      <input type="hidden" name="consent_version" value="1" />
    )}
    <input type="hidden" name="type" value="contact" />
    <input type="hidden" name="send_confirmation" value="on" />
    <!-- Honeypot: real people leave this empty. -->
    <input type="text" name="company_website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />
    <p class="lead-form__error" data-form-error hidden style="color:#b00020;font-family:var(--font-body);font-size:var(--text-sm);margin:0;"></p>
    <button type="submit" style="background-color: var(--color-cta); color: var(--color-text); border: none; border-radius: var(--radius-sm); box-shadow: var(--shadow-btn); padding: 10px 24px; font-family: var(--font-cta); font-size: var(--text-base); cursor: pointer;">{submit_label}</button>
  </form>
</section>

<script>
  // Progressive enhancement: without this, the native POST navigates to the raw
  // JSON returned by /api/lead. Wire every LeadForm to the shared submit helper,
  // redirecting to its success_url on success. (BookingRequest + the consultation
  // request form enhance their own forms separately.)
  import { enhanceLeadForm } from '@/lib/leadForm';
  document.querySelectorAll('form.lead-form__form').forEach((form) => {
    enhanceLeadForm(form as HTMLFormElement, {
      successUrl: form.getAttribute('data-success-url') || '/thank-you',
    });
  });
</script>
<style>
  .lead-form { padding: var(--space-xl) var(--space-md); }
  /* center the form column instead of pinning it to the far left of the full-width band */
  .lead-form > h2 { text-align: center; max-width: 560px; margin: 0 auto var(--space-md); }
  .lead-form__form { display: flex; flex-direction: column; gap: var(--space-sm); max-width: 560px; margin-inline: auto; }
  .lead-form__field { display: flex; flex-direction: column; gap: 4px; }
  .lead-form__field input, .lead-form__field textarea { padding: 8px 12px; border: 1px solid rgba(0,0,0,0.2); border-radius: var(--radius-sm); font-family: var(--font-body); font-size: var(--text-base); width: 100%; box-sizing: border-box; }
  .lead-form__field textarea { resize: vertical; }
</style>
