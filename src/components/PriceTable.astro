---
/**
 * PriceTable.astro — Generated by path-2-rebuild/02-synthesize (scaffold stub).
 * Token-driven faithful stub: correct prop shape + styling hooks wired to the
 * @theme tokens (see 03-design/design-tokens.md). The first Phase 3 subagent to
 * render this pattern completes it with VERBATIM captured content. Do NOT put
 * page-specific content here.
 */
interface Props {
  heading?: string;
  rows: Array<{ name: string; price: string; detail?: string }>;
  class?: string;
}
const { heading, rows = [] } = Astro.props;
---

<section class="price-table">
  {heading && <h2>{heading}</h2>}
  <table>
    <tbody>
      {rows.map((r) => (
        <tr><th>{r.name}{r.detail && <span class="price-table__detail">{r.detail}</span>}</th><td>{r.price}</td></tr>
      ))}
    </tbody>
  </table>
</section>

<style>
  .price-table { padding: var(--spacing-section) 1.5rem; max-width: var(--container-content); margin: 0 auto; font-family: var(--font-ui); }
  .price-table table { width: 100%; border-collapse: collapse; }
  .price-table th, .price-table td { text-align: left; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border); }
  .price-table td { text-align: right; font-weight: 700; }
  .price-table__detail { display: block; font-weight: 400; font-size: var(--text-sm); color: var(--color-text-muted); }
</style>
