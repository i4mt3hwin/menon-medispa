---
interface PriceItem {
  name: string;
  price: string;
  description?: string;
}
interface PriceSection {
  title?: string;
  items: PriceItem[];
}
interface Props {
  heading?: string;
  sections?: PriceSection[];
  bg_color?: string;
}
const { heading, sections = [], bg_color } = Astro.props;
---
<section class="price-table section" style={bg_color ? `background-color: ${bg_color};` : ''}>
  <div class="container container--narrow">
    {heading && <h2 class="price-table__heading">{heading}</h2>}

    {sections.map((section) => (
      <div class="price-table__section">
        {section.title && <h3 class="price-table__section-title">{section.title}</h3>}
        <dl class="price-table__list">
          {section.items.map((item) => (
            <div class="price-table__row">
              <dt class="price-table__name">
                {item.name}
                {item.description && (
                  <span class="price-table__description">{item.description}</span>
                )}
              </dt>
              <dd class="price-table__price">{item.price}</dd>
            </div>
          ))}
        </dl>
      </div>
    ))}
  </div>
</section>

<style>
  .price-table__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-text);
    text-align: center;
    margin: 0 0 var(--space-lg);
    text-wrap: balance;
  }

  .price-table__section {
    margin-bottom: var(--space-lg);
  }

  .price-table__section:last-child {
    margin-bottom: 0;
  }

  .price-table__section-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    padding-bottom: var(--space-xs);
    border-bottom: 2px solid var(--color-cta);
    text-wrap: balance;
  }

  .price-table__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .price-table__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-sm);
    padding: var(--space-xs) 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .price-table__row:last-child {
    border-bottom: none;
  }

  .price-table__name {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    flex: 1;
  }

  .price-table__description {
    display: block;
    font-size: var(--text-xs);
    color: rgba(0, 0, 0, 0.6);
    font-weight: 400;
    margin-top: 2px;
  }

  .price-table__price {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
    flex-shrink: 0;
    margin: 0;
  }

  /* Phone: stack name + price vertically */
  @media (max-width: 600px) {
    .price-table__row {
      flex-direction: column;
      gap: 2px;
    }

    .price-table__price {
      font-size: var(--text-xs);
    }
  }
</style>
