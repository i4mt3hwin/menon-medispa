---
/**
 * ArticleHero.astro, the editorial hero for a blog post.
 *
 * Full-bleed cover image + bottom-weighted scrim with the category eyebrow (links
 * to the topic hub), title, and a date / read-time meta line resting at the bottom.
 * Reuses the site's media-bg + on-media overlay vocabulary (base.css), so no new
 * design tokens. Carries the `hero` class so the global scroll-reveal skips it and
 * the MobileCtaBar observer (which watches `.hero`) fades the bar in past it.
 */
interface Props {
  title: string;
  categoryLabel: string;
  categorySlug: string;
  date: string;       // already formatted
  readTime: number;   // minutes
  image?: string;
  imageAlt?: string;
}
const { title, categoryLabel, categorySlug, date, readTime, image, imageAlt } = Astro.props;
---

<section class="article-hero hero media-bg" style="--scrim-strength:0.5">
  {image && (
    <img class="media-bg__img" src={image} alt={imageAlt ?? ''} loading="eager" decoding="async" />
  )}
  <span class="media-bg__scrim media-bg__scrim--b"></span>

  <div class="media-bg__inner container on-media article-hero__inner">
    <a href={`/blog/${categorySlug}`} class="article-hero__eyebrow">{categoryLabel}</a>
    <h1 class="article-hero__title">{title}</h1>
    <p class="article-hero__meta">
      {date && <span>{date}</span>}
      {date && <span class="article-hero__dot" aria-hidden="true">&middot;</span>}
      <span>{readTime} min read</span>
    </p>
  </div>
</section>

<style>
  .article-hero {
    min-height: clamp(360px, 50vw, 540px);
    display: flex;
    align-items: flex-end;
  }
  /* Cover image stays sharp (no blur) but a touch zoomed so edges never show. */
  .article-hero :global(.media-bg__img) {
    transform: scale(1.02);
  }
  .article-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
    max-width: 860px;
    padding-block: var(--space-xl) var(--space-lg);
  }
  .article-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-cta);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    padding: 5px 13px;
    border: 1px solid rgb(255 255 255 / 0.45);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.08);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    transition: background 0.18s ease;
  }
  .article-hero__eyebrow:hover { background: rgb(255 255 255 / 0.2); }
  .article-hero__title {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: var(--weight-regular);
    line-height: 1.08;
    margin: 0;
    text-wrap: balance;
    text-shadow: 0 2px 24px rgb(0 0 0 / 0.4);
  }
  .article-hero__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    margin: 0;
    opacity: 0.92;
  }
  .article-hero__dot { opacity: 0.7; }

  @media (max-width: 600px) {
    .article-hero { min-height: clamp(320px, 70vw, 440px); }
  }
</style>
