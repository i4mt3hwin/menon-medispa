---
/**
 * BookingRequest.astro — self-hosted "request + confirm" booking.
 *
 * A vanilla-JS month calendar + time-of-day window picker + contact fields that
 * POST to /api/lead (type=appointment_request). The row lands in D1 and the
 * front desk is emailed (Resend). This is a REQUEST, not a live-availability
 * booking — staff confirms. NON-PHI by design: no medical fields, and the
 * free-text box warns against medical detail. See lib/leadForm.ts for submit.
 *
 * Props:
 *   heading   — section heading
 *   prefill   — pre-selected service_interest (e.g. a service name; the form
 *               also reads a ?service= query param to pre-select and lock it)
 */
import site from '../lib/site';
import Turnstile from './Turnstile.astro';
import { allPackageServices } from '../lib/packages';
import { serviceInterestOptions, interestLabel } from '../lib/services';
import { CONSULT_NOTES } from '../lib/consult';

interface Props {
  heading?: string;
  prefill?: string;
}
const { heading = 'Request an Appointment', prefill } = Astro.props as Props;

// Multi-package services (e.g. Laser Hair Removal). Serialized to a data-attr so the
// client script can reveal an area picker when one of these services is chosen/locked.
// Keyed by the service name (which equals the service_interest value).
const packageData = Object.fromEntries(
  allPackageServices().map((p) => [
    p.service,
    {
      sessions: p.sessions,
      tiers: p.tiers.map((t) => ({
        size: t.size,
        label: t.label,
        perSession: t.perSession,
        packagePrice: t.packagePrice,
        duration: t.duration,
        areas: t.areas.map((a) => ({ name: a.name, perSession: a.perSession, packagePrice: a.packagePrice, duration: a.duration })),
      })),
    },
  ])
);

// Interest dropdown options + default, shared with the /consultation form (lib/services)
// so the two booking surfaces — and the consult-tier logic in lib/consult — never drift.
const { options, selected: selectedService } = serviceInterestOptions(prefill);
const labelFor = interestLabel;

// Day-of-week (0=Sun … 6=Sat) -> {opens, closes}, derived from site.hours. Sunday absent = closed.
const DOW = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
const hoursByDow: Record<number, { opens: string; closes: string }> = {};
for (const block of site.hours) {
  for (const day of block.days) {
    const i = DOW.indexOf(day);
    if (i >= 0) hoursByDow[i] = { opens: block.opens, closes: block.closes };
  }
}

const CONSENT_EMAIL_TEXT =
  'I agree to receive appointment updates and occasional offers from Menon Medispa by email. I can unsubscribe anytime.';
const HORIZON_DAYS = 60;
const WEEKDAYS = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
---

<div class="bk" data-booking data-hours={JSON.stringify(hoursByDow)} data-horizon={HORIZON_DAYS} data-packages={JSON.stringify(packageData)}>
  <div data-leadform-root>
    <form class="bk__form" method="POST" action="/api/lead" novalidate>
      <h2 class="bk__heading">{heading}</h2>
      <p class="bk__lead">Pick a day and a time that works for you. We will call or email to confirm.</p>

      <!-- What are you booking? — persistent above the wizard; shows the dropdown (generic
           entry, no ?service=) or the locked chip (?service= / prefill). NOT a [data-step],
           so it stays visible on every step. Service-driven UI (package picker, fee note)
           still lives in step 3 and reacts to this selection. -->
      <div class="bk__booking-for" data-booking-for>
        <div class="bk__field" data-service-field>
          <label for="bk-service">What are you interested in?</label>
          <select id="bk-service" name="service_interest" data-prefill={prefill}>
            {options.map((opt) => (
              <option value={opt} selected={opt === selectedService}>{labelFor(opt)}</option>
            ))}
          </select>
        </div>
        <div class="bk__locked" data-service-locked hidden>
          <div class="bk__locked-text">
            <span class="bk__locked-eyebrow">Booking</span>
            <span class="bk__locked-name" data-locked-name></span>
          </div>
          <button type="button" class="bk__locked-change" data-change>Change</button>
        </div>
      </div>

      <ol class="bk__progress" data-progress aria-label="Booking progress">
        <li class="bk__progress-item is-current" data-progress-step="1" aria-current="step"><span class="bk__progress-dot">1</span><span class="bk__progress-text">Date</span></li>
        <li class="bk__progress-item" data-progress-step="2"><span class="bk__progress-dot">2</span><span class="bk__progress-text">Time</span></li>
        <li class="bk__progress-item" data-progress-step="3"><span class="bk__progress-dot">3</span><span class="bk__progress-text">Details</span></li>
      </ol>

      <!-- Step 1: date -->
      <fieldset class="bk__step" data-step="1">
        <legend class="bk__step-label"><span class="bk__step-num">1</span> Choose a date</legend>
        <div class="bk-cal" role="group" aria-label="Choose an appointment date">
          <div class="bk-cal__head">
            <button type="button" class="bk-cal__nav" data-cal-prev aria-label="Previous month">&#8249;</button>
            <span class="bk-cal__month" data-cal-month aria-live="polite"></span>
            <button type="button" class="bk-cal__nav" data-cal-next aria-label="Next month">&#8250;</button>
          </div>
          <div class="bk-cal__weekdays" aria-hidden="true">
            {WEEKDAYS.map((d) => <span class="bk-cal__weekday">{d}</span>)}
          </div>
          <div class="bk-cal__grid" data-cal-grid></div>
          <p class="bk-cal__note">Open Mon–Fri 10–6, Sat 10–4. Closed Sundays.</p>
        </div>
      </fieldset>

      <!-- Step 2: time (revealed after a date is chosen) -->
      <fieldset class="bk__step bk__times" data-step="2" data-times hidden>
        <div class="bk__step-bar">
          <button type="button" class="bk__back" data-back-to="1"><span aria-hidden="true">&#8249;</span> Change date</button>
        </div>
        <h3 class="bk__chosen-date" data-time-hint tabindex="-1">Choose a time</h3>
        <div class="bk__slots" data-slots></div>
        <p class="bk__times-note">These are requested times — we will confirm by phone or email.</p>
        <button type="button" class="bk__next" data-next-time disabled>Continue</button>
      </fieldset>

      <!-- Step 3: details -->
      <fieldset class="bk__step" data-step="3" hidden>
        <div class="bk__step-bar">
          <button type="button" class="bk__back" data-back-to="2"><span aria-hidden="true">&#8249;</span> Back</button>
          <h3 class="bk__chosen-summary" data-detail-summary tabindex="-1"></h3>
        </div>
        <legend class="bk__step-label"><span class="bk__step-num">3</span> Your details</legend>

        <!-- Package picker: revealed when the chosen service is sold as multiple
             packages (e.g. Laser Hair Removal). Options are injected by the script
             from the service's data. "Not sure" routes to a consultation. -->
        <div class="bk__pkg" data-pkg hidden>
          <div class="bk__field">
            <label for="bk-pkg-area">Which area would you like?</label>
            <select id="bk-pkg-area" data-pkg-area>
              <option value="">I'm not sure yet — recommend during my consultation</option>
            </select>
          </div>
          <div class="bk__pkg-session" data-pkg-session hidden>
            <span class="bk__pkg-session-label">Session type</span>
            <div class="bk__pkg-toggle" role="radiogroup" aria-label="Session type">
              <label class="bk__pkg-opt">
                <input type="radio" name="pkg_session" value="package" checked />
                <span data-pkg-package-label>Package</span>
              </label>
              <label class="bk__pkg-opt">
                <input type="radio" name="pkg_session" value="single" />
                <span data-pkg-single-label>Single session</span>
              </label>
            </div>
          </div>
          <p class="bk__pkg-summary" data-pkg-summary hidden></p>
        </div>

        <p class="bk__fee-note" data-fee-note hidden>
          <strong>{CONSULT_NOTES.medical.emphasis}</strong>{CONSULT_NOTES.medical.rest}
        </p>

        <div class="bk__row">
          <div class="bk__field">
            <label for="bk-name">Name <span aria-hidden="true">*</span></label>
            <input id="bk-name" name="name" type="text" required autocomplete="name" />
          </div>
          <div class="bk__field">
            <label for="bk-phone">Phone</label>
            <input id="bk-phone" name="phone" type="tel" autocomplete="tel" />
          </div>
        </div>

        <div class="bk__field">
          <label for="bk-email">Email</label>
          <input id="bk-email" name="email" type="email" autocomplete="email" />
          <p class="bk__hint">We need an email or a phone number so we can confirm.</p>
        </div>

        <div class="bk__field">
          <label for="bk-message">Anything we should know? <span class="bk__optional">(optional)</span></label>
          <textarea id="bk-message" name="message" rows="3" placeholder="Questions, scheduling notes, etc."></textarea>
          <p class="bk__hint bk__hint--warn">Please do not include any medical details, conditions, or photos here.</p>
        </div>

        <label class="bk__consent">
          <input type="checkbox" name="consent_email" value="on" checked />
          <span>{CONSENT_EMAIL_TEXT}</span>
        </label>
      </fieldset>

      <!-- Hidden / system fields -->
      <input type="hidden" name="type" value="appointment_request" />
      <input type="hidden" name="preferred_date" value="" />
      <input type="hidden" name="preferred_window" value="" />
      <input type="hidden" name="consent_email_text" value={CONSENT_EMAIL_TEXT} />
      <input type="hidden" name="consent_version" value="1" />
      <input type="hidden" name="send_confirmation" value="on" />
      <!-- Honeypot: real people leave this empty. -->
      <input type="text" name="company_website" tabindex="-1" autocomplete="off" class="bk__hp" aria-hidden="true" />

      <Turnstile class="bk__turnstile" />
      <p class="bk__error" data-form-error role="alert" hidden></p>
      <button type="submit" class="bk__submit">Request Appointment</button>
      <p class="bk__fallback">Prefer to call? <a href={site.phone.tel}>{site.phone.display}</a></p>
    </form>

    <div class="bk__success" data-form-success role="status" aria-live="polite" hidden>
      <div class="bk__success-icon" aria-hidden="true">&#10003;</div>
      <h2 class="bk__heading">Request received</h2>
      <p>Thanks — we have your request and will call or email you shortly to confirm your appointment.</p>
      <p class="bk__fallback">Need to reach us now? <a href={site.phone.tel}>{site.phone.display}</a></p>
    </div>
  </div>
</div>

<script>
  import { enhanceLeadForm } from '../lib/leadForm';
  import { isMedicalConsult, withConsultTag } from '../lib/consult';

  const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const SLOT_MINUTES = 30; // request-grid granularity
  const pad = (n: number) => String(n).padStart(2, '0');
  const iso = (d: Date) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
  const toMin = (hhmm: string) => { const [h, m] = hhmm.split(':').map(Number); return h * 60 + m; };
  const fmtTime = (mins: number) => {
    let h = Math.floor(mins / 60); const m = mins % 60;
    const ap = h < 12 ? 'AM' : 'PM';
    h = h % 12; if (h === 0) h = 12;
    return `${h}:${pad(m)} ${ap}`;
  };
  const periodOf = (mins: number) => (mins < 720 ? 'Morning' : mins < 960 ? 'Afternoon' : 'Evening');

  function ensureOption(select: HTMLSelectElement, value: string) {
    if (!Array.from(select.options).some((o) => o.value === value)) {
      const opt = document.createElement('option');
      opt.value = value; opt.textContent = value;
      select.insertBefore(opt, select.firstChild);
    }
  }

  function initBooking(root: HTMLElement) {
    const hours: Record<string, { opens: string; closes: string }> = JSON.parse(root.dataset.hours || '{}');
    const horizon = parseInt(root.dataset.horizon || '60', 10);
    const form = root.querySelector('form') as HTMLFormElement;
    const grid = root.querySelector('[data-cal-grid]') as HTMLElement;
    const monthLabel = root.querySelector('[data-cal-month]') as HTMLElement;
    const prevBtn = root.querySelector('[data-cal-prev]') as HTMLButtonElement;
    const nextBtn = root.querySelector('[data-cal-next]') as HTMLButtonElement;
    const dateInput = root.querySelector('input[name="preferred_date"]') as HTMLInputElement;
    const timeInput = root.querySelector('input[name="preferred_window"]') as HTMLInputElement;
    const slotsWrap = root.querySelector('[data-slots]') as HTMLElement;
    const timeHint = root.querySelector('[data-time-hint]') as HTMLElement | null;
    const steps = Array.from(root.querySelectorAll('[data-step]')) as HTMLElement[];
    const progressItems = Array.from(root.querySelectorAll('[data-progress-step]')) as HTMLElement[];
    const nextTimeBtn = root.querySelector('[data-next-time]') as HTMLButtonElement | null;
    const detailSummary = root.querySelector('[data-detail-summary]') as HTMLElement | null;
    const submitBtn = root.querySelector('.bk__submit') as HTMLButtonElement | null;
    const leadEl = root.querySelector('.bk__lead') as HTMLElement | null;

    // Astro scopes this component's <style> to a [data-astro-cid-…] attribute that it only
    // stamps onto elements present in the template at build time. The calendar days and time
    // slots below are created at runtime with createElement, so without help they'd miss that
    // attribute and NONE of the scoped .bk-cal__day / .bk__slot rules — including the
    // .is-selected highlight — would match them (they'd render as unstyled default buttons).
    // Read the scope attribute off a template element and re-stamp it on each dynamic subtree.
    const scopeHost = [root, grid, slotsWrap].find(
      (el) => el && Array.from(el.attributes).some((a) => a.name.startsWith('data-astro-cid-')),
    );
    const SCOPE_ATTR = scopeHost
      ? Array.from(scopeHost.attributes).map((a) => a.name).find((n) => n.startsWith('data-astro-cid-'))
      : undefined;
    function applyScope(container: HTMLElement) {
      if (!SCOPE_ATTR) return;
      container.querySelectorAll('*').forEach((el) => el.setAttribute(SCOPE_ATTR, ''));
    }

    // "Today" pinned to the shop's timezone (America/New_York), not the visitor's,
    // so an out-of-state visitor near midnight can't select a day that's already past
    // (or miss one) relative to the clinic. Date-only, so day-of-week stays correct.
    function shopToday() {
      const parts = new Intl.DateTimeFormat('en-CA', {
        timeZone: 'America/New_York', year: 'numeric', month: '2-digit', day: '2-digit',
      }).formatToParts(new Date());
      const get = (t: string) => parseInt(parts.find((p) => p.type === t)?.value || '0', 10);
      return new Date(get('year'), get('month') - 1, get('day'));
    }
    const today = shopToday(); today.setHours(0, 0, 0, 0);
    const maxDate = new Date(today); maxDate.setDate(maxDate.getDate() + horizon);

    // The clinic's current minutes-of-day in America/New_York, so same-day slots that have already
    // passed (plus a short prep buffer) are hidden — a visitor can't request a time that's gone.
    const SAME_DAY_BUFFER_MIN = 60;
    function shopNowMinutes() {
      const parts = new Intl.DateTimeFormat('en-US', {
        timeZone: 'America/New_York', hour: '2-digit', minute: '2-digit', hour12: false,
      }).formatToParts(new Date());
      const get = (t: string) => parseInt(parts.find((p) => p.type === t)?.value || '0', 10);
      // Intl can emit "24" for midnight under hour12:false; normalize to 0.
      const h = get('hour') % 24;
      return h * 60 + get('minute');
    }
    let view = new Date(today.getFullYear(), today.getMonth(), 1);
    let selected: Date | null = null;

    const closed = (d: Date) => !hours[String(d.getDay())];
    const past = (d: Date) => d < today;
    const beyond = (d: Date) => d > maxDate;

    // All still-bookable 30-min slot start-times (minutes-of-day) for a date; [] = none.
    // On "today" (clinic tz) slots earlier than now + prep buffer are excluded, so a day whose
    // remaining hours have all passed returns [] — used to render the grid AND to disable the day.
    function slotsFor(d: Date): number[] {
      const h = hours[String(d.getDay())];
      if (!h) return [];
      const open = toMin(h.opens), close = toMin(h.closes);
      const earliest = iso(d) === iso(today) ? shopNowMinutes() + SAME_DAY_BUFFER_MIN : -1;
      const out: number[] = [];
      for (let t = open; t <= close - SLOT_MINUTES; t += SLOT_MINUTES) if (t >= earliest) out.push(t);
      return out;
    }

    // ── Wizard step machine ── one [data-step] fieldset visible at a time.
    // Reuses the .bk__step[hidden]{display:none} rule already in the styles.
    function showStep(n: number, opts: { focus?: boolean; scroll?: boolean } = {}) {
      const { focus = true, scroll = true } = opts;
      steps.forEach((s) => { s.hidden = Number(s.dataset.step) !== n; });
      progressItems.forEach((p) => {
        const k = Number(p.dataset.progressStep);
        p.classList.toggle('is-current', k === n);
        p.classList.toggle('is-done', k < n);
        if (k === n) p.setAttribute('aria-current', 'step');
        else p.removeAttribute('aria-current');
      });
      // Show "Request Appointment" ONLY on the final step so it never competes with
      // the step-2 "Continue" button (two gold buttons read as ambiguous).
      if (submitBtn) submitBtn.hidden = n !== 3;
      // Drop the intro lead once past date-picking — it's redundant on the time/details
      // steps and reclaims vertical space so the time grid fits the viewport better.
      if (leadEl) leadEl.hidden = n !== 1;
      // Scroll to the TOP of the wizard (not into the step) so the chosen-date
      // header / highlighted day stays in view — fixes the old scrollIntoView bug.
      if (scroll) root.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (focus) {
        const el = steps.find((s) => Number(s.dataset.step) === n);
        const target = el?.querySelector('[data-time-hint],[data-detail-summary],legend') as HTMLElement | null;
        target?.focus({ preventScroll: true });
      }
    }

    // Clearing the chosen time (and disabling Continue) whenever the date changes,
    // so a stale time can never carry into a different day. Single choke point.
    function resetTimeSelection() {
      timeInput.value = '';
      if (nextTimeBtn) nextTimeBtn.disabled = true;
    }

    function enterStep3() {
      if (detailSummary) {
        detailSummary.textContent = selected
          ? `${selected.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })} at ${timeInput.value}`
          : '';
      }
      showStep(3);
    }

    function renderSlots(d: Date) {
      slotsWrap.innerHTML = '';
      timeInput.value = '';
      // Single source of truth for which slots exist (also used to disable the day in renderMonth).
      const times = slotsFor(d);
      if (!times.length) {
        const note = document.createElement('p');
        note.className = 'bk__hint';
        note.textContent = 'No times left today, please pick another day.';
        slotsWrap.appendChild(note);
        applyScope(slotsWrap);
        return;
      }
      const groups: Record<string, number[]> = { Morning: [], Afternoon: [], Evening: [] };
      times.forEach((t) => groups[periodOf(t)].push(t));
      (['Morning', 'Afternoon', 'Evening'] as const).forEach((label) => {
        const times = groups[label];
        if (!times.length) return;
        const group = document.createElement('div');
        group.className = 'bk__slot-group';
        const gl = document.createElement('span');
        gl.className = 'bk__slot-group-label';
        gl.textContent = label;
        group.appendChild(gl);
        const row = document.createElement('div');
        row.className = 'bk__slot-row';
        times.forEach((t) => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'bk__slot';
          b.textContent = fmtTime(t);
          b.setAttribute('aria-pressed', 'false');
          b.addEventListener('click', () => {
            slotsWrap.querySelectorAll('.bk__slot').forEach((x) => { x.classList.remove('is-selected'); x.setAttribute('aria-pressed', 'false'); });
            b.classList.add('is-selected');
            b.setAttribute('aria-pressed', 'true');
            timeInput.value = b.textContent || '';
            if (nextTimeBtn) nextTimeBtn.disabled = false;
          });
          row.appendChild(b);
        });
        group.appendChild(row);
        slotsWrap.appendChild(group);
      });
      applyScope(slotsWrap);
    }

    function renderMonth() {
      monthLabel.textContent = `${MONTHS[view.getMonth()]} ${view.getFullYear()}`;
      grid.innerHTML = '';
      const startDow = new Date(view.getFullYear(), view.getMonth(), 1).getDay();
      const daysInMonth = new Date(view.getFullYear(), view.getMonth() + 1, 0).getDate();
      for (let i = 0; i < startDow; i++) {
        const blank = document.createElement('div');
        blank.className = 'bk-cal__cell bk-cal__cell--empty';
        grid.appendChild(blank);
      }
      for (let day = 1; day <= daysInMonth; day++) {
        const d = new Date(view.getFullYear(), view.getMonth(), day);
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'bk-cal__day';
        btn.textContent = String(day);
        btn.setAttribute('aria-label', d.toDateString());
        if (past(d) || beyond(d) || closed(d) || slotsFor(d).length === 0) {
          btn.disabled = true;
          btn.classList.add('is-disabled');
        } else {
          btn.addEventListener('click', () => selectDate(d));
        }
        if (selected && iso(d) === iso(selected)) {
          btn.classList.add('is-selected');
          btn.setAttribute('aria-pressed', 'true');
        }
        grid.appendChild(btn);
      }
      applyScope(grid);
      prevBtn.disabled = view.getFullYear() === today.getFullYear() && view.getMonth() === today.getMonth();
      nextBtn.disabled = view.getFullYear() === maxDate.getFullYear() && view.getMonth() === maxDate.getMonth();
    }

    function selectDate(d: Date) {
      selected = d;
      dateInput.value = iso(d);
      renderMonth();
      resetTimeSelection();
      renderSlots(d);
      if (timeHint) timeHint.textContent = `Times for ${d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })}`;
      showStep(2);
    }

    prevBtn.addEventListener('click', () => { view = new Date(view.getFullYear(), view.getMonth() - 1, 1); renderMonth(); });
    nextBtn.addEventListener('click', () => { view = new Date(view.getFullYear(), view.getMonth() + 1, 1); renderMonth(); });

    renderMonth();

    // Wizard navigation: Back/Change-date links go to their target step; the step-2
    // Continue button advances to details (filling the date+time recap first).
    root.querySelectorAll('[data-back-to]').forEach((b) =>
      b.addEventListener('click', () => showStep(Number((b as HTMLElement).dataset.backTo))));
    nextTimeBtn?.addEventListener('click', enterStep3);
    showStep(1, { focus: false, scroll: false }); // normalize state without yanking scroll/focus on load

    // Service lock: pre-select + lock the service when it comes from the URL (?service=)
    // or the SSR `prefill` (per-service booking-calendar pages) — so we don't ask again.
    const select = root.querySelector('select[name="service_interest"]') as HTMLSelectElement | null;
    const fieldWrap = root.querySelector('[data-service-field]') as HTMLElement | null;
    const lockedWrap = root.querySelector('[data-service-locked]') as HTMLElement | null;
    const lockedName = root.querySelector('[data-locked-name]') as HTMLElement | null;
    const changeBtn = root.querySelector('[data-change]') as HTMLButtonElement | null;
    if (select && fieldWrap && lockedWrap) {
      const urlSvc = new URLSearchParams(location.search).get('service');
      const svc = (urlSvc && urlSvc.trim()) || select.dataset.prefill || '';
      if (svc) {
        ensureOption(select, svc);
        select.value = svc;
        if (lockedName) lockedName.textContent = svc;
        lockedWrap.hidden = false;
        fieldWrap.hidden = true;
      }
      changeBtn?.addEventListener('click', () => { lockedWrap.hidden = true; fieldWrap.hidden = false; });
    }

    // Show the "$50 with Dr. Menon" notice when the chosen service is physician-led.
    // The set (injectables / Semaglutide / microneedling) lives in lib/consult so this
    // form and the /consultation form agree on which treatments need the medical consult.
    const feeNote = root.querySelector('[data-fee-note]') as HTMLElement | null;
    function updateFeeNote() {
      if (!feeNote || !select) return;
      feeNote.hidden = !isMedicalConsult(select.value);
    }
    updateFeeNote();

    // ── Multi-package picker (e.g. Laser Hair Removal: choose an area-size tier + area) ──
    // Revealed when the chosen/locked service has package data. The selection is folded
    // into service_interest at submit so the front desk sees the exact area + package.
    const packages: Record<string, any> = JSON.parse(root.dataset.packages || '{}');
    const pkgWrap = root.querySelector('[data-pkg]') as HTMLElement | null;
    const areaSelect = root.querySelector('[data-pkg-area]') as HTMLSelectElement | null;
    const sessionWrap = root.querySelector('[data-pkg-session]') as HTMLElement | null;
    const pkgSummary = root.querySelector('[data-pkg-summary]') as HTMLElement | null;
    const pkgPackageLabel = root.querySelector('[data-pkg-package-label]') as HTMLElement | null;
    const pkgSingleLabel = root.querySelector('[data-pkg-single-label]') as HTMLElement | null;

    const money = (n: string | number) => '$' + Number(n).toLocaleString('en-US');
    const currentPackage = () => (select && packages[select.value]) || null;
    const sessionType = () => {
      const r = sessionWrap?.querySelector('input[name="pkg_session"]:checked') as HTMLInputElement | null;
      return r ? r.value : 'package';
    };
    const selectedArea = () => {
      const o = areaSelect?.selectedOptions[0];
      return o && o.value ? o : null;
    };

    function updatePkgSummary() {
      if (!areaSelect || !sessionWrap || !pkgSummary) return;
      const pkg = currentPackage();
      const o = selectedArea();
      if (!pkg || !o) {
        sessionWrap.hidden = true;
        pkgSummary.textContent = pkg ? 'No problem — we will recommend the right package and confirm pricing at your visit.' : '';
        pkgSummary.hidden = !pkg;
        return;
      }
      sessionWrap.hidden = false;
      const per = o.dataset.persession || '', pkgp = o.dataset.packageprice || '', dur = o.dataset.duration || '', size = o.dataset.size || '';
      if (pkgPackageLabel) pkgPackageLabel.textContent = `${pkg.sessions}-session package — ${money(pkgp)}`;
      if (pkgSingleLabel) pkgSingleLabel.textContent = `Single session — ${money(per)}`;
      const isPkg = sessionType() === 'package';
      pkgSummary.hidden = false;
      pkgSummary.textContent = `${o.dataset.area} · ${size} area · ${dur} — ${isPkg ? `${pkg.sessions}-session package (${money(pkgp)})` : `single session (${money(per)})`}`;
    }

    function renderPackage(preferredSize?: string | null, preferredArea?: string | null) {
      if (!pkgWrap || !areaSelect) return;
      const pkg = currentPackage();
      if (!pkg) { pkgWrap.hidden = true; return; }
      pkgWrap.hidden = false;
      const prev = areaSelect.value;
      areaSelect.innerHTML = '';
      const none = document.createElement('option');
      none.value = '';
      none.textContent = "I'm not sure yet — recommend during my consultation";
      areaSelect.appendChild(none);
      pkg.tiers.forEach((t: any) => {
        const og = document.createElement('optgroup');
        og.label = `${t.label} — ${money(t.perSession)}/session`;
        t.areas.forEach((a: any) => {
          const opt = document.createElement('option');
          opt.value = a.name;
          opt.textContent = a.packagePrice !== t.packagePrice ? `${a.name} (package ${money(a.packagePrice)})` : a.name;
          opt.dataset.area = a.name;
          opt.dataset.size = t.size;
          opt.dataset.persession = String(a.perSession);
          opt.dataset.packageprice = String(a.packagePrice);
          opt.dataset.duration = a.duration;
          og.appendChild(opt);
        });
        areaSelect.appendChild(og);
      });
      // Restore / pre-select: explicit area wins, then a size tier, then the previous pick.
      const opts = Array.from(areaSelect.options);
      let pick = '';
      if (preferredArea && opts.some((o) => o.value === preferredArea)) pick = preferredArea;
      else if (preferredSize) { const m = opts.find((o) => o.dataset.size === preferredSize); if (m) pick = m.value; }
      else if (prev && opts.some((o) => o.value === prev)) pick = prev;
      areaSelect.value = pick;
      updatePkgSummary();
    }

    areaSelect?.addEventListener('change', updatePkgSummary);
    sessionWrap?.querySelectorAll('input[name="pkg_session"]').forEach((r) => r.addEventListener('change', updatePkgSummary));
    select?.addEventListener('change', () => { updateFeeNote(); renderPackage(); });

    // Initial render honours ?size= / ?area= deep links (from the on-page package table).
    const pkgParams = new URLSearchParams(location.search);
    renderPackage(pkgParams.get('size'), pkgParams.get('area'));

    function composeServiceInterest(base: string) {
      const pkg = currentPackage();
      if (!pkg) return base;
      const o = selectedArea();
      if (!o) return `${base} — consultation (area to be advised)`;
      const isPkg = sessionType() === 'package';
      const price = isPkg ? o.dataset.packageprice : o.dataset.persession;
      const label = isPkg ? `${pkg.sessions}-session pkg` : 'single session';
      return `${base} — ${o.dataset.area} (${o.dataset.size} · ${label}, ${money(price || 0)})`;
    }

    enhanceLeadForm(form, {
      successUrl: '/thank-you',
      validate: (data) => {
        if (!data.preferred_date) { showStep(1); return 'Please pick a date on the calendar.'; }
        if (!data.preferred_window) { showStep(2); return 'Please choose a time.'; }
        // Fold the chosen package/area into service_interest so the front desk sees it,
        // then tag physician-led picks so they're booked as the $50 Dr. Menon consult.
        data.service_interest = withConsultTag(composeServiceInterest(data.service_interest || ''));
        return null;
      },
    });
  }

  document.querySelectorAll<HTMLElement>('[data-booking]').forEach(initBooking);
</script>

<style>
  /* Warm-sand "color block" card with a GOLD TOP ACCENT: contains the whole scheduler so it
     reads as one panel, clearly lifted off the white page (the gold bar + stronger shadow keep
     the subtle sand tint from blending in). White inner fields (service box, calendar, slots)
     pop against the tint. Pattern mirrors QuickFacts (sand tint + thin border + radius-md). */
  .bk {
    max-width: 680px; margin: 0 auto;
    background: rgb(196 164 132 / 0.10);
    border: 1px solid rgb(0 0 0 / 0.07);
    border-top: 4px solid var(--color-cta-alt);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.08);
  }
  .bk__form { display: flex; flex-direction: column; gap: var(--space-md); }
  .bk__heading { font-family: var(--font-display); font-size: var(--text-h2); margin: 0; line-height: 1.2; text-align: center; }
  .bk__lead { font-family: var(--font-body); font-size: var(--text-base); opacity: 0.85; margin: 0; text-align: center; }
  .bk__fee-note {
    margin: 0;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    background: rgb(196 164 132 / 0.14);
    border: 1px solid rgb(196 164 132 / 0.45);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--color-text);
  }
  .bk__fee-note[hidden] { display: none; }

  /* min-width:0 overrides the browser-default `min-width: min-content` on <fieldset>,
     which otherwise refuses to shrink below the calendar's intrinsic width and makes
     the page scroll sideways on phones narrower than ~395px. */
  .bk__step { border: none; margin: 0; padding: 0; min-width: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  /* The `hidden` attribute must beat the display rules above (UA display:none is too weak). */
  .bk__step[hidden], .bk__success[hidden], .bk__submit[hidden] { display: none; }
  .bk__step-label { font-family: var(--font-ui); font-size: var(--text-sm); font-weight: var(--weight-bold); display: flex; align-items: center; gap: 10px; padding: 0; }
  .bk__step-label--sub { margin-left: 34px; font-weight: 600; opacity: 0.85; }
  .bk__step-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 24px; height: 24px; border-radius: 50%;
    background: var(--color-cta); color: var(--color-surface);
    font-size: 13px; font-weight: 700; flex: none;
  }

  /* Progress indicator (Date · Time · Details) */
  .bk__progress { display: flex; align-items: center; gap: 8px; list-style: none; margin: 0; padding: 0; }
  .bk__progress-item { display: flex; align-items: center; gap: 8px; flex: 1; font-family: var(--font-ui); font-size: var(--text-xs); opacity: 0.5; }
  .bk__progress-item.is-current { opacity: 1; font-weight: 700; }
  .bk__progress-item.is-done { opacity: 0.85; }
  .bk__progress-dot {
    display: inline-flex; align-items: center; justify-content: center; flex: none;
    width: 28px; height: 28px; border-radius: 50%; border: 2px solid var(--color-cta);
    color: var(--color-accent-ink); font-size: 13px; font-weight: 700;
  }
  .bk__progress-item.is-current .bk__progress-dot,
  .bk__progress-item.is-done .bk__progress-dot { background: var(--color-cta); color: var(--color-surface); }
  .bk__progress-item:not(:last-child)::after { content: ""; flex: 1; height: 2px; background: rgba(0,0,0,0.12); }
  .bk__progress-item.is-done::after { background: var(--color-cta); }

  /* Step bar: back link + chosen-date / recap header */
  .bk__step-bar { display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; }
  .bk__back {
    display: inline-flex; align-items: center; gap: 4px; min-height: 44px; padding: 0 4px;
    background: none; border: none; cursor: pointer; color: var(--color-accent-ink);
    font-family: var(--font-ui); font-size: var(--text-sm); font-weight: 600;
  }
  .bk__chosen-date, .bk__chosen-summary { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; margin: 0; }
  .bk__chosen-date:focus, .bk__chosen-summary:focus { outline: none; }
  .bk__next {
    align-self: flex-start; min-height: 48px; padding: 12px 24px; border: none; border-radius: var(--radius-sm);
    background: var(--color-cta); color: var(--color-surface); box-shadow: var(--shadow-btn);
    font-family: var(--font-cta); font-size: var(--text-base); font-weight: 600; cursor: pointer; transition: opacity 0.2s;
  }
  .bk__next:hover:not(:disabled) { opacity: 0.9; }
  .bk__next:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Calendar */
  .bk-cal { border: 1px solid rgba(0,0,0,0.12); border-radius: var(--radius-sm); padding: var(--space-sm); background: #fff; }
  .bk-cal__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-xs); }
  .bk-cal__month { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; }
  .bk-cal__nav {
    width: 44px; height: 44px; border: 1px solid rgba(0,0,0,0.15); background: #fff;
    border-radius: var(--radius-sm); cursor: pointer; font-size: 20px; line-height: 1; color: var(--color-text);
  }
  .bk-cal__nav:hover:not(:disabled) { border-color: var(--color-cta); color: var(--color-cta); }
  .bk-cal__nav:disabled { opacity: 0.3; cursor: not-allowed; }
  /* minmax(0,1fr), not 1fr: `1fr` = minmax(auto,1fr), whose `auto` floor won't let the
     7 columns shrink below the day cells' intrinsic 44px, overflowing narrow phones.
     minmax(0,1fr) lets the columns shrink to fit (cells stay 44px TALL for tap targets,
     width flexes ~31–44px), so the calendar never forces horizontal scroll. */
  .bk-cal__weekdays, .bk-cal__grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 6px; }
  .bk-cal__weekday { text-align: center; font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; opacity: 0.6; padding: 4px 0; }
  .bk-cal__cell--empty { aspect-ratio: 1; }
  .bk-cal__day {
    aspect-ratio: 1; min-height: 44px; width: 100%; border: 1px solid transparent; background: rgba(0,0,0,0.03);
    border-radius: var(--radius-sm); cursor: pointer; font-family: var(--font-body); font-size: var(--text-base); font-weight: 600;
    color: var(--color-text); transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .bk-cal__day:hover:not(.is-disabled) { border-color: var(--color-cta); }
  .bk-cal__day.is-selected { background: var(--color-accent-ink); color: var(--color-surface); border-color: var(--color-accent-ink); font-weight: 700; box-shadow: 0 0 0 2px var(--color-accent-ink), 0 2px 6px rgb(148 99 46 / 0.5); }
  .bk-cal__day.is-disabled { opacity: 0.32; cursor: not-allowed; text-decoration: line-through; }
  .bk-cal__note { font-family: var(--font-body); font-size: var(--text-xs); opacity: 0.6; margin: var(--space-xs) 0 0; }

  /* Time slots */
  .bk__field[hidden], .bk__locked[hidden] { display: none; }
  .bk__times-note { font-family: var(--font-body); font-size: var(--text-xs); opacity: 0.6; margin: 4px 0 0; }
  /* Time slots: kept compact so the whole time step fits the viewport after picking a date
     (smaller height/padding/font + tighter gaps + slightly narrower columns = more per screen). */
  .bk__slots { display: flex; flex-direction: column; gap: 12px; }
  .bk__slot-group { display: flex; flex-direction: column; gap: 5px; }
  .bk__slot-group-label { font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; opacity: 0.55; text-transform: uppercase; letter-spacing: 0.05em; }
  .bk__slot-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(84px, 1fr)); gap: 8px; }
  .bk__slot {
    position: relative; min-height: 44px; padding: 9px 12px; border: 1px solid rgba(0,0,0,0.18); background: #fff; border-radius: var(--radius-sm);
    cursor: pointer; font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-text);
    transition: background 0.15s, color 0.15s, border-color 0.15s, box-shadow 0.15s;
  }
  .bk__slot:hover { border-color: var(--color-cta); }
  .bk__slot.is-selected {
    background: var(--color-accent-ink); color: var(--color-surface); border-color: var(--color-accent-ink); font-weight: 700;
    box-shadow: 0 0 0 2px var(--color-accent-ink), 0 2px 8px rgb(148 99 46 / 0.55);
  }
  /* Unmistakable "selected" cue: a checkmark in the corner, no layout shift. */
  .bk__slot.is-selected::after { content: "\2713"; position: absolute; top: 3px; right: 7px; font-size: 12px; line-height: 1; font-weight: 700; }

  /* "What are you booking?" header — persistent above the wizard. Holds the service
     dropdown (generic) or the locked chip (?service=). The chip below has its own
     border/background, so suppress the wrapper's box when it's the one showing. */
  .bk__booking-for { display: flex; flex-direction: column; gap: var(--space-xs); padding: var(--space-sm);
    border: 1px solid rgba(0,0,0,0.12); border-radius: var(--radius-sm); background: #fff; }
  .bk__booking-for:has([data-service-locked]:not([hidden])) { border-color: transparent; background: none; padding: 0; }

  /* Service lock */
  .bk__locked {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-sm);
    padding: 12px 14px; border: 1px solid var(--color-cta); border-radius: var(--radius-sm); background: #fff;
  }
  .bk__locked-text { display: flex; flex-direction: column; gap: 1px; }
  .bk__locked-eyebrow { font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; opacity: 0.6; text-transform: uppercase; letter-spacing: 0.05em; }
  .bk__locked-name { font-family: var(--font-display); font-size: var(--text-base); }
  .bk__locked-change {
    flex: none; background: none; border: none; cursor: pointer; color: var(--color-accent-ink);
    font-family: var(--font-ui); font-size: var(--text-sm); font-weight: 600; text-decoration: underline;
  }

  /* Package picker (multi-package services, e.g. Laser Hair Removal) */
  .bk__pkg { display: flex; flex-direction: column; gap: var(--space-sm); }
  .bk__pkg[hidden] { display: none; }
  .bk__pkg-session { display: flex; flex-direction: column; gap: 6px; }
  .bk__pkg-session[hidden] { display: none; }
  .bk__pkg-session-label { font-family: var(--font-body); font-size: var(--text-xs); font-weight: var(--weight-bold); }
  .bk__pkg-toggle { display: flex; gap: 8px; flex-wrap: wrap; }
  .bk__pkg-opt {
    display: flex; align-items: center; gap: 8px; cursor: pointer; min-height: 44px;
    padding: 12px 16px; border: 1px solid rgba(0,0,0,0.18); border-radius: var(--radius-sm); background: #fff;
    font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-text);
    transition: border-color 0.15s, background 0.15s;
  }
  .bk__pkg-opt:hover { border-color: var(--color-cta); }
  .bk__pkg-opt:has(input:checked) { border-color: var(--color-cta); background: rgba(196,164,132,0.1); font-weight: 600; }
  .bk__pkg-opt input { accent-color: var(--color-cta); flex: none; }
  .bk__pkg-summary {
    margin: 0; padding: 10px 14px; border-radius: var(--radius-sm);
    background: rgb(196 164 132 / 0.12); border: 1px solid rgb(196 164 132 / 0.4);
    font-family: var(--font-body); font-size: var(--text-sm); line-height: 1.5; color: var(--color-text);
  }
  .bk__pkg-summary[hidden] { display: none; }

  /* Fields */
  .bk__row { display: flex; gap: var(--space-sm); }
  .bk__row .bk__field { flex: 1; }
  .bk__field { display: flex; flex-direction: column; gap: 4px; }
  .bk__field label { font-family: var(--font-body); font-size: var(--text-xs); font-weight: var(--weight-bold); }
  .bk__field label span[aria-hidden] { color: var(--color-cta); }
  .bk__optional { font-weight: 400; opacity: 0.6; }
  .bk__field input, .bk__field select, .bk__field textarea {
    padding: 12px 14px; border: 1px solid rgba(0,0,0,0.2); border-radius: var(--radius-sm);
    font-family: var(--font-body); font-size: var(--text-base); width: 100%; box-sizing: border-box; background: #fff; color: var(--color-text);
  }
  .bk__field input:focus, .bk__field select:focus, .bk__field textarea:focus { outline: none; border-color: var(--color-cta); }
  .bk__field textarea { resize: vertical; }
  .bk__hint { font-family: var(--font-body); font-size: var(--text-xs); opacity: 0.65; margin: 0; }
  .bk__hint--warn { opacity: 0.8; color: #8a5a00; }

  .bk__consent { display: flex; gap: 8px; align-items: flex-start; font-family: var(--font-body); font-size: var(--text-xs); opacity: 0.85; line-height: 1.4; }
  .bk__consent input { margin-top: 2px; flex: none; }

  .bk__hp { position: absolute; left: 0; width: 1px; height: 1px; overflow: hidden; opacity: 0; pointer-events: none; }

  .bk__error {
    font-family: var(--font-body); font-size: var(--text-sm); color: #b00020;
    background: rgba(176,0,32,0.07); border: 1px solid rgba(176,0,32,0.2); border-radius: var(--radius-sm); padding: 10px 12px; margin: 0;
  }
  .bk__submit {
    background: var(--color-cta); color: var(--color-surface); border: none; border-radius: var(--radius-sm);
    box-shadow: var(--shadow-btn); padding: 14px 24px; font-family: var(--font-cta); font-size: var(--text-base);
    font-weight: 600; cursor: pointer; transition: opacity 0.2s;
  }
  .bk__submit:hover:not(:disabled) { opacity: 0.9; }
  .bk__submit:disabled { opacity: 0.6; cursor: progress; }
  .bk__fallback { font-family: var(--font-body); font-size: var(--text-sm); text-align: center; margin: 0; opacity: 0.8; }
  .bk__fallback a { color: var(--color-accent-ink); font-weight: 600; }

  .bk__success { text-align: center; display: flex; flex-direction: column; gap: var(--space-sm); align-items: center; padding: var(--space-lg) 0; }
  .bk__success-icon {
    width: 56px; height: 56px; border-radius: 50%; background: var(--color-cta); color: var(--color-surface);
    display: flex; align-items: center; justify-content: center; font-size: 28px;
  }
  .bk__success p { font-family: var(--font-body); font-size: var(--text-base); margin: 0; opacity: 0.9; }

  @media (max-width: 520px) {
    .bk__row { flex-direction: column; }
    /* Compact progress on phones: dots + connectors only, hide the text labels. */
    .bk__progress-text { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0; overflow: hidden; clip: rect(0 0 0 0); clip-path: inset(50%); white-space: nowrap; border: 0; }
    /* Condense the scheduler card so more fits the mobile viewport (tap targets stay 44px). */
    .bk { padding: var(--space-sm); }
    .bk__form { gap: var(--space-sm); }
    .bk__heading { font-size: var(--text-h3); }
    .bk-cal { padding: var(--space-xs); }
    .bk-cal__weekdays, .bk-cal__grid { gap: 4px; }
  }
</style>
