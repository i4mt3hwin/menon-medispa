---
/**
 * PackageTable.astro — the on-page pricing grid for a multi-package service.
 *
 * Renders the area-size tiers from data/service-packages.json (via lib/packages):
 * one card per tier (Small / Medium / Large / XLarge) showing the 6-session
 * package price, per-session price, duration, and the treatment areas in that
 * tier. Each tier has a "Request this package" CTA that deep-links the booking
 * form with the service + size pre-selected (the form's area picker takes over).
 *
 * Usage:  <PackageTable slug="laser-hair-removal" heading="Laser Hair Removal Packages" />
 */
import site from '@/lib/site';
import { getPackagesBySlug, usd } from '@/lib/packages';

interface Props {
  slug: string;
  heading?: string;
}
const { slug, heading } = Astro.props as Props;
const pkg = getPackagesBySlug(slug);

const bookHref = (size?: string) => {
  const params = new URLSearchParams({ service: pkg!.service });
  if (size) params.set('size', size);
  return `${site.calcomUrl}?${params.toString()}`;
};
---
{pkg && (
  <section class="pkgtable section section--tint">
    <div class="container">
      {heading && <h2 class="pkgtable__heading">{heading}</h2>}
      <p class="pkgtable__plan">Every package is a series of <strong>{pkg.plan}</strong>. Single sessions available at the per-session rate.</p>

      <div class="pkgtable__grid">
        {pkg.tiers.map((tier) => (
          <article class="pkgtable__tier">
            <header class="pkgtable__tier-head">
              <h3 class="pkgtable__tier-name">{tier.label}</h3>
              <p class="pkgtable__tier-meta">{tier.duration} per session &middot; {usd(tier.perSession)}/session</p>
              <p class="pkgtable__tier-price">
                <span class="pkgtable__tier-amt">{usd(tier.packagePrice)}</span>
                <span class="pkgtable__tier-unit">{pkg.sessions}-session package</span>
              </p>
            </header>

            <ul class="pkgtable__areas">
              {tier.areas.map((a) => (
                <li class="pkgtable__area">
                  <span class="pkgtable__area-name">{a.name}</span>
                  {a.packagePrice !== tier.packagePrice && (
                    <span class="pkgtable__area-note">{usd(a.packagePrice)}/{pkg.sessions}</span>
                  )}
                </li>
              ))}
            </ul>

            <a class="btn btn--secondary btn--sm pkgtable__cta" href={bookHref(tier.size)}>Request {tier.label}</a>
          </article>
        ))}
      </div>

      {pkg.note && <p class="pkgtable__note">{pkg.note} Call <a href={site.phone.tel}>{site.phone.display}</a> for a personalized quote.</p>}
    </div>
  </section>
)}

<style>
  .pkgtable__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    text-align: center;
    margin: 0 0 var(--space-xs);
    text-wrap: balance;
  }
  .pkgtable__plan {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    opacity: 0.85;
    text-align: center;
    margin: 0 auto var(--space-lg);
    max-width: 640px;
    line-height: 1.6;
  }

  .pkgtable__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  .pkgtable__tier {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid rgb(0 0 0 / 0.08);
    border-radius: var(--radius-md);
    box-shadow: 0 14px 36px rgb(27 21 34 / 0.10);
    overflow: hidden;
  }

  .pkgtable__tier-head {
    padding: var(--space-md);
    border-bottom: 1px solid rgb(0 0 0 / 0.07);
    background: rgb(196 164 132 / 0.08);
  }
  .pkgtable__tier-name {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0;
    line-height: 1.15;
  }
  .pkgtable__tier-meta {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
    color: var(--color-text);
    opacity: 0.7;
    margin: 4px 0 0;
  }
  .pkgtable__tier-price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin: var(--space-sm) 0 0;
  }
  .pkgtable__tier-amt {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: var(--weight-bold);
    color: var(--color-text);
    line-height: 1;
  }
  .pkgtable__tier-unit {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.7;
  }

  .pkgtable__areas {
    list-style: none;
    margin: 0;
    padding: var(--space-sm) var(--space-md);
    flex: 1;
  }
  .pkgtable__area {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-sm);
    padding: 7px 0;
    border-bottom: 1px solid rgb(0 0 0 / 0.06);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
  }
  .pkgtable__area:last-child { border-bottom: none; }
  .pkgtable__area-note {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-cta);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pkgtable__cta {
    align-self: stretch;        /* fill the card width minus the side margins (no width:100% overflow) */
    margin: 0 var(--space-md) var(--space-md);
    box-sizing: border-box;
    text-align: center;
  }

  .pkgtable__note {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.75;
    text-align: center;
    margin: var(--space-lg) auto 0;
    max-width: 640px;
    line-height: 1.6;
  }
  .pkgtable__note a { color: inherit; font-weight: 600; }
</style>
