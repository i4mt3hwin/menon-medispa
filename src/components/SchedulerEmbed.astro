---
/**
 * SchedulerEmbed.astro — renders the self-hosted BookingRequest form.
 *
 * Previously wrapped a Cal.com embed; Cal.com was dropped in favour of the
 * internal /request-appointment flow (calendar form -> /api/lead -> D1 +
 * front-desk email). Kept as a thin wrapper so its one consumer
 * (BookingCalendarTemplate) needs no structural change.
 *
 * Props:
 *   heading  — section heading
 *   prefill  — service name to pre-select in the booking form
 */
import BookingRequest from './BookingRequest.astro';

interface Props {
  heading?: string;
  prefill?: string;
  /** @deprecated retained for backward compatibility; no longer used. */
  service_slug?: string;
  /** @deprecated retained for backward compatibility; no longer used. */
  variant?: 'inline' | 'link';
}

const { heading, prefill } = Astro.props as Props;
---

<section class="scheduler-embed">
  <div class="scheduler-embed__inner">
    <BookingRequest heading={heading ?? 'Book an Appointment'} prefill={prefill} />
  </div>
</section>

<style>
  .scheduler-embed { padding: var(--space-xl) var(--space-md); }
  .scheduler-embed__inner { max-width: 900px; margin: 0 auto; }
</style>
