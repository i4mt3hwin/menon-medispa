---
/**
 * TreatmentCard.astro, overlay-label card for the pillar (category) grids.
 * Full-bleed image fills the card; the treatment name sits on a soft bottom
 * gradient scrim with an optional one-line descriptor and an "Explore" cue.
 * The whole card is the link. Hover gently zooms the image and nudges the cue.
 *
 * Used by /face, /body, /hair treatment grids. Reuses the design-system tokens
 * (--scrim-rgb, --radius-sm) from base.css; owns its scoped styles.
 *
 * Props:
 *   name, treatment name (required, rendered as the card heading)
 *   href, link target (required); whole card is an <a>
 *   img, imported image (ImageMetadata) for the card photo (required)
 *   alt, image alt text (required)
 *   descriptor, optional short one-liner under the name
 *   ratio, optional aspect-ratio override (default "4 / 5")
 */
interface Props {
  name: string;
  href: string;
  img: ImageMetadata;
  alt: string;
  descriptor?: string;
  ratio?: string;
}

const { name, href, img, alt, descriptor, ratio = '4 / 5' } = Astro.props;
const external = href.startsWith('http');
---

<a
  href={href}
  class="tcard"
  style={`--tcard-ratio: ${ratio};`}
  aria-label={name}
  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
  <div class="tcard__media">
    <img
      src={img.src}
      alt={alt}
      class="tcard__img"
      width={img.width}
      height={img.height}
      loading="lazy"
      decoding="async"
    />
  </div>
  <span class="tcard__scrim" aria-hidden="true"></span>

  <div class="tcard__body">
    <h3 class="tcard__name">{name}</h3>
    {descriptor && <p class="tcard__desc">{descriptor}</p>}
    <span class="tcard__cue">Explore <span class="tcard__arrow" aria-hidden="true">&rarr;</span></span>
  </div>
</a>

<style>
  .tcard {
    position: relative;
    display: block;
    aspect-ratio: var(--tcard-ratio, 4 / 5);
    overflow: hidden;
    border-radius: var(--radius-sm);
    text-decoration: none;
    isolation: isolate;
    box-shadow: 0 4px 18px rgb(0 0 0 / 0.10);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .tcard:hover { box-shadow: 0 12px 34px rgb(0 0 0 / 0.22); }

  .tcard__media { position: absolute; inset: 0; z-index: 0; }
  .tcard__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .tcard:hover .tcard__img, .tcard:focus-visible .tcard__img { transform: scale(1.06); }

  .tcard__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to top,
      rgb(var(--scrim-rgb) / 0.86) 0%,
      rgb(var(--scrim-rgb) / 0.55) 30%,
      rgb(var(--scrim-rgb) / 0.12) 58%,
      rgb(var(--scrim-rgb) / 0) 100%
    );
  }

  .tcard__body {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--space-md);
    color: #fff;
  }

  .tcard__name {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    line-height: 1.15;
    margin: 0;
    text-wrap: balance;
    text-shadow: 0 1px 14px rgb(0 0 0 / 0.4);
  }

  .tcard__desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.45;
    margin: 0;
    opacity: 0.92;
    text-shadow: 0 1px 10px rgb(0 0 0 / 0.45);
  }

  .tcard__cue {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
    font-family: var(--font-cta);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-cta);
  }
  .tcard__arrow {
    display: inline-block;
    transition: transform 0.3s ease;
  }
  .tcard:hover .tcard__arrow, .tcard:focus-visible .tcard__arrow { transform: translateX(5px); }

  .tcard:focus-visible {
    outline: 2px solid var(--color-cta);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tcard__img, .tcard__arrow { transition: none; }
  }
</style>
