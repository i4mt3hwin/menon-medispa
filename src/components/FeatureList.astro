---
// Phase 3 Pass 1, FeatureList.astro
// Styled <ul> with icon bullets. Renders ALL items, zero summarization.
// items: string[] | {text:string}[] | {title:string,body?:string}[]

type FeatureItem = string | { text?: string; title?: string; body?: string };

interface Props {
  items: FeatureItem[];
  icon?: 'check' | 'dot' | 'star';
  color?: string;
  font_size?: string;
  columns?: 1 | 2;
  layout?: 'vertical' | 'horizontal';
}

const {
  items = [],
  icon = 'check',
  color,
  font_size,
  columns = 1,
  layout,
} = Astro.props;

// Map icon key to CSS content value (set as data attr, applied via CSS var)
const iconChar: Record<string, string> = {
  check: '✓',
  dot: '●',
  star: '★',
};
const bulletChar = iconChar[icon] ?? '✓';

// Normalise each item to an HTML string
function itemToHtml(item: FeatureItem): string {
  if (typeof item === 'string') return item;
  if (item.title && item.body) return `<strong>${item.title}</strong>, ${item.body}`;
  if (item.title) return item.title;
  if (item.text) return item.text;
  return '';
}
---

<ul
  class={`feature-list feature-list--cols-${columns}`}
  style={[
    color ? `--fl-color: ${color};` : '',
    font_size ? `--fl-size: ${font_size};` : '',
  ].filter(Boolean).join(' ') || undefined}
>
  {items.map((item) => (
    <li class="feature-list__item" data-bullet={bulletChar}>
      <span class="feature-list__text" set:html={itemToHtml(item)} />
    </li>
  ))}
</ul>

<style>
  .feature-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
    --fl-color: var(--color-text);
    --fl-size: var(--text-base);
  }

  .feature-list--cols-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .feature-list--cols-1 {
    grid-template-columns: 1fr;
  }

  .feature-list__item {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--fl-size);
    color: var(--fl-color);
    line-height: 1.5;
  }

  /* Bullet via ::before using the data-bullet attr value */
  .feature-list__item::before {
    content: attr(data-bullet);
    flex-shrink: 0;
    color: var(--color-cta);
    font-size: 0.9em;
    line-height: 1.6;
  }

  .feature-list__text {
    flex: 1;
  }

  /* Tablet + phone: collapse 2-col to 1 */
  @media (max-width: 600px) {
    .feature-list--cols-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
