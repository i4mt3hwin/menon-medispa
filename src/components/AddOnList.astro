---
/**
 * AddOnList.astro, compact "popular add-ons" list for the service sidebar.
 *
 * Reuses the add-on visual language (thumbnail + name + gold price) from the
 * existing full-width grids, as condensed rows for the narrow sidebar.
 * Renders nothing when `items` is empty. On pages that keep their full add-on
 * band, pass `seeAllHref="#add-ons"` to link down instead of re-listing all.
 */
import type { ImageMetadata } from 'astro';

interface AddOn {
  name: string;
  price?: string;
  img?: ImageMetadata;
  alt?: string;
}
interface Props {
  heading?: string;
  items?: AddOn[];
  seeAllHref?: string;
}
const { heading = 'Popular add-ons', items = [], seeAllHref } = Astro.props;
---
{items.length > 0 && (
  <div class="addon-list">
    <p class="addon-list__heading">{heading}</p>
    <ul class="addon-list__items">
      {items.map((a) => (
        <li class="addon-list__item">
          {a.img && (
            <span class="addon-list__thumb">
              <img src={a.img.src} alt={a.alt ?? a.name} loading="lazy" decoding="async" width="48" height="48" />
            </span>
          )}
          <span class="addon-list__name">{a.name}</span>
          {a.price && <span class="addon-list__price">{a.price}</span>}
        </li>
      ))}
    </ul>
    {seeAllHref && (
      <a href={seeAllHref} class="addon-list__more">See all add-ons</a>
    )}
  </div>
)}

<style>
  .addon-list {
    border: 1px solid rgb(0 0 0 / 0.08);
    border-radius: var(--radius-md);
    padding: var(--space-md);
  }
  .addon-list__heading {
    font-family: var(--font-display);
    font-size: var(--text-subheading);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    line-height: 1.2;
  }
  .addon-list__items { list-style: none; margin: 0; padding: 0; }
  .addon-list__item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px 0;
    border-bottom: 1px solid rgb(0 0 0 / 0.06);
  }
  .addon-list__item:last-child { border-bottom: none; padding-bottom: 0; }
  .addon-list__item:first-child { padding-top: 0; }
  .addon-list__thumb {
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .addon-list__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .addon-list__name {
    flex: 1;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.3;
  }
  .addon-list__price {
    flex: 0 0 auto;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-accent-ink);
  }
  .addon-list__more {
    display: inline-block;
    margin-top: var(--space-sm);
    font-family: var(--font-cta);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-cta);
    text-underline-offset: 3px;
  }
  .addon-list__more:hover { color: var(--color-cta); }
</style>
