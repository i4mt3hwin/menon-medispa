---
// Phase 3 Pass 1, ServicesGrid.astro
// Grid of service cards. Discovered from home/sections/06.json (Popular Treatments, 3 cards)
// and home/sections/05.json (Monthly Specials, 3 cards). Both use this component.

import ServiceCard from './ServiceCard.astro';
import type { ImageMetadata } from 'astro';

interface ServiceItem {
  title: string;
  href: string;
  image_src?: string | ImageMetadata; // imported Astro asset or generated/public URL
  image_alt?: string;
  description_html?: string;
  features?: string[];       // icon-list items, render ALL
  cta_text?: string;
}

interface Props {
  heading?: string;
  heading_tag?: 'h2' | 'h3';
  items: ServiceItem[];
  columns?: 2 | 3 | 4;
  bg_color?: string;
}

const {
  heading,
  heading_tag = 'h2',
  items = [],
  columns = 3,
  bg_color,
} = Astro.props;

const HeadingTag = heading_tag;
---

<section
  class="services-grid section"
  style={bg_color ? `background-color: ${bg_color};` : ''}
>
  <div class="container">
    {heading && (
      <HeadingTag class="services-grid__heading">{heading}</HeadingTag>
    )}

    <div class={`services-grid__items services-grid--cols-${columns}`}>
      {items.map((item) => (
        <ServiceCard
          title={item.title}
          href={item.href}
          image_src={item.image_src}
          image_alt={item.image_alt}
          description_html={item.description_html}
          features={item.features}
          cta_text={item.cta_text}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 400;
    color: var(--color-text);
    text-align: center;
    margin: 0 0 var(--space-md);
    line-height: 1.25;
    text-wrap: balance;
  }

  .services-grid__items {
    display: grid;
    gap: var(--space-md);
  }

  .services-grid--cols-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .services-grid--cols-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .services-grid--cols-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  /* Tablet: 3→2, 4→2 */
  @media (max-width: 1024px) {
    .services-grid--cols-3 {
      grid-template-columns: repeat(2, 1fr);
    }

    .services-grid--cols-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Phone: all collapse to 1 column */
  @media (max-width: 600px) {
    .services-grid--cols-2,
    .services-grid--cols-3,
    .services-grid--cols-4 {
      grid-template-columns: 1fr;
    }
  }
</style>
