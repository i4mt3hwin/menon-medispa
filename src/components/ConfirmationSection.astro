---
/**
 * ConfirmationSection.astro, thank-you / confirmation section.
 * Used on /thank-you after form submission or booking.
 * Centered layout: heading + message HTML + CTA button.
 *
 * Props:
 *   heading, main heading (default: "Thank You!")
 *   message_html, body content rendered with set:html
 *   cta_text, CTA button label (default: "Return Home")
 *   cta_href, CTA destination (default: "/")
 */
interface Props {
  heading?: string;
  message_html?: string;
  cta_text?: string;
  cta_href?: string;
}

const {
  heading = 'Thank You!',
  message_html,
  cta_text = 'Return Home',
  cta_href = '/',
} = Astro.props;
---

<section class="confirmation">
  <div class="confirmation__inner">

    <!-- Checkmark icon -->
    <div class="confirmation__icon" aria-hidden="true">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="28" cy="28" r="28" fill="var(--color-cta)" fill-opacity="0.12"/>
        <path d="M16 28L24 36L40 20" stroke="var(--color-cta)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <h1 class="confirmation__heading">{heading}</h1>

    {message_html ? (
      <div class="confirmation__message" set:html={message_html} />
    ) : (
      <p class="confirmation__message">
        We have received your submission and will be in touch shortly.
      </p>
    )}

    <a href={cta_href} class="confirmation__btn">
      {cta_text}
    </a>

  </div>
</section>

<style>
  .confirmation {
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .confirmation__inner {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }
  .confirmation__icon {
    margin-bottom: 8px;
  }
  .confirmation__heading {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    margin: 0;
    line-height: 1.15;
  }
  .confirmation__message {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.75;
    margin: 0;
    opacity: 0.82;
  }
  /* Allow rich message_html to inherit typography */
  .confirmation__message p {
    margin: 0 0 12px;
  }
  .confirmation__message p:last-child {
    margin-bottom: 0;
  }
  .confirmation__btn {
    display: inline-block;
    background-color: var(--color-cta);
    color: var(--color-surface);
    font-family: var(--font-cta);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 14px 40px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    letter-spacing: 0.04em;
    margin-top: 8px;
    transition: opacity 0.2s;
  }
  .confirmation__btn:hover {
    opacity: 0.86;
  }

  @media (max-width: 980px) {
    .confirmation__heading { font-size: 32px; }
  }
</style>
