---
interface FaqItem {
  question: string;
  answer_html: string;
}
interface Props {
  heading?: string;
  items: FaqItem[];
  bg_color?: string;
}
const { heading, items = [], bg_color } = Astro.props;
---
<section class="faq-accordion section" style={bg_color ? `background-color: ${bg_color};` : ''}>
  <div class="container container--narrow">
    {heading && <h2 class="faq-accordion__heading">{heading}</h2>}
    <div class="faq-accordion__list">
      {items.map((item) => (
        <details class="faq-accordion__item">
          <summary class="faq-accordion__question">
            <span class="faq-accordion__question-text">{item.question}</span>
            <span class="faq-accordion__icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-accordion__answer" set:html={item.answer_html} />
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-accordion__heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    text-align: center;
    color: var(--color-text);
    margin: 0 0 var(--space-md);
    text-wrap: balance;
  }

  .faq-accordion__list {
    /* Contained by .container--narrow */
  }

  .faq-accordion__item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
  }

  .faq-accordion__item:first-of-type {
    border-top: 1px solid rgba(0, 0, 0, 0.12);
  }

  .faq-accordion__question {
    cursor: pointer;
    padding: var(--space-sm) 0;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
  }

  .faq-accordion__question::-webkit-details-marker {
    display: none;
  }

  .faq-accordion__question-text {
    flex: 1;
  }

  .faq-accordion__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    position: relative;
    transition: transform 0.2s ease;
  }

  .faq-accordion__icon::before, .faq-accordion__icon::after {
    content: '';
    position: absolute;
    background-color: var(--color-cta);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  /* horizontal bar */
  .faq-accordion__icon::before {
    width: 14px;
    height: 2px;
    top: 50%;
    left: 3px;
    transform: translateY(-50%);
  }

  /* vertical bar */
  .faq-accordion__icon::after {
    width: 2px;
    height: 14px;
    top: 3px;
    left: 50%;
    transform: translateX(-50%);
  }

  details[open] .faq-accordion__icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  .faq-accordion__answer {
    padding: 0 0 var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.7;
  }

  .faq-accordion__answer p {
    margin: 0 0 0.75em;
  }

  .faq-accordion__answer p:last-child {
    margin-bottom: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-accordion__icon, .faq-accordion__icon::before, .faq-accordion__icon::after {
      transition: none;
    }
  }
</style>
