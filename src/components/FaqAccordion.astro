---
/**
 * FaqAccordion.astro — Generated by path-2-rebuild/02-synthesize (scaffold stub).
 * Token-driven faithful stub: correct prop shape + styling hooks wired to the
 * @theme tokens (see 03-design/design-tokens.md). The first Phase 3 subagent to
 * render this pattern completes it with VERBATIM captured content. Do NOT put
 * page-specific content here.
 */
interface Props {
  heading?: string;
  items: Array<{ q: string; a: string }>;
  class?: string;
}
const { heading, items = [] } = Astro.props;
---

<section class="faq">
  {heading && <h2>{heading}</h2>}
  {items.map((it) => (
    <details class="faq__item">
      <summary>{it.q}</summary>
      <div set:html={it.a} />
    </details>
  ))}
</section>

<style>
  .faq { padding: var(--spacing-section) 1.5rem; max-width: var(--container-content); margin: 0 auto; font-family: var(--font-ui); }
  .faq__item { border-bottom: 1px solid var(--color-border); padding: var(--spacing-gap-sm) 0; }
  .faq__item summary { font-weight: 700; cursor: pointer; }
</style>
