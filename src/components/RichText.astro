---
interface Props {
  html?: string;
  font?: string;
  size?: string;
  color?: string;
  max_width?: string;
  class?: string;
}
const {
  html,
  font      = 'var(--font-body)',
  size      = 'var(--text-base)',
  color     = 'var(--color-text)',
  max_width,
  class: className = '',
} = Astro.props;

const inlineStyle = [
  `font-family: ${font}`,
  `font-size: ${size}`,
  `color: ${color}`,
  max_width ? `max-width: ${max_width}` : '',
].filter(Boolean).join('; ');
---
{html ? (
  <div class={`rich-text ${className}`} style={inlineStyle} set:html={html} />
) : (
  <div class={`rich-text ${className}`} style={inlineStyle}><slot /></div>
)}

<style>
  .rich-text {
    line-height: 1.7;
  }
  .rich-text h1 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    margin: 0 0 0.5em;
  }
  .rich-text h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    margin: 0 0 0.5em;
  }
  .rich-text h3 {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    margin: 0 0 0.5em;
  }
  .rich-text p {
    margin: 0 0 1em;
  }
  .rich-text p:last-child {
    margin-bottom: 0;
  }
  .rich-text ul,
  .rich-text ol {
    padding-left: 1.5em;
    margin: 0 0 1em;
  }
  .rich-text li + li {
    margin-top: 0.25em;
  }
  .rich-text a {
    color: inherit;
    text-underline-offset: 2px;
  }
  .rich-text strong,
  .rich-text b {
    font-weight: 700;
  }
  .rich-text em,
  .rich-text i {
    font-style: italic;
  }
  .rich-text img {
    max-width: 100%;
    height: auto;
    display: block;
  }
</style>
