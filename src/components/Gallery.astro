---
// Phase 3 Pass 1, Gallery.astro
// Multi-image responsive grid for service and about pages.

interface GalleryImage {
  src: string | { src: string; width?: number; height?: number };  // string URL or Astro ImageMetadata
  alt: string;
  width?: number;
  height?: number;
}

interface Props {
  images: GalleryImage[];
  columns?: 2 | 3 | 4;
  aspect?: 'square' | 'portrait' | 'landscape' | 'auto';
  gap?: string;
}

const {
  images = [],
  columns = 3,
  aspect = 'square',
  gap = 'var(--space-sm)',
} = Astro.props;

// Aspect ratios mapped to CSS values
const aspectMap: Record<string, string> = {
  square: '1 / 1',
  portrait: '3 / 4',
  landscape: '4 / 3',
  auto: 'auto',
};
const aspectRatio = aspectMap[aspect] ?? '1 / 1';
---

<div
  class={`gallery gallery--cols-${columns} gallery--aspect-${aspect}`}
  style={`--gallery-gap: ${gap}; --gallery-aspect: ${aspectRatio};`}
>
  {images.map((img) => {
    const isObj = img.src !== null && typeof img.src === 'object';
    const resolvedSrc = isObj ? (img.src as { src: string }).src : (img.src as string);
    const resolvedWidth = img.width ?? (isObj ? (img.src as { width?: number }).width : undefined);
    const resolvedHeight = img.height ?? (isObj ? (img.src as { height?: number }).height : undefined);
    return (
      <figure class="gallery__item">
        <img
          src={resolvedSrc}
          alt={img.alt}
          width={resolvedWidth}
          height={resolvedHeight}
          class="gallery__img"
          loading="lazy"
          decoding="async"
        />
      </figure>
    );
  })}
</div>

<style>
  .gallery {
    display: grid;
    gap: var(--gallery-gap, var(--space-sm));
  }

  /* Column counts */
  .gallery--cols-2 { grid-template-columns: repeat(2, 1fr); }
  .gallery--cols-3 { grid-template-columns: repeat(3, 1fr); }
  .gallery--cols-4 { grid-template-columns: repeat(4, 1fr); }

  .gallery__item {
    margin: 0;
    padding: 0;
    overflow: hidden;
    border-radius: var(--radius-sm);
    /* Respect the aspect prop unless 'auto' */
    aspect-ratio: var(--gallery-aspect, auto);
  }

  .gallery__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius-sm);
    /* height: 100% only matters when parent has a fixed aspect-ratio */
  }

  /* auto aspect: let image determine height */
  .gallery--aspect-auto .gallery__item {
    aspect-ratio: auto;
    height: auto;
  }

  .gallery--aspect-auto .gallery__img {
    height: auto;
  }

  /* Tablet (1024→601): 3-col→2-col, 4-col→2-col */
  @media (max-width: 1024px) {
    .gallery--cols-3, .gallery--cols-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Phone (≤600px): 2-col stays 2-col (small gallery), 3/4→1-col */
  @media (max-width: 600px) {
    .gallery--cols-3, .gallery--cols-4 {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 420px) {
    .gallery--cols-2, .gallery--cols-3.gallery--cols-4 {
      grid-template-columns: 1fr;
    }
  }
</style>
