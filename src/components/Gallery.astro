interface Props {
  heading?: string;
  images: Array<{ src: string; alt: string }>;
  columns?: number;
  class?: string;
}
const { heading, images = [], columns = 3 } = Astro.props;
---

<section class="gallery">
  {heading && <h2>{heading}</h2>}
