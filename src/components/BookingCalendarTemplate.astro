---
/**
 * BookingCalendarTemplate.astro — layout for /booking-calendar/[slug] pages.
 * Replaces Wix Bookings with a Cal.com SchedulerEmbed (link variant until
 * real Cal.com event URLs are set in site.ts calcomUrl).
 *
 * Props:
 *   service_title  — display name of the service
 *   service_slug   — slug (used for cal.com event-type deep-link)
 *   category       — optional category badge
 *   description    — optional short description / tagLine
 *   duration_note  — e.g. "60 minutes"
 *   price_note     — e.g. "Starting at $150"
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SchedulerEmbed from './SchedulerEmbed.astro';
import site from '../lib/site';

interface Props {
  service_title: string;
  service_slug: string;
  category?: string;
  description?: string;
  duration_note?: string;
  price_note?: string;
}

const {
  service_title,
  service_slug,
  category,
  description,
  duration_note,
  price_note,
} = Astro.props;
---

<BaseLayout title={`Book: ${service_title} | Menon Medispa`}>
  <article class="booking-page">

    <!-- Page header -->
    <header class="booking-page__header">
      <div class="booking-page__header-inner">
        {category && (
          <span class="booking-page__badge">{category}</span>
        )}
        <h1 class="booking-page__title">Book: {service_title}</h1>
        {description && (
          <p class="booking-page__desc">{description}</p>
        )}
        {(duration_note || price_note) && (
          <div class="booking-page__meta">
            {duration_note && (
              <span class="booking-page__meta-item">
                <strong>Duration:</strong> {duration_note}
              </span>
            )}
            {price_note && (
              <span class="booking-page__meta-item">
                <strong>Price:</strong> {price_note}
              </span>
            )}
          </div>
        )}
      </div>
    </header>

    <!-- Scheduling embed / CTA -->
    <SchedulerEmbed
      heading={`Schedule Your ${service_title}`}
      service_slug={service_slug}
      variant="link"
    />

    <!-- Phone fallback -->
    <section class="booking-page__fallback">
      <p class="booking-page__fallback-text">
        Prefer to call?
        <a href={site.phone.tel} class="booking-page__phone">{site.phone.display}</a>
      </p>
      <p class="booking-page__fallback-text">
        Or <a href="/contact" class="booking-page__contact-link">send us a message</a>.
      </p>
    </section>

  </article>
</BaseLayout>

<style>
  /* Header */
  .booking-page__header {
    background-color: var(--color-surface-dark);
    color: var(--color-surface);
    padding: var(--space-xl) var(--space-md) var(--space-lg);
  }
  .booking-page__header-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .booking-page__badge {
    display: inline-block;
    font-family: var(--font-cta);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-cta);
  }
  .booking-page__title {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    margin: 0;
    line-height: 1.2;
  }
  .booking-page__desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    margin: 0;
    opacity: 0.85;
    line-height: 1.6;
  }
  .booking-page__meta {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    opacity: 0.8;
  }
  .booking-page__meta-item {
    display: inline-block;
  }

  /* Fallback contact */
  .booking-page__fallback {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
    background-color: rgba(196,164,132,0.07);
  }
  .booking-page__fallback-text {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    margin: 4px 0;
    opacity: 0.8;
  }
  .booking-page__phone,
  .booking-page__contact-link {
    color: var(--color-cta);
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .booking-page__title { font-size: 30px; }
  }
</style>
