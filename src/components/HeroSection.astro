---
/**
 * HeroSection.astro — Generated by path-2-rebuild/02-synthesize (scaffold stub).
 * Token-driven faithful stub: correct prop shape + styling hooks wired to the
 * @theme tokens (see 03-design/design-tokens.md). The first Phase 3 subagent to
 * render this pattern completes it with VERBATIM captured content. Do NOT put
 * page-specific content here.
 */
interface Props {
  heading: string;
  heading_tag?: "h1" | "h2";
  subheading?: string;
  body?: string[];
  image?: { src: string; alt: string };
  ctas?: Array<{ text: string; href: string; variant?: string }>;
  background?: string;
  text_color?: string;
  layout?: "centered" | "split-left" | "split-right" | "stacked";
  class?: string;
}
const { heading, heading_tag = "h1", subheading, body = [], image, ctas = [], background, text_color, layout = "centered" } = Astro.props;
---

<section class={`hero hero--${layout}`} style={background ? `background:${background}` : undefined}>
  <div class="hero__inner">
    {heading_tag === "h1" ? <h1>{heading}</h1> : <h2>{heading}</h2>}
    {subheading && <p class="hero__sub">{subheading}</p>}
    {body.map((p) => <p>{p}</p>)}
  </div>
</section>

<style>
  .hero { padding: var(--spacing-section-lg) 1.5rem; }
  .hero__inner { max-width: var(--container-content); margin: 0 auto; text-align: center; }
  .hero__sub { font-family: var(--font-body); font-size: var(--text-lg); }
</style>
