---
interface Props {
  heading?: string;
  eyebrow?: string;
  subheading?: string;  // alias for eyebrow
  body?: string;
  ctas?: Array<{ text: string; href: string; variant?: 'primary' | 'secondary' }>;
  bg_video_url?: string;
  bg_image_url?: string;
  bg_image_alt?: string;
  backgroundImage?: string | { src: string };  // alias for bg_image_url, accepts import objects
  backgroundAlt?: string;                       // alias for bg_image_alt
  sideImage?: string;                           // optional side image (ignored layout-wise, kept for compat)
  social_proof?: Array<{ image_key: string; alt: string }>;
  stars_text?: string;
  review_count_text?: string;
  height?: string;
  layout?: 'left-overlay' | 'centered' | 'split';
}

const {
  heading,
  eyebrow,
  subheading,
  body,
  ctas = [],
  bg_video_url,
  bg_image_url,
  bg_image_alt,
  backgroundImage,
  backgroundAlt,
  social_proof = [],
  stars_text,
  review_count_text,
  height = '599px',
  layout = 'left-overlay',
} = Astro.props;

// Normalise background image: backgroundImage prop aliases bg_image_url, handles import objects
const rawBgImg = bg_image_url ?? backgroundImage;
const resolvedBgImageUrl = rawBgImg
  ? (typeof rawBgImg === 'object' ? (rawBgImg as { src: string }).src : rawBgImg)
  : undefined;
const resolvedBgImageAlt = bg_image_alt ?? backgroundAlt ?? '';

// Resolve heading/eyebrow: prop wins, slot fallback used in template
const resolvedHeading = heading;
const resolvedEyebrow = eyebrow ?? subheading;

// Check if named slots are provided (Astro.slots.has returns true at runtime)
const hasSlotHeading = Astro.slots.has('heading');
const hasSlotEyebrow = Astro.slots.has('eyebrow');
const hasSlotBody    = Astro.slots.has('body');
const hasSlotCta     = Astro.slots.has('cta');
const hasSlotImage   = Astro.slots.has('image');
const hasSlotSocialProof = Astro.slots.has('social-proof');
const hasSlotAside   = Astro.slots.has('aside');
const hasDefaultSlot = Astro.slots.has('default');
---

<section
  class={`hero hero--${layout}`}
  style={`--hero-height: ${height};`}
  aria-label="Hero"
>
  {/* Background layer */}
  {bg_video_url && (
    <video
      class="hero__bg-video"
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
      poster={resolvedBgImageUrl ?? undefined}
    >
      <source src={bg_video_url} type="video/mp4" />
    </video>
  )}
  {!bg_video_url && resolvedBgImageUrl && (
    <img
      class="hero__bg-image"
      src={resolvedBgImageUrl}
      alt={resolvedBgImageAlt}
      aria-hidden={resolvedBgImageAlt === '' ? 'true' : undefined}
      loading="eager"
    />
  )}

  {/* If a default slot is provided WITHOUT a heading prop AND without named heading slot → freeform layout */}
  {hasDefaultSlot && !hasSlotHeading && !resolvedHeading ? (
    <div class="hero__content hero__content--freeform">
      <slot />
      {hasSlotAside && <div class="hero__aside"><slot name="aside" /></div>}
    </div>
  ) : (
    <div class="hero__content">
      {/* Eyebrow */}
      {hasSlotEyebrow ? (
        <p class="hero__eyebrow"><slot name="eyebrow" /></p>
      ) : resolvedEyebrow ? (
        <p class="hero__eyebrow">{resolvedEyebrow}</p>
      ) : null}

      {/* Heading — h1 */}
      {hasSlotHeading ? (
        <h1 class="hero__heading"><slot name="heading" /></h1>
      ) : resolvedHeading ? (
        <h1 class="hero__heading">{resolvedHeading}</h1>
      ) : null}

      {/* Body */}
      {hasSlotBody ? (
        <div class="hero__body"><slot name="body" /></div>
      ) : body ? (
        <p class="hero__body">{body}</p>
      ) : null}

      {/* CTA slot OR ctas prop */}
      {hasSlotCta ? (
        <div class="hero__ctas"><slot name="cta" /></div>
      ) : ctas.length > 0 ? (
        <div class="hero__ctas">
          {ctas.map((cta) => (
            <a
              href={cta.href}
              class={`hero__cta hero__cta--${cta.variant ?? 'primary'}`}
            >
              {cta.text}
            </a>
          ))}
        </div>
      ) : null}

      {/* Social proof — slot or props */}
      {hasSlotSocialProof ? (
        <div class="hero__social-proof"><slot name="social-proof" /></div>
      ) : (social_proof.length > 0 || stars_text || review_count_text) ? (
        <div class="hero__social-proof">
          {social_proof.length > 0 && (
            <div class="hero__proof-avatars">
              {social_proof.map((item) => (
                <img
                  class="hero__proof-avatar"
                  src={`/images/${item.image_key}.png`}
                  alt={item.alt}
                  width="50"
                  height="50"
                  loading="lazy"
                />
              ))}
            </div>
          )}
          <div class="hero__proof-text">
            {stars_text && <p class="hero__stars">{stars_text}</p>}
            {review_count_text && <p class="hero__review-count">{review_count_text}</p>}
          </div>
        </div>
      ) : null}

      {/* Default slot content (e.g. Button + social proof passed as direct children alongside heading prop) */}
      {hasDefaultSlot && !hasSlotCta && ctas.length === 0 && (
        <div class="hero__ctas"><slot /></div>
      )}

      {/* Side image slot */}
      {hasSlotImage && <div class="hero__image-col"><slot name="image" /></div>}
      {hasSlotAside  && <div class="hero__aside"><slot name="aside" /></div>}
    </div>
  )}
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: var(--hero-height, 599px);
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* Background media — fills entire section */
  .hero__bg-video,
  .hero__bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
    z-index: 0;
  }

  /* Dark scrim over hero background for contrast — gradient left-heavy for left-overlay layout */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.52) 0%,
      rgba(0, 0, 0, 0.32) 55%,
      rgba(0, 0, 0, 0.10) 100%
    );
    pointer-events: none;
  }

  /* Content block sits on top of background */
  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 620px;
  }

  /* left-overlay: text block pushed to the left, matching Wix bbox x=261 */
  .hero--left-overlay .hero__content {
    margin-left: clamp(var(--space-md), 18%, 261px);
    margin-right: auto;
  }

  /* centered: content block centered */
  .hero--centered .hero__content {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
    align-items: center;
  }

  /* split: content in left half */
  .hero--split .hero__content {
    margin-left: var(--space-lg);
    margin-right: auto;
    width: 50%;
  }

  /* Eyebrow — lato-light, 18px, matches Wix H1 used as label */
  .hero__eyebrow {
    font-family: var(--font-ui);
    font-size: 18px;
    font-weight: var(--weight-regular);
    color: #FFFFFF;
    margin: 0;
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0,0,0,0.55);
  }

  /* Main heading — raleway, hero size 38px */
  .hero__heading {
    font-family: var(--font-body);
    font-size: var(--text-hero);
    font-weight: var(--weight-regular);
    color: #FFFFFF;
    margin: 0;
    line-height: 1.25;
    text-shadow: 0 2px 8px rgba(0,0,0,0.55);
  }

  /* Body paragraph */
  .hero__body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    color: rgba(255,255,255,0.92);
    line-height: 1.5;
    margin: 0;
    max-width: 440px;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  /* CTA row */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .hero__cta {
    display: inline-block;
    padding: 8px 16px;
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: var(--weight-regular);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: opacity 0.2s;
    min-width: 200px;
    text-align: center;
  }

  .hero__cta:hover {
    opacity: 0.88;
  }

  .hero__cta--primary {
    background-color: var(--color-cta);
    color: var(--color-text);
    box-shadow: var(--shadow-btn);
  }

  .hero__cta--secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-cta);
  }

  /* Social proof row */
  .hero__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .hero__proof-avatars {
    display: flex;
    align-items: center;
    gap: -8px; /* intentional negative gap for overlapping circles */
  }

  /* Circular avatar overlap effect */
  .hero__proof-avatars .hero__proof-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-surface);
    margin-left: -8px;
  }

  .hero__proof-avatars .hero__proof-avatar:first-child {
    margin-left: 0;
  }

  .hero__proof-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero__stars {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: #FFFFFF;
    margin: 0;
    line-height: 1;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  .hero__review-count {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: var(--weight-regular);
    color: rgba(255,255,255,0.9);
    margin: 0;
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  /* Mobile */
  @media (max-width: 980px) {
    .hero {
      height: auto;
      min-height: var(--hero-height, 599px);
      padding: var(--space-md) var(--space-sm);
      align-items: flex-start;
    }

    .hero__bg-video,
    .hero__bg-image {
      width: 100%;
      height: 100%;
    }

    .hero--left-overlay .hero__content,
    .hero--split .hero__content {
      margin-left: 0;
      margin-right: 0;
      max-width: 100%;
      width: 100%;
    }

    .hero__body {
      max-width: 100%;
    }
  }
</style>
