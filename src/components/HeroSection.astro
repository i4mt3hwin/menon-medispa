---
interface Props {
  heading?: string;
  eyebrow?: string;
  subheading?: string;  // alias for eyebrow
  body?: string;
  ctas?: Array<{ text: string; href: string; variant?: 'primary' | 'secondary' }>;
  bg_video_url?: string;
  bg_image_url?: string;
  bg_image_alt?: string;
  backgroundImage?: string | { src: string };  // alias for bg_image_url, accepts import objects
  backgroundAlt?: string;                       // alias for bg_image_alt
  sideImage?: string;                           // optional side image (ignored layout-wise, kept for compat)
  social_proof?: Array<{ image_key: string; alt: string }>;
  stars_text?: string;
  review_count_text?: string;
  height?: string;
  layout?: 'left-overlay' | 'centered' | 'split';
}

const {
  heading,
  eyebrow,
  subheading,
  body,
  ctas = [],
  bg_video_url,
  bg_image_url,
  bg_image_alt,
  backgroundImage,
  backgroundAlt,
  social_proof = [],
  stars_text,
  review_count_text,
  height = '599px',
  layout = 'left-overlay',
} = Astro.props;

// Normalise background image: backgroundImage prop aliases bg_image_url, handles import objects
const rawBgImg = bg_image_url ?? backgroundImage;
const resolvedBgImageUrl = rawBgImg
  ? (typeof rawBgImg === 'object' ? (rawBgImg as { src: string }).src : rawBgImg)
  : undefined;
const resolvedBgImageAlt = bg_image_alt ?? backgroundAlt ?? '';

// Resolve heading/eyebrow: prop wins, slot fallback used in template
const resolvedHeading = heading;
const resolvedEyebrow = eyebrow ?? subheading;

// Check if named slots are provided (Astro.slots.has returns true at runtime)
const hasSlotHeading = Astro.slots.has('heading');
const hasSlotEyebrow = Astro.slots.has('eyebrow');
const hasSlotBody    = Astro.slots.has('body');
const hasSlotCta     = Astro.slots.has('cta');
const hasSlotImage   = Astro.slots.has('image');
const hasSlotSocialProof = Astro.slots.has('social-proof');
const hasSlotAside   = Astro.slots.has('aside');
const hasDefaultSlot = Astro.slots.has('default');
---

<section
  class={`hero hero--${layout}`}
  style={`--hero-height: ${height};`}
  aria-label="Hero"
>
  {/* Background layer */}
  {bg_video_url && (
    <video
      class="hero__bg-video"
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
      poster={resolvedBgImageUrl ?? undefined}
    >
      <source src={bg_video_url} type="video/mp4" />
    </video>
  )}
  {!bg_video_url && resolvedBgImageUrl && (
    <img
      class="hero__bg-image"
      src={resolvedBgImageUrl}
      alt={resolvedBgImageAlt}
      aria-hidden={resolvedBgImageAlt === '' ? 'true' : undefined}
      loading="eager"
    />
  )}

  {/* If a default slot is provided WITHOUT a heading prop AND without named heading slot → freeform layout */}
  {hasDefaultSlot && !hasSlotHeading && !resolvedHeading ? (
    <div class="hero__content hero__content--freeform">
      <slot />
      {hasSlotAside && <div class="hero__aside"><slot name="aside" /></div>}
    </div>
  ) : (
    <div class="hero__content">
      {/* Eyebrow */}
      {hasSlotEyebrow ? (
        <p class="hero__eyebrow"><slot name="eyebrow" /></p>
      ) : resolvedEyebrow ? (
        <p class="hero__eyebrow">{resolvedEyebrow}</p>
      ) : null}

      {/* Heading, h1 */}
      {hasSlotHeading ? (
        <h1 class="hero__heading"><slot name="heading" /></h1>
      ) : resolvedHeading ? (
        <h1 class="hero__heading">{resolvedHeading}</h1>
      ) : null}

      {/* Body */}
      {hasSlotBody ? (
        <div class="hero__body"><slot name="body" /></div>
      ) : body ? (
        <p class="hero__body">{body}</p>
      ) : null}

      {/* CTA slot OR ctas prop */}
      {hasSlotCta ? (
        <div class="hero__ctas"><slot name="cta" /></div>
      ) : ctas.length > 0 ? (
        <div class="hero__ctas">
          {ctas.map((cta) => (
            <a
              href={cta.href}
              class={`hero__cta hero__cta--${cta.variant ?? 'primary'}`}
            >
              {cta.text}
            </a>
          ))}
        </div>
      ) : null}

      {/* Social proof, slot or props */}
      {hasSlotSocialProof ? (
        <div class="hero__social-proof"><slot name="social-proof" /></div>
      ) : (social_proof.length > 0 || stars_text || review_count_text) ? (
        <div class="hero__social-proof">
          {social_proof.length > 0 && (
            <div class="hero__proof-avatars">
              {social_proof.map((item) => (
                <img
                  class="hero__proof-avatar"
                  src={`/images/${item.image_key}.png`}
                  alt={item.alt}
                  width="50"
                  height="50"
                  loading="lazy"
                />
              ))}
            </div>
          )}
          <div class="hero__proof-text">
            {stars_text && <p class="hero__stars">{stars_text}</p>}
            {review_count_text && <p class="hero__review-count">{review_count_text}</p>}
          </div>
        </div>
      ) : null}

      {/* Default slot content (e.g. Button + social proof passed as direct children alongside heading prop) */}
      {hasDefaultSlot && !hasSlotCta && ctas.length === 0 && (
        <div class="hero__ctas"><slot /></div>
      )}

      {/* Side image slot */}
      {hasSlotImage && <div class="hero__image-col"><slot name="image" /></div>}
      {hasSlotAside  && <div class="hero__aside"><slot name="aside" /></div>}
    </div>
  )}

  <div class="hero__scroll-cue" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: min(var(--hero-height, 560px), 86vh);
    overflow: hidden;
    isolation: isolate;
    display: flex;
    align-items: center;
    padding-block: var(--space-xl);
  }

  /* Background media, fills section. A light blur + the dark scrim below keep the
     foreground text readable while staying much sharper than the old 3px blur. */
  .hero__bg-video, .hero__bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
    z-index: 0;
    filter: blur(2px);
    transform: scale(1.04);   /* slight overscan hides the blurred edges + Ken Burns start */
  }

  /* Scrim for contrast, left-weighted (text sits left); centered layout uses an even scrim */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to right,
      rgb(var(--scrim-rgb) / 0.84) 0%,
      rgb(var(--scrim-rgb) / 0.58) 50%,
      rgb(var(--scrim-rgb) / 0.30) 100%
    );
  }
  .hero--centered::after {
    background:
      radial-gradient(135% 110% at 50% 38%, rgb(var(--scrim-rgb) / 0.12) 0%, rgb(var(--scrim-rgb) / 0.70) 100%),
      linear-gradient(to top, rgb(var(--scrim-rgb) / 0.62) 0%, rgb(var(--scrim-rgb) / 0.26) 45%, rgb(var(--scrim-rgb) / 0.42) 100%);
  }

  /* Content = page container; text aligned to the left gutter → no empty middle */
  .hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: flex-start;
  }
  /* Keep the readable text column a comfortable measure within the full-width row */
  .hero__content > :where(.hero__eyebrow, .hero__heading.hero__body) {
    max-width: 640px;
  }

  .hero--centered {
    min-height: 60vh;
    padding-block: var(--space-md);
  }
  .hero--centered .hero__content {
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    max-width: 880px;
  }
  .hero--centered .hero__content > * { margin-inline: auto; }

  /* Eyebrow, refined gold kicker (breaks the all-white monotone) */
  .hero__eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-regular);
    color: #FFFFFF;
    margin: 0;
    line-height: 1.4;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.85), 0 1px 3px rgba(0, 0, 0, 0.6);
  }
  /* Centered: flank the kicker with thin gold rules */
  .hero--centered .hero__eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }
  .hero--centered .hero__eyebrow::before, .hero--centered .hero__eyebrow::after {
    content: "";
    width: 40px;
    height: 1px;
    background: var(--color-cta);
    opacity: 0.85;
  }

  /* Main heading, elegant Playfair serif, cinematic scale */
  .hero__heading {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.6vw, 3.7rem);
    font-weight: 400;
    color: #FFFFFF;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }

  /* Body paragraph */
  .hero__body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    color: rgba(255, 255, 255, 0.94);
    line-height: 1.55;
    margin: 0;
    max-width: 520px;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.42);
  }

  /* CTA row */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    font-family: var(--font-cta);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    transition: opacity 0.2s, transform 0.12s;
  }
  .hero__cta:hover { opacity: 0.92; }
  .hero__cta:active { transform: translateY(1px); }

  .hero__cta--primary {
    background-color: var(--color-cta);
    color: var(--color-text);
    box-shadow: var(--shadow-btn);
  }
  .hero__cta--secondary {
    background-color: rgba(255, 255, 255, 0.08);
    color: #FFFFFF;
    border-color: rgba(255, 255, 255, 0.75);
  }

  /* Social proof row */
  .hero__social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .hero__proof-avatars {
    display: flex;
    align-items: center;
  }

  .hero__proof-avatars .hero__proof-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #FFFFFF;
    margin-left: -8px;
  }
  .hero__proof-avatars .hero__proof-avatar:first-child { margin-left: 0; }

  .hero__proof-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero__stars {
    font-family: var(--font-body);
    font-size: 1.35rem;
    letter-spacing: 2px;
    color: var(--color-star);
    margin: 0;
    line-height: 1;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
  }

  .hero__review-count {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--weight-regular);
    color: rgba(255, 255, 255, 0.92);
    margin: 0;
    line-height: 1.3;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
  }

  /* Tablet / mobile */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-block: var(--space-xl);
      align-items: center;
    }
    .hero__content > :where(.hero__eyebrow, .hero__heading.hero__body), .hero__body {
      max-width: 100%;
    }
    .hero__ctas {
      width: 100%;
      max-width: 360px;
    }
    .hero__cta { flex: 1 1 auto; }
    .hero--centered .hero__social-proof { flex-direction: column; }
  }

  /* Scroll cue, only on the cinematic centered hero */
  .hero__scroll-cue { display: none; }
  .hero--centered .hero__scroll-cue {
    display: block;
    position: absolute;
    bottom: 26px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    width: 24px;
    height: 38px;
    border: 2px solid rgba(255, 255, 255, 0.7);
    border-radius: 13px;
  }
  .hero--centered .hero__scroll-cue::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 8px;
    width: 3px;
    height: 8px;
    border-radius: 2px;
    background: #fff;
    transform: translateX(-50%);
    animation: hero-scroll 1.7s ease-in-out infinite;
  }
  @keyframes hero-scroll {
    0%   { opacity: 0; transform: translate(-50%, 0); }
    35%  { opacity: 1; }
    100% { opacity: 0; transform: translate(-50%, 12px); }
  }
  @media (max-width: 768px) {
    .hero--centered .hero__scroll-cue { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero--centered .hero__scroll-cue::after { animation: none; }
  }

  /* ── Motion: a slow Ken Burns drift on the media + staggered entrance ── */
  .hero__bg-image, .hero__bg-video {
    animation: hero-kenburns 24s ease-in-out infinite alternate;
  }
  @keyframes hero-kenburns {
    from { transform: scale(1.06); }
    to   { transform: scale(1.16); }
  }

  .hero__content > * {
    opacity: 0;
    animation: hero-rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }
  .hero__content > *:nth-child(1) { animation-delay: 0.05s; }
  .hero__content > *:nth-child(2) { animation-delay: 0.15s; }
  .hero__content > *:nth-child(3) { animation-delay: 0.25s; }
  .hero__content > *:nth-child(4) { animation-delay: 0.35s; }
  .hero__content > *:nth-child(5) { animation-delay: 0.45s; }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__bg-image, .hero__bg-video { animation: none; }
    .hero__content > * { opacity: 1; animation: none; }
  }
</style>
