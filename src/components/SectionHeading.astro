---
interface Props {
  text?: string;
  tag?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  subtext?: string;
  align?: 'left' | 'center' | 'right';
  font?: 'display' | 'body' | 'ui';
  size?: 'xl' | 'lg' | 'md' | 'sm';
  color?: string;
}

const {
  text,
  tag,
  level,
  subtext,
  align = 'center',
  font,
  size,
  color,
} = Astro.props;

// Derive tag from level when tag isn't explicitly given; fall back to h2
const Tag = (tag ?? (level ? `h${level}` : 'h2')) as 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
// resolved tag string for font/size logic (normalise to h1/h2/h3 for maps)
const resolvedTag = tag ?? (level ? `h${level}` : 'h2');

// Font family resolution
// Rule: h1/h2 default to --font-display; h3+ defaults to --font-body
// Explicit font prop overrides the default
const resolvedFont =
  font === 'display'
    ? 'var(--font-display)'
    : font === 'body'
      ? 'var(--font-body)'
      : font === 'ui'
        ? 'var(--font-ui)'
        : resolvedTag === 'h3' || resolvedTag === 'h4' || resolvedTag === 'h5' || resolvedTag === 'h6'
          ? 'var(--font-body)'
          : 'var(--font-display)';

// Size resolution maps size prop to token, then falls back to tag-based size
const sizeMap: Record<string, string> = {
  xl: 'var(--text-h1)',
  lg: 'var(--text-h2)',
  md: 'var(--text-h3)',
  sm: 'var(--text-sm)',
};

const tagSizeMap: Record<string, string> = {
  h1: 'var(--text-h1)',
  h2: 'var(--text-h2)',
  h3: 'var(--text-h3)',
  h4: 'var(--text-sm)',
  h5: 'var(--text-sm)',
  h6: 'var(--text-sm)',
};

const resolvedSize = size ? (sizeMap[size] ?? tagSizeMap[resolvedTag]) : tagSizeMap[resolvedTag];

const headingStyle = [
  `font-family: ${resolvedFont}`,
  `font-size: ${resolvedSize}`,
  color ? `color: ${color}` : 'color: var(--color-text)',
].join('; ');
---

<div class="section-heading" style={`text-align: ${align};`}>
  <Tag class="section-heading__text" style={headingStyle}>
    {text ?? <slot />}
  </Tag>

  {subtext && (
    <p
      class="section-heading__subtext"
      style={`color: ${color ?? 'var(--color-text)'};`}
    >
      {subtext}
    </p>
  )}
</div>

<style>
  .section-heading {
    width: 100%;
    box-sizing: border-box;
  }

  .section-heading__text {
    margin: 0;
    font-weight: var(--weight-bold);
    line-height: 1.2;
  }

  .section-heading__subtext {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    line-height: 1.6;
    margin: var(--space-sm) 0 0;
  }

  @media (max-width: 980px) {
    .section-heading__text {
      line-height: 1.3;
    }
  }
</style>
