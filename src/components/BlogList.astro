---
/**
 * BlogList.astro, blog index page component.
 * Renders a grid of post cards. Each card links to /post/{slug}.
 *
 * Props:
 *   posts, array of post summaries (see interface below)
 *   heading, optional section heading (default: "Blog")
 */
interface Post {
  slug: string;
  title: string;
  excerpt?: string;
  date?: string;
  featured_image?: string;
  category?: string;
  categorySlug?: string;
}

interface Props {
  posts: Post[];
  heading?: string;
}

const { posts = [], heading = 'Blog' } = Astro.props;

// Truncate excerpt to 150 chars for index card display
function truncate(str: string | undefined, max: number): string {
  if (!str) return '';
  if (str.length <= max) return str;
  return str.slice(0, max).replace(/\s+\S*$/, '') + '...';
}
---

<section class="blog-list section">
  <div class="container">
    {heading && (
      <h1 class="blog-list__heading">{heading}</h1>
    )}

    {posts.length === 0 ? (
      <p class="blog-list__empty">No posts found.</p>
    ) : (
      <div class="blog-list__grid">
        {posts.map((post) => (
          <article class="blog-list__card">
            {post.featured_image && (
              <a href={`/post/${post.slug}`} class="blog-list__img-link" tabindex="-1" aria-hidden="true">
                <img
                  src={post.featured_image}
                  alt={post.title}
                  class="blog-list__img"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}
            <div class="blog-list__body">
              {post.category && (
                post.categorySlug
                  ? <a href={`/blog/${post.categorySlug}`} class="blog-list__category blog-list__category--link">{post.category}</a>
                  : <span class="blog-list__category">{post.category}</span>
              )}
              <h2 class="blog-list__title">
                <a href={`/post/${post.slug}`} class="blog-list__title-link">{post.title}</a>
              </h2>
              {post.date && (
                <time class="blog-list__date" datetime={post.date}>{post.date}</time>
              )}
              {post.excerpt && (
                <p class="blog-list__excerpt">{truncate(post.excerpt, 150)}</p>
              )}
              <a href={`/post/${post.slug}`} class="blog-list__readmore" aria-label={`Read more: ${post.title}`}>
                Read More
              </a>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .blog-list__heading {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    text-align: center;
    margin-bottom: var(--space-lg);
    text-wrap: balance;
  }

  .blog-list__empty {
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-base);
    opacity: 0.6;
  }

  /* Desktop: 3 columns */
  .blog-list__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .blog-list__card {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.22s ease, transform 0.22s ease;
  }

  .blog-list__card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    transform: translateY(-2px);
  }

  .blog-list__img-link {
    display: block;
    overflow: hidden;
  }

  .blog-list__img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease, opacity 0.2s;
  }

  .blog-list__img-link:hover .blog-list__img {
    transform: scale(1.04);
    opacity: 0.92;
  }

  .blog-list__body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .blog-list__category {
    font-family: var(--font-cta);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-ink);
  }
  .blog-list__category--link { text-decoration: none; }
  .blog-list__category--link:hover { text-decoration: underline; }

  .blog-list__title {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.25;
    margin: 0;
    text-wrap: balance;
  }

  .blog-list__title-link {
    color: var(--color-text);
    text-decoration: none;
  }

  .blog-list__title-link:hover {
    color: var(--color-cta);
  }

  .blog-list__date {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    opacity: 0.55;
  }

  .blog-list__excerpt {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .blog-list__readmore {
    display: inline-block;
    margin-top: 4px;
    font-family: var(--font-cta);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent-ink);
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .blog-list__readmore:hover {
    text-decoration: underline;
  }

  /* Tablet: 2 columns */
  @media (max-width: 1024px) {
    .blog-list__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Phone: 1 column */
  @media (max-width: 600px) {
    .blog-list__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-list__card, .blog-list__img {
      transition: none;
    }
    .blog-list__card:hover {
      transform: none;
    }
    .blog-list__img-link:hover .blog-list__img {
      transform: none;
    }
  }
</style>
