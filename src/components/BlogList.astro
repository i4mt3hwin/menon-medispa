---
/**
 * BlogList.astro — Generated by path-2-rebuild/02-synthesize (scaffold stub).
 * Token-driven faithful stub: correct prop shape + styling hooks wired to the
 * @theme tokens (see 03-design/design-tokens.md). The first Phase 3 subagent to
 * render this pattern completes it with VERBATIM captured content. Do NOT put
 * page-specific content here.
 */
interface Props {
  heading?: string;
  posts: Array<{ title: string; excerpt?: string; href: string; image?: { src: string; alt: string }; date?: string }>;
  class?: string;
}
const { heading, posts = [] } = Astro.props;
---

<section class="blog-list">
  {heading && <h1>{heading}</h1>}
  <div class="blog-list__grid">
    {posts.map((p) => (
      <article class="blog-list__card">
        {p.image && <a href={p.href}><img src={p.image.src} alt={p.image.alt} loading="lazy" /></a>}
        <h2><a href={p.href}>{p.title}</a></h2>
        {p.date && <p class="blog-list__date">{p.date}</p>}
        {p.excerpt && <p>{p.excerpt}</p>}
      </article>
    ))}
  </div>
</section>

<style>
  .blog-list { max-width: var(--container-max); margin: 0 auto; padding: var(--spacing-section) 1.5rem; }
  .blog-list__grid { display: grid; gap: var(--spacing-gap-lg); grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
  .blog-list__card img { width: 100%; height: auto; border-radius: var(--radius-md); }
  .blog-list__card h2 { font-family: var(--font-display); font-size: var(--text-2xl); }
  .blog-list__date { font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-text-muted); }
</style>
