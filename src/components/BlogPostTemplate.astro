---
/**
 * BlogPostTemplate.astro, the unified blog post layout.
 *
 * Mirrors the redesigned service pages: editorial hero → two-column body
 * (ServiceLayout: prose main + sticky conversion sidebar) → testimonial → CTA
 * band → mobile CTA bar. The article body is slotted into ServiceLayout's main
 * column, so it inherits the shared `.service-article__main` prose vocabulary
 * (h2/h3/p/ul/li/figure/a) with no per-post styling.
 *
 * SEO: passes description + OG image + article type + BlogPosting/Breadcrumb
 * JSON-LD through to BaseLayout.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceLayout from '@/components/ServiceLayout.astro';
import ArticleHero from '@/components/ArticleHero.astro';
import ArticleSidebar from '@/components/ArticleSidebar.astro';
import ServiceTestimonial from '@/components/ServiceTestimonial.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import site from '@/lib/site';
import type { PostCard } from '@/lib/blog';

interface Props {
  title: string;
  seoTitle?: string;
  slug: string;
  description: string;
  date: string;          // formatted
  readTime: number;
  coverImage?: string;
  content_html: string;
  topicLabel: string;
  topicSlug: string;
  serviceSlug: string;
  serviceLabel: string;
  reviewTag: string;
  related: PostCard[];
  jsonld: Record<string, unknown>[];
}
const {
  title, seoTitle, slug, description, date, readTime, coverImage, content_html,
  topicLabel, topicSlug, serviceSlug, serviceLabel, reviewTag, related, jsonld,
} = Astro.props;
---

<BaseLayout
  title={`${seoTitle ?? title} | Menon Medispa`}
  description={description}
  canonical={`${site.url}/post/${slug}`}
  ogImage={coverImage}
  ogType="article"
  jsonld={jsonld}
>
  <ArticleHero
    title={title}
    categoryLabel={topicLabel}
    categorySlug={topicSlug}
    date={date}
    readTime={readTime}
    image={coverImage}
    imageAlt={title}
  />

  <ServiceLayout>
    <div class="blog-body" set:html={content_html} />
    <ArticleSidebar
      slot="aside"
      categoryLabel={topicLabel}
      date={date}
      readTime={readTime}
      serviceSlug={serviceSlug}
      serviceLabel={serviceLabel}
      related={related}
    />
  </ServiceLayout>

  {related.length > 0 && (
    <div class="post-more">
      <RelatedPosts heading={`More in ${topicLabel}`} posts={related} layout="band" />
    </div>
  )}

  <ServiceTestimonial slug={reviewTag} />

  <CtaBanner
    heading="Ready to book your visit?"
    subtext="Our team in Millburn will help you find the right treatment for your goals."
    cta_text="Request an Appointment"
    cta_href={site.calcomUrl}
    bg_image_url={coverImage}
  />

  <MobileCtaBar ctaLabel="Book Online" />
</BaseLayout>

<style>
  /* The "More in <topic>" band duplicates the sticky rail's related list, so it is
     for mobile only (where the rail's extras are hidden). Hidden on desktop. */
  .post-more { display: none; }
  @media (max-width: 900px) {
    .post-more { display: block; }
  }
</style>

<!-- Blog-body extras the shared prose vocabulary doesn't cover (lead paragraph,
     blockquote, captioned figures). Global because the body is injected via set:html. -->
<style is:global>
  .service-article__main .blog-body > p:first-of-type {
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--color-text);
  }
  .service-article__main .blog-body blockquote {
    border-left: 3px solid var(--color-cta);
    padding-left: var(--space-md);
    margin: var(--space-md) 0;
    font-style: italic;
    opacity: 0.9;
  }
  .service-article__main .blog-body figure.post-figure {
    margin: var(--space-md) 0;
  }
  .service-article__main .blog-body figure.post-figure img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    display: block;
  }
  .service-article__main .blog-body figcaption {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.7;
    margin-top: var(--space-xs);
  }
</style>
