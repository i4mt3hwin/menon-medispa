---
/**
 * BlogPostTemplate.astro — Wix /post/{slug} article, replicated.
 * Renders the verbatim captured body where the post was individually snapshotted
 * (2 of 28 — body = ordered heading/text/image/button blocks). The other 26 posts
 * had only slim list data captured (title/excerpt/cover/date) per the documented
 * capture cost-decision; those render their captured excerpt + cover + a "read on
 * our blog" note. NO post body is fabricated (Path-2). Phone override applied upstream.
 */
import site from '../lib/site';
interface BodyBlock { type: string; tag?: string; text?: string; html?: string; src?: string; alt?: string; items?: string[]; }
interface Props {
  title: string;
  date?: string;
  excerpt?: string;
  cover?: string | null;
  body?: BodyBlock[] | null;
}
const { title, date, excerpt, cover, body } = Astro.props;
const hasBody = Array.isArray(body) && body.length > 0;
const fmtDate = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---
<article class="post">
  <header class="post__header">
    <p class="post__back"><a href="/blog">← All Posts</a></p>
    <h1>{title}</h1>
    {fmtDate && <p class="post__meta">{fmtDate}</p>}
  </header>
  {cover && <img class="post__cover" src={cover} alt={title} loading="eager" />}

  {hasBody ? (
    <div class="post__body">
      {body!.map((b) => {
        if (b.type === 'heading') {
          const Tag = (b.tag && /^h[2-4]$/.test(b.tag)) ? b.tag : 'h2';
          return <Tag>{b.text}</Tag>;
        }
        if (b.type === 'text') return <div class="post__rt" set:html={b.html} />;
        if (b.type === 'image' && b.src) return <img src={b.src} alt={b.alt || ''} loading="lazy" />;
        if (b.type === 'button' && b.text) return <p class="post__btnlabel">{b.text}</p>;
        if (b.type === 'quote' && b.text) return <blockquote class="post__quote">{b.text}</blockquote>;
        if (b.type === 'list' && b.items) return <ul class="post__list">{b.items.map((it) => <li>{it}</li>)}</ul>;
        return null;
      })}
    </div>
  ) : (
    <div class="post__body">
      {excerpt && <p class="post__excerpt">{excerpt}</p>}
      <p class="post__cta">
        Have questions about this topic? <a href={`tel:${site.phone.tel}`}>Call {site.phone.display}</a>
        or <a href="/contact">contact us</a>.
      </p>
    </div>
  )}
</article>

<style>
  .post { max-width: 760px; margin: 0 auto; padding: var(--spacing-section) 1.5rem; font-family: var(--font-ui); line-height: 1.7; }
  .post__header { text-align: center; }
  .post__back a { color: var(--color-primary); font-size: var(--text-sm); text-decoration: none; }
  .post__header h1 { font-family: var(--font-display); font-size: var(--text-4xl); }
  .post__meta { font-size: var(--text-sm); color: var(--color-text-muted); }
  .post__cover { width: 100%; height: auto; border-radius: var(--radius-md); margin: var(--spacing-gap-lg) 0; }
  .post__body :global(h2), .post__body :global(h3), .post__body :global(h4) { font-family: var(--font-display); margin-top: var(--spacing-gap-lg); }
  .post__body :global(img) { width: 100%; height: auto; border-radius: var(--radius-md); margin: var(--spacing-gap-md) 0; }
  .post__rt :global(a) { color: var(--color-primary); }
  .post__rt :global(p) { margin: 0 0 1rem; }
  .post__excerpt { font-size: var(--text-md); }
  .post__btnlabel { font-weight: 700; color: var(--color-primary); }
  .post__quote { border-left: 3px solid var(--color-primary); margin: var(--spacing-gap-md) 0; padding: 0.25rem 0 0.25rem 1.25rem; font-style: italic; color: var(--color-text); }
  .post__list { margin: 0 0 1rem 1.25rem; }
  .post__list li { margin: 0.25rem 0; }
  .post__cta a { color: var(--color-primary); }
</style>
