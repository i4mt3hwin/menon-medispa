---
/**
 * BlogPostTemplate.astro — template for /post/[slug] pages.
 * Full post content rendered verbatim via set:html — zero summarization.
 *
 * Props:
 *   title              — post title (required)
 *   slug               — URL slug (required)
 *   date               — publication date string
 *   author             — author name
 *   featured_image_src — featured image URL
 *   featured_image_alt — featured image alt text (defaults to title)
 *   content_html       — full post HTML, rendered with set:html
 *   category           — category label
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../lib/site';

interface Props {
  title: string;
  slug: string;
  date?: string;
  author?: string;
  featured_image_src?: string;
  featured_image_alt?: string;
  content_html: string;
  category?: string;
}

const {
  title,
  slug,
  date,
  author,
  featured_image_src,
  featured_image_alt,
  content_html,
  category,
} = Astro.props;
---

<BaseLayout title={title}>
  <article class="blog-post">

    <!-- Post header -->
    <header class="blog-post__header">
      <div class="blog-post__header-inner">
        {category && (
          <span class="blog-post__category">{category}</span>
        )}
        <h1 class="blog-post__title">{title}</h1>
        {(date || author) && (
          <div class="blog-post__meta">
            {date && <time class="blog-post__date" datetime={date}>{date}</time>}
            {date && author && <span class="blog-post__meta-sep" aria-hidden="true"> · </span>}
            {author && <span class="blog-post__author">{author}</span>}
          </div>
        )}
      </div>
    </header>

    <!-- Featured image -->
    {featured_image_src && (
      <figure class="blog-post__hero">
        <img
          src={featured_image_src}
          alt={featured_image_alt ?? title}
          class="blog-post__hero-img"
          loading="eager"
          decoding="sync"
        />
      </figure>
    )}

    <!-- Full post content — rendered verbatim, zero summarization -->
    <div class="blog-post__body">
      <div class="blog-post__content" set:html={content_html} />
    </div>

    <!-- CTA section -->
    <section class="blog-post__cta">
      <div class="blog-post__cta-inner">
        <h2 class="blog-post__cta-heading">Ready to learn more?</h2>
        <p class="blog-post__cta-text">Our team at Menon Medispa is here to help you find the right treatment for your goals.</p>
        <div class="blog-post__cta-btns">
          <a
            href={site.calcomUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="blog-post__cta-btn blog-post__cta-btn--primary"
          >
            Book an Appointment
          </a>
          <a href="/contact" class="blog-post__cta-btn blog-post__cta-btn--secondary">
            Contact Us
          </a>
        </div>
      </div>
    </section>

  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 100%;
  }

  /* Header */
  .blog-post__header {
    background-color: var(--color-surface-dark);
    color: var(--color-surface);
    padding: var(--space-xl) var(--space-md) var(--space-lg);
  }
  .blog-post__header-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .blog-post__category {
    display: inline-block;
    font-family: var(--font-cta);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-cta);
  }
  .blog-post__title {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    margin: 0;
    line-height: 1.2;
  }
  .blog-post__meta {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    opacity: 0.7;
  }
  .blog-post__date,
  .blog-post__author,
  .blog-post__meta-sep {
    display: inline;
  }

  /* Featured image */
  .blog-post__hero {
    margin: 0;
  }
  .blog-post__hero-img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    display: block;
  }

  /* Body */
  .blog-post__body {
    padding: var(--space-xl) var(--space-md);
  }
  .blog-post__content {
    max-width: 760px;
    margin: 0 auto;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text);
  }
  /* Reset common rich-text elements */
  .blog-post__content h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    margin: var(--space-lg) 0 var(--space-md);
  }
  .blog-post__content h3 {
    font-family: var(--font-display);
    font-size: 26px;
    margin: var(--space-md) 0 12px;
  }
  .blog-post__content p {
    margin: 0 0 var(--space-md);
  }
  .blog-post__content ul,
  .blog-post__content ol {
    padding-left: var(--space-md);
    margin-bottom: var(--space-md);
  }
  .blog-post__content li {
    margin-bottom: 8px;
  }
  .blog-post__content img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    margin: var(--space-md) 0;
  }
  .blog-post__content a {
    color: var(--color-cta);
  }
  .blog-post__content blockquote {
    border-left: 3px solid var(--color-cta);
    padding-left: var(--space-md);
    margin: var(--space-md) 0;
    font-style: italic;
    opacity: 0.85;
  }

  /* Excerpt-only fallback styles (renders when full body is unavailable) */
  :global(.post-excerpt-lede) {
    font-size: var(--text-lg) !important;
    line-height: 1.7 !important;
    font-style: italic;
    color: var(--color-text);
    border-left: 4px solid var(--color-cta);
    padding-left: var(--space-md);
    margin-bottom: var(--space-lg) !important;
  }
  :global(.post-excerpt-cta-block) {
    background: rgba(196,164,132,0.08);
    border-radius: var(--radius-sm);
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  :global(.post-excerpt-cta-link) {
    display: inline-block;
    background-color: var(--color-cta);
    color: #fff;
    font-family: var(--font-cta);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 12px 28px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    align-self: flex-start;
    transition: opacity 0.2s;
  }
  :global(.post-excerpt-cta-link):hover { opacity: 0.86; }

  /* CTA */
  .blog-post__cta {
    background-color: rgba(196,164,132,0.1);
    padding: var(--space-xl) var(--space-md);
    text-align: center;
  }
  .blog-post__cta-inner {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }
  .blog-post__cta-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    margin: 0;
  }
  .blog-post__cta-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    margin: 0;
    opacity: 0.8;
  }
  .blog-post__cta-btns {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .blog-post__cta-btn {
    display: inline-block;
    font-family: var(--font-cta);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 14px 36px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .blog-post__cta-btn:hover { opacity: 0.86; }
  .blog-post__cta-btn--primary {
    background-color: var(--color-cta);
    color: #fff;
  }
  .blog-post__cta-btn--secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-cta);
  }

  @media (max-width: 980px) {
    .blog-post__title { font-size: 30px; }
    .blog-post__cta-heading { font-size: 26px; }
    .blog-post__cta-btns { flex-direction: column; align-items: center; }
  }
</style>
