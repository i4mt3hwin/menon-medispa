---
/**
 * BlogPostTemplate.astro — Generated by path-2-rebuild/02-synthesize (scaffold stub).
 * Token-driven faithful stub: correct prop shape + styling hooks wired to the
 * @theme tokens (see 03-design/design-tokens.md). The first Phase 3 subagent to
 * render this pattern completes it with VERBATIM captured content. Do NOT put
 * page-specific content here.
 */
interface Props {
  title: string;
  date?: string;
  author?: string;
  html?: string;
  image?: { src: string; alt: string };
  class?: string;
}
const { title, date, author, html, image } = Astro.props;
---

<article class="blog-post">
  <header class="blog-post__header">
    <h1>{title}</h1>
    {(date || author) && <p class="blog-post__meta">{[author, date].filter(Boolean).join(" · ")}</p>}
  </header>
  {image && <img src={image.src} alt={image.alt} />}
  {html && <div class="blog-post__body" set:html={html} />}
</article>

<style>
  .blog-post { max-width: 760px; margin: 0 auto; padding: var(--spacing-section) 1.5rem; font-family: var(--font-ui); line-height: 1.7; }
  .blog-post__header { text-align: center; }
  .blog-post__meta { font-size: var(--text-sm); color: var(--color-text-muted); }
  .blog-post img { width: 100%; height: auto; border-radius: var(--radius-md); margin: var(--spacing-gap-lg) 0; }
</style>
