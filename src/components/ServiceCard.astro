---
/**
 * ServiceCard.astro — Generated by path-2-rebuild/02-synthesize (scaffold stub).
 * Token-driven faithful stub: correct prop shape + styling hooks wired to the
 * @theme tokens (see 03-design/design-tokens.md). The first Phase 3 subagent to
 * render this pattern completes it with VERBATIM captured content. Do NOT put
 * page-specific content here.
 */
interface Props {
  title: string;
  blurb?: string;
  image?: { src: string; alt: string };
  href?: string;
  class?: string;
}
const { title, blurb, image, href } = Astro.props;
---

<article class="service-card">
  {image && <img src={image.src} alt={image.alt} loading="lazy" />}
  <h3>{title}</h3>
  {blurb && <p>{blurb}</p>}
  {href && <a class="service-card__link" href={href}>Learn More</a>}
</article>

<style>
  .service-card { background: var(--color-surface); border-radius: var(--radius-md); box-shadow: var(--shadow-card); overflow: hidden; }
  .service-card img { width: 100%; height: auto; display: block; }
  .service-card h3 { font-family: var(--font-display); padding: 0 var(--spacing-gap-md); }
  .service-card p { font-family: var(--font-ui); padding: 0 var(--spacing-gap-md); }
  .service-card__link { display: inline-block; margin: var(--spacing-gap-sm) var(--spacing-gap-md) var(--spacing-gap-md); color: var(--color-primary); }
</style>
