---
// Phase 3 Pass 1, ServiceCard.astro
// Renders a single service card: image top, display-font title, description, feature list, CTA button.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FeatureList from './FeatureList.astro';

type ImageSource = string | ImageMetadata | { src: string };

interface Props {
  title: string;
  href?: string;
  image_src?: ImageSource;               // imported asset, generated URL, or public URL
  image?: ImageSource;                   // alias for image_src
  image_alt?: string;
  imageAlt?: string;                     // alias for image_alt
  description_html?: string;
  features?: string[];
  cta_text?: string;
  bg?: string;
}

const {
  title,
  href,
  image_src,
  image,
  image_alt,
  imageAlt,
  description_html,
  features = [],
  cta_text = 'Request to Book',
  bg,
} = Astro.props;

// Normalise image source, support both prop names and both string/object forms
const rawSrc = image_src ?? image;
const resolvedImageAlt = image_alt ?? imageAlt ?? title;
const resolvedImageAsset =
  rawSrc && typeof rawSrc === 'object' && 'width' in rawSrc && 'height' in rawSrc
    ? (rawSrc as ImageMetadata)
    : undefined;
const resolvedImageSrc = rawSrc
  ? (typeof rawSrc === 'object' ? (rawSrc as { src: string }).src : rawSrc)
  : undefined;
---

<div
  class="service-card"
  style={bg ? `background-color: ${bg};` : 'background-color: var(--color-surface);'}
>
  {resolvedImageAsset ? (
    <div class="service-card__img-wrap">
      <Image
        src={resolvedImageAsset}
        alt={resolvedImageAlt}
        class="service-card__img"
        widths={[360, 520, 670, 800]}
        sizes="(max-width: 600px) 335px, (max-width: 1024px) calc((100vw - 96px) / 2), 33vw"
        loading="lazy"
        decoding="async"
      />
    </div>
  ) : resolvedImageSrc && (
    <div class="service-card__img-wrap">
      <img
        src={resolvedImageSrc}
        alt={resolvedImageAlt}
        class="service-card__img"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}

  <div class="service-card__body">
    <h3 class="service-card__title">{title}</h3>

    {description_html && (
      <div class="service-card__desc" set:html={description_html} />
    )}

    {features.length > 0 && (
      <FeatureList items={features} icon="check" />
    )}

    <a href={href} class="btn btn--primary btn--sm service-card__cta">{cta_text}</a>
  </div>
</div>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.22s ease, transform 0.22s ease;
  }

  .service-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.13);
    transform: translateY(-2px);
  }

  .service-card__img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .service-card__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
    transition: transform 0.35s ease;
  }

  .service-card:hover .service-card__img {
    transform: scale(1.04);
  }

  .service-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-md);
    gap: var(--space-sm);
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 400;
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
    text-wrap: balance;
  }

  .service-card__desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }

  .service-card__cta {
    align-self: flex-start;
    margin-top: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card, .service-card__img {
      transition: none;
    }
    .service-card:hover {
      transform: none;
    }
    .service-card:hover .service-card__img {
      transform: none;
    }
  }
</style>
