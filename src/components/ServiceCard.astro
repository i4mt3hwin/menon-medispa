---
// Phase 3 Pass 1 — ServiceCard.astro
// Renders a single service card: image top, display-font title, description, feature list, CTA button.
import FeatureList from './FeatureList.astro';

interface Props {
  title: string;
  href?: string;
  image_src?: string | { src: string };  // imported asset string or ImageMetadata
  image?: string | { src: string };      // alias for image_src
  image_alt?: string;
  imageAlt?: string;                     // alias for image_alt
  description_html?: string;
  features?: string[];
  cta_text?: string;
  bg?: string;
}

const {
  title,
  href,
  image_src,
  image,
  image_alt,
  imageAlt,
  description_html,
  features = [],
  cta_text = 'Request to Book',
  bg,
} = Astro.props;

// Normalise image source — support both prop names and both string/object forms
const rawSrc = image_src ?? image;
const resolvedImageAlt = image_alt ?? imageAlt ?? title;
const resolvedImageSrc = rawSrc
  ? (typeof rawSrc === 'object' ? (rawSrc as { src: string }).src : rawSrc)
  : undefined;
---

<div
  class="service-card"
  style={bg ? `background-color: ${bg};` : 'background-color: var(--color-surface);'}
>
  {resolvedImageSrc && (
    <div class="service-card__img-wrap">
      <img
        src={resolvedImageSrc}
        alt={resolvedImageAlt}
        class="service-card__img"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}

  <div class="service-card__body">
    <h3 class="service-card__title">{title}</h3>

    {description_html && (
      <div class="service-card__desc" set:html={description_html} />
    )}

    {features.length > 0 && (
      <FeatureList items={features} icon="check" />
    )}

    <a href={href} class="service-card__cta">{cta_text}</a>
  </div>
</div>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.2s ease-in-out;
  }

  .service-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.14);
  }

  .service-card__img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .service-card__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .service-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-md);
    gap: var(--space-sm);
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 400;
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
  }

  .service-card__desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }

  .service-card__cta {
    display: inline-block;
    align-self: flex-start;
    margin-top: auto;
    padding: 11px 16px;
    background-color: var(--color-cta);
    color: var(--color-text);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    text-decoration: none;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(117, 77, 77, 0.6);
    transition: background-color 0.2s ease-in-out, border-color 0.2s ease-in-out;
  }

  .service-card__cta:hover {
    background-color: color-mix(in srgb, var(--color-cta) 85%, #000 15%);
  }
</style>
