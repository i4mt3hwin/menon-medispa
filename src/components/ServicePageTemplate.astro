---
/**
 * ServicePageTemplate.astro — Generated by path-2-rebuild/02-synthesize (scaffold stub).
 * Token-driven faithful stub: correct prop shape + styling hooks wired to the
 * @theme tokens (see 03-design/design-tokens.md). The first Phase 3 subagent to
 * render this pattern completes it with VERBATIM captured content. Do NOT put
 * page-specific content here.
 */
interface Props {
  title: string;
  intro?: string;
  html?: string;
  image?: { src: string; alt: string };
  price?: string;
  bookHref?: string;
  class?: string;
}
const { title, intro, html, image, price, bookHref } = Astro.props;
---

<article class="service-page">
  <header class="service-page__hero">
    <h1>{title}</h1>
    {intro && <p>{intro}</p>}
    {price && <p class="service-page__price">{price}</p>}
  </header>
  {image && <img src={image.src} alt={image.alt} />}
  {html && <div class="service-page__body" set:html={html} />}
  {bookHref && <a class="service-page__book" href={bookHref}>Book Now</a>}
</article>

<style>
  .service-page { max-width: var(--container-content); margin: 0 auto; padding: var(--spacing-section) 1.5rem; font-family: var(--font-ui); }
  .service-page__hero { text-align: center; }
  .service-page img { width: 100%; height: auto; border-radius: var(--radius-md); margin: var(--spacing-gap-lg) 0; }
  .service-page__book { display: inline-block; background: var(--color-primary); color: var(--color-surface); padding: 0.7rem 1.6rem; border-radius: var(--radius-sm); text-decoration: none; }
</style>
