---
/**
 * ServicePageTemplate.astro — canonical layout for individual service pages.
 * Covers the 81 services formerly at /service-page/{slug} on the Wix site.
 * All props are rendered verbatim; zero summarization.
 *
 * Props:
 *   title                — service name (required)
 *   slug                 — URL slug (required)
 *   category             — optional category badge text
 *   description_html     — intro/description HTML (rendered with set:html)
 *   duration             — e.g. "60 minutes"
 *   price                — e.g. "Starting at $150"
 *   benefits             — bullet list of benefit strings
 *   what_to_expect_html  — what-to-expect section HTML
 *   aftercare_html       — aftercare instructions HTML
 *   faqs                 — array of {question, answer} pairs
 *   hero_image_src       — hero image URL
 *   hero_image_alt       — hero image alt text
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../lib/site';

interface Props {
  title: string;
  slug: string;
  category?: string;
  description_html?: string;
  duration?: string;
  price?: string;
  benefits?: string[];
  what_to_expect_html?: string;
  aftercare_html?: string;
  faqs?: Array<{ question: string; answer: string }>;
  hero_image_src?: string;
  hero_image_alt?: string;
  contact_html?: string;
}

const {
  title,
  slug,
  category,
  description_html,
  duration,
  price,
  benefits = [],
  what_to_expect_html,
  aftercare_html,
  faqs = [],
  hero_image_src,
  hero_image_alt,
  contact_html,
} = Astro.props;

const bookingUrl = site.calcomUrl;
const bookingLabel = `Book ${title}`;
---

<BaseLayout title={title}>
  <article class="service-page">

    <!-- Hero — background-color fallback ensures no black void when image 404s -->
    <section class="service-page__hero" style={hero_image_src ? `background-color: var(--color-header-bg); background-image: url('${hero_image_src}');` : 'background-color: var(--color-header-bg);'}>
      <div class="service-page__hero-overlay">
        {category && (
          <span class="service-page__badge">{category}</span>
        )}
        <h1 class="service-page__title">{title}</h1>
        {(duration || price) && (
          <div class="service-page__meta">
            {duration && <span class="service-page__meta-item">{duration}</span>}
            {price && <span class="service-page__meta-item">{price}</span>}
          </div>
        )}
        <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="service-page__hero-btn">
          Book an Appointment
        </a>
      </div>
    </section>

    <!-- Description -->
    {description_html && (
      <section class="service-page__section">
        <div class="service-page__container">
          <div class="service-page__richtext" set:html={description_html} />
        </div>
      </section>
    )}

    <!-- Benefits -->
    {benefits.length > 0 && (
      <section class="service-page__section service-page__section--tinted">
        <div class="service-page__container">
          <h2 class="service-page__h2">Benefits</h2>
          <ul class="service-page__benefits">
            {benefits.map((b) => (
              <li class="service-page__benefit-item">{b}</li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- What to Expect -->
    {what_to_expect_html && (
      <section class="service-page__section">
        <div class="service-page__container">
          <h2 class="service-page__h2">What to Expect</h2>
          <div class="service-page__richtext" set:html={what_to_expect_html} />
        </div>
      </section>
    )}

    <!-- Aftercare -->
    {aftercare_html && (
      <section class="service-page__section service-page__section--tinted">
        <div class="service-page__container">
          <h2 class="service-page__h2">Aftercare</h2>
          <div class="service-page__richtext" set:html={aftercare_html} />
        </div>
      </section>
    )}

    <!-- FAQs -->
    {faqs.length > 0 && (
      <section class="service-page__section">
        <div class="service-page__container">
          <h2 class="service-page__h2">Frequently Asked Questions</h2>
          <div class="service-page__faqs">
            {faqs.map((faq) => (
              <details class="service-page__faq">
                <summary class="service-page__faq-q">{faq.question}</summary>
                <div class="service-page__faq-a">{faq.answer}</div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Contact Details (captured from Wix for 3 services) -->
    {contact_html && (
      <section class="service-page__section service-page__section--tinted">
        <div class="service-page__container">
          <h2 class="service-page__h2">Contact Details</h2>
          <div class="service-page__richtext" set:html={contact_html} />
        </div>
      </section>
    )}

    <!-- Final CTA -->
    <section class="service-page__cta-section">
      <div class="service-page__container service-page__cta-inner">
        <h2 class="service-page__cta-heading">Ready to experience {title}?</h2>
        <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="service-page__cta-btn">
          {bookingLabel}
        </a>
      </div>
    </section>

  </article>
</BaseLayout>

<style>
  /* Hero */
  .service-page__hero {
    position: relative;
    min-height: 420px;
    background-size: cover;
    background-position: center;
    background-color: var(--color-surface-dark);
    display: flex;
    align-items: flex-end;
  }
  .service-page__hero-overlay {
    width: 100%;
    padding: var(--space-xl) var(--space-md) var(--space-lg);
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.18) 60%, transparent 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .service-page__badge {
    display: inline-block;
    background-color: var(--color-cta);
    color: #fff;
    font-family: var(--font-cta);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--radius-sm);
  }
  .service-page__title {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    margin: 0;
    line-height: 1.15;
  }
  .service-page__meta {
    display: flex;
    gap: var(--space-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    opacity: 0.88;
  }
  .service-page__meta-item {
    display: inline-block;
  }
  .service-page__hero-btn {
    display: inline-block;
    background-color: var(--color-cta);
    color: #fff;
    font-family: var(--font-cta);
    font-size: var(--text-base);
    font-weight: 600;
    padding: 14px 36px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    margin-top: 8px;
    transition: opacity 0.2s;
  }
  .service-page__hero-btn:hover { opacity: 0.86; }

  /* Sections */
  .service-page__section {
    padding: var(--space-xl) var(--space-md);
  }
  .service-page__section--tinted {
    background-color: rgba(196,164,132,0.07);
  }
  .service-page__container {
    max-width: 760px;
    margin: 0 auto;
  }
  .service-page__h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    margin-bottom: var(--space-md);
  }
  .service-page__richtext {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.75;
  }

  /* Benefits */
  .service-page__benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px var(--space-md);
  }
  .service-page__benefit-item {
    font-family: var(--font-body);
    font-size: var(--text-base);
    padding-left: 20px;
    position: relative;
  }
  .service-page__benefit-item::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-cta);
    font-weight: 700;
  }

  /* FAQs */
  .service-page__faqs {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .service-page__faq {
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .service-page__faq-q {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    padding: 16px;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .service-page__faq-q::-webkit-details-marker { display: none; }
  .service-page__faq-q::after {
    content: '+';
    font-size: 20px;
    font-weight: 400;
    color: var(--color-cta);
    flex-shrink: 0;
  }
  details[open] .service-page__faq-q::after { content: '−'; }
  .service-page__faq-a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.7;
    padding: 0 16px 16px;
  }

  /* Final CTA */
  .service-page__cta-section {
    background-color: var(--color-surface-dark);
    color: var(--color-surface);
    padding: var(--space-xl) var(--space-md);
    text-align: center;
  }
  .service-page__cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }
  .service-page__cta-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    margin: 0;
  }
  .service-page__cta-btn {
    display: inline-block;
    background-color: var(--color-cta);
    color: #fff;
    font-family: var(--font-cta);
    font-size: var(--text-base);
    font-weight: 600;
    padding: 16px 48px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: opacity 0.2s;
  }
  .service-page__cta-btn:hover { opacity: 0.86; }

  @media (max-width: 980px) {
    .service-page__title { font-size: 32px; }
    .service-page__h2 { font-size: 26px; }
    .service-page__benefits { grid-template-columns: 1fr; }
  }
</style>
