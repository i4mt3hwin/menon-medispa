---
/**
 * ServicePageTemplate.astro — Wix /service-page/{slug} layout, replicated.
 * Renders captured Bookings data verbatim (name/category/price/duration/tagLine)
 * + the verbatim captured Service Description where one was individually snapshotted
 * (3 of 81; the rest were template+data per the documented capture cost-decision —
 * NO description is fabricated). Book CTA → single Cal.com placeholder constant.
 */
import site from '../lib/site';
interface Props {
  name: string;
  category?: string;
  price?: string;
  duration?: number | null;
  tagLine?: string;
  description?: string;
  cover?: string | null;
}
const { name, category, price, duration, tagLine, description, cover } = Astro.props;
const CALCOM = site.calcomUrl;
const descLines = (description || '').split('\n').filter((l) => l.trim());
---
<main class="svc">
  <section class="svc-hero">
    {cover && <img class="svc-hero__img" src={cover} alt={name} loading="eager" />}
    <h1 class="svc-name">{name}</h1>
    {tagLine && <p class="svc-tag">{tagLine}</p>}
    <div class="svc-meta">
      {price && <span class="svc-price">{price}</span>}
      {duration && <span class="svc-dur">{duration} min</span>}
      {category && <span class="svc-cat">{category}</span>}
    </div>
    <a class="svc-book" href={CALCOM} rel="noopener" target="_blank">Request to book</a>
  </section>

  {descLines.length > 0 && (
    <section class="svc-desc">
      <h2>Service Description</h2>
      {descLines.map((l) => <p>{l}</p>)}
    </section>
  )}

  <section class="svc-contact">
    <h2>Contact Details</h2>
    <p>{site.address.formatted}, USA</p>
    <p>Tel: <a href={`tel:${site.phone.tel}`}>{site.phone.display}</a></p>
    <p>Email: <a href={`mailto:${site.email}`}>{site.email}</a></p>
  </section>
</main>

<style>
  .svc { width: 100%; }
  .svc-hero, .svc-desc, .svc-contact {
    max-width: var(--container-content); margin: 0 auto; padding: var(--spacing-section) 1.5rem;
    text-align: center; font-family: var(--font-ui);
  }
  .svc-hero__img { max-width: 100%; height: auto; border-radius: var(--radius-md); margin-bottom: var(--spacing-gap-md); }
  .svc-name { font-family: var(--font-display); font-size: var(--text-4xl); margin: 0 0 0.5rem; }
  .svc-tag { font-family: var(--font-body); font-size: var(--text-lg); color: var(--color-text-muted); margin: 0 0 var(--spacing-gap-md); }
  .svc-meta { display: flex; gap: var(--spacing-gap-md); justify-content: center; flex-wrap: wrap; margin-bottom: var(--spacing-gap-md); }
  .svc-price { font-weight: 700; color: var(--color-primary); font-size: var(--text-lg); }
  .svc-dur, .svc-cat { color: var(--color-text-muted); }
  .svc-book {
    display: inline-block; background: var(--color-primary); color: var(--color-surface);
    padding: 0.75rem 2rem; border-radius: var(--radius-sm); font-weight: 700; text-decoration: none;
  }
  .svc-book:hover { background: var(--color-secondary); }
  .svc-desc { text-align: left; }
  .svc-desc h2, .svc-contact h2 { font-family: var(--font-display); font-size: var(--text-2xl); }
  .svc-desc p { line-height: 1.7; margin: 0 0 1rem; }
  .svc-contact a { color: var(--color-primary); }
</style>
