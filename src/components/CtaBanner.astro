---
interface Props {
  heading: string;
  subtext?: string;
  cta_text: string;
  cta_href: string;
  bg_image_url?: string;
  bg_color?: string;
  text_color?: string;
  overlay_opacity?: number;
}

const {
  heading,
  subtext,
  cta_text,
  cta_href,
  bg_image_url,
  bg_color,
  text_color,
  overlay_opacity = 0.45,
} = Astro.props;

const hasBgImage = Boolean(bg_image_url);

// Build section background style — always add a fallback color so a 404 image
// degrades to a warm brand tint rather than a pure black void.
const sectionStyle = hasBgImage
  ? `background-color: var(--color-header-bg); background-image: url('${bg_image_url}'); background-size: cover; background-position: center;`
  : bg_color
    ? `background-color: ${bg_color};`
    : `background-color: var(--color-cta);`;

const resolvedTextColor = text_color ?? 'var(--color-text)';
---

<section class="cta-banner" style={sectionStyle} aria-label="Call to action">
  {/* Semi-transparent overlay — only when bg image is set */}
  {hasBgImage && (
    <div
      class="cta-banner__overlay"
      style={`background-color: rgba(0,0,0,${overlay_opacity});`}
      aria-hidden="true"
    />
  )}

  <div class="cta-banner__inner" style={`color: ${resolvedTextColor};`}>
    <h2
      class="cta-banner__heading"
      style={`color: ${resolvedTextColor};`}
    >
      {heading}
    </h2>

    {subtext && (
      <p
        class="cta-banner__subtext"
        style={`color: ${resolvedTextColor};`}
      >
        {subtext}
      </p>
    )}

    <a
      href={cta_href}
      class="cta-banner__cta"
    >
      {cta_text}
    </a>
  </div>
</section>

<style>
  .cta-banner {
    position: relative;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
  }

  /* Dim layer sits between bg image and content */
  .cta-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  /* Inner content above overlay */
  .cta-banner__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    max-width: 760px;
    margin: 0 auto;
  }

  .cta-banner__heading {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    margin: 0;
    line-height: 1.2;
  }

  .cta-banner__subtext {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    line-height: 1.6;
    margin: 0;
    max-width: 560px;
  }

  .cta-banner__cta {
    display: inline-block;
    padding: 10px 28px;
    background-color: var(--color-cta);
    color: var(--color-text);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    text-decoration: none;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-btn);
    transition: opacity 0.2s;
  }

  .cta-banner__cta:hover {
    opacity: 0.88;
  }

  @media (max-width: 980px) {
    .cta-banner {
      padding: var(--space-lg) var(--space-sm);
    }

    .cta-banner__heading {
      font-size: var(--text-h2);
    }

    .cta-banner__inner {
      max-width: 100%;
    }
  }
</style>
