---
interface Props {
  heading: string;
  subtext?: string;
  cta_text: string;
  cta_href: string;
  bg_image_url?: string;
  bg_color?: string;
  text_color?: string;
  overlay_opacity?: number;
}

const {
  heading,
  subtext,
  cta_text,
  cta_href,
  bg_image_url,
  bg_color,
  text_color,
  overlay_opacity = 0.55,
} = Astro.props;

const hasBgImage = Boolean(bg_image_url);
---

{hasBgImage ? (
  <section
    class="cta-banner cta-banner--media media-bg"
    style={`--scrim-strength: ${overlay_opacity};`}
    aria-label="Call to action"
  >
    <img
      class="media-bg__img media-bg__img--blur"
      src={bg_image_url}
      alt=""
      aria-hidden="true"
    />
    <span class="media-bg__scrim media-bg__scrim--brand"></span>
    <div class="media-bg__inner cta-banner__inner container on-media">
      <h2 class="cta-banner__heading">{heading}</h2>
      {subtext && (
        <p class="cta-banner__subtext">{subtext}</p>
      )}
      <a href={cta_href} class="btn btn--primary btn--lg">
        {cta_text}
      </a>
    </div>
  </section>
) : (
  <section
    class="cta-banner cta-banner--plain section"
    style={bg_color ? `background-color: ${bg_color};` : `background-color: var(--color-cta);`}
    aria-label="Call to action"
  >
    <div
      class="cta-banner__inner container"
      style={text_color ? `color: ${text_color};` : ''}
    >
      <h2
        class="cta-banner__heading"
        style={text_color ? `color: ${text_color};` : ''}
      >
        {heading}
      </h2>
      {subtext && (
        <p
          class="cta-banner__subtext"
          style={text_color ? `color: ${text_color};` : ''}
        >
          {subtext}
        </p>
      )}
      <a href={cta_href} class="btn btn--secondary btn--lg btn--on-dark">
        {cta_text}
      </a>
    </div>
  </section>
)}

<style>
  .cta-banner {
    width: 100%;
    box-sizing: border-box;
    text-align: center;
  }

  /* Image variant: blurred photo + scrim, minimum height for visual impact */
  .cta-banner--media {
    min-height: clamp(240px, 30vw, 420px);
    display: flex;
    align-items: center;
  }

  .cta-banner__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding-block: var(--space-lg);
  }

  .cta-banner__heading {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    margin: 0;
    line-height: 1.2;
    text-wrap: balance;
  }

  .cta-banner__subtext {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    line-height: 1.6;
    margin: 0;
    max-width: 560px;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .cta-banner--media {
      min-height: clamp(200px, 28vw, 340px);
    }

    .cta-banner__heading {
      font-size: var(--text-h2);
    }
  }

  /* Phone */
  @media (max-width: 600px) {
    .cta-banner--media {
      min-height: 220px;
    }
  }
</style>
