---
/**
 * ChatAssistant.astro, built-in decision-tree chat widget.
 * Replaces Wix Chat. HIPAA-safe: no AI, no free-text input, no PHI egress.
 * Tree content lives in lib/chat-tree.ts; this component wires it up client-side.
 *
 * Rendered as static HTML + an inline <script> that drives all interaction.
 * CHAT_TREE, phone, calcomUrl, and address are passed via define:vars so the
 * client script never needs a network request.
 */
import CHAT_TREE from '../lib/chat-tree';
import site from '../lib/site';
---

<div id="chat-assistant-root" aria-label="Chat assistant" style="position: fixed; bottom: 24px; right: 24px; z-index: 1000;">
  <!-- Toggle button -->
  <button
    id="chat-toggle"
    aria-expanded="false"
    aria-controls="chat-panel"
    title="Open chat assistant"
    style="
      background-color: var(--color-cta);
      color: var(--color-surface);
      border: none;
      border-radius: 50%;
      width: 56px;
      height: 56px;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(0,0,0,0.18);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s;
    "
  >
    <!-- Chat bubble icon (open state) -->
    <svg id="chat-icon-open" width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M20 2H4C2.9 2 2 2.9 2 4V22L6 18H20C21.1 18 22 17.1 22 16V4C22 2.9 21.1 2 20 2Z" fill="currentColor"/>
    </svg>
    <!-- Close (X) icon (panel open state) -->
    <svg id="chat-icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display:none;">
      <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
    </svg>
    <span class="sr-only">Open chat assistant</span>
  </button>

  <!-- Chat panel -->
  <div
    id="chat-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Chat with Menon Medispa"
    hidden
    style="
      position: absolute;
      bottom: 68px;
      right: 0;
      width: 320px;
      background: var(--color-surface);
      border-radius: var(--radius-md);
      box-shadow: 0 8px 32px rgba(0,0,0,0.16);
      overflow: hidden;
    "
  >
    <!-- Panel header -->
    <div style="
      background-color: var(--color-cta);
      color: var(--color-surface);
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    ">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M20 2H4C2.9 2 2 2.9 2 4V22L6 18H20C21.1 18 22 17.1 22 16V4C22 2.9 21.1 2 20 2Z" fill="currentColor"/>
      </svg>
      <span style="font-family: var(--font-cta); font-size: var(--text-sm); font-weight: 600;" id="chat-title">Menon Medispa Assistant</span>
      <button
        id="chat-close"
        type="button"
        aria-label="Close chat"
        style="margin-left: auto; background: none; border: none; color: var(--color-surface); cursor: pointer; padding: 2px 4px; line-height: 1; display: inline-flex; align-items: center;"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Message area -->
    <div
      id="chat-messages"
      style="
        padding: 16px;
        min-height: 140px;
        max-height: 300px;
        overflow-y: auto;
        font-family: var(--font-body);
        font-size: var(--text-sm);
        line-height: 1.5;
      "
    >
      <!-- Populated by client script -->
    </div>

    <!-- Options area -->
    <div
      id="chat-options"
      style="
        padding: 8px 16px 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      "
    >
      <!-- Option buttons populated by client script -->
    </div>

    <!-- Footer -->
    <div style="
      padding: 8px 16px;
      border-top: 1px solid rgba(0,0,0,0.08);
      background: rgba(0,0,0,0.02);
    ">
      <p style="font-family: var(--font-body); font-size: 13px; opacity: 0.55; margin: 0;">
        This chat does not collect personal health information.
      </p>
    </div>
  </div>
</div>

<script define:vars={{ chatTreeJson: JSON.stringify(CHAT_TREE), phoneTel: site.phone.tel, calcomUrl: site.calcomUrl, addressFormatted: site.address.formatted }}>
  (function () {
    const tree = JSON.parse(chatTreeJson);
    const MAPS_URL = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(addressFormatted);

    let currentNodeId = tree.root;
    let history = []; // stack of node IDs for back navigation

    // --- DOM refs ---
    const root    = document.getElementById('chat-assistant-root');
    const toggle  = document.getElementById('chat-toggle');
    const panel   = document.getElementById('chat-panel');
    const iconOpen  = document.getElementById('chat-icon-open');
    const iconClose = document.getElementById('chat-icon-close');
    const msgArea = document.getElementById('chat-messages');
    const optArea = document.getElementById('chat-options');

    const closeBtn = document.getElementById('chat-close');

    function setOpen(open) {
      panel.hidden = !open;
      toggle.setAttribute('aria-expanded', String(open));
      iconOpen.style.display  = open ? 'none' : '';
      iconClose.style.display = open ? ''     : 'none';
      if (open) {
        renderNode(currentNodeId);
        panel.querySelector('#chat-messages').focus?.();
      }
    }

    // --- Toggle open/close ---
    toggle.addEventListener('click', function () {
      setOpen(panel.hidden);
    });

    // --- Explicit close (panel header X; the floating circle is hidden on
    //     service pages where chat is folded into the mobile CTA bar) ---
    if (closeBtn) closeBtn.addEventListener('click', function () { setOpen(false); });

    // --- Render a node ---
    function renderNode(nodeId) {
      const node = tree.nodes[nodeId];
      if (!node) return;
      currentNodeId = nodeId;

      // Message
      msgArea.innerHTML = '';
      const msgEl = document.createElement('p');
      msgEl.style.cssText = 'margin: 0 0 4px; white-space: pre-line;';
      msgEl.textContent = node.message;
      msgArea.appendChild(msgEl);

      // Options
      optArea.innerHTML = '';

      // Back button (shown when history has entries)
      if (history.length > 0) {
        const backBtn = makeOptionBtn('← Back');
        backBtn.addEventListener('click', function () {
          const prev = history.pop();
          renderNode(prev);
        });
        optArea.appendChild(backBtn);
      }

      node.options.forEach(function (opt) {
        // Skip the static '← Back' entries in the tree since we handle back dynamically
        if (opt.label === '← Back') return;

        const btn = makeOptionBtn(opt.label);
        btn.addEventListener('click', function () {
          handleOption(opt);
        });
        optArea.appendChild(btn);
      });
    }

    // --- Handle an option click ---
    function handleOption(opt) {
      if (opt.to) {
        // Navigate to another node
        history.push(currentNodeId);
        renderNode(opt.to);
        return;
      }

      switch (opt.action) {
        case 'book':
          window.open(calcomUrl, '_blank', 'noopener,noreferrer');
          break;
        case 'call':
          window.location.href = 'tel:' + phoneTel;
          break;
        case 'maps':
          window.open(MAPS_URL, '_blank', 'noopener,noreferrer');
          break;
        case 'lead': {
          // Try scrolling to #contact first; fall back to /contact
          const contactEl = document.getElementById('contact');
          if (contactEl) {
            panel.hidden = true;
            toggle.setAttribute('aria-expanded', 'false');
            iconOpen.style.display  = '';
            iconClose.style.display = 'none';
            contactEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } else {
            window.location.href = '/contact';
          }
          break;
        }
        case 'link':
          if (opt.href) {
            // Internal links navigate in same tab; external in new tab
            if (opt.href.startsWith('http')) {
              window.open(opt.href, '_blank', 'noopener,noreferrer');
            } else {
              window.location.href = opt.href;
            }
          }
          break;
        default:
          break;
      }
    }

    // --- Create a styled option button ---
    function makeOptionBtn(label) {
      const btn = document.createElement('button');
      btn.textContent = label;
      btn.style.cssText = [
        'display: block',
        'width: 100%',
        'text-align: left',
        'background: var(--color-surface)',
        'border: 1px solid rgba(196,164,132,0.5)',
        'border-radius: var(--radius-sm)',
        'padding: 9px 12px',
        'font-family: var(--font-body)',
        'font-size: 15px',
        'cursor: pointer',
        'transition: background 0.15s',
        'color: var(--color-text)',
      ].join(';');
      btn.addEventListener('mouseenter', function () {
        btn.style.background = 'rgba(196,164,132,0.12)';
      });
      btn.addEventListener('mouseleave', function () {
        btn.style.background = 'var(--color-surface)';
      });
      return btn;
    }
  })();
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  #chat-toggle:hover {
    opacity: 0.88;
  }
  /* Panel visibility: the `hidden` attribute must win over the layout display.
     (An inline `display:flex` previously defeated [hidden], so the empty panel
     was always shown and could not be dismissed, worst on mobile.) */
  #chat-panel {
    display: flex;
    flex-direction: column;
  }
  #chat-panel[hidden] {
    display: none !important;
  }
  @media (max-width: 480px) {
    #chat-panel {
      width: min(320px, calc(100vw - 32px)) !important;
      max-height: calc(100vh - 104px);
    }
    #chat-messages {
      max-height: 44vh !important;
    }
  }
</style>
